[core]
  longpaths = true
[http]
  postBuffer = 524288000
[safe]
  directory = '*'
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[user]
  name = pinokio
  email = pinokio@localhost
[init]
  defaultBranch = main
[push]
  autoSetupRemote = true
