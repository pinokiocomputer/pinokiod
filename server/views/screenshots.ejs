@media only screen and (max-width: 600px) {
  aside {
    width: unset;
    flex-shrink: unset;
  }
  aside {
    padding: 0 10px;
  }
  aside .tab i {
    width: 100%;
  }
  aside .tab .caption {
    display: none;
  }
  aside .tab {
    margin: 0;
    padding: 10px;
    border-left: none;
  }
  aside .btn-tab {
    flex-direction: column;
    padding: 10px 0;
  }
  aside .btn-tab .btn {
    display: flex;
    justify-content: center;
  }
  aside .btn-tab .btn .caption {
    display: none; 
  }
  header .flexible {
    min-width: unset;
  }
}


@media only screen and (max-width: 480px) {
  .gallery-grid {
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 10px;
  }
  
  .gallery-container {
    padding: 10px;
  }
}
</style>
