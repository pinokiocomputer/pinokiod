  align-items: center;
  opacity: 1;
}
</style>
<script>
document.addEventListener("DOMContentLoaded", async () => {
  const n = new N()
  let updated = {}
  document.addEventListener("input", (e) => {
    let host = e.target.getAttribute("data-host")
    let index = e.target.getAttribute("data-index")
    if (!updated[host]) {
      updated[host] = {}
    }
    updated[host][index] = e.target.value
  })
  document.querySelector("#save").addEventListener("click", async (e) => {
    console.log({ updated })
    let res = await fetch("/keys", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(updated)
    }).then((res) => {
      return res.json()
    })
    console.log("res" ,res)
    n.Noty({
      text: `Updated!`
    })
    setTimeout(() => {
      location.href = location.href
    }, 1000)
  })
})
</script>
</head>
<body class='<%=theme%>' data-agent="<%=agent%>">
  <main>
    <header class='navheader grabbable'>
      <h1>
        <a class='home-button home' href="/home"><i class='fa-solid fa-home'></i></a>
        <div class='flexible'></div>
        <div class='nav-btns'>
          <button class='btn' id='open-fs' data-filepath="<%=filepath%>" data-command="view"><i class="fa-solid fa-eye"></i> Open in File Explorer</button>
          <div id='save' class='btn'>
            <span class='save'><i class="fa-solid fa-check"></i> Save</span>
          </div>
        </div>
      </h1>
    </header>
    <% if (items.length > 0) { %>
      <div id='editor'>
        <% items.forEach((item) => { %>
          <div class='env-item'>
            <label for="<%=item.host%>"><%=item.host%></label>
            <% item.vals.forEach((val, index) => { %>
              <input data-host="<%=item.host%>" data-index="<%=index%>" type="text" value="<%=val%>">
            <% }) %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class='empty'>
        <div>no keys are set</div>
        <br>
        <a target="_blank" href="https://pinokiocomputer.github.io/home/docs/#/?id=autofill-from-shared-key-store" class='btn'>Learn how this works</a>
      </div>
    <% } %>
  </main>
</body>
</html>
