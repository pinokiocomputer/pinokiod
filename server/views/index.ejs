<style>
.bubble {
  position: relative;
  background: rgba(0,0,0,0.1);
  color: #333;
  border-radius: 10px;
  padding: 10px 15px;
  font-size: 14px;
  flex-grow: 1;
  line-height: 1.4;
  margin: 0 10px;
  font-weight: bold;
}
/* Left-side tail */
.bubble::before {
  content: "";
  position: absolute;
  top: 10px; /* Vertical alignment of the tail */
  left: -20px; /* Positioning outside the bubble */
  border-width: 10px;
  border-style: solid;
  border-color: transparent rgba(0,0,0,0.1) transparent transparent;
}
body.dark .bubble {
  background: rgba(0,0,0,0.4);
  color: white;
}
body.dark .bubble:before {
  border-color: transparent rgba(0,0,0,0.4) transparent transparent;
}
.line2 {
  display: flex;
  align-items: center;
  cursor: pointer;
  background: rgba(0,0,100,0.04);
}
.line2 a {
  text-decoration: none;
  color: black;
}
.status {
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}
.status.offline {
  background: silver;
}
.status.online {
  background: yellowgreen;
}
.switch {
  padding: 10px;
  margin: 10px 0;
}
.switch[data-online=true] {
  color: yellowgreen;
}
.button {
  padding: 10px;
}
.on, .off {
  display: flex;
  align-items: center;
}
header .runner {
  padding: 10px 0 0;
}
.proxy {
  padding: 0 10px;
  text-align: right;
}
.proxy a {
  text-decoration: none;
  display: inline-block;
  padding: 5px 10px;
  border-radius: 2px;
  background: black;
  color: white;
}
.browser-options-btns {
  display: flex;
  padding-top: 5px;
}
.browser-options-row {
/*
  border-top: 1px solid rgba(0,0,0,0.1);
  border-bottom: 1px solid rgba(0,0,0,0.1);
  */
  display: flex;
  padding: 10px;
  align-items: flex-start;
}
.browser-options-row h3 {
  margin: 0;
  font-size: 14px;
  margin-bottom: 3px;
}
.browser-options-row .btn.disabled {
  opacity: 0.7;
}
.browser-options-row .btn {
  font-weight: bold;
  width: 100px;
  text-align: center;
  display: block;
  margin-right: 10px;
  flex-shrink: 0;
  padding: 5px;
}
.badge {
  font-size: 12px;
  padding: 5px 10px;
  background: rgba(0,0,100,0.1);
  border-radius: 5px;
  display: inline-block;
  margin-top: 5px;
}
a.badge {
  color: royalblue;
  text-decoration: none;
  cursor: pointer;
}
.badge a {
  color: royalblue;
  text-decoration: none;
}
body.dark .btn {
  color: white;
}
body.dark .badge {
  background: rgba(255,255,255,0.1);
}
/*
body.dark .browser-options-row {
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
*/
body.dark .context-menu-wrapper {
  background: rgba(0,0,0,0.9) !important;
  color: white !important;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 12px 30px rgba(0,0,0,0.45);
}
.context-menu-wrapper {
  background: whitesmoke !important;
  border-radius: 10px;
  overflow: hidden;
}
.menu-btns {
  position: relative;
}
.context-menu {
  position: absolute;
  right: auto;
  margin: 0;
  padding: 0;
  z-index: 10;
  border: none;
  outline: none;
  background: transparent;
}
.context-menu:popover-open {
  border: none;
  outline: none;
}
.context-menu .btn:hover {
  color: cornflowerblue !important;
}
.context-menu .btn {
  background: none !important;
  border: none !important;
  display: block;
  width: 80px;
  padding: 6px 10px !important;
  text-align: left;
  color: black;
  margin: 0 !important;
}
body.dark .btn {
  background: rgba(255,255,255,0.05) !important;
}
.app-btns .btn {
  border-radius: 4px;
  padding: 8px 10px;
  width: 70px;
  /*
  padding: 6px 10px;
  */
  text-align: center;
}
body.dark .context-menu .btn {
  color: white;
  background: none !important;
}
body.dark .open-menu, body.dark .browse, body.dark .toggle-star {
  border: none !important;
  /*
  background: black !important;
  */
  color: white !important;
}
.open-menu:hover, .browse:hover, .toggle-star:hover, body.dark .open-menu:hover, body.dark .browse:hover, body.dark .toggle-star:hover {
  color: royalblue !important;
}
.open-menu, .browse, .toggle-star {
/*
  width: 80px;
  */
  border-radius: 0 !important;
  background: rgba(0,0,0,0.04) !important;
  color: black !important;
  /*
  border: 1px solid rgba(0, 0, 0, 0.3);
  */
}
.toggle-star.is-starred i {
  color: #b8860b;
}
body.dark .toggle-star.is-starred i {
  color: #ffcc66;
}
.open-menu.selected {
  border: none !important;
  /*
  background: none !important;
  */
}
.open-menu.selected span {
  display: none;
}
main {
  display: flex;
}
.submenu .tab {
  padding: 0;
}
.submenu .tab {
  border-left: 10px solid transparent;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: royalblue !important;
  opacity: 1;
}
aside .tab i {
  width: 20px;
  text-align: center;
  display: block;
}
body.dark aside .tab {
  color: white;
}
aside .tab.hidden {
  padding: 0;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
  text-decoration: none;
  padding: 10px;
  font-size: 12px;
  opacity: 0.5;
  border-left: 10px solid transparent;
}
body.dark aside .tab.selected {

  color: white;
  /*
  border-left: 10px solid white;
  */
}
aside .tab.selected {
/*
  border-left: 10px solid black;
  */
  font-weight: bold;
  opacity: 1;
}
aside .btn-tab {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 0 10px;
  margin-top: 10px;
}
aside .btn-tab .btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
  text-align: left;
  margin: 0;
  padding: 10px 12px;
  border: none !important;
  border-radius: 0 !important;
  background: rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}
body.dark aside .btn-tab .btn {
  background: rgba(255, 255, 255, 0.06) !important;
}
aside .btn-tab .btn i {
  width: 18px;
  text-align: center;
  flex-shrink: 0;
}
aside .btn-tab .btn .caption {
  display: block;
}
.home-apps-header {
  margin: 0;
  padding: 8px 12px 8px;
}

.home-apps-header h2 {
  margin: 0;
  font-size: 18px;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
}

.home-apps-header p {
  margin: 4px 0 0;
  font-size: 12px;
  line-height: 1.35;
  color: rgba(15, 23, 42, 0.7);
  word-break: break-word;
}

.home-apps-header-actions {
  margin-top: 4px;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  min-width: 0;
}

.home-apps-header-main-actions {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  min-width: 0;
  flex: 1 1 auto;
}

.home-apps-header-actions .qr {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
}

.home-apps-header-actions .qr > a {
  display: inline-flex !important;
  align-items: center;
  gap: 5px;
  height: 25px;
  min-height: 25px;
  padding: 0 10px;
  border: 1px solid rgba(127, 127, 127, 0.3);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.8);
  text-decoration: none !important;
  color: inherit !important;
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  cursor: pointer;
  box-sizing: border-box;
}

.home-apps-header-actions .qr img {
  display: none;
}

.home-apps-header-actions .qr .caption {
  display: block;
  margin: 0;
  font-size: 11px;
  line-height: 1.25;
  font-weight: 700;
  width: auto !important;
  text-align: left;
  white-space: nowrap;
  word-break: normal;
}

.home-apps-header-actions .peer-access-trigger-icon {
  font-size: 11px;
  line-height: 1;
}

.home-apps-header-actions .qr .caption:last-child {
  display: none;
}

.home-apps-header .home-apps-create-btn {
  display: inline-flex !important;
  align-items: center;
  gap: 5px;
  border: 1px solid royalblue !important;
  background: royalblue !important;
  color: #f8fbff !important;
  border-radius: 4px;
  height: 25px;
  min-height: 25px;
  padding: 0 10px;
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  cursor: pointer;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
  box-sizing: border-box;
}

.home-apps-header .home-apps-create-btn i {
  font-size: 11px;
  line-height: 1;
}

.home-apps-header .home-apps-create-btn:hover {
  border-color: #315cd8 !important;
  background: #315cd8 !important;
}

.home-apps-header .home-apps-create-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.home-apps-header .home-apps-sort {
  display: inline-flex;
  position: relative;
  align-items: center;
  gap: 5px;
  height: 25px;
  min-height: 25px;
  padding: 0 10px;
  border: 1px solid rgba(127, 127, 127, 0.3);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.8);
  box-sizing: border-box;
  margin-left: auto;
  align-self: flex-start;
  flex: 0 0 auto;
  transition: border-color 0.12s ease, background-color 0.12s ease;
}

.home-apps-header .home-apps-sort:hover {
  border-color: rgba(65, 105, 225, 0.45);
  background: rgba(65, 105, 225, 0.08);
}

.home-apps-header .home-apps-sort:focus-within {
  border-color: royalblue;
  background: rgba(65, 105, 225, 0.12);
}

.home-apps-header .home-apps-sort .home-apps-sort-icon {
  font-size: 11px;
  line-height: 1;
  opacity: 0.85;
  flex: 0 0 auto;
}

.home-apps-header .home-apps-sort .home-apps-sort-caret {
  font-size: 9px;
  line-height: 1;
  opacity: 0.7;
  pointer-events: none;
  flex: 0 0 auto;
}

.home-apps-header .home-apps-sort label {
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  color: rgba(15, 23, 42, 0.78);
  margin: 0;
  white-space: nowrap;
}

.home-apps-header .home-apps-sort select {
  border: 0;
  outline: none;
  background: transparent;
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  color: inherit;
  padding: 0;
  margin: 0;
  min-width: 88px;
  height: 100%;
  appearance: none;
  -webkit-appearance: none;
  cursor: pointer;
}

.home-apps-header .home-apps-sort .ts-wrapper {
  flex: 0 0 auto;
  width: 132px;
  min-width: 132px;
}

.home-apps-header .home-apps-sort .ts-wrapper.single .ts-control {
  border: 0;
  outline: none;
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin: 0;
  min-height: 0;
  border-radius: 0;
  cursor: pointer;
}

.home-apps-header .home-apps-sort .ts-control > .item {
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  color: inherit;
}

.home-apps-header .home-apps-sort .ts-control > input {
  width: 0 !important;
  min-width: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
}

.home-apps-header .home-apps-sort .ts-dropdown {
  margin: 8px 0 0;
  width: 100%;
  min-width: 100%;
  border: 1px solid rgba(127, 127, 127, 0.25);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 12px 26px rgba(15, 23, 42, 0.14);
}

.home-apps-header .home-apps-sort .ts-dropdown .option {
  font-size: 12px;
  font-weight: 600;
  color: rgba(15, 23, 42, 0.9);
  padding: 7px 10px;
  white-space: nowrap;
}

.home-apps-header .home-apps-sort .ts-dropdown .option.active,
.home-apps-header .home-apps-sort .ts-dropdown [data-selectable].option:hover {
  background: rgba(65, 105, 225, 0.14);
  color: rgba(15, 23, 42, 0.95);
}

body.dark .home-apps-header {
  border-bottom-color: rgba(255, 255, 255, 0.14);
}

body.dark .home-apps-header h2 {
  color: rgba(241, 245, 249, 0.96);
}

body.dark .home-apps-header p {
  color: rgba(203, 213, 225, 0.86);
}

body.dark .home-apps-header .home-apps-create-btn {
  border-color: royalblue !important;
  background: royalblue !important;
  color: rgba(248, 250, 252, 0.98) !important;
}

body.dark .home-apps-header .home-apps-create-btn:hover {
  border-color: #315cd8 !important;
  background: #315cd8 !important;
}

body.dark .home-apps-header .home-apps-sort {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(15, 23, 42, 0.55);
}

body.dark .home-apps-header .home-apps-sort:hover {
  border-color: rgba(99, 140, 255, 0.65);
  background: rgba(65, 105, 225, 0.2);
}

body.dark .home-apps-header .home-apps-sort:focus-within {
  border-color: #5f84ff;
  background: rgba(65, 105, 225, 0.28);
}

body.dark .home-apps-header .home-apps-sort label {
  color: rgba(226, 232, 240, 0.9);
}

body.dark .home-apps-header .home-apps-sort select {
  color: rgba(226, 232, 240, 0.9);
}

body.dark .home-apps-header .home-apps-sort .ts-control > .item {
  color: rgba(226, 232, 240, 0.9);
}

body.dark .home-apps-header .home-apps-sort .ts-dropdown {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(15, 23, 42, 0.98);
  box-shadow: 0 14px 28px rgba(2, 6, 23, 0.68);
}

body.dark .home-apps-header .home-apps-sort .ts-dropdown .option {
  color: rgba(226, 232, 240, 0.92);
}

body.dark .home-apps-header .home-apps-sort .ts-dropdown .option.active,
body.dark .home-apps-header .home-apps-sort .ts-dropdown [data-selectable].option:hover {
  background: rgba(95, 132, 255, 0.24);
  color: rgba(248, 250, 252, 0.98);
}

body.dark .home-apps-header-actions .qr {
  border-color: transparent;
  background: transparent;
}

body.dark .home-apps-header-actions .qr > a {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(15, 23, 42, 0.55);
}
.home-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  padding: 2px;
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 6px;
  overflow: visible;
  background: rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}
body.dark .home-mode-switch {
  border-color: rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.06);
}
.home-mode-switch .mode-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 34px;
  padding: 0 12px;
  border-radius: 4px;
  text-decoration: none;
  color: inherit;
  border: none;
  background: transparent;
  font-weight: 600;
  font-size: 13px;
  opacity: 1;
  line-height: 1;
  box-sizing: border-box;
}
.home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}
.home-mode-switch .mode-link.selected,
.home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}
body.dark .home-mode-switch .mode-link.selected,
body.dark .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}
.home-search-mode-switch {
  flex: 0 0 auto;
  margin-right: 0;
  align-self: center;
}
.home-search-form {
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.1);
}
body.dark .home-search-form {
  border-bottom-color: rgba(148, 163, 184, 0.22);
}
.home-search-form .home-search-mode-switch {
  align-self: center;
}
.home-search-form .home-mode-switch {
  gap: 0;
  padding: 0;
  height: 25px;
  align-items: center;
  overflow: hidden;
  box-sizing: border-box;
}
.home-search-form .home-mode-switch .mode-link {
  height: 100%;
  padding: 0 10px;
  border-radius: 0;
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  font-weight: 400;
}
.home-search-form .home-mode-switch .mode-link + .mode-link {
  border-left: 1px solid rgba(0, 0, 0, 0.14);
}
body.dark .home-search-form .home-mode-switch .mode-link + .mode-link {
  border-left-color: rgba(255, 255, 255, 0.05);
}
.home-search-form input[type='search'].flexible {
  height: 25px;
  min-height: 25px;
  box-sizing: border-box;
  padding: 0 10px;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 400;
  line-height: 1;
}
#suggestion {
  padding: 20px;
  display: flex;
  align-items: center;
}
#suggestion img {
  width: 50px;
  height: 50px;
}
#suggestion h4 {
  margin: 0;
}
