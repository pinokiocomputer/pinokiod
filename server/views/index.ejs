    return bb.starred - aa.starred
  }
  if (sortMode === "last_opened") {
    if (aa.lastLaunch !== bb.lastLaunch) {
      return bb.lastLaunch - aa.lastLaunch
    }
    if (aa.launchCount !== bb.launchCount) {
      return bb.launchCount - aa.launchCount
    }
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
      return byName
    }
  } else if (sortMode === "az") {
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
      return byName
    }
  } else {
    if (aa.launchCount !== bb.launchCount) {
      return bb.launchCount - aa.launchCount
    }
    if (aa.lastLaunch !== bb.lastLaunch) {
      return bb.lastLaunch - aa.lastLaunch
    }
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
