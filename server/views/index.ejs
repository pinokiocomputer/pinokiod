}
main {
  display: flex;
}
.submenu .tab {
  padding: 0;
}
.submenu .tab {
  border-left: 10px solid transparent;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: royalblue !important;
  opacity: 1;
}
aside .tab i {
  width: 20px;
  text-align: center;
  display: block;
}
body.dark aside .tab {
  color: white;
}
aside .tab.hidden {
  padding: 0;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
