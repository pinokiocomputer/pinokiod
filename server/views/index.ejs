const HOME_SORT_DEFAULT = "most_used"
const HOME_SORT_STORAGE_KEY = "pinokio.home.apps.sort"
const normalizeHomeSortMode = (value) => {
  const normalized = String(value || "").trim().toLowerCase()
  if (normalized === "most_used" || normalized === "most-used") {
    return "most_used"
  }
  if (normalized === "last_opened" || normalized === "last-opened") {
    return "last_opened"
  }
  if (normalized === "az" || normalized === "a-z") {
    return "az"
  }
  return HOME_SORT_DEFAULT
}
const readStoredHomeSortMode = () => {
  try {
    if (!window || !window.localStorage) {
      return HOME_SORT_DEFAULT
    }
    return normalizeHomeSortMode(window.localStorage.getItem(HOME_SORT_STORAGE_KEY))
  } catch (_) {
    return HOME_SORT_DEFAULT
  }
}
const persistHomeSortMode = (value) => {
  const normalized = normalizeHomeSortMode(value)
  try {
    if (window && window.localStorage) {
      window.localStorage.setItem(HOME_SORT_STORAGE_KEY, normalized)
    }
  } catch (_) {}
  return normalized
}
const updateSearchParam = (name, value, options = {}) => {
  const params = new URLSearchParams(location.search)
  if (typeof value === "string" && value.trim().length > 0) {
    params.set(name, value)
  } else {
    params.delete(name)
  }
  const query = params.toString()
  const nextPath = query ? `${location.pathname}?${query}` : location.pathname
  if (options && options.replace) {
    window.history.replaceState({ path: nextPath }, "", nextPath)
  } else {
    window.history.pushState({ path: nextPath }, "", nextPath)
  }
  return nextPath
}
