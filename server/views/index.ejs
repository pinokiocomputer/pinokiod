      display: menu.style.display,
      position: menu.style.position,
      top: menu.style.top,
      left: menu.style.left,
    }
    menu.style.visibility = 'hidden'
    menu.style.display = 'block'
    menu.style.position = 'fixed'
    menu.style.top = '0'
    menu.style.left = '0'
    width = menu.offsetWidth
