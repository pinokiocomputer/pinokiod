  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    closeContextMenuForNode(target)
    await showHomeAppShareModal(target)
    return
  }
  if (e.target.classList.contains("home-actions-close")) {
    target = e.target
  } else {
    target = e.target.closest(".home-actions-close")
  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    const dialog = target.closest(".home-actions-dialog")
    if (dialog) {
      closeHomeActionsDialog(dialog)
    }
    return
  }
  if (e.target.classList.contains("home-actions-dialog")) {
    closeHomeActionsDialog(e.target)
    return
  }
  if (e.target.classList.contains("home-run-stop")) {
    target = e.target
  } else {
    target = e.target.closest(".home-run-stop")
  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    stopHomeRunMenuItem(target)
    return
  }
  if (e.target.classList.contains("home-run-command")) {
    target = e.target
  } else {
    target = e.target.closest(".home-run-command")
  }
  if (target) {
    const confirmText = target.getAttribute("data-confirm")
    if (confirmText && !confirm(confirmText)) {
      e.preventDefault()
      e.stopPropagation()
      return
    }
  }
  target = e.target.closest(".home-app-line")
  if (target && !shouldIgnoreHomeLineNavigation(e)) {
    e.preventDefault()
    e.stopPropagation()
    navigateHomeAppLine(target)
    return
  }
  if (e.target.classList.contains("toggle-star")) {
    target = e.target
  } else {
    target = e.target.closest(".toggle-star")
  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    if (target.dataset.pending === "1") {
      return
    }
    const appId = target.getAttribute("data-app-id")
    if (!appId) {
      return
    }
    const currentlyStarred = target.getAttribute("data-starred") === "1"
    const nextStarred = !currentlyStarred
    target.dataset.pending = "1"
    try {
      const response = await fetch(`/apps/preferences/${encodeURIComponent(appId)}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ starred: nextStarred })
      })
      const payload = await response.json().catch(() => ({}))
      if (!response.ok || !payload || !payload.preference) {
        throw new Error(payload && payload.error ? payload.error : "Failed to update app star")
      }
      target.setAttribute("data-starred", payload.preference.starred ? "1" : "0")
      if (payload.preference.starred) {
        target.classList.add("is-starred")
      } else {
        target.classList.remove("is-starred")
      }
      const icon = target.querySelector("i")
      if (icon) {
        icon.className = payload.preference.starred ? "fa-solid fa-star" : "fa-regular fa-star"
      }
      const starLabel = payload.preference.starred ? "Unstar app" : "Star app"
      target.setAttribute("title", starLabel)
      target.setAttribute("aria-label", starLabel)
      const label = target.querySelector("span")
      if (label) {
        label.textContent = payload.preference.starred ? "Starred" : "Star"
      }
      const line = target.closest(".line")
      if (line) {
        line.setAttribute("data-starred", payload.preference.starred ? "1" : "0")
        line.setAttribute("data-launch-count-total", String(payload.preference.launch_count_total || 0))
        line.setAttribute("data-last-launch-at", payload.preference.last_launch_at || "")
      }
      reorderHomeSectionsByPreference()
      if (payload.preference.starred) {
        showHomeStarToast()
      }
    } catch (error) {
      alert(error && error.message ? error.message : "Failed to update app star")
    } finally {
      delete target.dataset.pending
    }
    return
  }
  if (e.target.classList.contains("shutdown")) {
    target = e.target
  } else {
    target = e.target.closest(".shutdown")
  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    let src = target.getAttribute("data-src")
    let id = target.getAttribute('data-id')
    let type = target.getAttribute('data-type')
    console.log({ id, src, type })
    target.disabled = true
    const stopIcon = target.querySelector("i.fa-stop")
    const spinIcon = target.querySelector("i.fa-spin")
    if (stopIcon) {
      stopIcon.classList.add("hidden")
    }
    if (spinIcon) {
      spinIcon.classList.remove("hidden")
    }

    let params = {}
    if (id) params.id = id
    if (src) params.uri = "~/" + src

    if (type === "shell") {
      socket.run({
        method: "kernel.bin.shell_kill",
        params: { id }
      }, (packet) => {
        console.log("packet", packet)
        if (packet.type === "result") {
          socket.close()
          target.querySelector("i.fa-stop").className = "fa-solid fa-check"
          const resultSpinIcon = target.querySelector("i.fa-spin")
          if (resultSpinIcon) {
            resultSpinIcon.classList.add("hidden")
          }
          n.Noty({
            text: `stopped`,
            silent: true
          })
          setTimeout(() => {
            location.href = location.href
          }, 500)
        }
      })
    } else {
      socket.run({
        method: "kernel.api.stop",
        params,
      }, (packet) => {
        console.log("packet", packet)
        if (packet.type === "result") {
          socket.close()
          target.querySelector("i.fa-stop").className = "fa-solid fa-check"
