const getMenuDimensions = (menu) => {
  let width = parseFloat(menu.dataset.cachedWidth)
  let height = parseFloat(menu.dataset.cachedHeight)
  if (!width || !height) {
    const prev = {
      visibility: menu.style.visibility,
      display: menu.style.display,
      position: menu.style.position,
      top: menu.style.top,
      left: menu.style.left,
    }
    menu.style.visibility = 'hidden'
    menu.style.display = 'block'
    menu.style.position = 'fixed'
    menu.style.top = '0'
    menu.style.left = '0'
    width = menu.offsetWidth
    height = menu.offsetHeight
    if (width > 0) {
      menu.dataset.cachedWidth = width
    }
    if (height > 0) {
      menu.dataset.cachedHeight = height
    }
    menu.style.visibility = prev.visibility
    menu.style.display = prev.display
    menu.style.position = prev.position
    menu.style.top = prev.top
    menu.style.left = prev.left
  }
  return {
    width: width || 0,
    height: height || 0
  }
}
const parseLineStarSortMeta = (line) => {
  if (!line) {
    return {
      starred: 0,
      launchCount: 0,
      lastLaunch: 0,
      index: Number.MAX_SAFE_INTEGER,
      name: "",
    }
  }
  const starred = line.getAttribute("data-starred") === "1" ? 1 : 0
  const launchCount = Number.parseInt(line.getAttribute("data-launch-count-total") || "0", 10)
  const lastLaunchRaw = line.getAttribute("data-last-launch-at") || ""
  const lastLaunch = lastLaunchRaw ? (Date.parse(lastLaunchRaw) || 0) : 0
  const index = Number.parseInt(line.getAttribute("data-index") || String(Number.MAX_SAFE_INTEGER), 10)
  const name = (line.getAttribute("data-name") || "").toLowerCase()
  return {
    starred,
    launchCount: Number.isFinite(launchCount) ? launchCount : 0,
    lastLaunch,
    index: Number.isFinite(index) ? index : Number.MAX_SAFE_INTEGER,
    name
  }
}
const readCurrentHomeSortMode = () => {
  const sortSelect = document.querySelector("#home-apps-sort-select")
  if (sortSelect) {
    return normalizeHomeSortMode(sortSelect.value)
  }
  const currentParams = new URLSearchParams(location.search)
  return normalizeHomeSortMode(currentParams.get("sort"))
}
const compareLinesByPreference = (a, b, sortMode = readCurrentHomeSortMode()) => {
  const aa = parseLineStarSortMeta(a)
  const bb = parseLineStarSortMeta(b)
  if (aa.starred !== bb.starred) {
    return bb.starred - aa.starred
  }
  if (sortMode === "last_opened") {
    if (aa.lastLaunch !== bb.lastLaunch) {
      return bb.lastLaunch - aa.lastLaunch
    }
    if (aa.launchCount !== bb.launchCount) {
      return bb.launchCount - aa.launchCount
    }
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
      return byName
    }
  } else if (sortMode === "az") {
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
      return byName
    }
  } else {
    if (aa.launchCount !== bb.launchCount) {
      return bb.launchCount - aa.launchCount
    }
    if (aa.lastLaunch !== bb.lastLaunch) {
      return bb.lastLaunch - aa.lastLaunch
    }
    const byName = aa.name.localeCompare(bb.name)
    if (byName !== 0) {
      return byName
    }
  }
  if (aa.index !== bb.index) {
    return aa.index - bb.index
  }
  return aa.name.localeCompare(bb.name)
}
const reorderHomeSectionsByPreference = (sortMode = readCurrentHomeSortMode()) => {
  const sections = [".running-apps", ".not-running-apps"]
  for (const selector of sections) {
    const section = document.querySelector(selector)
    if (!section) {
      continue
    }
    const lines = Array.from(section.querySelectorAll(":scope > .line"))
    lines.sort((x, y) => compareLinesByPreference(x, y, sortMode))
    for (const line of lines) {
      section.appendChild(line)
    }
  }
}
