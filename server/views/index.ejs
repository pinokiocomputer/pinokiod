      controlInput: null,
      dropdownParent: sortDropdownParent || undefined
    })
  }
}
document.addEventListener("click", async (e) => {
  if (e.target.classList.contains("toggle-star")) {
    target = e.target
  } else {
    target = e.target.closest(".toggle-star")
  }
  if (target) {
    e.preventDefault()
    e.stopPropagation()
    if (target.dataset.pending === "1") {
      return
    }
    const appId = target.getAttribute("data-app-id")
    if (!appId) {
      return
    }
    const currentlyStarred = target.getAttribute("data-starred") === "1"
    const nextStarred = !currentlyStarred
    target.dataset.pending = "1"
    try {
      const response = await fetch(`/apps/preferences/${encodeURIComponent(appId)}`, {
        method: "PUT",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ starred: nextStarred })
      })
      const payload = await response.json().catch(() => ({}))
      if (!response.ok || !payload || !payload.preference) {
        throw new Error(payload && payload.error ? payload.error : "Failed to update app star")
      }
      target.setAttribute("data-starred", payload.preference.starred ? "1" : "0")
      if (payload.preference.starred) {
        target.classList.add("is-starred")
      } else {
        target.classList.remove("is-starred")
      }
      const icon = target.querySelector("i")
      if (icon) {
        icon.className = payload.preference.starred ? "fa-solid fa-star" : "fa-regular fa-star"
      }
      const label = target.querySelector("span")
      if (label) {
        label.textContent = payload.preference.starred ? "Starred" : "Star"
      }
      const line = target.closest(".line")
      if (line) {
        line.setAttribute("data-starred", payload.preference.starred ? "1" : "0")
        line.setAttribute("data-launch-count-total", String(payload.preference.launch_count_total || 0))
        line.setAttribute("data-last-launch-at", payload.preference.last_launch_at || "")
      }
      reorderHomeSectionsByPreference()
    } catch (error) {
      alert(error && error.message ? error.message : "Failed to update app star")
    } finally {
      delete target.dataset.pending
    }
    return
  }
  if (e.target.classList.contains("shutdown")) {
    target = e.target
  } else {
    target = e.target.closest(".shutdown")
