const renderHomeShareSetupHtml = ({ detail, actions }) => {
  return `
    <div class="home-app-share-modal">
      <div class="home-app-share-modal__setup-card">
        <div class="home-app-share-modal__intro">${escapeHomeShareHtml(detail)}</div>
