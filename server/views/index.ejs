  body.is-home .main-sidebar,
  main > .container:has(.home-search-form) + .main-sidebar {
    display: none !important;
  }
}
@media only screen and (max-width: 480px) {
  .btn2 {
    padding: 5px;
    font-size: 11px;
  }
  .nav-btns {
    flex-grow: 1;
    justify-content: center;
    padding: 0;
  }
