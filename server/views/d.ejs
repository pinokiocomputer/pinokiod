        </div>
      </div>
    <% } %>

    <% if (ideMenu && ideMenu.menu && ideMenu.menu.length) { %>
      <div class='menu-container menu-column ide-column'>
        <div class='tab-header'>
          <h3><i class='<%= ideMenu.icon %>'></i> <%= ideMenu.title %></h3>
        </div>
        <% if (ideMenu.subtitle || ideMenu.subtitle_link_href) { %>
          <div class='column-subtitle'>
            <% if (ideMenu.subtitle) { %>
              <span><%= ideMenu.subtitle %></span><% if (ideMenu.subtitle_link_href && ideMenu.subtitle_link_label) { %> <% } %>
            <% } %>
            <% if (ideMenu.subtitle_link_href && ideMenu.subtitle_link_label) { %>
              <a class='column-subtitle-link' href="<%= ideMenu.subtitle_link_href %>" target="_parent"><%= ideMenu.subtitle_link_label %></a>
            <% } %>
          </div>
        <% } %>
        <div class='tab-content'>
          <% ideMenu.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <div class='tab-copy'>
                <h2 class='tab-title'><%= i.title %></h2>
                <% if (i.subtitle) { %>
                  <div class='tab-subtitle subtitle'><%= i.subtitle %></div>
                <% } %>
              </div>
              <div class='tab-actions'>
                <button class="tab-action-link" type="button" data-plugin-settings="true" data-href="<%= i.href %>" title="<%=tr("build.manage_plugin")%>" data-tippy-content="<%=tr("build.manage_plugin")%>" aria-label="<%=tr("build.manage_plugin")%>">
                  <i class="fa-solid fa-gear"></i>
                </button>
                <div class='disclosure-indicator' aria-hidden="true">
                  <i class="fa-solid fa-chevron-right"></i>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <% remaining.forEach((item) => { %>
    <% if (item.menu) { %>
      <div class='menu-container'>
        <div class='tab-header'>
          <h3><i class='<%= item.icon %>'></i> <%= item.title %></h3>
        </div>
        <div class='tab-content'>
          <% item.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <div class='tab-copy'>
                <h2 class='tab-title'><%= i.title %></h2>
                <% if (i.subtitle) { %>
                  <div class='tab-subtitle subtitle'><%= i.subtitle %></div>
                <% } %>
              </div>
              <div class='tab-actions'>
                <button class="tab-action-link" type="button" data-plugin-settings="true" data-href="<%= i.href %>" title="<%=tr("build.manage_plugin")%>" data-tippy-content="<%=tr("build.manage_plugin")%>" aria-label="<%=tr("build.manage_plugin")%>">
                  <i class="fa-solid fa-gear"></i>
                </button>
                <div class='disclosure-indicator' aria-hidden="true">
                  <i class="fa-solid fa-chevron-right"></i>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <div class='tab' data-index="<%= index++ %>">
        <% if (item.image) { %>
          <img src="<%= item.image %>">
        <% } else if (item.icon) { %>
          <i class="img <%= item.icon %>"></i>
        <% } %>
        <div class='col'>
          <h2><%= item.title %></h2>
          <% if (item.subtitle) { %>
            <div class='subtitle'><%= item.subtitle %></div>
          <% } %>
          <div class='btns'>
            <% if (item.link) { %>
              <a class='btn' target="_blank" href="<%= item.link %>"><i class="fa-solid fa-circle-info"></i></a>
            <% } %>
            <a class='run-btn btn' href="<%= item.href %>"><i class="fa-solid <%= item.type === "Start" ? 'fa-play' : 'fa-rocket' %>"></i> <%= item.type === "Start" ? tr("home.run") : item.type %></a>
          </div>
        </div>
      </div>
    <% } %>
  <% }) %>
  <% if (retry) { %>
    <div class='requirements'>
      <div class='content'>
        <div class='loading'>
          <i class="fa-solid fa-circle-notch fa-spin"></i>
        </div>
      </div>
    </div>
  <% } %>
</main>
<script>
<% if (retry) { %>
setTimeout(() => {
  location.href = location.href
}, 2000)
<% } %>
