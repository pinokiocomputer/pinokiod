<style>
main {
  box-sizing: border-box;
  padding: 0;
  /*
  flex-wrap: wrap;
  */
  /*
  max-width: 800px;
  padding: 30px 45px;
  */
  /*
  justify-content: center;
  */
}
.tab-content {
  display: flex;
  flex-wrap: wrap;
  flex-grow: 1;
  width: 100%;
}
.submenu.tab {
  margin: 10px 0;
}
.tab {
  width: 100%;
  text-decoration: none;
  display: flex;
  font-size: 14px;
  font-weight: bold;
  color: black;
  overflow: hidden;
  box-sizing: border-box;
  align-items: center;
  gap: 10px;
  padding: 10px;
  cursor: pointer;
  transition: background 0.2s ease;

  /*
  margin-bottom: 10px;
  background: rgba(0,0,0,0.05);
  */
}
.tab:hover,
.tab:focus-visible {
  background: rgba(0, 0, 0, 0.1);
}
.tab:focus-visible {
  outline: 2px solid royalblue;
  outline-offset: 2px;
}
body.dark .tab {
  color: white;
  background: rgba(255,255,255,0.03);
}
body.dark .tab:hover,
body.dark .tab:focus-visible {
  background: rgba(255, 255, 255, 0.08);
}
.tab h2 {
  margin: 0;
  font-weight: normal;
  font-size: 14px;
}
.tab .col {
  flex-grow: 1;
  margin-left: 10px;
}
.tab i.img {
  flex-shrink: 0;
  height: 40px;
  width: 40px;
  background: white;
  color: black;
  display: flex;
  justify-content: center;
  font-size: 20px;
  align-items: center;
  border-radius: 40px;
}
.tab img {
  border-radius: 40px;
  height: 40px;
  width: 40px;
  background: white;
}
.tab .disclosure-indicator {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  color: rgba(0, 0, 0, 0.4);
  flex-shrink: 0;
  pointer-events: none;
  transition: transform 0.2s ease, color 0.2s ease;
}
.tab:hover .disclosure-indicator,
.tab:focus-visible .disclosure-indicator {
  color: rgba(0, 0, 0, 0.7);
  transform: translateX(2px);
}
.tab.is-starting {
  cursor: wait;
  opacity: 0.7;
}
.tab.is-starting .disclosure-indicator {
  opacity: 0.85;
}
body.dark .tab .disclosure-indicator {
  color: rgba(255, 255, 255, 0.4);
}
body.dark .tab:hover .disclosure-indicator,
body.dark .tab:focus-visible .disclosure-indicator {
  color: rgba(255, 255, 255, 0.9);
}
.ai-perm-link {
  border: none;
  background: none;
  color: rgba(0, 0, 0, 0.55);
  padding: 6px;
  border-radius: 8px;
  cursor: pointer;
}
.ai-perm-link:hover,
.ai-perm-link:focus-visible {
  background: rgba(0, 0, 0, 0.08);
  color: rgba(0, 0, 0, 0.85);
}
body.dark .ai-perm-link {
  color: rgba(255, 255, 255, 0.75);
}
body.dark .ai-perm-link:hover,
body.dark .ai-perm-link:focus-visible {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.95);
}
