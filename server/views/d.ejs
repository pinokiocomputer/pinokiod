let list = []
const rebuildTabList = () => {
  list = []
  document.querySelectorAll(".tab").forEach((el, index) => {
    el.setAttribute("data-index", String(index))
    list.push({
      index,
      text: el.textContent,
      isTerminalOption: el.hasAttribute("data-terminal-option-tab"),
    })
  })
}
const search = (items, value) => {
  let filtered = []
  for(let i=0; i<items.length; i++) {
    let item = items[i]
  let re = new RegExp(value, "i")
    if (re.test(item.text)) {
      filtered.push({ item })
    }
  }
  return filtered
}

let selectedIndex = -1
let selectedBtnIndex = 0
let filteredCount = list.length
let filteredBtnsCount = 0

const renderSearch = () => {
  let target = document.querySelector("form input[type=search]")
  const searching = target.value.trim().length > 0
  let result
  if (!searching) {
    result = list.map((i, index) => {
      return { item: i }
    })
  } else {
    result = search(list, target.value)
  }
  let all = document.querySelectorAll(".tab")
  for(let el of all) {
    el.classList.add("hidden")
    el.classList.remove("selected")
  }
  document.querySelectorAll(".terminal-shell-group").forEach((group) => {
    const panel = group.querySelector("[data-terminal-options-panel]")
    if (!panel) {
      return
    }
    if (searching) {
      panel.classList.add("hidden")
    } else {
      panel.classList.toggle("hidden", !group.classList.contains("is-expanded"))
    }
  })

  filteredCount = result.length
  for(let i=0; i<result.length; i++) {
    let selector = result[i]
    let el = document.querySelector(".tab[data-index='" + selector.item.index + "']")
    el.classList.remove("hidden")
    if (selector.item.isTerminalOption) {
      const group = el.closest(".terminal-shell-group")
      if (group) {
        const shellTab = group.querySelector(".tab[data-terminal-group]")
        if (shellTab) {
          shellTab.classList.remove("hidden")
        }
        const panel = group.querySelector("[data-terminal-options-panel]")
        if (panel) {
          panel.classList.remove("hidden")
        }
      }
    }
    if (i === selectedIndex) {
      el.classList.add("selected")
    } else {
      el.classList.remove("selected")
    }
  }
  document.querySelectorAll(".terminal-shell-group").forEach((group) => {
    const hasVisibleOptions = Array.from(group.querySelectorAll(".tab[data-href]")).some((tab) => {
      return !tab.classList.contains("hidden")
    })
    group.classList.toggle("hidden", !hasVisibleOptions)
  })
}
rebuildTabList()
renderSearch()
const workspaceCwd = (() => {
  const node = document.querySelector(".file-open")
  if (!node) {
    return ""
  }
  const value = node.getAttribute("data-filepath")
  return typeof value === "string" ? value.trim() : ""
})()
const generateSession = () => {
  if (typeof crypto !== 'undefined' && crypto.randomUUID) {
    return crypto.randomUUID()
  }
  return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`
}
const appendWorkspaceCwd = (value, cwd = workspaceCwd) => {
  if (!value || typeof value !== "string" || !cwd) {
    return value
  }
  const hasPrefix = value.startsWith("@")
  const raw = hasPrefix ? value.slice(1) : value
  try {
    const parsed = new URL(raw, window.location.origin)
    const isPluginLauncher = parsed.pathname.startsWith("/run/plugin/")
      || parsed.pathname.startsWith("/pinokio/run/plugin/")
      || (parsed.pathname.startsWith("/run/api/") && /\/pinokio\.js$/i.test(parsed.pathname))
    if (parsed.origin !== window.location.origin || !isPluginLauncher) {
      return value
    }
    if (!parsed.searchParams.has("cwd")) {
      parsed.searchParams.set("cwd", cwd)
    }
    const next = `${parsed.pathname}${parsed.search}${parsed.hash}`
    return hasPrefix ? `@${next}` : next
  } catch (_) {
    return value
  }
}
const appendSessionParam = (value, session) => {
  if (!value) return value
  if (value.includes('session=')) {
    return value
  }
  const delimiter = value.includes('?') ? '&' : '?'
  return `${value}${delimiter}session=${session}`
}
const pluginInstallPreflightCache = new Map()
const normalizePluginPathFromLaunchHref = (rawHref) => {
  if (!rawHref || typeof rawHref !== "string") {
    return ""
  }
  try {
    const parsed = new URL(rawHref, window.location.origin)
    if (parsed.origin !== window.location.origin) {
      return ""
    }
    if (parsed.pathname.startsWith("/pinokio/run/plugin/")) {
      return parsed.pathname
    }
    if (parsed.pathname.startsWith("/run/plugin/") || (parsed.pathname.startsWith("/run/api/") && /\/pinokio\.js$/i.test(parsed.pathname))) {
      return parsed.pathname.replace(/^\/run/, "")
    }
  } catch (_) {}
  return ""
}
const pluginInstallHrefFromState = (state, fallbackPath) => {
  const detailUrl = state && typeof state.detailUrl === "string" && state.detailUrl
    ? state.detailUrl
    : `/plugin?path=${encodeURIComponent(fallbackPath)}`
  try {
    const parsed = new URL(detailUrl, window.location.origin)
    parsed.searchParams.set("next", "install")
    return `${parsed.pathname}${parsed.search}${parsed.hash}`
  } catch (_) {
    const separator = detailUrl.includes("?") ? "&" : "?"
    return `${detailUrl}${separator}next=install`
  }
}
const getPluginInstallRedirect = async (rawHref) => {
  const pluginPath = normalizePluginPathFromLaunchHref(rawHref)
  if (!pluginPath) {
    return ""
  }
  if (pluginInstallPreflightCache.has(pluginPath)) {
    return pluginInstallPreflightCache.get(pluginPath)
  }
  let redirectHref = ""
  try {
    const response = await fetch(`/api/plugin/install-state?path=${encodeURIComponent(pluginPath)}`, {
      cache: "no-store"
    })
    const state = await response.json().catch(() => ({}))
    if (response.ok && state && state.ok && state.hasInstall && state.hasInstalledCheck && state.installed === false) {
      redirectHref = pluginInstallHrefFromState(state, pluginPath)
    }
  } catch (_) {}
  pluginInstallPreflightCache.set(pluginPath, redirectHref)
  return redirectHref
}
const redirectToPluginInstallIfNeeded = async (rawHref) => {
  const redirectHref = await getPluginInstallRedirect(rawHref)
  if (!redirectHref) {
    return false
  }
  window.top.location.href = redirectHref
  return true
}
const pluginSettingsHrefFromLaunchHref = (rawHref) => {
  const launchHref = appendWorkspaceCwd(rawHref || "")
  const pluginPath = normalizePluginPathFromLaunchHref(launchHref)
  if (!pluginPath) {
    return ""
  }
  const parsed = new URL("/plugin", window.location.origin)
  parsed.searchParams.set("path", pluginPath)
  if (workspaceCwd) {
    parsed.searchParams.set("cwd", workspaceCwd)
  }
  return `${parsed.pathname}${parsed.search}`
}
const START_ICON_HTML = '<i class="fa-solid fa-chevron-right"></i>'
const STARTING_ICON_HTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>'
const TERMINAL_GROUP_ICON_HTML = '<i class="fa-solid fa-chevron-right"></i>'
const TERMINAL_GROUP_LOADING_HTML = '<i class="fa-solid fa-circle-notch fa-spin"></i>'
const setTabLaunchState = (tab, state) => {
  if (!tab) return
  const indicator = tab.querySelector('.disclosure-indicator')
  if (indicator) {
    indicator.innerHTML = state === 'starting' ? STARTING_ICON_HTML : START_ICON_HTML
  }
  if (state === 'starting') {
    tab.classList.add('is-starting')
  } else {
    tab.classList.remove('is-starting')
  }
}
const setTerminalGroupState = (tab, state) => {
  if (!tab) {
    return
  }
  const indicator = tab.querySelector('.disclosure-indicator')
  if (indicator) {
    indicator.innerHTML = state === 'loading' ? TERMINAL_GROUP_LOADING_HTML : TERMINAL_GROUP_ICON_HTML
  }
  if (state === 'loading') {
    tab.classList.add('is-loading')
  } else {
    tab.classList.remove('is-loading')
  }
}
const setTerminalGroupExpanded = (group, expanded) => {
  if (!group) {
    return
  }
  group.classList.toggle('is-expanded', expanded)
  const panel = group.querySelector('[data-terminal-options-panel]')
  if (panel) {
    panel.classList.toggle('hidden', !expanded)
  }
}
const toggleTerminalGroup = async (tab) => {
  if (!tab) {
    return
  }
  const group = tab.closest('.terminal-shell-group')
  if (!group) {
    return
  }
  const panel = group.querySelector('[data-terminal-options-panel]')
  if (!panel) {
    return
  }
  if (group.dataset.loaded === '1') {
    setTerminalGroupExpanded(group, !group.classList.contains('is-expanded'))
    rebuildTabList()
    renderSearch()
    return
  }
  if (group.dataset.loading === '1') {
    return
  }
  const url = tab.dataset.optionsUrl
  if (!url) {
    return
  }
  group.dataset.loading = '1'
  setTerminalGroupExpanded(group, true)
  setTerminalGroupState(tab, 'loading')
  panel.innerHTML = `<div class="terminal-shell-status"><i class="fa-solid fa-circle-notch fa-spin"></i><span>${<%-trj("build.loading_shell_options")%>}</span></div>`
  try {
    const html = await fetch(url).then((res) => res.text())
    if (!html || html.trim().length === 0) {
      panel.innerHTML = `<div class="terminal-shell-status"><span>${<%-trj("build.no_shell_options")%>}</span></div>`
    } else {
      panel.innerHTML = html
      group.dataset.loaded = '1'
    }
  } catch (_) {
    panel.innerHTML = `<div class="terminal-shell-status"><span>${<%-trj("build.unable_shell_options")%>}</span></div>`
  } finally {
    delete group.dataset.loading
    setTerminalGroupState(tab, 'idle')
    rebuildTabList()
    renderSearch()
  }
}
const pendingLaunchTabs = new Map()
const launchTab = async (tab) => {
  if (!tab) {
    return false
  }

  if (tab.classList.contains('is-starting')) {
    return false
  }

  const baseHref = tab.dataset.href
  const baseTarget = tab.dataset.target

  if (!baseHref || !baseTarget) {
    return false
  }

  const session = generateSession()
  const href = appendSessionParam(appendWorkspaceCwd(baseHref), session)
  const target = appendSessionParam(appendWorkspaceCwd(baseTarget), session)

  if (await redirectToPluginInstallIfNeeded(href)) {
    return true
  }

  pendingLaunchTabs.set(session, tab)
  setTabLaunchState(tab, 'starting')

  const labelNode = tab.querySelector('.tab-title')
  const label = labelNode ? labelNode.textContent.trim() : ""

  window.parent.postMessage({
    launch: {
      name: target,
      href,
      label
    }
  }, "*")

  window.setTimeout(() => {
    if (pendingLaunchTabs.get(session) === tab) {
      pendingLaunchTabs.delete(session)
      setTabLaunchState(tab, 'idle')
    }
  }, 1500)

  return true
}
const extractSession = (value) => {
  if (!value || typeof value !== 'string') {
    return null
  }
  const match = value.match(/session=([^&]+)/)
  return match ? match[1] : null
}
document.querySelector("form input[type=search]").addEventListener("input", (e) => {
  selectedIndex = 0
  selectedBtnIndex = 0
  renderSearch()
})
document.querySelector("form input[type=search]").focus()
document.addEventListener("click", async (e) => {
  const settingsTarget = e.target.closest('[data-plugin-settings][data-href]')
  if (settingsTarget) {
    e.preventDefault()
    e.stopPropagation()
    const settingsHref = pluginSettingsHrefFromLaunchHref(settingsTarget.getAttribute('data-href') || '')
    if (settingsHref) {
      window.top.location.href = settingsHref
    }
    return
  }

  const infoTarget = e.target.closest('[data-doc-link][data-href]')
  if (infoTarget) {
    e.preventDefault()
    e.stopPropagation()
    window.open(infoTarget.getAttribute('data-href'), '_blank')
    return
  }

  const groupTab = e.target.closest('.tab[data-terminal-group]')
  if (groupTab) {
    e.preventDefault()
    e.stopPropagation()
    toggleTerminalGroup(groupTab)
    return
  }

  const tab = e.target.closest('.tab[data-href]')
  if (!tab) {
    return
  }

  if (await launchTab(tab)) {
    e.preventDefault()
    e.stopPropagation()
  }
})

document.addEventListener('keydown', async (e) => {
  if (!['Enter', ' ', 'Spacebar'].includes(e.key)) {
    return
  }

  const target = e.target
  if (!(target instanceof HTMLElement)) {
    return
  }

  const groupTab = target.closest('.tab[data-terminal-group]')
  if (groupTab && groupTab === target) {
    e.preventDefault()
    e.stopPropagation()
    toggleTerminalGroup(groupTab)
    return
  }

  const tab = target.closest('.tab[data-href]')
  if (!tab || tab !== target) {
    return
  }

  const launched = await launchTab(tab)
  if (launched) {
    e.preventDefault()
    e.stopPropagation()
  }
})

window.addEventListener('message', (event) => {
  const data = event.data
  if (!data || typeof data !== 'object') {
    return
  }

  let session = null

  if (typeof data.session === 'string') {
    session = data.session
  }

  if (!session && typeof data.id === 'string') {
    session = extractSession(data.id)
  }

  if (!session && data.data && typeof data.data.id === 'string') {
    session = extractSession(data.data.id)
  }

  if (!session && data.launch && typeof data.launch.href === 'string') {
    session = extractSession(data.launch.href)
  }

  if (!session && typeof data.href === 'string') {
    session = extractSession(data.href)
  }

  if (session && pendingLaunchTabs.has(session)) {
    const tab = pendingLaunchTabs.get(session)
    pendingLaunchTabs.delete(session)
    setTabLaunchState(tab, 'idle')
    return
  }

  if (data.type === 'start' || data.type === 'result' || data.type === 'error' || data.type === 'disconnect') {
    pendingLaunchTabs.forEach((tab) => {
      setTabLaunchState(tab, 'idle')
    })
    pendingLaunchTabs.clear()
  }
})
</script>
