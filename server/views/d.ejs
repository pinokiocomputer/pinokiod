  width: 40px;
  background: white;
  color: black;
  display: flex;
  justify-content: center;
  font-size: 20px;
  align-items: center;
  border-radius: 40px;
}
.tab img {
  flex: 0 0 40px;
  border-radius: 40px;
  height: 40px;
  width: 40px;
  background: white;
  object-fit: cover;
}
.tab .disclosure-indicator {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  color: rgba(0, 0, 0, 0.4);
  flex-shrink: 0;
  pointer-events: none;
  transition: transform 0.2s ease, color 0.2s ease;
}
.tab:hover .disclosure-indicator,
.tab:focus-visible .disclosure-indicator {
  color: rgba(0, 0, 0, 0.7);
  transform: translateX(2px);
}
.tab.is-starting {
  cursor: wait;
  opacity: 0.7;
}
