<div class='spec'>
  <div class='explain'>
    <h3><i class="fa-regular fa-circle-check"></i> TODO</h3>
    <ol>
      <li><strong>Build manually:</strong> Open the project files and start building. <a class='btn file-open' data-filepath="<%=filepath%>"><i class="fa-solid fa-folder-open"></i> open project folder</a></li>
      <li><strong>Build with AI:</strong> Click any of the below AI tools to instantly start building with AI.</li>
    </ol>
  </div>
</div>

  <%
    let index = 0;
    const userTerminal = dynamic && dynamic.length ? dynamic[0] : null;
    const cliMenu = dynamic.find((item) => item && item.title === "Terminal Agents");
    const ideMenu = dynamic.find((item) => item && item.title === "Desktop App Agents");
    const handled = new Set();
    if (userTerminal) handled.add(userTerminal);
    if (cliMenu) handled.add(cliMenu);
    if (ideMenu) handled.add(ideMenu);
    const remaining = dynamic.filter((item) => !handled.has(item));
  %>

  <div class='menu-grid'>
    <% if (userTerminal && userTerminal.menu && userTerminal.menu.length) { %>
      <div class='menu-container menu-column user-terminal'>
        <div class='tab-header'>
          <h3><i class='<%= userTerminal.icon %>'></i> <%= userTerminal.title %></h3>
        </div>
        <% if (userTerminal.subtitle) { %>
          <div class='column-subtitle'><%= userTerminal.subtitle %></div>
        <% } %>
        <div class='tab-content'>
          <% userTerminal.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <h2><%= i.title %></h2>
              <% if (i.subtitle) { %>
                <div class='subtitle'><%= i.subtitle %></div>
              <% } %>
              <div class='flexible'></div>
              <% if (i.link) { %>
                <div target="_blank" data-href="<%= i.link %>" title="Open docs" data-tippy-content="Open docs"><i class="fa-solid fa-circle-info"></i></div>
              <% } %>
              <button class="ai-perm-link" type="button" data-ai-consent="<%= i.href %>" title="AI permissions" data-tippy-content="AI permissions">
                <i class="fa-solid fa-shield-halved"></i>
              </button>
              <div class='disclosure-indicator' aria-hidden="true">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (cliMenu && cliMenu.menu && cliMenu.menu.length) { %>
      <div class='menu-container menu-column cli-column'>
        <div class='tab-header'>
          <h3><i class='<%= cliMenu.icon %>'></i> Terminal Agents</h3>
        </div>
        <% if (cliMenu.subtitle) { %>
          <div class='column-subtitle'><%= cliMenu.subtitle %></div>
        <% } %>
        <div class='tab-content'>
          <% cliMenu.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <h2><%= i.title %></h2>
              <% if (i.subtitle) { %>
                <div class='subtitle'><%= i.subtitle %></div>
              <% } %>
              <div class='flexible'></div>
              <% if (i.link) { %>
                <div target="_blank" data-href="<%= i.link %>" title="Open docs" data-tippy-content="Open docs"><i class="fa-solid fa-circle-info"></i></div>
              <% } %>
              <button class="ai-perm-link" type="button" data-ai-consent="<%= i.href %>" title="AI permissions" data-tippy-content="AI permissions">
                <i class="fa-solid fa-shield-halved"></i>
              </button>
              <div class='disclosure-indicator' aria-hidden="true">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (ideMenu && ideMenu.menu && ideMenu.menu.length) { %>
      <div class='menu-container menu-column ide-column'>
        <div class='tab-header'>
          <h3><i class='<%= ideMenu.icon %>'></i> Desktop App Agents</h3>
        </div>
        <% if (ideMenu.subtitle) { %>
          <div class='column-subtitle'><%= ideMenu.subtitle %></div>
        <% } %>
        <div class='tab-content'>
          <% ideMenu.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <h2><%= i.title %></h2>
              <% if (i.subtitle) { %>
                <div class='subtitle'><%= i.subtitle %></div>
              <% } %>
              <div class='flexible'></div>
              <% if (i.link) { %>
                <div target="_blank" data-href="<%= i.link %>" title="Open docs" data-tippy-content="Open docs"><i class="fa-solid fa-circle-info"></i></div>
              <% } %>
              <button class="ai-perm-link" type="button" data-ai-consent="<%= i.href %>" title="AI permissions" data-tippy-content="AI permissions">
                <i class="fa-solid fa-shield-halved"></i>
              </button>
              <div class='disclosure-indicator' aria-hidden="true">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <% remaining.forEach((item) => { %>
    <% if (item.menu) { %>
      <div class='menu-container'>
        <div class='tab-header'>
          <h3><i class='<%= item.icon %>'></i> <%= item.title %></h3>
        </div>
        <div class='tab-content'>
          <% item.menu.forEach((i) => { %>
            <div class='tab' role="button" tabindex="0" data-index="<%= index++ %>" data-target="@<%= i.href %>" data-href="<%= i.href %>">
              <% if (i.image) { %>
                <img src="<%= i.image %>">
              <% } else if (i.icon) { %>
                <i class="img <%= i.icon %>"></i>
              <% } %>
              <h2><%= i.title %></h2>
              <% if (i.subtitle) { %>
                <div class='subtitle'><%= i.subtitle %></div>
              <% } %>
              <div class='flexible'></div>
              <% if (i.link) { %>
                <div target="_blank" data-href="<%= i.link %>" title="Open docs" data-tippy-content="Open docs"><i class="fa-solid fa-circle-info"></i></div>
              <% } %>
              <button class="ai-perm-link" type="button" data-ai-consent="<%= i.href %>" title="AI permissions" data-tippy-content="AI permissions">
                <i class="fa-solid fa-shield-halved"></i>
              </button>
              <div class='disclosure-indicator' aria-hidden="true">
                <i class="fa-solid fa-chevron-right"></i>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } else { %>
      <div class='tab' data-index="<%= index++ %>">
        <% if (item.image) { %>
          <img src="<%= item.image %>">
        <% } else if (item.icon) { %>
          <i class="img <%= item.icon %>"></i>
        <% } %>
        <div class='col'>
          <h2><%= item.title %></h2>
          <% if (item.subtitle) { %>
            <div class='subtitle'><%= item.subtitle %></div>
          <% } %>
          <div class='btns'>
            <% if (item.link) { %>
              <a class='btn' target="_blank" href="<%= item.link %>"><i class="fa-solid fa-circle-info"></i></a>
            <% } %>
            <a class='run-btn btn' href="<%= item.href %>"><i class="fa-solid <%= item.type === "Start" ? 'fa-play' : 'fa-rocket' %>"></i> <%= item.type %></a>
          </div>
        </div>
      </div>
    <% } %>
  <% }) %>
  <% if (retry) { %>
    <div class='requirements'>
      <div class='content'>
        <div class='loading'>
          <i class="fa-solid fa-circle-notch fa-spin"></i>
        </div>
      </div>
    </div>
  <% } %>
</main>
