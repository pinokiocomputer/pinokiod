}
.submenu.tab {
  margin: 10px 0;
}
.tab {
  width: 100%;
  text-decoration: none;
  display: flex;
  font-size: 14px;
  font-weight: bold;
  color: black;
  overflow: hidden;
  box-sizing: border-box;
  align-items: center;
  min-width: 0;
  gap: 10px;
  padding: 10px;
  cursor: pointer;
  transition: background 0.2s ease;

  /*
  margin-bottom: 10px;
  background: rgba(0,0,0,0.05);
  */
}
.tab:hover,
.tab:focus-visible {
  background: rgba(0, 0, 0, 0.1);
}
.tab:focus-visible {
  outline: 2px solid royalblue;
  outline-offset: 2px;
}
body.dark .tab {
  color: white;
  background: rgba(255,255,255,0.03);
}
body.dark .tab:hover,
body.dark .tab:focus-visible {
  background: rgba(255, 255, 255, 0.08);
}
.tab h2 {
