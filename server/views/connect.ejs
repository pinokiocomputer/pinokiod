}
body.dark .config {
  color: white;
}
.config {
  color: black;
  padding: 30px;
  margin: 10px 0;
}
.config-header {
}
.config-body {
  padding-top: 20px;
  margin-top: 20px;
}
.config .btn {
  font-size: 16px;
  font-weight: bold;
  width: 100px;
  background: royalblue;
  flex-shrink: 0;
}
.config-row {
  padding: 10px 20px 0 0;
}
.label {
  padding-bottom: 5px;
  font-weight: bold;
}
.config-row input[type=text] {
  padding: 7px;
}
.header-label {
  padding: 0;
  font-size: 30px;
  /*
  text-align: center;
  */
  text-transform: capitalize;
}
body.dark .container {
  color: white;
}
.container {
}
.dark .container-row {
  background: rgba(255, 255, 255, 0.04);
}
.container-row {
  background: rgba(0, 0, 100, 0.04);
  box-sizing: border-box;
}
.header-label-sub h1 {
  font-size: 25px;
  letter-spacing: -1px;
  font-weight: lighter;
}
.header-label-sub {
  font-size: 16px;
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.1);
}
.header-label-sub .s {
  padding: 10px 0;
  opacity: 0.7;
}
.line2 {
  display: flex;
  align-items: center;
  cursor: pointer;
  background: rgba(0,0,100,0.04);
}
.line2 a {
  text-decoration: none;
  color: black;
}
.status {
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}
.status.offline {
  background: silver;
}
.status.online {
  background: yellowgreen;
}
.switch {
  padding: 10px;
  margin: 10px 0;
}
.switch[data-online=true] {
  color: yellowgreen;
}
.button {
  padding: 10px;
}
.on, .off {
  display: flex;
  align-items: center;
}
header .runner {
  padding: 10px 0 0;
}
.proxy {
  padding: 0 10px;
  text-align: right;
}
.proxy a {
  text-decoration: none;
  display: inline-block;
  padding: 5px 10px;
  border-radius: 2px;
  background: black;
  color: white;
}
.browser-options-btns {
  display: flex;
  padding-top: 5px;
}
.browser-options-row {
/*
  border-top: 1px solid rgba(0,0,0,0.1);
  border-bottom: 1px solid rgba(0,0,0,0.1);
  */
  display: flex;
  padding: 10px;
  align-items: flex-start;
}
.browser-options-row h3 {
  margin: 0;
  font-size: 14px;
  margin-bottom: 3px;
}
.browser-options-row .btn.disabled {
  opacity: 0.7;
}
.browser-options-row .btn {
  font-weight: bold;
  width: 100px;
  text-align: center;
  display: block;
  margin-right: 10px;
  flex-shrink: 0;
  padding: 5px;
}
.badge {
  font-size: 12px;
  padding: 5px 10px;
  background: rgba(0,0,100,0.1);
  border-radius: 5px;
  display: inline-block;
  margin-top: 5px;
}
a.badge {
  color: royalblue;
  text-decoration: none;
  cursor: pointer;
}
.badge a {
  color: royalblue;
  text-decoration: none;
}
body.dark .btn {
  color: white;
  background: rgba(255,255,255,0.05) !important;
}
body.dark .badge {
  background: rgba(255,255,255,0.1);
}
/*
body.dark .browser-options-row {
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
*/
body.dark .context-menu-wrapper {
  background: rgba(0,0,0,0.9) !important;
  color: white !important;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 12px 30px rgba(0,0,0,0.45);
}
.context-menu-wrapper {
  background: rgba(0,0,0,0.06) !important;
}
.context-menu {
 /* 
  max-height: 10000px;
  overflow: hidden;
  transition: max-height 1s ease-in-out;
  */
  display: flex;
  margin: 0 5px 0 0;
}
.context-menu .btn:hover {
  color: cornflowerblue !important;
}
.context-menu .btn {
  background: none !important;
  border: none !important;
  display: block;
  width: 80px;
  padding: 6px 10px !important;
  text-align: left;
  color: black;
}
.blank {
  width: 50px;
  height: 50px;
  flex-shrink: 0;
}
body.dark .section-header {
/*
  border-bottom: 1px solid rgba(255,255,255,0.07);
  */
}
.section-header {
/*
  border-bottom: 1px solid rgba(0, 0, 0,0.04);
  */
  font-weight: normal;
  font-size: 14px;
  padding: 15px 5px;
  /*
  margin: 0 0 15px;
  */
}
.section-header h2 {
  font-size: 20px;
  font-weight: lighter;
}
.section-header .section {
  padding: 0;
}
.section-header .section div {
  font-weight: normal;
  opacity: 0.6;
  font-size: 14px;
}
.section-header h3 {
  display: flex;
  margin: 0;
}
.section-header .col {
  padding-left: 10px;
  flex-grow: 1;
  min-width: 0;
  word-wrap: break-word;
}
.tab .btn {
  color: black;
  background: none !important;
}
body.dark .tab .btn {
  background: none !important;
}
.app-btns .btn {
  border-radius: 4px;
  padding: 8px 10px;
  width: 70px;
  /*
  padding: 6px 10px;
  */
  text-align: center;
}
body.dark .context-menu .btn {
  color: white;
}
.context-menu.collapsed {
/*
  max-height: 0; 
  */
  display: none;
}
body.dark .open-menu, body.dark .browse {
  border: none !important;
  /*
  background: black !important;
  */
  color: white !important;
}
.open-menu:hover, .browse:hover, body.dark .open-menu:hover, body.dark .browse:hover {
  color: royalblue !important;
}
.open-menu, .browse {
  width: 80px;
  border-radius: 0 !important;
  background: rgba(0,0,0,0.04) !important;
  color: black !important;
  /*
  border: 1px solid rgba(0, 0, 0, 0.3);
  */
}
.open-menu.selected {
  border: none !important;
  /*
  background: none !important;
  */
}
.open-menu.selected span {
  display: none;
}
.sections {
  display: flex;
}
.section {
  display: block;
}
.section h2 {
  margin: 0;
}
.line.align-top h3 .col .btn {
  box-sizing: border-box;
  margin-top: 5px;
  width: 100%;
}
.desc {
  font-size: 14px;
  padding: 5px 0;
  font-weight: normal;
}
.section-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  gap: 1rem; /* Optional spacing between columns */
}
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  gap: 1rem; /* Optional spacing between columns */
}
.grid-1 {
  padding: 10px;
}
.grid-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); /* Responsive columns that wrap */
  gap: 1rem; /* Optional spacing between columns */
  padding: 10px;
}
.grid-3 > * {
  min-width: 0;
}
.section-header .grid-1, .section-header .grid-2, .section-header .grid-3 {
  background: none !important;
  padding: 0 !important;
}
.grid-1, .grid-2, .grid-3 {
  background: rgba(0,0,0,0.04);
  margin-top: 5px;
}
body.dark .grid-1, body.dark .grid-2, body.dark .grid-3 {
  background: rgba(255,255,255,0.03);
  margin-top: 5px;
}
main {
  display: flex;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
aside .tab i {
  width: 20px;
  text-align: center;
}
body.dark aside .tab {
  color: white;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: royalblue !important;
  opacity: 1;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
  text-decoration: none;
  padding: 10px;
  font-size: 12px;
  opacity: 0.5;
  border-left: 10px solid transparent;
}
body.dark aside .tab.selected {
  color: white;
}
aside .selected {
  font-weight: bold;
  opacity: 1;
}
/*
body.dark aside .selected {
  border-left: 10px solid white;
}
aside .selected {
  border-left: 10px solid black;
  font-weight: bold;
  opacity: 1;
}
*/
.tab-content {
  width: 100%;
  flex-direction: column;
  flex-wrap: wrap;
  gap: 15px;
}
.tab:hover {
  color: royalblue;
}
.tab-content .tab {
  text-decoration: none;
  display: flex;
  font-size: 14px;
  font-weight: bold;
  color: black;
  overflow: hidden;
  box-sizing: border-box;
  align-items: center;
  gap: 5px;
  background: rgba(0,0,0,0.04);
  border-radius: 5px;
}
.tab .desc {
  flex-grow: 1;
  text-align: right;
}
body.dark aside .tab {
  background: none;
}
body.dark .tab {
  color: white;
  background: rgba(255,255,255,0.03);
}
.tab h2 {
  margin: 0;
  font-size: 14px;
}
.tab .col {
  flex-grow: 1;
  margin-left: 10px;
}
.tab .emoji {
  width: 30px;
  height: 30px;
  font-size: 20px;
  box-sizing: border-box;
  text-align:center;
  display: flex;
  justify-content: center;
  align-items: center;
}
.tab i.img {
  height: 30px;
  width: 30px;
  display: flex;
  justify-content: center;
  font-size: 20px;
  align-items: center;
  border-radius: 3px;
}
.tab .profile img, .tab .profile i {
  height: 30px;
  width: 30px;
  font-size: 30px;
  border-radius: 3px;
}
.menu-container {
  max-width: 800px;
  padding: 20px;
  align-items: flex-start;
}
.menu-container {
  display: flex;
  box-sizing: border-box;
}
.submenu .tab {
  padding: 0;
}
body.dark .net:hover, .net:hover {
  color: royalblue;
}
body.dark .net {
/*
  border-left: 3px solid white;
  */
  color: rgba(255,255,255,0.7);
}
.net {
  color: rgba(0,0,0,0.7);
  width: auto;
  margin: 3px 0;
  /*
  padding-left: 5px;
  border-left: 3px solid black;
  */
  font-size: 12px;
  text-decoration: none;
  display: block;
  background: none;
}
.net .mark {
  background: rgba(0,0,0,0.9);
  border-radius: 3px;
  color: white;
  width: 40px;
  display: inline-block;
  text-align: center;
  margin-right: 5px;
  padding: 2px 8px;
  font-size: 12px;
}
body.dark .net .mark {
  background: white;
  color: black;
}
.placeholder-icon {
  font-size: 40px;
  width: 50px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}
.launch-btns .btn {
  text-transform: capitalize;
}
.launch-btns {
  display: flex;
}
.launch-btns .btn.launch{
  width: 150px !important;
  text-align: center !important;
}
.installed-apps .title i {
  color: silver !important;
}
.tab.connected p {
  margin: 0;
}
.tab.connected {
  display: block;
}
.tab.connected .tab {
  border-radius: 0;
}
.tab.connected .tab {
  background: none;
}
td.bold {
  font-weight: bold;
  width: 100px;
}
/*
.tab.connected .desc, .tab.connected i, .tab.connected h2{
  color: #78b61a;
}
body.dark .tab.connected .desc, body.dark .tab.connected i, body.dark .tab.connected h2{
  color: greenyellow;
}
*/
.profile {
  width: 100%;
  padding: 10px;
  display: flex;
  gap: 10px;
  font-size: 14px;
  box-sizing: border-box;
}
.profile-column {
  flex-grow: 1;
}
.profile-column table {
  width: 100%;
}
body.dark .profile td {
  background: rgba(255,255,255,0.04);
}
.profile td {
  min-width: 100px;
  vertical-align: top;
  font-size: 14px;
  padding:6px 10px;
  white-space: pre-wrap;
  background: rgba(0,0,0,0.04);
  word-break: break-word;
}
.app-icon {
  width: 25px;
  padding: 5px;
}

/*
@media only screen and (max-width: 800px) {
  body {
    display: flex !important;
    flex-direction: row !important;
  }
}
*/
@media only screen and (max-width: 600px) {
  aside {
    width: unset;
    flex-shrink: unset;
  }
  aside {
    padding: 0 10px;
  }
  aside .tab.submenu {
    padding: 10px;
  }
  aside .tab i {
    width: 100%;
  }
  aside .tab .caption {
    display: none;
  }
  aside .tab {
    margin: 0;
    padding: 10px;
    border-left: none;
  }
  aside .btn-tab {
    flex-direction: column;
    padding: 10px 0;
  }
  aside .btn-tab .btn {
    display: flex;
    justify-content: center;
  }
  aside .btn-tab .btn .caption {
    display: none; 
  }
  header .flexible {
    min-width: unset;
  }
}

@media only screen and (max-width: 480px) {
  .btn2 {
    padding: 5px;
    font-size: 11px;
  }
  .nav-btns {
    flex-grow: 1;
    justify-content: center;
    padding: 0;
  }
}
</style>
<script src="/window_storage.js"></script>
<script src="/popper.min.js"></script>
<script src="/tippy-bundle.umd.min.js"></script>
<script src="/hotkeys.min.js"></script>
<script src="/sweetalert2.js"></script>
<script src="/common.js"></script>
<script src="/opener.js"></script>
<script src="/nav.js"></script>
<script src="/urldropdown.js"></script>
<script>
// Initialize URL Dropdown with empty behavior for connect page
document.addEventListener('DOMContentLoaded', function() {
  initUrlDropdown({
    clearBehavior: 'empty'
  });
});
</script>
</head>
<body class='<%=theme%>' data-agent="<%=agent%>">
<header class='navheader grabbable'>
<h1>
<a class='home' href="/home"><img class='icon' src="/pinokio-black.png"></a>
<button class='btn2' id='minimize-header' data-tippy-content="fullscreen" title='fullscreen'>
  <div><i class="fa-solid fa-expand"></i></div>
</button>
<button class='btn2' id='back' data-tippy-content="back"><div><i class="fa-solid fa-chevron-left"></i></div></button>
<button class='btn2' id='forward' data-tippy-content="forward"><div><i class="fa-solid fa-chevron-right"></i></div></button>
<button class='btn2' id='refresh-page' data-tippy-content="refresh"><div><i class="fa-solid fa-rotate-right"></i></div></button>
<button class='btn2' id='screenshot' data-tippy-content="screen capture"><i class="fa-solid fa-camera"></i></button>
<button class='btn2' id='inspector' data-tippy-content="X-ray mode"><i class="fa-solid fa-eye"></i></button>
<button class='btn2 mobile-link-button' id='mobile-link-button' data-tippy-content="enter url"><i class="fa-solid fa-link"></i></button>
<div class='mobile-flexible'></div>
<form class='urlbar'>
  <div class='url-input-container'>
    <input type='url' placeholder='enter any local url to open in pinokio'>
    <div class='url-dropdown' id='url-dropdown'></div>
  </div>
</form>
<a class='btn2' href="/columns" data-tippy-content="split into 2 columns">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class='btn2' href="/rows" data-tippy-content="split into 2 rows">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class='btn2' id='new-window' data-tippy-content="open a new window" title='open a new window' data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class='btn2 hidden' id='close-window' data-tippy-content='close this section'>
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<main>
<div class='container'>
  <div class='config'>
    <div class='config-header'>
      <div class='header-label'><i class="fa-solid fa-plug"></i> Login</div>
      <div class='desc'>Log into localhost apps with 3rd party services.</div>
    </div>
  </div>
  <div class='menu-container'>
    <div class='tab-content'>
      <% items.forEach((item) => { %>
        <% if (item.profile) { %>
          <a href="<%=item.url%>" class="tab connected">
            <div class='tab'>
              <% if (item.image) { %>
                <img class="app-icon" src="<%=item.image%>"/>
              <% } else if (item.icon) { %>
                <i class="<%=item.icon%> img"></i>
              <% } else if (item.emoji) { %>
                <div class='emoji'><%=item.emoji%></div>
              <% } %>
              <h2><%=item.title%></h2>
              <div class="desc"><%-item.description%></div>
              <div class="btn">
                <i class="fa-solid fa-angle-right"></i>
              </div>
            </div>
            <div class="profile">
              <% if (item.profile.image) { %>
                <img src="<%=item.profile.image%>">
              <% } else if (item.profile.icon) { %>
                <i class="<%=item.profile.icon%>"></i>
              <% }  %>
              <div class='profile-column'>
                <table>
                <% item.profile.items.forEach((row) => { %>
                  <tr><td class='bold'><%=row.key%></td><td><%=row.val%></td></tr>
                <% }) %>
                </table>
              </div>
            </div>
          </a>
        <% } else { %>
          <a href="<%=item.url%>" class="tab">
            <% if (item.image) { %>
              <img class="icon" src="<%=item.image%>"/>
            <% } else if (item.icon) { %>
              <i class="<%=item.icon%> img"></i>
            <% } else if (item.emoji) { %>
              <div class='emoji'><%=item.emoji%></div>
            <% } %>
            <h2><%=item.title%></h2>
            <div class="desc"><%=item.description%></div>
            <div class="btn">
              <i class="fa-solid fa-angle-right"></i>
            </div>
          </a>
        <% } %>
      <% }) %>
    </div>
  </div>
</div>
<%- include('partials/main_sidebar', { selected: 'connect' }) %>
</main>
</body>
</html>
