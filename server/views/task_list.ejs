<!doctype html>
<html lang="en">
<%
  const tr = typeof t === "function" ? t : ((key) => { throw new Error("i18n translator is not initialized") })
%>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= tr("nav.tasks") %></title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/css/brands.min.css" rel="stylesheet">
  <link href="/noty.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
  <script>
  window.PINOKIO_I18N = Object.assign({}, window.PINOKIO_I18N || {}, <%- JSON.stringify(typeof i18nCatalog === "object" && i18nCatalog ? i18nCatalog : {}) %>);
  </script>
  <script src="/task-launcher.js" defer></script>
  <% if (agent === "electron") { %>
    <link href="/electron.css" rel="stylesheet"/>
  <% } %>
</head>
<%
  const filterLabel = (value) => {
    const labels = {
      workspaces: tr("tasks.target_workspaces"),
      api: tr("tasks.target_api"),
      plugin: tr("tasks.target_plugin")
    }
    return labels[value] || value
  }
%>
<body class="<%= theme %> main-sidebar-page task-launcher-page task-page task-library-page" data-agent="<%= agent %>">
  <%- include('partials/app_navheader', { agent }) %>
  <main>
  <div class="task-container">
  <section class="task-shell">
    <header class="task-shell-header">
      <div class="task-shell-header-main">
        <p class="task-eyebrow"><%= tr("nav.tasks") %></p>
        <h1 class="task-title"><%= tr("nav.tasks") %></h1>
        <p class="task-description"><%- tr("tasks.stored_in", { path: `<code>${tasksRootPath}</code>` }) %></p>
      </div>
      <div class="task-header-actions">
        <button class="task-link-button" type="button" data-task-library-download-open>
          <i class="fa-solid fa-download" aria-hidden="true"></i>
          <span><%= tr("common.download") %></span>
        </button>
        <a class="task-link-button primary" href="/tasks/new">
          <i class="fa-solid fa-plus" aria-hidden="true"></i>
          <span><%= tr("common.create") %></span>
        </a>
      </div>
    </header>

    <div class="task-shell-body">
      <% if (error) { %>
        <div class="task-status error"><%= error %></div>
      <% } %>

      <section class="task-section" data-task-library>
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title"><%= tr("tasks.library") %></h2>
            <p class="task-section-subcopy"><%= tr("tasks.library_description") %></p>
          </div>
        </div>
        <div class="task-library-controls">
          <label class="task-library-search-field">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <input class="task-library-search-input" type="search" placeholder="<%= tr("tasks.search_placeholder") %>" data-task-library-search <%= items.length ? '' : 'disabled' %>>
            <button class="task-library-search-clear" type="button" data-task-library-clear hidden><%= tr("common.clear") %></button>
          </label>
          <div class="task-filter-row" role="tablist" aria-label="<%=tr("tasks.filters")%>">
            <a class="task-filter-chip <%= !currentFilter ? 'active' : '' %>" href="/tasks"><%= tr("common.all") %></a>
            <% filterOptions.forEach((filter) => { %>
              <a class="task-filter-chip <%= currentFilter === filter ? 'active' : '' %>" href="/tasks?filter=<%= encodeURIComponent(filter) %>"><%= filterLabel(filter) %></a>
            <% }) %>
          </div>
        </div>

        <% if (!items.length) { %>
          <div class="task-empty-state">
            <p class="task-empty-copy"><%= tr("tasks.empty_library") %></p>
          </div>
        <% } else { %>
          <div class="task-empty-state task-library-search-empty" data-task-library-empty hidden>
            <p class="task-empty-copy"><%= tr("tasks.no_search_matches") %></p>
          </div>
          <div class="task-list" data-task-library-list>
            <% items.forEach((item) => { %>
              <%
                const taskSearchParts = [
                  item.id,
                  item.ref,
                  item.title,
                  item.description,
                  item.path,
                  item.target,
                  item.ui && item.ui.sourceValue,
                  item.ui && item.ui.statusValue,
                  ...(item.ui && Array.isArray(item.ui.badges)
                    ? item.ui.badges.map((badge) => badge && badge.label ? badge.label : "")
                    : []),
                  ...(Array.isArray(item.inputs)
                    ? item.inputs.reduce((parts, input) => {
                        if (input && input.name) parts.push(input.name)
                        if (input && input.label) parts.push(input.label)
                        return parts
                      }, [])
                    : [])
                ].filter(Boolean).join(' ').toLowerCase()
              %>
              <a class="task-list-item task-list-link" href="/task?id=<%= encodeURIComponent(item.id) %>" data-task-library-item data-task-search="<%= taskSearchParts %>">
                <div class="task-list-copy">
                  <div class="task-list-title-row">
                    <div class="task-list-title"><%= item.title %></div>
                    <% if (item.ui && Array.isArray(item.ui.badges) && item.ui.badges.length) { %>
                      <div class="task-badge-row task-list-badges">
                        <% item.ui.badges.forEach((badge) => { %>
                          <span class="task-badge <%= badge.tone ? `task-badge-${badge.tone}` : '' %>"><%= badge.label %></span>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>
                  <% if (item.description) { %>
                    <p class="task-list-description"><%= item.description %></p>
                  <% } %>
                  <% if (item.ui && item.ui.sourceValue) { %>
                    <p class="task-list-meta"><span class="task-list-meta-id"><%= item.id %></span><span class="task-list-meta-sep">·</span><span><%= item.ui.sourceValue %></span></p>
                  <% } %>
                  <% if (item.ui && item.ui.statusValue) { %>
                    <p class="task-list-status"><%= item.ui.statusValue %></p>
                  <% } %>
                </div>
                <div class="task-list-open" aria-hidden="true">
                  <i class="fa-solid fa-chevron-right"></i>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </section>
  </div>
  <div class="task-tool-sheet-layer task-library-download-layer" data-task-library-download-layer hidden>
    <button type="button" class="task-tool-sheet-backdrop" aria-label="<%= tr("tasks.close_download_dialog") %>" data-task-library-download-close></button>
    <section class="task-tool-sheet task-library-download-sheet" role="dialog" aria-modal="true" aria-labelledby="task-library-download-title">
      <div class="task-tool-sheet-header">
        <div class="task-tool-sheet-heading">
          <div class="task-tool-sheet-title" id="task-library-download-title"><%= tr("tasks.download_task") %></div>
          <div class="task-tool-sheet-description"><%= tr("tasks.download_task_description") %></div>
        </div>
        <button type="button" class="task-tool-sheet-close" aria-label="<%= tr("tasks.close_download_dialog") %>" data-task-library-download-close>
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </div>
      <form class="task-tool-sheet-body task-library-download-form" action="/task" method="get">
        <label class="task-field">
          <span class="task-label"><%= tr("tasks.repository_url") %></span>
          <input class="task-input" type="url" name="ref" placeholder="https://github.com/you/your-task" required data-task-library-download-input>
        </label>
        <div class="task-actions task-library-download-actions">
          <button class="task-link-button" type="button" data-task-library-download-close><%= tr("common.cancel") %></button>
          <button class="task-button primary" type="submit">
            <i class="fa-solid fa-download" aria-hidden="true"></i>
            <span><%= tr("common.download") %></span>
          </button>
        </div>
      </form>
    </section>
  </div>
  <%- include('partials/main_sidebar', { selected: 'tasks' }) %>
  </main>
  <%- include('partials/app_common_scripts') %>
</body>
</html>
