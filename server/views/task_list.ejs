<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Tasks</title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
</head>
<body class="<%= theme %> task-launcher-page">
  <main class="task-shell">
    <header class="task-shell-header">
      <div class="task-shell-header-main">
        <p class="task-eyebrow">Tasks</p>
        <h1 class="task-title">Reusable task packages for Pinokio.</h1>
        <p class="task-description">Create tasks locally or install them from git. Each task lives under <code>PINOKIO_HOME/tasks</code> and opens into the right working root when you run it.</p>
      </div>
      <div class="task-header-actions">
        <a class="task-link-button" href="/home">
          <i class="fa-solid fa-house" aria-hidden="true"></i>
          <span>Home</span>
        </a>
        <a class="task-link-button primary" href="/tasks/new">
          <i class="fa-solid fa-plus" aria-hidden="true"></i>
          <span>Create task</span>
        </a>
      </div>
    </header>

    <div class="task-shell-body">
      <% if (error) { %>
        <div class="task-status error"><%= error %></div>
      <% } %>

      <section class="task-section">
        <div class="task-section-head">
          <h2 class="task-section-title">Install from git</h2>
          <div class="task-section-note">Shared tasks resolve by remote ref, not by local folder name.</div>
        </div>
        <form class="task-grid" action="/task" method="get">
          <label class="task-field">
            <span class="task-label">Task repository URL</span>
            <input class="task-input" type="url" name="ref" placeholder="https://github.com/you/your-task" required>
          </label>
          <div class="task-actions">
            <button class="task-button primary" type="submit">
              <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
              <span>Open task</span>
            </button>
          </div>
        </form>
      </section>

      <section class="task-section">
        <div class="task-section-head">
          <h2 class="task-section-title">Installed tasks</h2>
          <div class="task-section-note"><%= items.length %> total</div>
        </div>

        <% if (!items.length) { %>
          <div class="task-empty-state">
            <p class="task-empty-copy">No tasks installed yet. Create one locally or open a remote task URL to install it on demand.</p>
          </div>
        <% } else { %>
          <div class="task-list">
            <% items.forEach((item) => { %>
              <article class="task-list-item">
                <div class="task-list-copy">
                  <div class="task-list-title-row">
                    <div class="task-list-title"><%= item.title %></div>
                    <span class="task-badge"><%= item.id %></span>
                  </div>
                  <p class="task-list-description"><%= item.description || 'No description yet.' %></p>
                  <div class="task-badge-row">
                    <span class="task-badge">
                      <i class="fa-solid fa-folder-tree" aria-hidden="true"></i>
                      <span><%= item.path %></span>
                    </span>
                    <span class="task-badge">
                      <i class="fa-solid fa-brackets-curly" aria-hidden="true"></i>
                      <span><%= item.inputs.length %> input<%= item.inputs.length === 1 ? '' : 's' %></span>
                    </span>
                    <% if (item.ref) { %>
                      <span class="task-badge">
                        <i class="fa-solid fa-code-branch" aria-hidden="true"></i>
                        <span>Remote</span>
                      </span>
                    <% } else { %>
                      <span class="task-badge">
                        <i class="fa-solid fa-laptop-code" aria-hidden="true"></i>
                        <span>Local</span>
                      </span>
                    <% } %>
                  </div>
                </div>
                <div class="task-actions-row">
                  <a class="task-link-button primary" href="/task?id=<%= encodeURIComponent(item.id) %>">
                    <i class="fa-solid fa-play" aria-hidden="true"></i>
                    <span>Run</span>
                  </a>
                  <a class="task-link-button" href="/share/task?<%= item.ref ? `ref=${encodeURIComponent(item.ref)}` : `id=${encodeURIComponent(item.id)}` %>">
                    <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
                    <span>Share</span>
                  </a>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    </div>
  </main>
</body>
</html>
