<button class='btn2' id='inspector' data-tippy-content="X-ray mode"><i class="fa-solid fa-eye"></i></button>
<div class='flexible'></div>
<a class='btn2' href="/columns" data-tippy-content="split into 2 columns">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class='btn2' href="/rows" data-tippy-content="split into 2 rows">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class='btn2' id='new-window' data-tippy-content="open a new window" title='open a new window' data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class='btn2 hidden' id='close-window' data-tippy-content='close this section'>
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<main>
  <div class="container">
      <h1><img class='logo2' src="/pinokio-black.png"/> Project Setup</h1>

      <div class="progress-bar">
          <div class="step active" data-step="1">1</div>
          <div class="step" data-step="2">2</div>
          <div class="step" data-step="3">3</div>
      </div>

      <form id="bootstrap-form">
          <!-- Step 1: New vs Clone -->
          <div class="step-content active" id="step-1">
              <h2>Step 1: Choose Your Starting Point</h2>
              <div class="radio-group">
                  <label>
                      <input type="radio" name="startType" value="new" required>
                      <span>New Project</span>
                      <p class="description">Start with a fresh project</p>
                  </label>
                  <label>
                      <input type="radio" name="startType" value="clone" required>
                      <span>Clone Repository</span>
                      <p class="description">Clone an existing git repository</p>
                  </label>
              </div>
              <div class="button-group">
                  <button type="button" class="btn btn-primary" onclick="nextStep()">Next <i class="fa-solid fa-chevron-right"></i></button>
              </div>
          </div>

          <!-- Step 2: Project Type -->
          <div class="step-content" id="step-2">
              <h2>Step 2: Select Project Type</h2>

              <!-- Clone Project Options -->
              <div id="clone-options" class="project-options">
                  <div class="git-url-input">
                      <label for="gitUrl">Git Repository URL:</label>
                      <input type="url" name="gitUrl" id="gitUrl" placeholder="https://github.com/username/repository.git">
                  </div>

                  <div class="radio-group">
                      <label>
                          <input type="radio" name="projectType" value="nodejs">
                          <span>Node.js</span>
                      </label>
                      <label>
                          <input type="radio" name="projectType" value="python">
                          <span>Python</span>
                      </label>
                      <label>
                          <input type="radio" name="projectType" value="empty">
                          <span>Others</span>
                      </label>
                  </div>

                  <!-- Python Options for Clone -->
                  <div id="python-options-clone" class="conditional-options">
                      <h3>Python Options</h3>
                      <div class="checkbox-group">
                          <label>
                              <input type="checkbox" name="pythonOptions" value="gradio">
                              <span>Gradio</span>
                          </label>
                          <label>
                              <input type="checkbox" name="pythonOptions" value="torch">
                              <span>Torch</span>
                          </label>
                      </div>
                  </div>
              </div>

              <!-- New Project Options -->
              <div id="new-options" class="project-options">
                  <div class="radio-group">
                      <label>
                          <input type="radio" name="projectType" value="empty">
                          <span>Empty Project</span>
                      </label>
                      <label>
                          <input type="radio" name="projectType" value="cli">
                          <span>CLI App Launcher</span>
                      </label>

                      <!-- CLI App Launcher Options -->
                      <div id="cli-options" class="conditional-options">
                          <div class="radio-group">
                              <label>
                                  <input type="radio" name="cliType" value="instant">
                                  <span>Instant Command Launcher</span>
                                  <p class="description">npx, uvx, etc.</p>
                              </label>
                              <label>
                                  <input type="radio" name="cliType" value="installable">
                                  <span>Installable CLI App Launcher</span>
                                  <p class="description">CLI apps that require an installation step</p>
                              </label>
                          </div>

                          <!-- Instant CLI Options -->
                          <div id="instant-cli-options" class="conditional-options">
                              <h4>Launch Command</h4>
                              <input type="text" name="launchCommand" placeholder="e.g., npx create-react-app">
                              <!--
                              <h4>Path to Run Command From (optional)</h4>
                              <input type="text" name="launchPath" placeholder="e.g., /home/user/projects">
                              -->
                          </div>

                          <!-- Installable CLI Options -->
                          <div id="installable-cli-options" class="conditional-options">
                              <h4>Install Command</h4>
                              <input type="text" name="installCommand" placeholder="e.g., npm install -g @my/cli-tool">
                              <h4>Path to Run Install Command From (optional)</h4>
                              <input type="text" name="installPath" placeholder="e.g., /home/user">
                              <h4>Launch Command</h4>
                              <input type="text" name="installableLaunchCommand" placeholder="e.g., my-cli-tool start">
                              <h4>Path to Run Launch Command From (optional)</h4>
                              <input type="text" name="launchPath" placeholder="e.g., /home/user/projects">
                          </div>

                          <!-- Virtual Environment Option -->
                          <div class="checkbox-group">
                              <label>
                                  <input type="checkbox" name="useVenv" value="true">
                                  <span>Use virtual environment (venv)</span>
                              </label>
                          </div>
                      </div>

                      <label>
                          <input type="radio" name="projectType" value="documentation">
                          <span>Documentation</span>
                      </label>

                      <!-- Documentation Options -->
                      <div id="documentation-options" class="conditional-options">
                          <div class="radio-group">
                              <label>
                                  <input type="radio" name="docType" value="local">
                                  <span>Documentation from Local Project</span>
                              </label>
                              <div id="local-doc-options" class="conditional-options">
                                  <h4>Local Project Path</h4>
                                  <input type="text" name="localDocPath" placeholder="e.g., /home/user/my-project" id='local'>
                              </div>

                              <label>
                                  <input type="radio" name="docType" value="remote">
                                  <span>Documentation from Remote Git Repository</span>
                              </label>
                              <div id="remote-doc-options" class="conditional-options">
                                  <h4>Remote Git Repository URL</h4>
                                  <input type="text" name="remoteDocUrl" placeholder="e.g., https://github.com/user/repo.git">
                              </div>
                          </div>
                      </div>
                      <label>
                          <input type="radio" name="projectType" value="nodejs">
                          <span>Node.js</span>
                      </label>
                      <label>
                          <input type="radio" name="projectType" value="python">
                          <span>Python</span>
                      </label>
                  </div>


                  <!-- Python Options -->
                  <div id="python-options" class="conditional-options">
                      <h3>Python Options</h3>
                      <div class="checkbox-group">
                          <label>
                              <input type="checkbox" name="pythonOptions" value="gradio">
                              <span>Gradio</span>
                          </label>
                          <label>
                              <input type="checkbox" name="pythonOptions" value="torch">
                              <span>Torch</span>
                          </label>
                      </div>
                  </div>
              </div>

              <div class="button-group">
                  <button type="button" class="btn btn-secondary" onclick="prevStep()"><i class="fa-solid fa-chevron-left"></i> Back</button>
                  <button type="button" class="btn btn-primary" onclick="nextStep()">Next <i class="fa-solid fa-chevron-right"></i></button>
              </div>
          </div>

          <!-- Step 3: AI Prompt -->
          <div class="step-content" id="step-3">
              <h2>Step 3: AI Prompt (Optional)</h2>
              <p>Enter a prompt to build your app with AI assistance.</p>
              <blockquote>The prompt will be stored in README.md, which can be used by any AI coding tool to build the app and the launcher.</blockquote>
              <textarea
                  name="aiPrompt"
                  id="aiPrompt"
                  rows="4"
                  placeholder="Describe what you want to build... (optional)"
              ></textarea>

              <div class="button-group">
                  <button type="button" class="btn btn-secondary" onclick="prevStep()"><i class="fa-solid fa-chevron-left"></i> Back</button>
                  <button type="submit" class="btn btn-success">Create</button>
              </div>
          </div>
      </form>
      <div id='terminal'></div>
      <div id='end'></div>
  </div>
</main>
<script>
let currentStep = 1;
const totalSteps = 3;

document.addEventListener('DOMContentLoaded', function() {
    // Initialize form
    showStep(currentStep);

    // Add event listeners for conditional logic
    const startTypeRadios = document.querySelectorAll('input[name="startType"]');
    startTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleStartTypeChange);
    });

    const projectTypeRadios = document.querySelectorAll('input[name="projectType"]');
    projectTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleProjectTypeChange);
    });

    const cliTypeRadios = document.querySelectorAll('input[name="cliType"]');
    cliTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleCliTypeChange);
    });

    const docTypeRadios = document.querySelectorAll('input[name="docType"]');
    docTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleDocTypeChange);
    });

    // Form submission
    document.getElementById('bootstrap-form').addEventListener('submit', handleSubmit);

    document.querySelector("#local").addEventListener("click", (e) => {
      let socket = new Socket()
      socket.run({
        method: "kernel.bin.filepicker",
        params: {
          cwd: "<%-JSON.stringify(cwd).slice(1, -1)%>",
          title: "Select a path",
          type: "folder",
        }
      }, async (packet) => {
        console.log('packet', packet)
        if (packet.type === "result") {
          if (packet.data.paths.length > 0) {
            let p = packet.data.paths[0]
            e.target.value = p
          }
        }
      }).then((res) => {
        console.log("Ended", res)
      })
    })
});

function showStep(stepNumber) {
    // Hide all steps
    document.querySelectorAll('.step-content').forEach(step => {
        step.classList.remove('active');
    });

    // Show current step
    document.getElementById(`step-${stepNumber}`).classList.add('active');

    // Update progress bar
    document.querySelectorAll('.progress-bar .step').forEach((step, index) => {
        step.classList.remove('active', 'completed');
        if (index + 1 < stepNumber) {
            step.classList.add('completed');
        } else if (index + 1 === stepNumber) {
            step.classList.add('active');
        }
    });
}

function nextStep() {
    if (validateCurrentStep()) {
        if (currentStep < totalSteps) {
            currentStep++;
            showStep(currentStep);
        }
    }
}

function prevStep() {
    if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
    }
}

function validateCurrentStep() {
    if (currentStep === 1) {
        const startType = document.querySelector('input[name="startType"]:checked');
        if (!startType) {
            alert('Please select whether to start with a new project or clone a repository.');
            return false;
        }
        return true;
    }

    if (currentStep === 2) {
        const startType = document.querySelector('input[name="startType"]:checked');
        const projectType = document.querySelector('input[name="projectType"]:checked');

        if (!projectType) {
            alert('Please select a project type.');
            return false;
        }

        if (startType.value === 'clone') {
            const gitUrl = document.getElementById('gitUrl').value.trim();
            if (!gitUrl) {
                alert('Please enter a Git repository URL.');
                return false;
            }
        }

        // Validate CLI options
        if (projectType.value === 'cli') {
            const cliType = document.querySelector('input[name="cliType"]:checked');
            if (!cliType) {
                alert('Please select a CLI app launcher type.');
                return false;
            }

            if (cliType.value === 'instant') {
                const launchCommand = document.querySelector('input[name="launchCommand"]').value.trim();
                if (!launchCommand) {
                    alert('Please enter a launch command.');
                    return false;
                }
            } else if (cliType.value === 'installable') {
                const installCommand = document.querySelector('input[name="installCommand"]').value.trim();
                const launchCommand = document.querySelector('input[name="installableLaunchCommand"]').value.trim();
                if (!installCommand) {
                    alert('Please enter an install command.');
                    return false;
                }
                if (!launchCommand) {
                    alert('Please enter a launch command.');
                    return false;
                }
            }
        }

        // Validate Documentation options
        if (projectType.value === 'documentation') {
            const docType = document.querySelector('input[name="docType"]:checked');
            if (!docType) {
                alert('Please select a documentation source.');
                return false;
            }

            if (docType.value === 'local') {
                const localDocPath = document.querySelector('input[name="localDocPath"]').value.trim();
                if (!localDocPath) {
                    alert('Please enter a local project path.');
                    return false;
                }
            } else if (docType.value === 'remote') {
                const remoteDocUrl = document.querySelector('input[name="remoteDocUrl"]').value.trim();
                if (!remoteDocUrl) {
                    alert('Please enter a remote Git repository URL.');
                    return false;
                }
            }
        }

        return true;
    }

    return true;
}

function handleStartTypeChange(event) {
    const startType = event.target.value;
    const newOptions = document.getElementById('new-options');
    const cloneOptions = document.getElementById('clone-options');

    // Clear any existing selections
    document.querySelectorAll('input[name="projectType"]').forEach(radio => {
        radio.checked = false;
    });

    // Clear Git URL
    document.getElementById('gitUrl').value = '';

    // Hide python options
    document.getElementById('python-options').classList.remove('show');
    document.getElementById('python-options-clone').classList.remove('show');

    if (startType === 'clone') {
        cloneOptions.classList.add('show');
        newOptions.classList.remove('show');
    } else {
        newOptions.classList.add('show');
        cloneOptions.classList.remove('show');
    }
}

function handleProjectTypeChange(event) {
    const projectType = event.target.value;
    const startType = document.querySelector('input[name="startType"]:checked').value;

    // Hide all conditional options first
    document.getElementById('python-options').classList.remove('show');
    document.getElementById('python-options-clone').classList.remove('show');
    document.getElementById('cli-options').classList.remove('show');
    document.getElementById('documentation-options').classList.remove('show');

    // Clear all checkboxes and radio buttons
    document.querySelectorAll('input[name="pythonOptions"]').forEach(checkbox => {
        checkbox.checked = false;
    });
    document.querySelectorAll('input[name="cliType"]').forEach(radio => {
        radio.checked = false;
    });
    document.querySelectorAll('input[name="docType"]').forEach(radio => {
        radio.checked = false;
    });

    // Clear CLI input fields
    clearCliInputs();

    // Show appropriate options based on project type
    if (projectType === 'python') {
        if (startType === 'clone') {
            document.getElementById('python-options-clone').classList.add('show');
        } else {
            document.getElementById('python-options').classList.add('show');
        }
    } else if (projectType === 'cli') {
        document.getElementById('cli-options').classList.add('show');
    } else if (projectType === 'documentation') {
        document.getElementById('documentation-options').classList.add('show');
    }
}

function handleCliTypeChange(event) {
    const cliType = event.target.value;

    // Hide all CLI sub-options first
    document.getElementById('instant-cli-options').classList.remove('show');
    document.getElementById('installable-cli-options').classList.remove('show');

    // Clear CLI input fields
    clearCliInputs();

    // Show appropriate CLI options
    if (cliType === 'instant') {
        document.getElementById('instant-cli-options').classList.add('show');
    } else if (cliType === 'installable') {
        document.getElementById('installable-cli-options').classList.add('show');
    }
}

function clearCliInputs() {
    document.querySelectorAll('input[name="launchCommand"], input[name="launchPath"], input[name="installableLaunchCommand"], input[name="installCommand"], input[name="installPath"]').forEach(input => {
        input.value = '';
    });
    document.querySelector('input[name="useVenv"]').checked = false;
}

function handleDocTypeChange(event) {
    const docType = event.target.value;

    // Hide all documentation sub-options first
    document.getElementById('local-doc-options').classList.remove('show');
    document.getElementById('remote-doc-options').classList.remove('show');

    // Clear documentation input fields
    document.querySelector('input[name="localDocPath"]').value = '';
    document.querySelector('input[name="remoteDocUrl"]').value = '';

    // Show appropriate documentation options
    if (docType === 'local') {
        document.getElementById('local-doc-options').classList.add('show');
    } else if (docType === 'remote') {
        document.getElementById('remote-doc-options').classList.add('show');
    }
}

function handleSubmit(event) {
    event.preventDefault();

    const formData = new FormData(event.target);
    const config = {
        startType: formData.get('startType'),
        projectType: formData.get('projectType'),
        gitUrl: formData.get('gitUrl'),
        pythonOptions: formData.getAll('pythonOptions'),
        cliType: formData.get('cliType'),
        launchCommand: formData.get('launchCommand'),
        installableLaunchCommand: formData.get('installableLaunchCommand'),
        launchPath: formData.get('launchPath'),
        installCommand: formData.get('installCommand'),
        installPath: formData.get('installPath'),
        useVenv: formData.get('useVenv'),
        docType: formData.get('docType'),
        localDocPath: formData.get('localDocPath'),
        remoteDocUrl: formData.get('remoteDocUrl'),
        aiPrompt: formData.get('aiPrompt')
    };

    displayResults(config);
}

async function displayResults(config) {
  let shell_id
  <% if (theme === "dark") { %>
  let _theme = xtermTheme.FrontEndDelight
  <% } else { %>
  let _theme = xtermTheme.Tomorrow
  <% } %>
  const theme = Object.assign({ }, _theme, {
    selectionBackground: "red",
    selectionForeground: "white"
  })

  let term_config = {
    scrollback: 9999999,
    fontSize: 14,
    fontFamily: 'monospace',
    theme,
  }
  let res = await fetch("/xterm_config").then((res) => {
    return res.json()
  })
  if (res && res.config) {
    term_config = res.config
  }
  let socket = new Socket()
  const resizeSync = window.PinokioResizeSync.create({
    socket,
    getShellId: () => shell_id
  })
  const baseConfig = Object.assign({}, term_config)
  if (window.PinokioTerminalSettings && typeof window.PinokioTerminalSettings.applyToConfig === 'function') {
    term_config = window.PinokioTerminalSettings.applyToConfig(term_config)
  }
  const term = new Terminal(term_config)
  if (window.PinokioTerminalSettings && typeof window.PinokioTerminalSettings.register === 'function') {
    window.PinokioTerminalSettings.register(term, { baseConfig })
  }
  term.open(document.querySelector("#terminal"))
  const terminalContainer = document.querySelector("#terminal")
  window.PinokioTouch.bindTerminalFocus(term, terminalContainer)
  term.attachCustomKeyEventHandler(event => {
    console.log({ event })
    if ((event.ctrlKey || event.metaKey) && event.key === 'c') {
      const selection = term.getSelection();
      if (selection) {
        navigator.clipboard.writeText(selection);
        return false;
      }
    }
    if ((event.ctrlKey || event.metaKey) && event.key === 'v') {
      return true
    }
    return true;
  });
  term.onData((data) => {
    console.log({ key: data, shell_id })
    if (socket && shell_id) {
      socket.run({
        key: data,
        id: shell_id
      })
    }
  });
  const fitAddon = new FitAddon.FitAddon();
  term.loadAddon(fitAddon);
  fitAddon.fit();
  resizeSync.updateTerm(term, fitAddon, socket)
  term.focus()
  let observer = new ResizeObserver(() => {
    fitAddon.fit()
    resizeSync.sendResize(term.cols, term.rows)
  });
  observer.observe(document.body)
  const write = (text) => {
    if (text !== "\u0007") {
      term.write(text)
    }
  }
  resizeSync.reset()
  socket.run({
    method: "kernel.bin.init_launcher",
    cwd: "<%-JSON.stringify(cwd).slice(1, -1)%>",
    name: "<%=name%>",
    params: config
  }, async (packet) => {
    console.log('packet', packet)
    if (packet.type === 'start') {
      document.querySelector(".play-btn").classList.add("hidden")
      document.querySelector(".starting-btn").classList.add("hidden")
      document.querySelector(".stop-btn").classList.remove("hidden")
    } else if (packet.type === "result") {
      if (packet.data.success) {
        location.href = packet.data.success
      } else if (packet.data.error) {
        alert(packet.data.error)
      }
    } else if (packet.type === "stream") {
      // set the current shell id
      if (packet.data.id) {
        if (!shell_id) {
          shell_id = packet.data.id
          resizeSync.sendInitial()
        } else {
          shell_id = packet.data.id
        }
      }
      if (packet.data.raw) {
        write(packet.data.raw)
      } else if (packet.data.json) {
        write(JSON.stringify(packet.data.json).replace(/\n/g, "\r\n"))
        write("\r\n")
      } else if (packet.data.json2) {
        write(JSON.stringify(packet.data.json2, null, 2).replace(/\n/g, "\r\n"))
        write("\r\n")
      }
      document.querySelector("#end").scrollIntoView({ behavior: 'smooth' });
    } else if (packet.type === 'disconnect') {
      term.write("\r\nDisconnected...\r\n")
      socket.close()
      resizeSync.reset()
    } else if (packet.type === 'connect') {
      if (packet.data) {
        if (packet.data.shell) {
          shell_id = packet.data.shell
        }
        resizeSync.sendInitial()
        if (packet.data.state) {
          write(packet.data.state)
        }
      }
    } else if (packet.type === 'resize') {
      resizeSync.handleResizePacket(packet)
    }
  }).then((res) => {
    console.log("Ended", res)
  })
}

</script>
</body>
</html>
