<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

.container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
}
img.logo2 {
  height: 50px;
  width: 50px;
  vertical-align: middle;
}
h1, h2, h3, h4 {
  letter-spacing: -1px;
  font-size: 30px;
  font-weight: lighter;
}
h4 {
  font-size: 15px;
  letter-spacing: 0px;
}

h2 {
  font-size: 25px;
}
h1 {
  letter-spacing: 0px;
  font-size:40px;
  text-align: center;
  text-transform: uppercase;
}

body.dark blockquote {
    border-left: 10px solid rgba(255,255,255,0.1);
}
blockquote {
    padding: 10px;
    border-left: 10px solid rgba(0, 0, 0, 0.05);
    margin: 10px 0;
}

.progress-bar {
    display: flex;
    justify-content: center;
    margin: 20px 0;
}

.progress-bar .step {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 1rem;
    font-weight: bold;
    transition: all 0.3s ease;
}

body.dark .progress-bar .step.active {
    background: rgba(255,255,255,0.1);
}
.progress-bar .step.active {
    background: rgba(0,0,0,0.1);
    color: #ffffff;
}

.progress-bar .step.completed {
    background-color: #000000;
    color: #ffffff;
}

.step-content {
    display: none;
    padding: 2rem;
    margin-bottom: 2rem;
}

.step-content.active {
    display: block;
}

.step-content h2 {
    margin-bottom: 1.5rem;
}

/*
.radio-group {
    margin-bottom: 1.5rem;
}
*/

body.dark .radio-group label {
    background: rgba(0,0,0,0.3);
}
.radio-group label {
    display: flex;
    align-items: center;
    margin-bottom: 5px;
    padding: 10px;
    background: rgba(0,0,0,0.04);
    cursor: pointer;
    transition: all 0.3s ease;
}

/*
.radio-group label:hover {
    background-color: #f0f0f0;
}
*/

.radio-group label input[type="radio"] {
    margin-right: 0.5rem;
}

.radio-group label span {
    font-weight: 500;
    flex: 1;
}

.radio-group label .description {
    margin-left: 0.5rem;
}

.checkbox-group {
  margin: 10px 0;
}

.checkbox-group label {
    display: flex;
    align-items: center;
    /*
    margin-bottom: 5px;
    padding: 4px 0;
    */
    padding: 10px;
}

.checkbox-group label input[type="checkbox"] {
    margin-right: 0.5rem;
}

body.dark .conditional-options {
    background: rgba(255,255,255,0.03);
}
.conditional-options {
    margin: 20px 0 20px 20px;
    padding: 1rem;
    background: rgba(0,0,0,0.1);
    /*
    border: 1px solid #000000;
    */
    display: none;
}

/*
.conditional-options .radio-group label, .conditional-options .checkbox-group label {
  background: none !important;
}
*/

.conditional-options.show {
    display: block;
}

/*
.conditional-options h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
}

.conditional-options h4 {
    margin-bottom: 10px;
    font-size: 1rem;
    font-weight: 500;
}
*/

.project-options {
    display: none;
}

.project-options.show {
    display: block;
}

textarea, input[type="url"], input[type="text"] {
    width: 100%;
    padding: 10px;
    border: 1px solid #000000;
    font-family: inherit;
    margin: 5px 0 15px 0;
}

textarea {
    resize: vertical;
}

textarea:focus, input[type="url"]:focus, input[type="text"]:focus {
    outline: none;
}

.git-url-input {
    margin-bottom: 1.5rem;
}

.git-url-input label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
}

.button-group {
    display: flex;
    justify-content: space-between;
    margin-top: 2rem;
}

.btn {
    padding: 0.75rem 1.5rem;
    border: 1px solid #000000;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
}


.results {
    display: none;
    padding: 2rem;
    border: 1px solid #000000;
}

.results.show {
    display: block;
}

.results h2 {
    margin-bottom: 1rem;
}

#config-output {
    padding: 1rem;
    font-family: 'Courier New', monospace;
    white-space: pre-wrap;
}



















