  dependenciesEl.addEventListener("input", (event) => {
    const search = event.target && event.target.matches("[data-app-autolaunch-dependency-search]")
      ? event.target
      : null
    if (!search) return
    filterDependencyPicker(search.closest("[data-app-autolaunch-dependency-picker]"))
  })
  dependenciesEl.addEventListener("click", (event) => {
    const togglePicker = event.target && event.target.closest("[data-app-autolaunch-toggle-dependency-picker]")
    if (togglePicker) {
      event.preventDefault()
      dependencyPickerOpen = !dependencyPickerOpen
      renderDependencies()
      if (dependencyPickerOpen) {
        window.setTimeout(() => {
          const search = dependenciesEl.querySelector("[data-app-autolaunch-dependency-search]")
          if (search) search.focus()
        }, 0)
      }
      return
    }
    const add = event.target && event.target.closest("[data-app-autolaunch-add-dependency]")
    if (add) {
      event.preventDefault()
      const dependency = add.getAttribute("data-app-autolaunch-add-dependency")
      if (!(selectedScript || state.autolaunch)) {
        dependencyPickerOpen = false
        renderDependencies()
        setFeedback("Choose this app's launch script before adding requirements.", true)
        return
      }
      const dependencies = Array.isArray(state.autolaunch_depends) ? state.autolaunch_depends.slice() : []
      if (dependency && !dependencies.includes(dependency)) {
        dependencyPickerOpen = false
        pendingDependencyId = dependency
        dependencyScriptPickerOpen = dependency
        renderDependencies()
        loadDependencyScriptCandidates(dependency)
        setFeedback("")
      }
      return
    }
    const closeScriptModal = event.target && event.target.closest("[data-app-autolaunch-close-dependency-script-modal]")
    if (closeScriptModal) {
      event.preventDefault()
      if (pendingDependencyId === dependencyScriptPickerOpen) {
        pendingDependencyId = ""
      }
      if (dependencyScriptPickerOpen) {
        delete dependencyScriptSelections[dependencyScriptPickerOpen]
      }
      dependencyScriptPickerOpen = ""
      renderDependencies()
      setFeedback("")
      return
    }
    const configure = event.target && event.target.closest("[data-app-autolaunch-configure-dependency]")
    if (configure) {
      event.preventDefault()
      const dependency = configure.getAttribute("data-app-autolaunch-configure-dependency")
      pendingDependencyId = ""
      dependencyScriptPickerOpen = dependency
      renderDependencies()
      if (dependencyScriptPickerOpen) {
        loadDependencyScriptCandidates(dependency)
      }
      return
    }
    const scriptChoice = event.target && event.target.closest("[data-app-autolaunch-dependency-script-choice]")
    if (scriptChoice) {
      const dependency = scriptChoice.getAttribute("data-app-autolaunch-dependency-script-app")
      if (dependency && scriptChoice.value) {
        dependencyScriptSelections[dependency] = scriptChoice.value
        renderDependencies()
      }
      return
    }
    const confirmScript = event.target && event.target.closest("[data-app-autolaunch-confirm-dependency-script]")
    if (confirmScript) {
      event.preventDefault()
      const dependency = confirmScript.getAttribute("data-app-autolaunch-dependency-script-app")
      const dependencyApp = dependency ? dependencyById(dependency) : null
      const script = dependency ? (dependencyScriptSelections[dependency] || (dependencyApp && dependencyApp.autolaunch) || "") : ""
      if (dependency && script) {
        saveDependencyScript(dependency, script)
      }
      return
    }
    const remove = event.target && event.target.closest("[data-app-autolaunch-remove-dependency]")
    if (remove) {
      event.preventDefault()
      const dependency = remove.getAttribute("data-app-autolaunch-remove-dependency")
      const dependencies = Array.isArray(state.autolaunch_depends) ? state.autolaunch_depends : []
      if (dependency) {
        saveDependencies(dependencies.filter((id) => id !== dependency))
      }
      return
    }
  })
