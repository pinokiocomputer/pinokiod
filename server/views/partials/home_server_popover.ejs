<div class="home-server-popover" data-home-server-popover data-home-server-status="loading">
  <button
    type="button"
    class="btn2 home-server-popover__trigger"
    data-home-server-trigger
    data-tippy-content="Home Server"
    title="Home Server"
    aria-label="Home Server"
    aria-haspopup="dialog"
    aria-expanded="false"
  >
    <span class="home-server-popover__wifi" aria-hidden="true">
      <i class="fa-solid fa-wifi"></i>
      <span class="home-server-popover__wifi-slash"></span>
      <span class="home-server-popover__wifi-dot"></span>
    </span>
  </button>
  <div class="home-server-popover__panel" data-home-server-panel role="dialog" aria-label="Home Server" hidden>
    <div data-home-server-content>
      <div class="home-server-popover__loading">Checking Home Server...</div>
    </div>
  </div>
</div>
