<% } %>
<style>
body.frozen {
  display: flex;
  flex-direction: column;
  height: 100%;
}
#table > table {
  border-left: 2px solid black;
  padding-left: 5px;
  margin: 10px 0;
}
.highlight {
  background: yellow;
  width: 100px;
}
th {
  background: rgba(0,0,0,0.1);
  padding: 10px;
  font-size: 12px;
}
td {
  font-size: 12px;
  padding: 10px;
}
td.val {
  background: rgba(0,0,0,0.06);
}
td.key {
  background: rgba(0,0,0,0.1);
}
.button {
  cursor: pointer; 
  background: rgba(0,0,0,0.8);
  color: white;
  padding: 5px 10px;
  border-radius: 4px;
}
.button:hover {
  
}
<% if (init) { %>
  main {
    width: 100%;
    box-sizing: border-box;
    max-width: 600px;
    padding: 20px;
    margin: 0 auto;
  }
<% } else { %>
  #editor {
    width: 100%;
    box-sizing: border-box;
    max-width: 600px;
    padding: 20px;
    margin: 0 auto;
  }
<% } %>

header .btn {
  font-family: Sans-serif;
  display: block;
  margin-left: 10px;
  font-style: normal;
  font-size: 12px;
  font-weight: normal;
  padding: 5px 10px;
}
.disabled {
  opacity: 0.7;
}
body.dark .env-item input[type=text] {
  background: white;
}
.env-item input[type=text] {
  width: 100%;
  padding: 10px;
  box-sizing: border-box;
  border: none;
  background: rgba(0,0,100, 0.1);
}
body.dark .env-item label {
  color: cornflowerblue;
}
.env-item label {
  color: royalblue;
  display: block;
  margin-bottom: 5px;
  font-weight: bold;
  font-size: 18px;
}
.env-item.highlighted {
  border: 5px solid red;
}
.env-item {
/*
  padding-top: 10px;
  padding-bottom: 30px;
  */
  padding: 10px;
  margin-bottom: 20px;
}
body.dark .comment {
  border-left: 2px solid white;
}
.comment {
  opacity: 0.8;
  border-left: 2px solid black;
  padding-left: 10px;
}
#save {
  background: royalblue;
}
#delete-project {
  color: #fff;
  background: firebrick;
  width: 100%;
  display: block;
  text-align: center;
  margin-top: 20px;
  padding: 12px 16px;
}
#delete-project:hover {
  background: #b22222;
  color: #fff;
  border: none;
}
a#customize {
  text-decoration: underline;
  cursor: pointer;
}
.e {
  padding: 10px 0;
}
#editor {
  padding: 20px 0;
}
.center {
  display: flex;
  align-items: center;
  justify-content: center;
}
body {
  display: block;
  padding: 10px;
}
.card {
  display: flex;
  padding: 10px 0;
  box-sizing: border-box;
}
.card img {
  width: 100px;
  border-radius: 10px;
}
.card .description {
  opacity: 0.8;
}
.card .title {
  font-weight: bold;
  font-size: 30px;
  letter-spacing: -1px;
}
.card .col {
  padding-left: 10px;
}
h1 {
  font-size: 50px;
  padding-bottom: 20px;
}
footer {
  background: none;
  padding: 0;
  text-align: right;
  display: flex;
  margin: 10px 0 20px 0;
}
footer .btn {
  margin-left: 10px;
  display: inline-block;
  -webkit-appearance: button;
  -moz-appearance: button;
  appearance: button;

}
footer .btn.go-home {
  margin-left: 0px;
}
.btn.home-button {
  background: none !important;
  margin: 0 !important;
  font-size: 16px !important;
}
#editor {
  height: auto;
}
.env-title {
  font-weight: bold;
  margin-bottom: 5px;
}
.env-description {
  margin-bottom: 10px;
}
.warning {
  padding: 10px;
  margin: 10px 0 20px;
  border-left: 5px solid rgba(0,0,0,0.1);
}
.warning a {
  text-decoration: none;
  color: royalblue;
}
.install-options {
  margin: 0 0 20px;
}
body.dark .install-option {
  border-color: rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.04);
}
.install-option {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 16px;
  border: 1px solid rgba(15,23,42,0.12);
  border-radius: 4px;
  background: rgba(15,23,42,0.03);
}
.install-option-copy {
  min-width: 0;
  flex: 1;
}
.install-option-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 700;
}
body.dark .install-option-list {
  color: rgba(255,255,255,0.72);
}
.install-option-list {
  margin: 8px 0 0;
  padding-left: 18px;
  color: rgba(15,23,42,0.74);
  line-height: 1.45;
}
.install-option-list li + li {
  margin-top: 4px;
}
body.dark .beta-badge {
  border-color: rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.84);
}
.beta-badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 7px;
  border-radius: 999px;
  border: 1px solid rgba(15,23,42,0.12);
  background: rgba(15,23,42,0.06);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}
body.dark .toggle-switch-text {
  color: rgba(255,255,255,0.82);
}
.toggle-switch {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  user-select: none;
  white-space: nowrap;
}
.toggle-switch input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}
body.dark .toggle-slider {
  background: rgba(255,255,255,0.18);
}
.toggle-slider {
  position: relative;
  width: 42px;
  height: 24px;
  border-radius: 999px;
  background: rgba(15,23,42,0.16);
  transition: background 0.2s ease;
}
.toggle-slider::after {
  content: "";
  position: absolute;
  top: 3px;
  left: 3px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: white;
  box-shadow: 0 1px 2px rgba(15,23,42,0.2);
  transition: transform 0.2s ease;
}
.toggle-switch input:checked + .toggle-slider {
  background: royalblue;
}
.toggle-switch input:checked + .toggle-slider::after {
  transform: translateX(18px);
}
.toggle-switch-text {
  font-size: 12px;
  font-weight: 700;
  color: rgba(15,23,42,0.72);
}
@media (max-width: 640px) {
  .install-option {
    flex-direction: column;
    align-items: stretch;
  }
  .toggle-switch {
    justify-content: space-between;
  }
}
</style>
<script>
document.addEventListener("DOMContentLoaded", async () => {
  const n = new N()
  const navigateHome = () => {
    const isAppHost = new URLSearchParams(window.location.search || "").get("host") === "app"
    if (isAppHost && window.parent && window.parent !== window) {
      try {
        window.parent.location.assign("/home")
        return
      } catch (_) {}
    }
    window.location.assign("/home")
  }
  const protectionInput = document.querySelector("#protection-enabled")
  const protectionState = document.querySelector("[data-protection-state]")
  const syncProtectionState = () => {
    if (!protectionInput || !protectionState) {
      return
    }
    protectionState.textContent = protectionInput.checked ? <%-trj("common.on")%> : <%-trj("common.off")%>
  }
  if (protectionInput) {
    protectionInput.addEventListener("change", syncProtectionState)
    syncProtectionState()
  }
  document.querySelector("#save").addEventListener("click", async (e) => {
    // save
    const vals = {}
    const els = document.querySelectorAll(".env-item")
    for(let el of els) {
      let input = el.querySelector("input[type=text]")
      vals[input.id] = input.value
    }
    console.log("vals", vals)
    let res = await fetch("/env", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        filepath: location.pathname.slice(5),
        vals,
        protection_enabled: protectionInput ? protectionInput.checked : undefined
      })
    }).then((res) => {
      return res.json()
    })
    console.log("res" ,res)
    <% if (init && name) { %>
      //location.href = "/pinokio/browser/<%=name%>"
      location.href = "/p/<%=encodeURIComponent(name)%>?install_protection=1"
    <% } else { %>
      n.Noty({
        text: <%-trj("editor.updated")%>
      })
    <% } %>
  })
  <% if (init) { %>
    document.querySelector("#customize").addEventListener("click", (e) => {
      e.preventDefault()
      e.stopPropagation()
      document.querySelector("#editor").classList.toggle("hidden")
      document.body.classList.toggle("center")
    })
  <% } %>
  <% if (!init && name) { %>
    const deleteBtn = document.querySelector("#delete-project")
    if (deleteBtn) {
      const projectName = <%- JSON.stringify(name) %>
      deleteBtn.addEventListener("click", async (e) => {
        e.preventDefault()
        e.stopPropagation()
        const confirmed = confirm(<%-trj("editor.delete_project_confirm")%>)
        if (!confirmed) {
          return
        }
        Swal.fire({
          html: '<i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("common.deleting")%>',
          customClass: {
            container: "loader-container",
            popup: "loader-popup",
            htmlContainer: "loader-dialog",
            footer: "hidden",
            actions: "hidden"
          }
        })
        try {
          const res = await fetch("/pinokio/delete", {
            method: "post",
            headers: {
              "Content-Type": "application/json"
            },
            body: JSON.stringify({ name: projectName })
          }).then((response) => response.json())
          Swal.close()
          if (res && res.success) {
            navigateHome()
          } else if (res && res.error) {
            alert(res.error)
          } else {
            alert(<%-trj("editor.failed_delete_project")%>)
          }
        } catch (err) {
          Swal.close()
          alert(err.message || <%-trj("editor.failed_delete_project")%>)
        }
      })
    }
  <% } %>
})
</script>
</head>
<body class='<%=theme%> <%=init ? 'center' : ''%>' data-agent="<%=agent%>">
  <main>
    <% if (init) { %>
      <div>
        <h1><%=tr("common.install")%></h1>
        <% if (config) { %>
          <div class='card'>
            <% if (config.icon) { %>
              <img src="<%=config.icon%>">
            <% } %>
            <div class='col'>
              <div class='title'><%=config.title%></div>
              <div class='description'><%=config.description%></div>
            </div>
          </div>
        <% } %>
        <div class='warning'>
          <%=tr("editor.third_party_warning_prefix")%> <a href="<%=gitRemote%>" target="_blank"><%=gitRemote%>.</a>
        </div>
        <div class='install-options'>
          <div class='install-option'>
            <div class='install-option-copy'>
              <div class='install-option-title'><%=tr("editor.protection")%> <span class='beta-badge'><%=tr("editor.beta")%></span></div>
              <ul class='install-option-list'>
                <li><%=tr("editor.protection_blocks")%></li>
                <li><%=tr("editor.protection_risk")%></li>
                <li><%=tr("editor.protection_change_later")%></li>
              </ul>
            </div>
            <label class='toggle-switch' for='protection-enabled'>
              <input id='protection-enabled' type='checkbox' <%= protection_enabled ? 'checked' : '' %>>
              <span class='toggle-slider' aria-hidden='true'></span>
              <span class='toggle-switch-text' data-protection-state><%= protection_enabled ? tr("common.on") : tr("common.off") %></span>
            </label>
          </div>
        </div>
        <footer>
          <a href="/home" class='btn go-home'><i class='fa-solid fa-home'></i> <%=tr("common.home")%></a>
          <div class='flexible'></div>
          <button id='customize' class='btn'><i class="fa-solid fa-gear"></i> <%=tr("editor.customize")%></button>
          <div id='save' class='btn'>
            <span class='save'><i class="fa-solid fa-check"></i> <%=tr("common.install")%></span>
          </div>
        </footer>
      </div>
    <% } else { %>
      <header class='navheader grabbable'>
        <h1>
          <% if (home) { %>
            <a class='home-button home' href="/home"><i class='fa-solid fa-home'></i></a>
          <% } %>
          <div class='flexible'></div>
          <div class='nav-btns'>
            <a class='btn' href="<%=editorpath%>"><i class="fa-solid fa-pen-to-square"></i> <%=tr("editor.edit_file")%></a>
            <button class='btn' id='open-fs' data-filepath="<%=filepath%>"><i class="fa-solid fa-eye"></i> <%=tr("app.open_in_file_explorer")%></button>
            <div id='save' class='btn'>
              <span class='save'><i class="fa-solid fa-check"></i> <%=tr("common.save")%></span>
            </div>
          </div>
        </h1>
      </header>
    <% } %>
    <div id='editor' class='<%=init ? "hidden" : ""%>'>
      <% items.forEach((item) => { %>
        <% if (item.type === "comment") { %>
          <div class='comment'><%=item.val.replaceAll(/^[ #]+/g, "")%></div>
        <% } else { %>
          <div class='env-item'>
            <label for="<%=item.key%>"><%=item.key%></label>
            <input id="<%=item.key%>" type="text" value="<%=item.val%>">
          </div>
        <% } %>
      <% }) %>
      <% if (name) { %>
        <button class='btn' id='delete-project'>
          <i class="fa-solid fa-trash"></i> <%=tr("editor.delete_project")%>
        </button>
      <% } %>
    </div>
  </main>
</body>
</html>
