<script src="/report.js"></script>
</head>
<body class='<%=theme%> main-sidebar-page task-launcher-page task-page settings-page <%= hasHome ? "has-home" : "needs-home-setup" %>' data-agent="<%=agent%>">
<!--
<nav>
  <a class='logo' href="/home">dal</a>
</nav>
  -->
<header class='navheader grabbable'>
<h1>
<a class='home' href="/home"><img class='icon' src="/pinokio-black.png"></a>
<button class='btn2' id='minimize-header' data-tippy-content="<%=tr("common.fullscreen")%>" title='<%=tr("common.fullscreen")%>'>
  <div><i class="fa-solid fa-expand"></i></div>
</button>
<button class='btn2' id='back' data-tippy-content="<%=tr("common.back")%>"><div><i class="fa-solid fa-chevron-left"></i></div></button>
<button class='btn2' id='forward' data-tippy-content="<%=tr("common.forward")%>"><div><i class="fa-solid fa-chevron-right"></i></div></button>
<button class='btn2' id='refresh-page' data-tippy-content="<%=tr("common.refresh")%>"><div><i class="fa-solid fa-rotate-right"></i></div></button>
<% paths.forEach((path) => { %>
  <% if (path.action) { %>
    <a class='path nav-button' id="<%=path.id%>" onclick="<%=path.action%>"><%-path.name%></a>
  <% } else if (path.path) { %>
    <a class='path' href="<%=path.path%>"><%-path.name%></a>
  <% } %>
<% }) %>
<button class='btn2' id='screenshot' data-tippy-content="<%=tr("common.screen_capture")%>"><i class="fa-solid fa-camera"></i></button>
<button class='btn2' id='inspector' data-tippy-content="<%=tr("common.xray_mode")%>"><i class="fa-solid fa-eye"></i></button>
<button class='btn2 mobile-link-button' id='mobile-link-button' data-tippy-content="<%=tr("common.enter_url")%>"><i class="fa-solid fa-link"></i></button>
<div class='mobile-flexible'></div>
<form class='urlbar'>
  <div class='url-input-container'>
    <input type='url' placeholder='<%=tr("common.url_placeholder")%>'>
    <div class='url-dropdown' id='url-dropdown'></div>
  </div>
</form>
<a class='btn2' href="/columns" data-tippy-content="<%=tr("common.split_columns")%>">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class='btn2' href="/rows" data-tippy-content="<%=tr("common.split_rows")%>">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class='btn2' id='new-window' data-tippy-content="<%=tr("common.open_new_window")%>" title='<%=tr("common.open_new_window")%>' data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class='btn2 hidden' id='close-window' data-tippy-content='<%=tr("common.close_section")%>'>
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<main>
<div class='task-container settings-container'>
  <section class='task-shell settings-shell'>
    <header class='task-shell-header'>
      <div class='task-shell-header-main'>
        <p class='task-eyebrow'><%=tr("settings.title")%></p>
        <h1 class='task-title'><%=tr("settings.title")%></h1>
        <% if (hasHome) { %>
          <p class='task-description'><%=tr("settings.description.has_home")%></p>
        <% } else { %>
          <p class='task-description'><%=tr("settings.description.needs_home")%></p>
        <% } %>
      </div>
    </header>
    <div class='task-shell-body settings-shell-body'>
      <section class='task-section settings-section <%= hasHome ? "" : "settings-section-priority" %>'>
        <div class='task-section-head'>
          <div class='settings-section-heading'>
            <h2 class='settings-section-title'><%=tr("settings.general")%></h2>
            <% if (!hasHome) { %>
              <span class='settings-priority-badge'><%=tr("settings.required_first")%></span>
            <% } %>
          </div>
          <% if (!hasHome) { %>
            <p class='settings-priority-note'><%=tr("settings.choose_home_note")%></p>
          <% } %>
        </div>
        <div class='item settings-static'>
          <span class='settings-static-label'><%=tr("settings.version")%></span>
          <% if (version.pinokio) { %>
            <div class='settings-static-value'><%=version.pinokio%> (<%=tr("settings.server_version")%>: <%=version.pinokiod%>)</div>
          <% } else { %>
            <div class='settings-static-value'>(<%=tr("settings.server_version")%>: <%=version.pinokiod%>)</div>
          <% } %>
        </div>
        <form class='settings-form'>
          <% config.forEach((c) => { %>
            <div class='item settings-item <%=c.show_on_click ? "hidden" : ""%>' <%=c.show_on_click ? "data-onclick=" + c.show_on_click : ""%>>
              <label><%=c.label || c.key%></label>
              <% if (c.options) { %>
                <select name="<%=c.key%>">
                  <% c.options.forEach((o) => { %>
                    <% const optionValue = (o && typeof o === "object") ? o.value : o %>
                    <% const optionLabel = (o && typeof o === "object") ? o.label : o %>
                    <% if (optionValue === c.val) { %>
                      <option value="<%=optionValue%>" selected><%=optionLabel%></option>
                    <% } else { %>
                      <option value="<%=optionValue%>"><%=optionLabel%></option>
                    <% } %>
                  <% }) %>
                </select>
              <% } else { %>
                <% if (c.val) { %>
                  <input class='homepath' name="<%=c.key%>" type='text' value="<%=c.val%>" placeholder="<%=c.placeholder ? c.placeholder : ''%>" data-first-home="<%= c.key === 'home' && !hasHome ? 'true' : 'false'%>">
                <% } else { %>
                  <input class='homepath' name="<%=c.key%>" type='text' placeholder="<%=c.placeholder ? c.placeholder : ''%>" data-first-home="<%=c.key === 'home' && !hasHome ? 'true' : 'false'%>">
                <% } %>
              <% } %>
              <% if (c.description) { %>
                <% if (Array.isArray(c.description)) { %>
                  <% c.description.forEach((d) => { %>
                    <div class='explanation'><%=d%></div>
                  <% }) %>
                <% } else { %>
                  <div class='explanation'><%=c.description%></div>
                <% } %>
              <% } %>
            </div>
          <% }) %>
          <div class='item settings-item settings-actions'>
            <button id='save' class='btn disabled'><%=tr("settings.save")%></button>
            <a id='proxy'><%=tr("settings.proxy_question")%></a>
          </div>
        </form>
        <div class='loading hidden'>
          <i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("settings.loading")%>
        </div>
      </section>
      <% if (hasHome && locals.bin) { %>
        <section id='troubleshoot' class='task-section settings-section troubleshoot'>
          <div class='task-section-head'>
            <h2 class='settings-section-title'><%=tr("settings.troubleshoot")%></h2>
          </div>
          <div class='item settings-item'>
            <label><%=tr("settings.bin")%></label>
            <div class='d'><%=tr("settings.bin_description")%></div>
            <div class='reset-bin-loading hidden'>
              <i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("settings.loading")%>
            </div>
            <div class='settings-inline-actions'>
              <button class='btn' data-filepath="<%=bin%>"><i class="fa-solid fa-up-right-from-square"></i> <%=tr("settings.view_folder")%></button>
              <button class='red btn' id='del-bin'><i class="fa-solid fa-trash-can"></i> <%=tr("settings.reset")%></button>
            </div>
          </div>
          <div class='item settings-item'>
            <label><%=tr("settings.server_cache")%></label>
            <div class='d'><%=tr("settings.server_cache_description")%></div>
            <div class='reset-cache-loading hidden'>
              <i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("settings.loading")%>
            </div>
            <div class='settings-inline-actions'>
              <button class='btn' data-filepath="<%=cache%>"><i class="fa-solid fa-up-right-from-square"></i> <%=tr("settings.view_folder")%></button>
              <button class='red btn' id='del-cache'><i class="fa-solid fa-trash-can"></i> <%=tr("settings.reset")%></button>
            </div>
          </div>
          <div class='item settings-item'>
            <label><%=tr("settings.environment_variables")%></label>
            <div class='d'><%=tr("settings.environment_variables_description")%></div>
            <div class='reset-env-loading hidden'>
              <i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("settings.loading")%>
            </div>
            <div class='settings-inline-actions'>
              <button class='btn' data-filepath="<%=env%>"><i class="fa-solid fa-up-right-from-square"></i> <%=tr("settings.view_environment_file")%></button>
              <button class='red btn' id='del-env'><i class="fa-solid fa-trash-can"></i> <%=tr("settings.reset")%></button>
            </div>
          </div>
          <% if (agent === "electron") { %>
            <div class='item settings-item'>
              <label><%=tr("settings.browser_cache")%></label>
              <div class='d'><%=tr("settings.browser_cache_description")%></div>
              <div class='reset-browser-cache-loading hidden'>
                <i class="fa-solid fa-circle-notch fa-spin"></i> <%=tr("settings.loading")%>
              </div>
              <div class='settings-inline-actions'>
                <button class='red btn' id='del-browser-cache'><i class="fa-solid fa-trash-can"></i> <%=tr("settings.reset_browser_cache")%></button>
              </div>
            </div>
          <% } %>
          <div class='item settings-item'>
            <label><%=tr("settings.drive")%></label>
            <div class='d'><%=tr("settings.drive_description")%></div>
            <div class='settings-inline-actions'>
              <button class='btn' data-filepath="<%=drive%>"><i class="fa-solid fa-up-right-from-square"></i> <%=tr("settings.view_folder")%></button>
            </div>
          </div>
        </section>
        <section class='task-section settings-section keys'>
          <div class='task-section-head'>
            <h2 class='settings-section-title'><%=tr("settings.keys")%></h2>
          </div>
          <div class='item settings-item'>
            <div class='d'><%=tr("settings.keys_description")%></div>
            <pre>{
  "openai.com": [
    "12345678-FAKEaccesstoken1234567890abcdef"
  ],
  "x.com": [
    "12345678-FAKEaccesstoken1234567890abcdef",
    "FAKEaccesstokensecret0987654321abcdef"
  ]
}</pre>
            <div class='settings-inline-actions'>
              <a class='btn' href="/keys"><i class="fa-solid fa-key"></i> <%=tr("settings.edit_keys")%></a>
            </div>
          </div>
        </section>
        <section class='task-section settings-section advanced'>
          <div class='task-section-head'>
            <h2 class='settings-section-title'><%=tr("settings.advanced")%></h2>
          </div>
          <div class='item settings-item'>
            <div class='d'><%=tr("settings.advanced_environment_description")%></div>
            <div class='settings-inline-actions'>
              <a class='btn' href="/env"><i class="fa-regular fa-pen-to-square"></i> <%=tr("settings.edit_environment")%></a>
            </div>
          </div>
          <div class='item settings-item'>
            <div class='d'><%=tr("settings.app_search_test_description")%></div>
            <div class='settings-inline-actions'>
              <a class='btn' href="/apps/search/test"><i class="fa-solid fa-magnifying-glass"></i> <%=tr("settings.open_app_search_test")%></a>
            </div>
          </div>
        </section>
      <% } %>
      <% if (hasHome) { %>
        <section class='task-section settings-section docs'>
          <div class='task-section-head'>
            <h2 class='settings-section-title'><%=tr("settings.docs")%></h2>
          </div>
          <div class='item settings-item'>
            <div class='d'><%=tr("settings.docs_description")%></div>
            <div class='settings-inline-actions'>
              <a class='btn' href="/settings/docs/pinokio/download"><i class="fa-solid fa-download"></i> <%=tr("settings.download_pinokio_skill")%></a>
              <a class='btn' href="/settings/docs/gepeto/download"><i class="fa-solid fa-download"></i> <%=tr("settings.download_gepeto_skill")%></a>
            </div>
          </div>
        </section>
        <section class='task-section settings-section debug'>
          <div class='task-section-head'>
            <h2 class='settings-section-title'><%=tr("settings.debug")%></h2>
          </div>
          <div class='item settings-item'>
            <label><%=tr("settings.command_path")%></label>
            <div class='d'><%=tr("settings.command_path_description")%></div>
            <form id='debug-path-form' class='debug-path-form'>
              <input id='debug-path-cmd' type='text' placeholder='<%=tr("settings.debug_path_placeholder")%>' autocomplete='off'>
              <button id='debug-path-submit' class='btn' type='submit'><i class="fa-solid fa-magnifying-glass"></i> <%=tr("settings.lookup")%></button>
            </form>
            <div id='debug-path-result' class='debug-path-result hidden'></div>
          </div>
          <div class='item settings-item'>
            <label><%=tr("settings.shell_environment")%></label>
            <div class='d'><%=tr("settings.shell_environment_description")%></div>
            <div class='debug-shell-controls'>
              <select id='debug-shell-select'>
                <option value=""><%=tr("settings.no_running_shells")%></option>
              </select>
              <button id='debug-shell-refresh' class='btn' type='button'><i class="fa-solid fa-rotate-right"></i> <%=tr("settings.refresh")%></button>
            </div>
            <div id='debug-shell-result' class='debug-path-result hidden'></div>
            <pre id='debug-shell-env' class='debug-shell-env hidden'></pre>
          </div>
        </section>
      <% } %>
    </div>
  </section>
</div>
<%- include('partials/main_sidebar', { selected: 'settings' }) %>
</main>
<script>
document.addEventListener("DOMContentLoaded", async () => {
  //Reporter()
  const n = new N()
  const homeInput = document.querySelector('input.homepath[name="home"]')
  let showHomeWarning = () => {}
  const originalHome = homeInput ? (homeInput.defaultValue || '') : ''
  const isFirstHome = homeInput ? homeInput.dataset.firstHome === 'true' : false
  if (homeInput) {
    const warning = document.createElement('div')
	    warning.className = 'home-warning hidden'
	    warning.innerHTML = `
	      <ul>
	        <li><%=tr("settings.home_warning_exfat")%></li>
	        <li><%=tr("settings.home_warning_spaces")%></li>
	      </ul>
	    `
    const parent = homeInput.parentElement
    if (parent) {
      parent.appendChild(warning)
    }
    const revealWarning = () => warning.classList.remove('hidden')
    showHomeWarning = revealWarning
    homeInput.addEventListener('focus', revealWarning)
    homeInput.addEventListener('input', revealWarning)
    homeInput.addEventListener('click', revealWarning)
  }
  const updateThemeClassAcrossShells = (nextTheme) => {
    if (!nextTheme) {
      return
    }
    const applyTheme = (doc) => {
      if (!doc || !doc.body) {
        return
      }
      doc.body.classList.remove('dark', 'light')
      doc.body.classList.add(nextTheme)
    }
    let ctx = window
    const visited = new Set()
    while (ctx && !visited.has(ctx)) {
      visited.add(ctx)
      try {
        applyTheme(ctx.document)
      } catch (err) {
        break
      }
      try {
        if (!ctx.parent || ctx.parent === ctx) {
          break
        }
        ctx = ctx.parent
      } catch (err) {
        break
      }
    }
  }
  const debugPathForm = document.querySelector("#debug-path-form")
  if (debugPathForm) {
    const debugPathInput = document.querySelector("#debug-path-cmd")
    const debugPathSubmit = document.querySelector("#debug-path-submit")
    const debugPathResult = document.querySelector("#debug-path-result")
    const showDebugPathResult = (message, hasError = false) => {
      debugPathResult.textContent = message
      debugPathResult.classList.remove("hidden")
      if (hasError) {
        debugPathResult.classList.add("error")
      } else {
        debugPathResult.classList.remove("error")
      }
    }
    debugPathForm.addEventListener("submit", async (e) => {
      e.preventDefault()
      e.stopPropagation()
      const cmd = debugPathInput.value.trim()
      if (!cmd) {
        showDebugPathResult(<%-trj("settings.enter_command_name_first")%>, true)
        debugPathInput.focus()
        return
      }
      if (cmd.includes("/") || cmd.includes("\\") || /\s/.test(cmd)) {
        showDebugPathResult(<%-trj("settings.single_command_name_only")%>, true)
        return
      }
      debugPathSubmit.setAttribute("disabled", "disabled")
      showDebugPathResult(<%-trj("settings.looking_up_command", { command: "__COMMAND__" })%>.replace("__COMMAND__", cmd))
      try {
        const response = await fetch(`/pinokio/path/${encodeURIComponent(cmd)}`)
        const payload = await response.json().catch(() => {
          return {}
        })
        if (!response.ok) {
          if (payload.error) {
            showDebugPathResult(`${cmd}: ${payload.error}`, true)
          } else {
            showDebugPathResult(`${cmd}: Request failed (${response.status})`, true)
          }
          return
        }
        if (payload.path) {
          showDebugPathResult(`${cmd}: ${payload.path}`)
        } else {
          showDebugPathResult(`${cmd}: Not found`, true)
        }
      } catch (err) {
        showDebugPathResult(`Lookup failed: ${err && err.message ? err.message : "Unknown error"}`, true)
      } finally {
        debugPathSubmit.removeAttribute("disabled")
      }
    })
  }
  const debugShellSelect = document.querySelector("#debug-shell-select")
  if (debugShellSelect) {
    const debugShellRefresh = document.querySelector("#debug-shell-refresh")
    const debugShellResult = document.querySelector("#debug-shell-result")
    const debugShellEnv = document.querySelector("#debug-shell-env")
    const setDebugShellStatus = (message, hasError = false) => {
      debugShellResult.textContent = message
      debugShellResult.classList.remove("hidden")
      if (hasError) {
        debugShellResult.classList.add("error")
      } else {
        debugShellResult.classList.remove("error")
      }
    }
    const hideDebugShellEnv = () => {
      debugShellEnv.classList.add("hidden")
      debugShellEnv.textContent = ""
    }
    const shortenDebugShellText = (text, maxLength) => {
      if (!text || text.length <= maxLength) {
        return text
      }
      return `${text.slice(0, maxLength - 3)}...`
    }
    const summarizeShellMessage = (shell) => {
      if (!shell) {
        return "(interactive)"
      }
      const sourceMessage = shell.source_message
      if (typeof sourceMessage === "string") {
        const trimmed = sourceMessage.trim()
        if (trimmed.length > 0) {
          return trimmed
        }
      } else if (Array.isArray(sourceMessage)) {
        const lines = sourceMessage
          .map((line) => {
            if (typeof line === "string") {
              return line.trim()
            }
            return line == null ? "" : String(line)
          })
          .filter((line) => {
            return line.length > 0
          })
        if (lines.length > 0) {
          return lines.join(" ; ")
        }
      } else if (sourceMessage && typeof sourceMessage === "object") {
        try {
          return JSON.stringify(sourceMessage)
        } catch (err) {
          return String(sourceMessage)
        }
      }
      if (shell && typeof shell.cmd === "string" && shell.cmd.trim().length > 0) {
        return shell.cmd.trim()
      }
      return "(interactive)"
    }
    const shellLabel = (shell, index) => {
      const cwd = shell && shell.path ? shortenDebugShellText(shell.path, 55) : "(no cwd)"
      const message = shortenDebugShellText(summarizeShellMessage(shell), 70)
      return `${index + 1}. ${cwd} | ${message}`
    }
    const loadShellEnv = async (shellId) => {
      if (!shellId) {
        hideDebugShellEnv()
        setDebugShellStatus("Select a shell first.", true)
        return
      }
      setDebugShellStatus(`Loading environment from ${shellId}...`)
      try {
        const response = await fetch(`/pinokio/debug/shell/env?id=${encodeURIComponent(shellId)}`)
        const payload = await response.json().catch(() => {
          return {}
        })
        if (!response.ok) {
          hideDebugShellEnv()
          if (payload.error) {
            setDebugShellStatus(payload.error, true)
          } else {
          setDebugShellStatus(<%-trj("settings.request_failed_status", { status: "__STATUS__" })%>.replace('__STATUS__', () => response.status), true)
          }
          return
        }
        const env = payload && payload.env && typeof payload.env === "object" ? payload.env : {}
        const keys = Object.keys(env)
        const lines = keys.map((key) => {
          return `${key}=${env[key]}`
        })
        debugShellEnv.textContent = lines.length > 0 ? lines.join("\n") : <%-trj("settings.no_environment_variables")%>
        debugShellEnv.classList.remove("hidden")
        const resolvedShell = payload && payload.shell && payload.shell.id ? payload.shell.id : shellId
        setDebugShellStatus(<%-trj("settings.shell_vars_count", { shell: "__SHELL__", count: "__COUNT__" })%>.replace('__SHELL__', () => resolvedShell).replace('__COUNT__', () => keys.length))
      } catch (err) {
        hideDebugShellEnv()
        const message = err && err.message ? err.message : <%-trj("common.unknown_error")%>
        setDebugShellStatus(<%-trj("settings.failed_load_shell_environment", { message: "__MESSAGE__" })%>.replace('__MESSAGE__', () => message), true)
      }
    }
    const refreshShellList = async () => {
      const previousId = debugShellSelect.value
      debugShellRefresh.setAttribute("disabled", "disabled")
      setDebugShellStatus(<%-trj("settings.loading_running_shells")%>)
      try {
        const response = await fetch("/info/shells")
        const payload = await response.json().catch(() => {
          return []
        })
        if (!response.ok || !Array.isArray(payload)) {
          throw new Error(`Request failed (${response.status})`)
        }
        const runningShells = payload.filter((shell) => {
          return shell && shell.id && !shell.done
        })
        debugShellSelect.innerHTML = ""
        if (runningShells.length === 0) {
          const option = document.createElement("option")
          option.value = ""
          option.textContent = <%-trj("settings.no_running_shells")%>
          debugShellSelect.appendChild(option)
          hideDebugShellEnv()
          setDebugShellStatus(<%-trj("settings.no_running_shells_found")%>)
          return
        }
        runningShells.forEach((shell, index) => {
          const option = document.createElement("option")
          option.value = shell.id
          option.textContent = shellLabel(shell, index)
          debugShellSelect.appendChild(option)
        })
        const selectedId = runningShells.find((shell) => {
          return shell.id === previousId
        }) ? previousId : runningShells[0].id
        debugShellSelect.value = selectedId
        await loadShellEnv(selectedId)
      } catch (err) {
        hideDebugShellEnv()
        const message = err && err.message ? err.message : <%-trj("common.unknown_error")%>
        setDebugShellStatus(<%-trj("settings.failed_load_shells", { message: "__MESSAGE__" })%>.replace('__MESSAGE__', () => message), true)
      } finally {
        debugShellRefresh.removeAttribute("disabled")
      }
    }
    debugShellRefresh.addEventListener("click", async (e) => {
      e.preventDefault()
      await refreshShellList()
    })
    debugShellSelect.addEventListener("change", async () => {
      const shellId = debugShellSelect.value
      await loadShellEnv(shellId)
    })
    await refreshShellList()
  }
  <% if (locals.bin) { %>
    document.querySelector("#del-bin").addEventListener("click", async (e) => {
      console.log("del-bin")
      let proceed = confirm(<%-trj("terminal.delete_bin_confirm")%>)
      if (proceed) {
        document.querySelector(".reset-bin-loading").classList.remove("hidden")
        document.querySelector("#del-bin").classList.add("hidden")
        let res = await fetch("/pinokio/delete", {
          method: "post",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ type: "bin" })
        }).then((res) => {
          return res.json()
        })
        console.log(res)
        document.querySelector(".reset-bin-loading").classList.add("hidden")
        if (res.error) {
          alert(res.error)
        } else {
          location.href = location.href
        }
      }
    })
    document.querySelector("#del-cache").addEventListener("click", async (e) => {
