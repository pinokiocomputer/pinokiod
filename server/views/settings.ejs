}
header .btn2 {
  color: var(--light-color); 
}
*/
/*
body.dark header .home {
  color: var(--light-link-color); 
}
*/
header .home {
  color: var(--light-color); 
}
body.dark hr {
  background: white;
}
hr {
  opacity: 0.03;
  background: black;
  margin: 30px 0;
  height: 1px;
  border: none;
}
.reset-cache-loading {
  padding: 10px;
  background: rgba(0,0,0,0.1);
  margin-bottom: 10px;
  text-align: center;
}
.reset-bin-loading {
  padding: 10px;
  background: rgba(0,0,0,0.1);
  margin-bottom: 10px;
  text-align: center;
}
#proxy {
  text-decoration: underline;
  margin-left: 10px;
  display: inline-block;
  cursor: pointer;
}
body.dark .keys pre {
  background: rgba(255,255,255,0.02) !important;
}
.keys pre {
  padding: 20px;
  margin: 20px 0;
  background: rgba(0,0,100,0.04) !important;
}
.debug-path-form {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.debug-path-form input[type=text] {
  width: 100%;
  min-width: 0;
}
.debug-path-result {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: 6px;
  background: rgba(0,0,100,0.04);
  font-family: monospace;
  font-size: 12px;
  word-break: break-all;
}
body.dark .debug-path-result {
  background: rgba(255,255,255,0.06);
}
.debug-path-result.error {
  color: #bf411d;
}
.debug-shell-controls {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.debug-shell-controls select {
  width: 100%;
  min-width: 0;
}
.debug-shell-env {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: 6px;
  background: rgba(0,0,100,0.04);
  font-family: monospace;
  font-size: 12px;
  line-height: 1.4;
  max-height: 320px;
  overflow: auto;
  white-space: pre-wrap;
  word-break: break-all;
}
body.dark .debug-shell-env {
  background: rgba(255,255,255,0.06);
}
.swal2-actions {
  justify-content: center !important;
}
.swal2-title {
  text-align: center !important;
}
main {
  display: flex;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
aside .tab i {
  width: 20px;
  text-align: center;
}
body.dark aside .tab {
  color: white;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: royalblue !important;
  opacity: 1;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
  text-decoration: none;
  padding: 10px;
  font-size: 12px;
  opacity: 0.5;
  border-left: 10px solid transparent;
}
body.dark aside .tab.selected {
  color: white;
}
aside .selected {
  font-weight: bold;
  opacity: 1;
}

/*
@media only screen and (max-width: 800px) {
  body {
    display: flex !important;
    flex-direction: row !important;
  }
}
*/
@media only screen and (max-width: 600px) {
  aside {
    width: unset;
    flex-shrink: unset;
  }
  aside {
    padding: 0 10px;
  }
  aside .tab.submenu {
    padding: 10px;
  }
  aside .tab i {
    width: 100%;
  }
  aside .tab .caption {
    display: none;
  }
  aside .tab {
    margin: 0;
    padding: 10px;
    border-left: none;
  }
  aside .btn-tab {
    flex-direction: column;
    padding: 10px 0;
  }
  aside .btn-tab .btn {
    display: flex;
    justify-content: center;
  }
  aside .btn-tab .btn .caption {
    display: none; 
  }
  header .flexible {
    min-width: unset;
  }
}

@media only screen and (max-width: 480px) {
  .btn2 {
    padding: 5px;
    font-size: 11px;
  }
  .nav-btns {
    flex-grow: 1;
    justify-content: center;
    padding: 0;
  }
}

body.settings-page .task-container {
  --settings-radius: 6px;
  --settings-radius-tight: 4px;
  padding: 20px 28px 32px;
}

body.settings-page .settings-shell {
  width: min(980px, 100%);
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  overflow: visible;
  backdrop-filter: none;
}

body.settings-page .settings-shell-body {
  padding: 2px 28px 20px;
  display: grid;
  gap: 0;
}

body.settings-page.needs-home-setup .settings-shell-body {
  padding-top: 14px;
}

body.settings-page .settings-section {
  padding: 22px 0 24px;
  border-top: 1px solid var(--task-border);
}

body.settings-page .settings-shell-body > .settings-section:first-child {
  border-top: 0;
}

body.settings-page .settings-section-priority {
  position: relative;
  padding: 22px 24px 24px;
  border: 1px solid color-mix(in srgb, var(--task-accent) 24%, var(--task-border));
  border-radius: 14px;
  background:
    linear-gradient(180deg, color-mix(in srgb, var(--task-accent) 5%, var(--task-panel)) 0%, var(--task-panel) 100%);
  box-shadow: 0 16px 34px color-mix(in srgb, var(--task-accent) 8%, transparent);
}

body.dark.settings-page .settings-section-priority {
  box-shadow: 0 18px 42px rgba(0,0,0,0.24);
}

body.settings-page .settings-shell-body > .settings-section-priority:first-child {
  border-top: 1px solid color-mix(in srgb, var(--task-accent) 24%, var(--task-border));
}

body.settings-page .settings-section-priority::before {
  content: "";
  position: absolute;
  inset: 0 auto 0 0;
  width: 3px;
  border-radius: 14px 0 0 14px;
  background: var(--task-accent);
  opacity: 0.55;
}

body.settings-page .settings-section-priority > * {
  position: relative;
  z-index: 1;
}

body.settings-page .task-shell-header-main {
  max-width: 780px;
}

body.settings-page .task-description {
  max-width: 70ch;
  font-size: 14px;
  line-height: 1.55;
}

body.settings-page .task-section-head {
  margin: 0;
}

body.settings-page .settings-section-heading {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

body.settings-page .settings-priority-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 22px;
  padding: 0 8px;
  border: 1px solid color-mix(in srgb, var(--task-accent) 20%, var(--task-border));
  border-radius: 999px;
  background: color-mix(in srgb, var(--task-accent) 12%, var(--task-panel));
  color: var(--task-accent);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

body.settings-page .settings-priority-note {
  margin: 10px 0 0;
  max-width: 54ch;
  color: var(--task-text);
  font-size: 13px;
  line-height: 1.5;
}

body.settings-page .settings-section .item {
  margin: 0;
  padding: 14px 0 15px;
  border-left: 0;
  border-top: 1px solid var(--task-border);
  background: transparent;
}

body.settings-page .settings-section .item:first-of-type {
  padding-top: 0;
  border-top: 0;
}

body.settings-page .settings-section > .task-section-head + .item {
  padding-top: 0;
  border-top: 0;
}

body.settings-page .settings-section .item:last-of-type {
  padding-bottom: 0;
}

body.settings-page .settings-static {
  padding: 0;
  border-top: 0;
}

body.settings-page .settings-section-title {
  margin: 0;
  font-size: 15px;
  line-height: 1.2;
  letter-spacing: -0.02em;
  font-weight: 700;
}

body.settings-page .settings-static-label,
body.settings-page .item label {
  display: block;
  padding: 0;
  font-size: 12px;
  line-height: 1.3;
  font-weight: 700;
  text-transform: none;
  letter-spacing: 0;
  color: var(--task-text);
}

body.settings-page .settings-static-value,
body.settings-page .item .d {
  padding: 0;
  color: var(--task-muted);
  font-size: 13px;
  line-height: 1.45;
}

body.settings-page .item .explanation {
  padding-top: 0;
  color: var(--task-muted);
  font-size: 12px;
  line-height: 1.45;
}

body.settings-page .settings-form {
  display: grid;
  gap: 0;
}

body.settings-page .settings-item {
  display: grid;
  align-content: start;
  gap: 10px;
}

body.settings-page .settings-static {
  gap: 6px;
}

body.settings-page .item input[type=text],
body.settings-page .item select,
body.settings-page .debug-path-form input[type=text],
body.settings-page .debug-shell-controls select {
  width: 100%;
  min-height: 30px;
  padding: 0 10px;
  border: 1px solid var(--task-border);
  border-radius: var(--settings-radius);
  background: color-mix(in srgb, var(--task-panel) 94%, var(--task-soft));
  color: var(--task-text);
  box-sizing: border-box;
}

body.settings-page .item input[type=text]:focus,
body.settings-page .item select:focus,
body.settings-page .debug-path-form input[type=text]:focus,
body.settings-page .debug-shell-controls select:focus {
  outline: none;
  border-color: color-mix(in srgb, var(--task-accent) 40%, var(--task-border));
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--task-accent) 12%, transparent);
}

body.settings-page .settings-actions,
body.settings-page .settings-inline-actions,
body.settings-page .debug-shell-controls,
body.settings-page .debug-path-form {
  display: flex;
  gap: 10px;
  align-items: center;
  flex-wrap: wrap;
}

body.settings-page .debug-path-form {
  margin-top: 0;
}

body.settings-page .debug-path-form input[type=text] {
  flex: 1 1 280px;
}

body.settings-page .debug-shell-controls select {
  flex: 1 1 260px;
}

body.settings-page .btn,
body.settings-page #proxy {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 30px;
  padding: 0 10px;
  border-radius: var(--settings-radius-tight);
  border: 1px solid var(--task-border-strong);
  background: transparent;
  color: var(--task-text);
  text-decoration: none;
  font-size: 12px;
  font-weight: 600;
  line-height: 1;
  cursor: pointer;
  transition: background 140ms ease, border-color 140ms ease, color 140ms ease;
}

body.settings-page .btn:hover,
body.settings-page #proxy:hover {
  background: var(--task-soft);
}

body.settings-page .settings-actions {
  padding-top: 18px;
  align-items: center;
}

body.settings-page #save,
body.settings-page .btn.primary {
  background: var(--task-accent-surface);
  border-color: var(--task-accent-surface);
  color: var(--task-accent-contrast);
}

body.settings-page #save:hover,
body.settings-page .btn.primary:hover {
  background: var(--task-accent-hover);
  border-color: var(--task-accent-hover);
}

body.settings-page #proxy {
  min-height: auto;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: var(--task-muted);
  font-size: 12px;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 0.16em;
}

body.settings-page #proxy:hover {
  background: transparent;
  color: var(--task-text);
}

body.settings-page .red.btn {
  color: #b42318;
  border-color: color-mix(in srgb, #b42318 18%, var(--task-border));
  background: color-mix(in srgb, #b42318 5%, transparent);
}

body.dark.settings-page .red.btn {
  color: #fda29b;
  background: color-mix(in srgb, #fda29b 10%, transparent);
}

body.settings-page .loading,
body.settings-page .debug-path-result,
body.settings-page .debug-shell-env {
  margin-top: 12px;
  padding: 12px 14px;
  border-radius: var(--settings-radius);
  border: 1px solid var(--task-border);
  background: color-mix(in srgb, var(--task-panel) 94%, var(--task-soft));
  color: var(--task-text);
  font-size: 12px;
  line-height: 1.5;
}

body.settings-page .debug-path-result.error {
  color: #b42318;
}

body.dark.settings-page .debug-path-result.error {
  color: #fda29b;
}

body.settings-page pre {
  margin: 0;
  padding: 14px 16px;
  border-radius: var(--settings-radius);
  border: 1px solid var(--task-border);
  background: color-mix(in srgb, var(--task-panel) 94%, var(--task-soft));
  color: var(--task-text);
  font-size: 12px;
  line-height: 1.5;
  overflow-x: auto;
}

body.settings-page .home-warning {
  margin-top: 10px;
}

body.settings-page .task-shell-topline {
  margin-bottom: 6px;
}

@media (min-width: 1080px) {
  body.settings-page .settings-section {
    display: grid;
    grid-template-columns: 156px minmax(0, 1fr);
    column-gap: 34px;
    align-items: start;
  }

  body.settings-page .settings-section > :not(.task-section-head) {
    grid-column: 2;
    max-width: 700px;
  }

  body.settings-page .settings-section .task-section-head {
    grid-column: 1;
    position: relative;
    top: 2px;
  }

  body.settings-page .settings-section.debug > :not(.task-section-head),
  body.settings-page .settings-section.troubleshoot > :not(.task-section-head) {
    max-width: 760px;
  }

  body.settings-page .settings-section.settings-section-priority {
    display: block;
  }

  body.settings-page .settings-section.settings-section-priority .task-section-head {
    position: static;
    top: auto;
  }
}

@media (max-width: 820px) {
  body.settings-page .settings-shell {
    width: 100%;
  }

  body.settings-page .settings-shell-header,
  body.settings-page .settings-shell-body {
    padding-left: 18px;
    padding-right: 18px;
  }
}

@media (max-width: 560px) {
  body.settings-page .settings-shell-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  body.settings-page .task-container {
    padding: 16px 14px 24px;
  }

  body.settings-page .settings-actions,
  body.settings-page .settings-inline-actions,
  body.settings-page .debug-shell-controls,
  body.settings-page .debug-path-form {
    gap: 8px;
  }
}
</style>
