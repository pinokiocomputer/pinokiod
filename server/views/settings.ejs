  padding-left: 18px;
}
.swal2-popup.custom-home-modal {
  border-radius: 6px;
  padding: 18px 18px 14px 18px;
  background: #fdfdfd;
  box-shadow: 0 8px 28px rgba(0,0,0,0.12);
  text-align: left;
}
body.dark .swal2-popup.custom-home-modal {
  background: #1f1f25;
