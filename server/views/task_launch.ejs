<!doctype html>
<html lang="en">
<%
  const tr = typeof t === "function" ? t : ((key) => { throw new Error("i18n translator is not initialized") })
%>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= task.config.title %></title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/css/brands.min.css" rel="stylesheet">
  <link href="/noty.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
  <% if (agent === "electron") { %>
    <link href="/electron.css" rel="stylesheet"/>
  <% } %>
  <script>
  window.PINOKIO_I18N = Object.assign({}, window.PINOKIO_I18N || {}, <%- JSON.stringify(typeof i18nCatalog === "object" && i18nCatalog ? i18nCatalog : {}) %>);
  </script>
  <script src="/task-launcher.js" defer></script>
  <script src="/task-share.js" defer></script>
</head>
<%
  const effectiveTaskTarget = task.config.target || 'workspaces'
  const runRootCopy = effectiveTaskTarget === 'api'
    ? tr("tasks.creates_new_app")
    : effectiveTaskTarget === 'plugin'
      ? tr("tasks.creates_new_plugin")
      : tr("tasks.runs_in_new_workspace")
  const folderMeta = effectiveTaskTarget === 'workspaces' ? tr("common.optional") : ''
  const folderRequired = effectiveTaskTarget !== 'workspaces'
  const folderPlaceholder = effectiveTaskTarget === 'workspaces'
    ? (suggestedFolderName || tr("tasks.auto_generated"))
    : tr("tasks.folder_placeholder")
  const headerDescription = task.config.description && !/{{/.test(task.config.description)
    ? task.config.description
    : ''
%>
<body class="<%= theme %> main-sidebar-page task-launcher-page task-page task-detail-page" data-agent="<%= agent %>">
  <%- include('partials/app_navheader', { agent }) %>
  <main>
  <div class="task-container">
  <section class="task-shell">
    <header class="task-shell-header">
      <div class="task-shell-header-main">
        <div class="task-shell-topline">
          <p class="task-eyebrow"><%= tr("nav.tasks") %></p>
        </div>
        <h1 class="task-title"><%= task.config.title %></h1>
        <% if (headerDescription) { %>
          <p class="task-description"><%= headerDescription %></p>
        <% } %>
        <p class="task-detail-meta">
          <span class="task-detail-meta-item task-detail-meta-source">
            <span class="task-detail-meta-source-name"><%= taskUi.sourceValue %></span>
            <a class="task-detail-meta-link <%= shareState.remoteWebUrl ? '' : 'task-hidden' %>" href="<%= shareState.remoteWebUrl || '#' %>" target="_blank" rel="noopener noreferrer" data-task-share-remote-link aria-label="<%=tr("tasks.open_repository_github")%>">
              <i class="fa-brands fa-github" aria-hidden="true"></i>
            </a>
          </span>
          <span class="task-detail-meta-sep">•</span>
          <span class="task-detail-meta-item"><%= taskUi.statusValue %></span>
        </p>
      </div>
      <div class="task-header-actions">
        <a class="task-link-button" href="/tasks">
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          <span><%= tr("common.back") %></span>
        </a>
        <a class="task-link-button" href="<%= taskUi.editUrl %>">
          <i class="fa-solid fa-pen" aria-hidden="true"></i>
          <span><%= tr("common.edit") %></span>
        </a>
        <form class="task-inline-form" method="post" action="<%= taskUi.deleteUrl %>" data-task-confirm="<%= taskUi.deleteConfirm %>">
          <button class="task-button danger" type="submit">
            <i class="fa-solid fa-trash" aria-hidden="true"></i>
            <span><%= tr("common.delete") %></span>
          </button>
        </form>
      </div>
      <div class="task-header-share">
        <div class="task-share-link-box" data-task-share-link-box>
          <label class="task-share-link-field">
            <span class="task-sr-only"><%= tr("tasks.current_permalink") %></span>
            <textarea id="task-share-link" class="task-textarea task-share-url" readonly rows="1"><%= permalinkUrl %></textarea>
          </label>
          <button class="task-button" type="button" data-task-share-copy>
            <i class="fa-solid fa-copy" aria-hidden="true"></i>
            <span><%= tr("tasks.copy_link") %></span>
          </button>
        </div>
        <div class="task-share-next-step-main task-hidden" data-task-share-next-wrap>
          <p class="task-share-next-step-copy" data-task-share-next-copy></p>
          <div class="task-actions" data-task-share-next-actions></div>
        </div>
        <form class="task-share-inline-create task-hidden" data-task-share-create-form>
          <div class="task-inline-fields">
            <label class="task-field">
              <span class="task-label"><%= tr("common.repository_name") %></span>
              <input class="task-input" type="text" data-task-share-repo-name placeholder="task-repo">
            </label>
            <label class="task-field task-field-tight">
              <span class="task-label"><%= tr("common.visibility") %></span>
              <select class="task-select" data-task-share-visibility>
                <option value="public"><%= tr("common.public") %></option>
                <option value="private"><%= tr("common.private") %></option>
              </select>
            </label>
            <div class="task-actions task-share-inline-create-actions">
              <button class="task-button" type="button" data-task-share-create-cancel><%= tr("common.cancel") %></button>
              <button class="task-button primary" type="submit">
                <i class="fa-brands fa-github" aria-hidden="true"></i>
                <span><%= tr("common.continue") %></span>
              </button>
            </div>
          </div>
        </form>
        <div class="task-share-feedback" data-task-share-feedback hidden></div>
      </div>
    </header>

    <div class="task-shell-body">
      <% if (error) { %>
        <div class="task-status error"><%= error %></div>
      <% } %>

      <form class="task-run-form task-detail-layout" method="post" action="/task/start" data-task-pending-form="run">
        <input type="hidden" name="id" value="<%= task.id %>">

        <div class="task-detail-main">
          <section class="task-section task-prompt-section">
            <pre class="task-code task-prompt-code" data-task-rendered-prompt><%= renderedPrompt %></pre>
            <div class="task-prompt-actions">
              <button class="task-button primary task-run-button" type="submit">
                <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                <span><%= tr("home.run") %></span>
              </button>
              <p class="task-inline-help"><%= tr("tasks.run_local_help") %></p>
              <p class="task-submit-feedback" data-task-submit-feedback aria-live="polite" aria-hidden="true">
                <span data-task-submit-feedback-text></span>
              </p>
            </div>
          </section>
        </div>

        <aside class="task-detail-sidebar task-run-sidebar">
          <section class="task-section task-run-section">
            <div class="task-section-head">
              <div>
                <h2 class="task-section-title"><%= tr("home.run") %></h2>
              </div>
            </div>
            <div class="task-run-fields">
              <% if (task.inputs.length) { %>
                <% task.inputs.forEach((input) => { %>
                  <label class="task-field">
                    <span class="task-label"><%= input.label %><% if (input.required) { %><span class="task-label-required">*</span><% } %></span>
                    <input class="task-input" type="text" name="input.<%= input.name %>" value="<%= inputValues[input.name] || '' %>" placeholder="<%= input.name %>" <%= input.required ? 'required' : '' %>>
                  </label>
                <% }) %>
              <% } %>
              <label class="task-field">
                <span class="task-label"><%= tr("tasks.tool") %></span>
                <input type="hidden" name="tool" value="<%= selectedTool || '' %>" data-task-tool-value required>
                <div data-task-tool-picker data-selected="<%= selectedTool || '' %>"></div>
              </label>

              <label class="task-field">
                <span class="task-label"><%= tr("tasks.folder") %><% if (folderRequired) { %><span class="task-label-required">*</span><% } %><% if (folderMeta) { %><span class="task-label-meta"><%= folderMeta %></span><% } %></span>
                <input class="task-input" type="text" name="folderName" value="<%= folderName || '' %>" placeholder="<%= folderPlaceholder %>" <%= folderRequired ? 'required' : '' %>>
              </label>
            </div>
          </section>
        </aside>
      </form>
    </div>
  </section>
  </div>
  <%- include('partials/main_sidebar', { selected: 'tasks' }) %>
  </main>

  <div class="task-share-overlay task-hidden" data-task-share-overlay>
    <div class="task-share-overlay-backdrop" data-task-share-overlay-close></div>
    <section class="task-share-overlay-panel" role="dialog" aria-modal="true" aria-labelledby="task-share-overlay-title">
      <header class="task-share-overlay-header">
        <div>
          <p class="task-eyebrow"><%= tr("tasks.github_flow") %></p>
          <h2 id="task-share-overlay-title" class="task-share-overlay-title" data-task-share-overlay-title><%= tr("tasks.publish") %></h2>
          <p class="task-share-overlay-copy" data-task-share-overlay-copy><%= tr("tasks.github_flow_panel_copy") %></p>
        </div>
        <button class="task-button icon-only" type="button" data-task-share-overlay-close aria-label="<%= tr("common.close") %>">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </header>
      <div class="task-share-overlay-frame-wrap">
        <iframe class="task-share-overlay-frame" src="about:blank" allow="fullscreen *;" allowfullscreen data-task-share-overlay-frame></iframe>
      </div>
      <footer class="task-share-overlay-footer">
        <button class="task-button" type="button" data-task-share-overlay-close><%= tr("tasks.not_yet") %></button>
        <button class="task-button primary" type="button" data-task-share-overlay-refresh>
          <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
          <span><%= tr("tasks.done_check_again") %></span>
        </button>
      </footer>
    </section>
  </div>

  <script id="task-share-bootstrap" type="application/json"><%- JSON.stringify({
    task: {
      id: task.id,
      title: task.config.title,
      description: task.config.description || "",
      path: task.config.path || "tasks",
      target: effectiveTaskTarget,
      dir: task.dir,
      ref: task.ref || "",
      template: task.template || ""
    },
    share: shareState,
    stateUrl: `/task/share/state?${shareState.remoteRef ? `ref=${encodeURIComponent(shareState.remoteRef)}` : `id=${encodeURIComponent(task.id)}`}`,
  }) %></script>
  <%- include('partials/app_common_scripts') %>
</body>
</html>
