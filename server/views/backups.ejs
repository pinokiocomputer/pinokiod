<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/xterm.min.css" rel="stylesheet" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/markdown.css" rel="stylesheet"/>
<link href="/noty.css" rel="stylesheet"/>
<link href="/style.css" rel="stylesheet"/>
<link href="/urldropdown.css" rel="stylesheet" />
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<style>
main {
  display: flex;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
aside .tab i {
  width: 20px;
  text-align: center;
}
body.dark aside .tab {
  color: white;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: rgba(127, 91, 243, 0.9) !important;
  opacity: 1;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
  text-decoration: none;
  padding: 10px;
  font-size: 12px;
  opacity: 0.5;
  border-left: 10px solid transparent;
}
body.dark aside .tab.selected {
  color: white;
}
aside .tab.selected {
  font-weight: bold;
  opacity: 1;
}
@media only screen and (max-width: 600px) {
  aside {
    width: unset;
    flex-shrink: unset;
  }
  aside {
    padding: 0 10px;
  }
  aside .tab.submenu {
    padding: 10px;
  }
  aside .tab i {
    width: 100%;
  }
  aside .tab .caption {
    display: none;
  }
  aside .tab {
    margin: 0;
    padding: 10px;
    border-left: none;
  }
  aside .btn-tab {
    flex-direction: column;
    padding: 10px 0;
  }
  aside .btn-tab .btn {
    display: flex;
    justify-content: center;
  }
  aside .btn-tab .btn .caption {
    display: none; 
  }
  header .flexible {
    min-width: unset;
  }
}
@media only screen and (max-width: 480px) {
  .btn2 {
    padding: 5px;
    font-size: 11px;
  }
  .nav-btns {
    flex-grow: 1;
    justify-content: center;
    padding: 0;
  }
}
.backups-container {
  padding: 20px;
}
.backups-container h2 {
  font-size: 24px;
  margin-bottom: 15px;
}
.backup-meta {
  font-size: 12px;
  opacity: 0.75;
}
</style>
<script src="/window_storage.js"></script>
<script src="/hotkeys.min.js"></script>
<script src="/sweetalert2.js"></script>
<script src="/noty.js"></script>
<script src="/notyq.js"></script>
<script src="/xterm.js"></script>
<script src="/xterm-addon-fit.js"></script>
<script src="/xterm-addon-web-links.js"></script>
<script src="/xterm-theme.js"></script>
<script src="/Socket.js"></script>
<script src="/common.js"></script>
<script src="/nav.js"></script>
<script src="/urldropdown.js"></script>
<script src="/report.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".toggle-snapshots").forEach((btn) => {
    btn.addEventListener("click", () => {
      const name = btn.getAttribute("data-workspace")
      const selector = ".snapshot-list[data-workspace='" + name + "']"
      const panel = document.querySelector(selector)
      if (panel) {
        panel.classList.toggle("hidden")
      }
    })
  })
  document.querySelectorAll(".download-backup").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault()
      if (btn.dataset.loading === "1") return
      const workspace = btn.getAttribute("data-workspace")
      const snapshotId = btn.getAttribute("data-snapshot-id")
      if (!workspace || !snapshotId) return
      btn.dataset.loading = "1"
      const originalHtml = btn.innerHTML
      btn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin"></i> Downloading...`
      btn.disabled = true
      try {
        const res = await fetch(`/backups/restore/${encodeURIComponent(workspace)}/${encodeURIComponent(snapshotId)}`, {
          method: "POST",
          headers: {
            "Accept": "application/json"
          }
        })
        let ok = false
        let meta = null
        if (res.ok) {
          try {
            const payload = await res.json()
            ok = payload && payload.ok
            if (ok && payload && typeof payload.meta === "object") {
              meta = payload.meta
            }
          } catch (_) {}
        }
        if (ok) {
          const card = btn.closest(".line")
          if (card) {
            const statusBadge = card.querySelector(".backup-meta .badge")
            if (statusBadge) {
              statusBadge.textContent = "Downloaded"
            }
            const menu = card.querySelector(".menu-btns")
            if (menu) {
              menu.innerHTML = `
                <a class='btn frame-link' href="/p/${workspace}" target="_self">
                  <i class="fa-solid fa-play"></i> Install latest
                </a>
                <a class='btn frame-link' href="/backups/restore/${workspace}/${snapshotId}" target="_self">
                  <i class="fa-solid fa-rotate-right"></i> Restore snapshot
                </a>
                <button class='btn toggle-snapshots' type="button" data-workspace="${workspace}">
                  <i class="fa-regular fa-clock"></i> View versions…
                </button>
              `
              menu.querySelectorAll(".toggle-snapshots").forEach((toggle) => {
                toggle.addEventListener("click", () => {
                  const name = toggle.getAttribute("data-workspace")
                  const selector = ".snapshot-list[data-workspace='" + name + "']"
                  const panel = document.querySelector(selector)
                  if (panel) {
                    panel.classList.toggle("hidden")
                  }
                })
              })
            }
            if (meta && typeof meta === "object") {
              const titleSpan = card.querySelector(".title span")
              if (meta.title && titleSpan) {
                titleSpan.textContent = meta.title
              }
              const iconImg = card.querySelector(".item-icon img")
              if (iconImg && meta.icon) {
                iconImg.src = meta.icon
                iconImg.style.opacity = ""
              }
              if (meta.description) {
                let descEl = card.querySelector(".col .description:not(.backup-meta)")
                if (!descEl) {
                  const uriEl = card.querySelector(".col .uri")
                  if (uriEl && uriEl.parentNode) {
                    descEl = document.createElement("div")
                    descEl.className = "description"
                    uriEl.parentNode.insertBefore(descEl, uriEl.nextSibling)
                  }
                }
                if (descEl) {
                  descEl.textContent = meta.description
                }
              }
            }
          }
        } else {
          btn.innerHTML = originalHtml
          btn.disabled = false
          btn.dataset.loading = ""
        }
      } catch (_) {
        btn.innerHTML = originalHtml
        btn.disabled = false
        btn.dataset.loading = ""
      }
    })
  })
})
</script>
</head>
<body class='<%=theme%>' data-agent="<%=agent%>">
<header class='navheader grabbable'>
  <h1>
    <a class='home' href="/home"><img class='icon' src="/pinokio-black.png"></a>
  </h1>
</header>
<main>
  <div class='container'>
    <div class='content backups-container'>
      <h2>Backups</h2>
      <p class="subtitle">Local version history for workspaces on this machine.</p>
      <div style="margin: 10px 0 20px 0;">
        <a class="btn" href="/asset/pinokio/history.json" download>
          <i class="fa-solid fa-download"></i> Download backups
        </a>
      </div>
      <% if (items && items.length > 0) { %>
        <% items.forEach((item) => { %>
          <% const name = item.name; %>
          <% const last = item.last; %>
          <div class='line align-top'>
            <h3>
              <div class='item-icon'>
                <% if (item.meta && item.meta.icon) { %>
                  <img src="<%=item.meta.icon%>" onerror="this.onerror=null; this.src='/pinokio-black.png'">
                <% } else { %>
                  <img src="/pinokio-black.png" style="opacity:0.4;" onerror="this.onerror=null; this.src='/pinokio-black.png'">
                <% } %>
              </div>
              <div class='col'>
                <div class='title'>
                  <i class="fa-solid fa-circle"></i>
                  <span><%= item.meta && item.meta.title ? item.meta.title : name %></span>
                </div>
                <div class='uri'>~/pinokio/api/<%= name %></div>
                <% if (item.meta && item.meta.description) { %>
                  <div class='description'><%=item.meta.description%></div>
                <% } %>
                <% if (last) { %>
                  <div class='description backup-meta'>
                    <i class="fa-regular fa-clock"></i>
                    Last snapshot:
                    <span><%= new Date(last.id).toLocaleString() %></span>
                    ·
                    <span>Total: <%= item.snapshotCount %></span>
                  </div>
                  <div class='description backup-meta'>
                    <% if (last.platform) { %>
                      <% let platformIcon = "fa-solid fa-desktop"; %>
                      <% if (last.platform === "darwin") { platformIcon = "fa-brands fa-apple"; } %>
                      <% if (last.platform === "win32") { platformIcon = "fa-brands fa-windows"; } %>
                      <% if (last.platform === "linux") { platformIcon = "fa-brands fa-linux"; } %>
                      <span>
                        <i class="<%=platformIcon%>"></i>
                        <span><%= last.platform %></span>
                      </span>
                    <% } %>
                    <% if (last.arch) { %>
                      <span style="margin-left:10px;">
                        <i class="fa-solid fa-microchip"></i>
                        <span><%= last.arch %></span>
                      </span>
                    <% } %>
                    <% if (last.gpu) { %>
                      <span style="margin-left:10px;">
                        <i class="fa-solid fa-bolt"></i>
                        <span><%= last.gpu %></span>
                      </span>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class='description backup-meta'>No snapshots yet.</div>
                <% } %>
                <div class='description backup-meta'>
                  <% if (!item.hasGitRepos) { %>
                    <span class="badge">Local workspace (no git)</span>
                  <% } else if (!item.downloaded) { %>
                    <span class="badge">Not downloaded</span>
                  <% } else if (item.installed) { %>
                    <span class="badge">Installed</span>
                  <% } else { %>
                    <span class="badge">Downloaded</span>
                  <% } %>
                </div>
                <div class='menu-btns'>
                  <% if (!item.hasGitRepos) { %>
                    <a class='btn frame-link' href="/p/<%=name%>/dev?pinokio.publish=1" target="_self">
                      <i class="fa-brands fa-github"></i> Publish
                    </a>
                  <% } else if (!item.downloaded && last) { %>
                    <button class='btn download-backup' type="button" data-workspace="<%=name%>" data-snapshot-id="<%=last.id%>">
                      <i class="fa-solid fa-cloud-arrow-down"></i> Download
                    </button>
                  <% } else if (item.downloaded && !item.installed && last) { %>
                    <a class='btn frame-link' href="/p/<%=name%>" target="_self">
                      <i class="fa-solid fa-play"></i> Install latest
                    </a>
                    <a class='btn frame-link' href="/backups/restore/<%=name%>/<%=last.id%>" target="_self">
                      <i class="fa-solid fa-rotate-right"></i> Restore snapshot
                    </a>
                    <button class='btn toggle-snapshots' type="button" data-workspace="<%=name%>">
                      <i class="fa-regular fa-clock"></i> View versions…
                    </button>
                  <% } %>
                </div>
                <% if (item.hasGitRepos && history && history.workspaces && history.workspaces[name] && history.workspaces[name].snapshots) { %>
                  <div class="snapshot-list hidden" data-workspace="<%=name%>">
                    <ul>
                      <% history.workspaces[name].snapshots.slice().sort((a, b) => a.id - b.id).forEach((snap) => { %>
                        <li>
                          <span><%= new Date(snap.id).toISOString() %></span>
                          <a class="btn frame-link" href="/backups/restore/<%=name%>/<%=snap.id%>" target="_self">
                            <i class="fa-solid fa-rotate-right"></i> Restore
                          </a>
                        </li>
                      <% }) %>
                    </ul>
                  </div>
                <% } %>
              </div>
            </h3>
          </div>
        <% }) %>
      <% } else { %>
        <p>No history yet.</p>
      <% } %>
    </div>
  </div>
  <aside>
    <div class='btn-tab'>
      <button type='button' class='btn' id='create-launcher-button'><i class="fa-solid fa-plus"></i><div class='caption'>Create</div></button>
      <a class='btn' id='explore' href="/home?mode=explore"><i class="fa-solid fa-globe"></i><div class='caption'>Discover</div></a>
    </div>
    <a href="/home" class='tab'><i class='fas fa-laptop-code'></i><div class='caption'>This machine</div></a>
    <a href="/network" class='tab'><i class="fa-solid fa-wifi"></i><div class='caption'>Local network</div></a>
    <% if (list && list.length > 0) { %>
      <% let brands = { win32: "windows", darwin: "apple", linux: "Linux" } %>
      <% list.forEach(({ host, name, platform }) => { %>
        <a href="/net/<%=name%>" class='submenu tab'><i class="fa-brands fa-<%=brands[platform]%>"></i><div class='caption'><%=name%> (<%=current_host === host ? 'this machine' : host%>)</div></a>
      <% }) %>
    <% } %>
    <a href="/connect" class='tab'><i class="fa-solid fa-plug"></i><div class='caption'>Login</div></a>
    <a class='tab' href="<%=portal%>" target="_blank"><i class="fa-solid fa-question"></i><div class='caption'>Help</div></a>
    <a class='tab' id='genlog' href="/logs"><i class="fa-solid fa-laptop-code"></i><div class='caption'>Logs</div></a>
    <a class='tab selected' href="/backups"><i class="fa-solid fa-database"></i><div class='caption'>Backups</div></a>
    <a class='tab' href="/screenshots"><i class="fa-solid fa-camera"></i><div class='caption'>Screenshots</div></a>
    <a class='tab' href="/tools"><i class="fa-solid fa-toolbox"></i><div class='caption'>Installed Tools</div></a>
    <a class='tab' href="/agents"><i class="fa-solid fa-robot"></i><div class='caption'>Agents</div></a>
    <a class='tab' href="/home?mode=settings"><i class="fa-solid fa-gear"></i><div class='caption'>Settings</div></a>
    <%- include('partials/peer_access_points', { peer_access_points, peer_url, peer_qr }) %>
  </aside>
</main>
</body>
</html>
