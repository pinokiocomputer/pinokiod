                      <% }) %>
                    </div>
                    <div class='ai-container'>
                      <% ai.forEach((item, i) => { %>
                        <div data-meta="<%=JSON.stringify(item.data)%>" class='ai-tab-content <%=i===0 ? "selected" : ""%>' data-title="<%=item.title%>">
