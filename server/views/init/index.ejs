    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    color: rgba(0,0,0,0.6);
    transition: all 0.3s ease;
    width: 100%;
    text-align: left;
    /*

    border-bottom: 2px solid rgba(0,0,0,0.1);
    */
