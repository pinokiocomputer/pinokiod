body.dark blockquote {
    border-left: 10px solid white;
}
blockquote {
    text-transform: uppercase;
    /*
    */

    padding-left: 5px;
    border-left: 10px solid black;
    font-size: 16px;
    margin-bottom: 5px;
    font-weight: bold;
}

.progress-bar {
    display: flex;
    justify-content: center;
    margin: 20px 0;
}

.progress-bar .step {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 1rem;
    font-weight: bold;
    transition: all 0.3s ease;
}

body.dark .progress-bar .step.active {
    background: rgba(255,255,255,0.1);
}
.progress-bar .step.active {
    background: rgba(0,0,0,0.1);
    color: silver;
}

.progress-bar .step.completed {
    background-color: #000000;
    color: #ffffff;
}

.step-content {
    display: none;
    padding: 2rem;
    margin-bottom: 2rem;
}

.step-content.active {
    display: block;
}

.step-content h2 {
    margin-bottom: 10px;
}

/* Tab Styles */
.tab-container {
    display: flex;
}

.tab-nav {
  flex-shrink: 0;
    /*
    display: flex;
    border-bottom: 2px solid rgba(0,0,0,0.1);
