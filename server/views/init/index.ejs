<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize tabs
    initializeTabs();
    
    // Show launcher tab by default
    showTab('launcher');

    // Add tab click handlers
    const tabButtons = document.querySelectorAll('.tab-button');
    tabButtons.forEach(button => {
        button.addEventListener('click', () => {
            const tabName = button.getAttribute('data-tab');
            showTab(tabName);
        });
    });

    const projectTypeRadios = document.querySelectorAll('input[name="projectType"]');
    projectTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleProjectTypeChange);
    });


    const cliTypeRadios = document.querySelectorAll('input[name="cliType"]');
    cliTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleCliTypeChange);
    });

    const docTypeRadios = document.querySelectorAll('input[name="docType"]');
    docTypeRadios.forEach(radio => {
        radio.addEventListener('change', handleDocTypeChange);
    });

    // Form submission
    document.getElementById('bootstrap-form').addEventListener('submit', handleSubmit);

    document.querySelector("#local").addEventListener("click", (e) => {
      let socket = new Socket()
      socket.run({
        method: "kernel.bin.filepicker",
        params: {
          cwd: "<%-JSON.stringify(cwd).slice(1, -1)%>",
          title: "Select a path",
          type: "folder",
        }
      }, async (packet) => {
        if (packet.type === "result") {
          if (packet.data.paths.length > 0) {
            let p = packet.data.paths[0]
            e.target.value = p
          }
        }
      }).then((res) => {
        console.log("Ended", res)
      })
    })

    // Initialize Ace editors
    initializeAceEditors();
});

// Global Ace editors object
const aceEditors = {};

function initializeAceEditors() {
    document.querySelectorAll('.ace-editor').forEach(editorDiv => {
        const editorId = editorDiv.id;
        const editor = ace.edit(editorId);
        
        // Configure editor
        editor.setTheme('ace/theme/textmate');
        editor.session.setMode('ace/mode/sh');
        editor.setOptions({
            fontSize: '14px',
            showLineNumbers: true,
            showGutter: true,
            wrap: true,
            autoScrollEditorIntoView: true,
            maxLines: 20,
            minLines: 3,
            showPrintMargin: false
        });
        
        editor.session.insert({ row: editor.session.getLength(), column: 0 }, "\n\n");
        editor.session.getUndoManager().reset();
        editor.clearSelection();
        editor.moveCursorTo(0, 0);
        
        // Set placeholder
        const placeholder = editorDiv.dataset.placeholder;
        if (placeholder) {
            editor.setOptions({
                placeholder: placeholder
            });
        }
        
        // Store editor reference
        aceEditors[editorId] = editor;
        
        // Handle theme changes
        if (document.body.classList.contains('dark')) {
            editor.setTheme('ace/theme/monokai');
        }
    });
}

function initializeTabs() {
    // Initialize tab functionality
}

function showTab(tabName) {
    // Hide all tab contents
    document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
    });
    
    // Remove active class from all tab buttons
    document.querySelectorAll('.tab-button').forEach(button => {
        button.classList.remove('active');
    });
    
    // Show selected tab
    document.getElementById(`${tabName}-tab`).classList.add('active');
    document.querySelector(`[data-tab="${tabName}"]`).classList.add('active');
    
    // Update create button text
    const createButton = document.getElementById('create-button');
    createButton.textContent = 'Create'
    /*
    if (tabName === 'launcher') {
        createButton.textContent = 'Create Launcher';
    } else if (tabName === 'cli') {
        createButton.textContent = 'Create CLI Launcher';
    } else {
        createButton.textContent = 'Create Project';
    }
    */
    
    // Clear form selections when switching tabs
    document.querySelectorAll('input[name="projectType"]').forEach(radio => {
        radio.checked = false;
    });
    document.querySelectorAll('input[name="cliType"]').forEach(radio => {
        radio.checked = false;
    });
    
    // Hide all conditional options
    hideAllConditionalOptions();
    
    // Clear Git URL when switching away from launcher tab
    if (tabName !== 'launcher') {
        document.getElementById('gitUrl').value = '';
    }
    
    // Clear CLI inputs
    if (tabName !== 'cli') {
        clearCliInputs();
    }
}

function hideAllConditionalOptions() {
    document.getElementById('python-options').classList.remove('show');
    document.getElementById('python-options-clone').classList.remove('show');
    document.getElementById('instant-cli-options').classList.remove('show');
    document.getElementById('installable-cli-options').classList.remove('show');
    document.getElementById('venv-option').classList.remove('show');
    document.getElementById('clone-command-fields').classList.remove('show');
    document.getElementById('documentation-options').classList.remove('show');
    document.getElementById('local-doc-options').classList.remove('show');
    document.getElementById('remote-doc-options').classList.remove('show');
}


function handleProjectTypeChange(event) {
    const projectType = event.target.value;
    const activeTab = document.querySelector('.tab-content.active').id;
    const isLauncher = activeTab === 'launcher-tab';
    const isCli = activeTab === 'cli-tab';

    // Hide all conditional options first
    hideAllConditionalOptions();

    // Clear all checkboxes and radio buttons
    document.querySelectorAll('input[name="pythonOptions"]').forEach(checkbox => {
        checkbox.checked = false;
    });
    document.querySelectorAll('input[name="cliType"]').forEach(radio => {
        radio.checked = false;
    });
    document.querySelectorAll('input[name="docType"]').forEach(radio => {
        radio.checked = false;
    });

    // Clear CLI input fields
    clearCliInputs();

    // Show clone command fields when a project type is selected in launcher mode (but not for CLI)
    if (isLauncher && projectType !== 'cli') {
        document.getElementById('clone-command-fields').classList.add('show');
        updateCloneDefaults(projectType);
    }

    // Show appropriate options based on project type
    if (projectType === 'python') {
        if (isLauncher) {
            document.getElementById('python-options-clone').classList.add('show');
        } else {
            document.getElementById('python-options').classList.add('show');
        }
    } else if (projectType === 'documentation') {
        document.getElementById('documentation-options').classList.add('show');
    }
}

// Add CLI type change handler
function handleCliTypeChange(event) {
    const cliType = event.target.value;

    // Hide all CLI sub-options first
    document.getElementById('instant-cli-options').classList.remove('show');
    document.getElementById('installable-cli-options').classList.remove('show');
    document.getElementById('venv-option').classList.remove('show');

    // Clear CLI input fields
    clearCliInputs();

    // Show appropriate CLI options
    if (cliType === 'instant') {
        document.getElementById('instant-cli-options').classList.add('show');
    } else if (cliType === 'installable') {
        document.getElementById('installable-cli-options').classList.add('show');
        document.getElementById('venv-option').classList.add('show');
        // Re-initialize editors that just became visible
        setTimeout(() => {
            if (aceEditors['installCommand']) {
                aceEditors['installCommand'].session.insert({ row: aceEditors['installCommand'].session.getLength(), column: 0 }, "\n\n");
                aceEditors['installCommand'].session.getUndoManager().reset();
                aceEditors['installCommand'].clearSelection();
                aceEditors['installCommand'].moveCursorTo(0, 0);
                aceEditors['installCommand'].resize();
                aceEditors['installCommand'].renderer.updateFull();
            }
            if (aceEditors['installableLaunchCommand']) {
                aceEditors['installableLaunchCommand'].session.insert({ row: aceEditors['installableLaunchCommand'].session.getLength(), column: 0 }, "\n\n");
                aceEditors['installableLaunchCommand'].session.getUndoManager().reset();
                aceEditors['installableLaunchCommand'].clearSelection();
                aceEditors['installableLaunchCommand'].moveCursorTo(0, 0);
                aceEditors['installableLaunchCommand'].resize();
                aceEditors['installableLaunchCommand'].renderer.updateFull();
            }
        }, 50);
    }
}


function clearCliInputs() {
    // Clear regular inputs
    document.querySelectorAll('input[name="launchCommand"]').forEach(input => {
        input.value = '';
    });
    
    // Clear Ace editors
    if (aceEditors['installableLaunchCommand']) {
        aceEditors['installableLaunchCommand'].setValue('');
    }
    if (aceEditors['installCommand']) {
        aceEditors['installCommand'].setValue('');
    }
    
    document.querySelector('input[name="useVenv"]').checked = false;
}

function handleCliTypeChange(event) {
    const cliType = event.target.value;

    // Hide all CLI sub-options first
    document.getElementById('instant-cli-options').classList.remove('show');
    document.getElementById('installable-cli-options').classList.remove('show');

    // Clear CLI input fields
    clearCliInputs();

    // Show appropriate CLI options
    if (cliType === 'instant') {
        document.getElementById('instant-cli-options').classList.add('show');
    } else if (cliType === 'installable') {
        document.getElementById('installable-cli-options').classList.add('show');
        // Re-initialize editors that just became visible
        setTimeout(() => {
            if (aceEditors['installCommand']) {
                aceEditors['installCommand'].session.insert({ row: aceEditors['installCommand'].session.getLength(), column: 0 }, "\n\n");
                aceEditors['installCommand'].session.getUndoManager().reset();
                aceEditors['installCommand'].clearSelection();
                aceEditors['installCommand'].moveCursorTo(0, 0);
                aceEditors['installCommand'].resize();
                aceEditors['installCommand'].renderer.updateFull();
            }
            if (aceEditors['installableLaunchCommand']) {
                aceEditors['installableLaunchCommand'].session.insert({ row: aceEditors['installableLaunchCommand'].session.getLength(), column: 0 }, "\n\n");
                aceEditors['installableLaunchCommand'].session.getUndoManager().reset();
                aceEditors['installableLaunchCommand'].clearSelection();
                aceEditors['installableLaunchCommand'].moveCursorTo(0, 0);
                aceEditors['installableLaunchCommand'].resize();
                aceEditors['installableLaunchCommand'].renderer.updateFull();
            }
        }, 50);
    }
}

function updateCloneDefaults(projectType) {
    // Use Ace editor setValue() method instead of .value
    const installCommandEditor = aceEditors['cloneInstallCommand'];
    const startCommandEditor = aceEditors['cloneStartCommand'];

    if (installCommandEditor && startCommandEditor) {
        if (projectType === 'nodejs') {
            installCommandEditor.setValue('npm install');
            startCommandEditor.setValue('npm start');
        } else if (projectType === 'python') {
            installCommandEditor.setValue('uv pip install -r requirements.txt');
            startCommandEditor.setValue('python app.py');
        } else if (projectType === 'empty') {
            // Clear fields for "Use AI" category
            installCommandEditor.setValue('');
            startCommandEditor.setValue('');
        }
        
        // Clear selection and move cursor to end for better UX
        installCommandEditor.clearSelection();
        startCommandEditor.clearSelection();
    }
}

function handleDocTypeChange(event) {
    const docType = event.target.value;

    // Hide all documentation sub-options first
    document.getElementById('local-doc-options').classList.remove('show');
    document.getElementById('remote-doc-options').classList.remove('show');

    // Clear documentation input fields
    document.querySelector('input[name="localDocPath"]').value = '';
    document.querySelector('input[name="remoteDocUrl"]').value = '';

    // Show appropriate documentation options
    if (docType === 'local') {
        document.getElementById('local-doc-options').classList.add('show');
    } else if (docType === 'remote') {
        document.getElementById('remote-doc-options').classList.add('show');
    }
}

function validateForm() {
    const activeTab = document.querySelector('.tab-content.active').id;
    const isLauncher = activeTab === 'launcher-tab';
    const isCli = activeTab === 'cli-tab';
        const gitUrl = document.getElementById('gitUrl').value.trim();
    
    // Validate Git URL for launcher tab
    if (isLauncher) {
        const gitUrl = document.getElementById('gitUrl').value.trim();
        if (!gitUrl) {
            alert('Please enter a Git repository URL.');
            return false;
        }
        const name = document.getElementById('foldername-launcher').value.trim();
        if (!name) {
            alert('Please enter a folder name.');
            return false;
        }
        if (name.includes(" ")) {
            alert('No spaces allowed');
            return false;
        }
        
        const projectType = document.querySelector('input[name="projectType"]:checked');
        if (!projectType) {
            alert('Please select a project type.');
            return false;
        }
    }
    
    // Validate CLI tab
    if (isCli) {
        const cliType = document.querySelector('input[name="cliType"]:checked');
        if (!cliType) {
            alert('Please select a CLI type.');
            return false;
        }

        const name = document.getElementById('foldername-cli').value.trim();
        if (!name) {
            alert('Please enter a folder name.');
            return false;
        }
        if (name.includes(" ")) {
            alert('No spaces allowed');
            return false;
        }
        
        if (cliType.value === 'instant') {
            const launchCommand = document.querySelector('input[name="launchCommand"]').value.trim();
            if (!launchCommand) {
                alert('Please enter a launch command.');
                return false;
            }
        } else if (cliType.value === 'installable') {
            const installCommand = aceEditors['installCommand'] ? aceEditors['installCommand'].getValue().trim() : '';
            const launchCommand = aceEditors['installableLaunchCommand'] ? aceEditors['installableLaunchCommand'].getValue().trim() : '';
            if (!installCommand) {
                alert('Please enter at least one install command.');
                return false;
            }
            if (!launchCommand) {
                alert('Please enter at least one launch command.');
                return false;
            }
        }
    }
    
    // Validate project tab
    if (!isLauncher && !isCli) {
        const projectType = document.querySelector('input[name="projectType"]:checked');
        if (!projectType) {
            alert('Please select a project type.');
            return false;
        }

        const name = document.getElementById('foldername-new').value.trim();
        if (!name) {
            alert('Please enter a folder name.');
            return false;
        }
        if (name.includes(" ")) {
            alert('No spaces allowed');
            return false;
        }
        
        // Validate Documentation options
        if (projectType.value === 'documentation') {
            const docType = document.querySelector('input[name="docType"]:checked');
            if (!docType) {
                alert('Please select a documentation source.');
                return false;
            }
            
            if (docType.value === 'local') {
                const localDocPath = document.querySelector('input[name="localDocPath"]').value.trim();
                if (!localDocPath) {
                    alert('Please enter a local project path.');
                    return false;
                }
            } else if (docType.value === 'remote') {
                const remoteDocUrl = document.querySelector('input[name="remoteDocUrl"]').value.trim();
                if (!remoteDocUrl) {
                    alert('Please enter a remote Git repository URL.');
                    return false;
                }
            }
        }
    }
    
    return true;
}

function handleSubmit(event) {
    event.preventDefault();
    
    if (!validateForm()) {
        return;
    }

    const formData = new FormData(event.target);
    const activeTab = document.querySelector('.tab-content.active').id;
    const isLauncher = activeTab === 'launcher-tab';
    const isCli = activeTab === 'cli-tab';
    const gitUrl = isLauncher ? formData.get('gitUrl').trim() : '';

    // Get values from Ace editors and clean them
    const cloneInstallCommandText = aceEditors['cloneInstallCommand'] ? aceEditors['cloneInstallCommand'].getValue().trim() : '';
    const cloneStartCommandText = aceEditors['cloneStartCommand'] ? aceEditors['cloneStartCommand'].getValue().trim() : '';
    const installCommandText = aceEditors['installCommand'] ? aceEditors['installCommand'].getValue().trim() : '';
    const installableLaunchCommandText = aceEditors['installableLaunchCommand'] ? aceEditors['installableLaunchCommand'].getValue().trim() : '';
    const aiPromptText = aceEditors['aiPrompt'] ? aceEditors['aiPrompt'].getValue().trim() : '';

    // Set startType and projectType based on active tab
    let startType, projectType, name;
    if (isLauncher) {
        startType = 'clone';
        projectType = formData.get('projectType');
        name = formData.get("foldername-launcher").trim();
    } else if (isCli) {
        startType = 'new';
        projectType = 'cli';
        name = formData.get("foldername-cli").trim();
    } else {
        startType = 'new';
        projectType = formData.get('projectType');
        name = formData.get("foldername-new").trim();
    }

    // For CLI category, map the projectType to cliType for backwards compatibility
    let mappedProjectType = projectType;
    let cliType = formData.get('cliType');

    if (projectType === 'cli') {
        // When CLI is selected as projectType, cliType determines the actual type
        mappedProjectType = 'cli';
    }

    const config = {
        name,
        startType: startType,
        projectType: mappedProjectType,
        gitUrl: gitUrl,
        cloneInstallCommand: cloneInstallCommandText ? cloneInstallCommandText.split('\n').filter(line => line.trim() !== '') : [],
        cloneStartCommand: cloneStartCommandText ? cloneStartCommandText.split('\n').filter(line => line.trim() !== '') : [],
        allowInstallUserInput: formData.get('allowInstallUserInput'),
        allowStartUserInput: formData.get('allowStartUserInput'),
        pythonOptions: formData.getAll('pythonOptions'),
        cliType: cliType,
        launchCommand: formData.get('launchCommand'),
        installableLaunchCommand: installableLaunchCommandText ? installableLaunchCommandText.split('\n').filter(line => line.trim() !== '') : [],
        installCommand: installCommandText ? installCommandText.split('\n').filter(line => line.trim() !== '') : [],
        useVenv: formData.get('useVenv'),
        docType: formData.get('docType'),
        localDocPath: formData.get('localDocPath'),
        remoteDocUrl: formData.get('remoteDocUrl'),
        aiPrompt: aiPromptText
    };

    displayResults(config);
}

async function displayResults(config) {
  let shell_id
  <% if (theme === "dark") { %>
  let _theme = xtermTheme.FrontEndDelight
  <% } else { %>
  let _theme = xtermTheme.Tomorrow
  <% } %>
  const theme = Object.assign({ }, _theme, {
    selectionBackground: "red",
    selectionForeground: "white"
  })

  let term_config = {
    scrollback: 9999999,
    fontSize: 14,
    theme,
  }
  let res = await fetch("/xterm_config").then((res) => {
    return res.json()
  })
  if (res && res.config) {
    term_config = res.config
  }
  let socket = new Socket()
  const term = new Terminal(term_config)
  term.open(document.querySelector("#terminal"))
  term.attachCustomKeyEventHandler(event => {
    console.log({ event })
    if ((event.ctrlKey || event.metaKey) && event.key === 'c') {
      const selection = term.getSelection();
      if (selection) {
        navigator.clipboard.writeText(selection);
        return false;
      }
    }
    if ((event.ctrlKey || event.metaKey) && event.key === 'v') {
      navigator.clipboard.readText().then((text) => {
        console.log({ text })
        socket.run({
          //key: "\x1b[200~" + text + "\x1b[201~",
          key: text,
          id: shell_id,
          paste: true
        })

      })
      return false
    }
    return true;
  });
  term.onKey(({ key }) => {
    console.log({ key, shell_id })
    if (socket) {
      if (shell_id) {
        socket.run({
          key,
          id: shell_id
        })
      }
    }
  });
  const fitAddon = new FitAddon.FitAddon();
  term.loadAddon(fitAddon);
  fitAddon.fit();
  term.focus()
  let observer = new ResizeObserver(() => {
    fitAddon.fit()
    console.log(`Resized to ${term.cols}x${term.rows}`);
    // Trigger your custom handler here
    if (socket) {
      if (shell_id) {
        socket.run({
          resize: {
            cols: term.cols,
            rows: term.rows,
          },
          id: shell_id
        })
      }
    }
  });
  observer.observe(document.body)
  const write = (text) => {
    if (text !== "\u0007") {
      term.write(text)
    }
  }
  socket.run({
    method: "kernel.proto.create",
    cwd: "<%-JSON.stringify(cwd).slice(1, -1)%>",
//    name: "<%=name%>",
    params: config
  }, async (packet) => {
    console.log('packet', packet)
    if (packet.type === 'start') {
      document.querySelector(".play-btn").classList.add("hidden")
      document.querySelector(".starting-btn").classList.add("hidden")
      document.querySelector(".stop-btn").classList.remove("hidden")
    } else if (packet.type === "result") {
      if (packet.data.success) {
        location.href = packet.data.success
      } else if (packet.data.error) {
        alert(packet.data.error)
        location.href = location.href
      }
    } else if (packet.type === "stream") {
      // set the current shell id
      if (packet.data.id) {
        shell_id = packet.data.id
      }
      if (packet.data.raw) {
        write(packet.data.raw)
      } else if (packet.data.json) {
        write(JSON.stringify(packet.data.json).replace(/\n/g, "\r\n"))
        write("\r\n")
      } else if (packet.data.json2) {
        write(JSON.stringify(packet.data.json2, null, 2).replace(/\n/g, "\r\n"))
        write("\r\n")
      }
      document.querySelector("#end").scrollIntoView({ behavior: 'smooth' });
    } else if (packet.type === 'disconnect') {
      term.write("\r\nDisconnected...\r\n")
      socket.close()
    } else if (packet.type === 'connect') {
      if (packet.data) {
        if (packet.data.shell) {
          shell_id = packet.data.shell
        }
      }
    }
  }).then((res) => {
    console.log("Ended", res)
  })
}

