<html>
<head>
<title>Pinokio Terminal Sessions</title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/style.css" rel="stylesheet"/>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<script src="/sweetalert2.js"></script>
<style>
:root {
  --terminals-viewport-height: 100dvh;
}

html,
body,
main,
#terminals-main {
  width: 100%;
  max-width: 100%;
}

html,
body {
  margin: 0;
  height: 100%;
}

body {
  overflow: hidden;
  display: flex !important;
  flex-direction: column !important;
  align-items: stretch;
}

main {
  display: flex;
  flex: 1 1 auto;
  min-height: 0;
  height: auto;
  max-height: none;
  overflow: hidden;
}

.terminals-page,
main > .container.terminals-page,
.container.terminals-page {
  min-height: 0;
}

.container.terminals-page,
main > .container.terminals-page {
  height: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
}

#terminals-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 0;
  padding: 0;
  height: auto;
  overflow: hidden;
  gap: 0;
  box-sizing: border-box;
}

@media only screen and (max-width: 768px) {
  body {
    flex-direction: column !important;
  }
  header.navheader {
    display: block;
    align-self: auto;
    overflow: visible;
    width: 100%;
    min-width: 0;
    max-width: none;
    height: auto;
  }
  header.navheader h1 {
    display: flex;
    flex-direction: row;
    align-items: center;
    overflow-x: auto;
    overflow-y: hidden;
    flex-wrap: nowrap;
  }
}

.container.terminals-page > form.search {
  flex: 0 0 auto;
  padding: 10px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.1);
}

body.dark .container.terminals-page > form.search {
  border-bottom-color: rgba(148, 163, 184, 0.22);
}

.terminals-workspaces-header {
  margin: 0;
  padding: 12px 12px 10px;
  border-bottom: 1px solid rgba(127, 127, 127, 0.22);
}

.terminals-workspaces-header h2 {
  margin: 0;
  font-size: 18px;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
}

.terminals-workspaces-header p {
  margin: 4px 0 0;
  font-size: 12px;
  line-height: 1.35;
  color: rgba(15, 23, 42, 0.7);
}

.terminals-workspaces-header.hidden {
  display: none;
}

body.dark .terminals-workspaces-header {
  border-bottom-color: rgba(255, 255, 255, 0.14);
}

body.dark .terminals-workspaces-header h2 {
  color: rgba(241, 245, 249, 0.96);
}

body.dark .terminals-workspaces-header p {
  color: rgba(203, 213, 225, 0.86);
}

.terminals-search-form {
  --terminals-top-control-height: 25px;
  --terminals-top-control-radius: 6px;
  --terminals-top-toolbar-bg: rgba(255, 255, 255, 0.76);
  --terminals-top-toolbar-border: rgba(15, 23, 42, 0.14);
  --terminals-top-toolbar-strong: #0f172a;
  --terminals-top-toolbar-muted: rgba(15, 23, 42, 0.72);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
}

body.dark .terminals-search-form {
  --terminals-top-toolbar-bg: rgba(15, 23, 42, 0.34);
  --terminals-top-toolbar-border: rgba(148, 163, 184, 0.24);
  --terminals-top-toolbar-strong: rgba(241, 245, 249, 0.96);
  --terminals-top-toolbar-muted: rgba(203, 213, 225, 0.86);
}

.terminals-top-search-controls {
  display: block;
  flex: 1;
  min-width: 0;
}

.terminals-top-session {
  --terminals-top-toolbar-strong: royalblue;
  --terminals-top-toolbar-muted: royalblue;
  display: none;
  align-items: center;
  gap: 9px;
  flex: 1;
  min-width: 0;
  margin: 0;
  min-height: var(--terminals-top-control-height);
  padding: 5px 8px;
  border: 1px solid var(--terminals-top-toolbar-border);
  border-radius: var(--terminals-top-control-radius);
  background: var(--terminals-top-toolbar-bg);
  color: royalblue;
  box-sizing: border-box;
}

.terminals-top-session.hidden {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-search-controls {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-session {
  display: flex;
}

.terminals-top-session h4 {
  order: 1;
  margin: 0;
  font-size: 12px;
  font-weight: 650;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--terminals-top-toolbar-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.terminals-top-session-leading-actions {
  order: 0;
  flex: 0 0 auto;
}

.terminals-top-session-search-spacer {
  order: 2;
  flex: 0 1 260px;
  min-width: 0;
  max-width: 360px;
}

@media only screen and (max-width: 1200px) {
  .terminals-top-session-search-spacer {
    flex-basis: 140px;
    max-width: 180px;
  }
}

@media only screen and (max-width: 1080px) {
  .terminals-top-session-search-spacer {
    display: none;
  }
}

.terminals-top-session-path {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 0 1 auto;
}

.terminals-top-session-crumb {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--terminals-top-toolbar-muted);
  opacity: 1;
}

.terminals-top-session-crumb-link {
  border: none;
  background: transparent;
  padding: 0;
  margin: 0;
  color: inherit;
  font: inherit;
  line-height: inherit;
  cursor: pointer;
}

.terminals-top-session-crumb-link:hover {
  color: var(--terminals-top-toolbar-strong);
}

.terminals-top-session-crumb-link:focus-visible {
  outline: none;
  color: var(--terminals-top-toolbar-strong);
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.28);
  border-radius: 4px;
}

.terminals-top-session-separator {
  font-size: 10px;
  color: var(--terminals-top-toolbar-muted);
  opacity: 0.7;
  flex: 0 0 auto;
}

.terminals-top-session-current {
  min-width: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex: 0 1 auto;
}

.terminals-top-session-current-label {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 650;
}

.terminals-search-form .home-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 0;
  padding: 0;
  height: var(--terminals-top-control-height);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: var(--terminals-top-control-radius);
  overflow: hidden;
  background: rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

body.dark .terminals-search-form .home-mode-switch {
  border-color: rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.06);
}

.terminals-search-form .home-mode-switch .mode-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 100%;
  padding: 0 10px;
  border-radius: 0;
  text-decoration: none;
  color: inherit;
  border: none;
  background: transparent;
  font-weight: 400;
  font-size: 12px;
  opacity: 1;
  line-height: 1;
  box-sizing: border-box;
}

.terminals-search-form .home-mode-switch .mode-link + .mode-link {
  border-left: 1px solid rgba(0, 0, 0, 0.14);
}

body.dark .terminals-search-form .home-mode-switch .mode-link + .mode-link {
  border-left-color: rgba(255, 255, 255, 0.05);
}

.terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}

body.dark .terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}

.terminals-search-form .home-mode-switch .mode-link.selected,
.terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

body.dark .terminals-search-form .home-mode-switch .mode-link.selected,
body.dark .terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

#terminals-empty-main {
  border: 1px dashed rgba(127, 127, 127, 0.4);
  border-radius: 10px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 16px;
  box-sizing: border-box;
}

#terminals-empty-main.hidden {
  display: none;
}

.terminals-columns {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  gap: 8px;
  box-sizing: border-box;
}

.terminals-columns-rail {
  flex: 1;
  min-height: 0;
  display: flex;
  width: 100%;
  max-width: 100%;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  align-items: stretch;
  scrollbar-gutter: stable;
  padding-bottom: 0;
  box-sizing: border-box;
}

.terminals-columns.hidden {
  display: none;
}

.terminals-list-intro {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  position: relative;
  overflow: visible;
}

body.dark .terminals-list-intro {
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.terminals-list-intro-toolbar {
  display: flex;
  align-items: center;
  gap: 9px;
  min-height: var(--terminals-top-control-height);
  min-width: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: var(--terminals-top-toolbar-strong);
  padding: 0;
  box-sizing: border-box;
}

.terminals-list-intro-search {
  order: 2;
  flex: 0 1 360px;
  min-width: 160px;
  max-width: 420px;
  margin-left: auto;
}

.terminals-list-intro-search input[type="search"] {
  width: 100%;
}

.terminals-list-intro-breadcrumb {
  order: 1;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1 1 auto;
  font-size: 12px;
  font-weight: 650;
  letter-spacing: 0.005em;
  color: royalblue;
}

.terminals-list-intro-toolbar.has-actions .terminals-list-intro-breadcrumb {
  margin-left: 0;
  padding-left: 0;
  border-left: none;
}

.terminals-list-intro-crumb {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.terminals-list-intro-crumb-root {
  color: royalblue;
  opacity: 1;
}

.terminals-list-intro-crumb-link {
  border: none;
  background: transparent;
  padding: 0;
  margin: 0;
  color: inherit;
  font: inherit;
  line-height: inherit;
  cursor: pointer;
}

.terminals-list-intro-crumb-link:hover {
  color: royalblue;
  opacity: 1;
}

.terminals-list-intro-crumb-link:focus-visible {
  outline: none;
  color: royalblue;
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.28);
  border-radius: 6px;
}

body.dark .terminals-list-intro-crumb-link:hover,
body.dark .terminals-list-intro-crumb-link:focus-visible {
  color: royalblue;
}

.terminals-list-intro-crumb-current {
  opacity: 1;
}

.terminals-list-intro-separator {
  font-size: 10px;
  color: royalblue;
  opacity: 0.7;
  flex: 0 0 auto;
}

.terminals-list-intro-actions {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  flex: 0 0 auto;
}

.terminals-list-intro-leading-actions {
  order: 0;
  margin-right: 0;
  padding-right: 0;
  border-right: none;
}

.terminals-list-intro-trailing-actions {
  order: 3;
  margin-left: 0;
  padding-left: 0;
  border-left: none;
}

.terminals-list-intro-main-action {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: var(--terminals-top-control-height);
  min-height: var(--terminals-top-control-height);
  padding: 0 10px;
  border-radius: calc(var(--terminals-top-control-radius) - 1px);
  font-size: 12px;
  line-height: 1;
  font-weight: 650;
}

.terminals-list-intro-main-action i {
  font-size: 12px;
  line-height: 1;
}

.terminals-list-intro .terminals-list-intro-main-action {
  gap: 6px;
  height: var(--terminals-top-control-height);
  min-height: var(--terminals-top-control-height);
  padding: 0 10px;
  border-radius: calc(var(--terminals-top-control-radius) - 1px);
  font-size: 12px;
  font-weight: 650;
}

.terminals-list-intro .terminals-list-intro-main-action i {
  font-size: 12px;
  line-height: 1;
}

.terminals-list-intro .terminals-list-intro-main-action.terminals-create-toggle {
  border: 1px solid #5e7fee;
  background: #4b6ee8;
  color: #f8fbff;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
}

.terminals-list-intro .terminals-list-intro-main-action.terminals-create-toggle:hover {
  border-color: #6f8ef3;
  background: #5475ec;
}

.terminals-list-intro .terminals-list-intro-main-action.terminals-create-toggle:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.terminals-list-intro-action {
  width: var(--terminals-top-control-height);
  height: var(--terminals-top-control-height);
  border-radius: calc(var(--terminals-top-control-radius) - 1px);
  border: none;
  background: transparent;
  color: var(--terminals-top-toolbar-muted);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  cursor: pointer;
  transition: background-color 130ms ease, color 130ms ease, transform 130ms ease;
}

.terminals-list-intro-action i {
  font-size: 12px;
}

.terminals-list-intro-action:hover {
  background: rgba(148, 163, 184, 0.2);
  color: var(--terminals-top-toolbar-strong);
}

.terminals-list-intro-action:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.4);
}

.terminals-list-intro-action:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
}

.terminals-list-intro-action[data-label]::after {
  content: attr(data-label);
  position: absolute;
  top: calc(100% + 7px);
  left: 50%;
  transform: translate(-50%, -2px);
  opacity: 0;
  pointer-events: none;
  padding: 4px 7px;
  border-radius: 6px;
  background: rgba(15, 23, 42, 0.93);
  color: #f8fafc;
  font-size: 10px;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  transition: opacity 120ms ease, transform 120ms ease;
  z-index: 6;
}

.terminals-list-intro-action[data-label]:hover::after,
.terminals-list-intro-action[data-label]:focus-visible::after {
  opacity: 1;
  transform: translate(-50%, 0);
}

body.dark .terminals-list-intro-action {
  background: transparent;
  color: var(--terminals-top-toolbar-muted);
}

body.dark .terminals-list-intro-action:hover {
  background: rgba(148, 163, 184, 0.2);
  color: var(--terminals-top-toolbar-strong);
}

@media only screen and (max-width: 860px) {
  .terminals-list-intro-toolbar {
    flex-wrap: wrap;
    row-gap: 7px;
  }
  .terminals-list-intro-leading-actions {
    order: 1;
    margin-right: 0;
    padding-right: 0;
    border-right: none;
  }
  .terminals-list-intro-trailing-actions {
    order: 3;
    margin-left: 0;
    padding-left: 0;
    border-left: none;
  }
  .terminals-list-intro-breadcrumb {
    order: 0;
    flex-basis: 100%;
    font-size: 12px;
  }
  .terminals-list-intro-search {
    order: 1;
    flex: 1 1 100%;
    max-width: none;
    margin-left: 0;
  }
  .terminals-list-intro-toolbar.has-actions .terminals-list-intro-breadcrumb {
    margin-left: 0;
    padding-left: 0;
    border-left: none;
  }
}

.terminals-list-intro-refresh,
.terminals-list-intro-refresh:hover,
.terminals-list-intro-refresh:focus-visible {
  color: royalblue;
}

.terminals-list-intro-refresh-idle,
.terminals-list-intro-refresh-busy {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.terminals-list-intro-progress {
  position: absolute;
  left: 0;
  top: 0;
  width: 34%;
  height: 2px;
  opacity: 0;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(29, 78, 216, 0), rgba(29, 78, 216, 0.95), rgba(29, 78, 216, 0));
  transform: translateX(-140%);
}

.terminals-list-intro.is-loading .terminals-list-intro-progress {
  opacity: 1;
  animation: terminalsIntroRefreshBar 1.1s linear infinite;
}

.terminals-list-intro-refresh-idle i,
.terminals-list-intro-refresh-busy i {
  font-size: 12px;
}

.terminals-list-intro-refresh-busy {
  display: none;
}

.terminals-list-intro.is-loading .terminals-list-intro-refresh {
  pointer-events: none;
  cursor: wait;
}

.terminals-list-intro.is-loading .terminals-list-intro-refresh-idle {
  display: none;
}

.terminals-list-intro.is-loading .terminals-list-intro-refresh-busy {
  display: inline-flex;
}

.terminals-top-session.is-loading .terminals-list-intro-refresh {
  pointer-events: none;
  cursor: wait;
}

.terminals-top-session.is-loading .terminals-list-intro-refresh-idle {
  display: none;
}

.terminals-top-session.is-loading .terminals-list-intro-refresh-busy {
  display: inline-flex;
}

body.dark .terminals-list-intro-refresh,
body.dark .terminals-list-intro-refresh:hover,
body.dark .terminals-list-intro-refresh:focus-visible {
  color: royalblue;
}

@keyframes terminalsIntroRefreshBar {
  0% {
    transform: translateX(-140%);
  }
  100% {
    transform: translateX(280%);
  }
}

.terminals-column {
  flex: 0 0 100%;
  border: none;
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.02);
  height: 100%;
  min-height: 0;
  min-width: 0;
}
.terminals-column.terminals-column-chooser {
  border: none;
}

.terminals-column header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-bottom: 1px solid rgba(127, 127, 127, 0.2);
  min-height: 35px;
}

.terminals-column h4 {
  margin: 0;
  font-size: 13px;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.terminals-column.terminals-column-chooser h4 {
  flex: 0 0 auto;
}

.terminals-chooser-content {
  display: flex;
  flex-direction: column;
  min-height: 0;
  flex: 1;
}

.terminals-launcher-modal {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.terminals-launcher-modal.hidden {
  display: none;
}

.terminals-launcher-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.34);
  backdrop-filter: blur(2px);
}

body.dark .terminals-launcher-backdrop {
  background: rgba(8, 10, 16, 0.55);
}

.terminals-launcher-panel {
  position: relative;
  width: min(760px, calc(100vw - 24px));
  max-height: min(78vh, 700px);
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(15, 23, 42, 0.15);
  border-radius: 10px;
  overflow: hidden;
  background: #f8fafc;
  color: #0f172a;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
  --terminals-launcher-control-height: 34px;
}

body.dark .terminals-launcher-panel {
  border: 1px solid rgba(127, 127, 127, 0.28);
  background: #111319;
  color: #f3f4f6;
  box-shadow: 0 18px 70px rgba(0, 0, 0, 0.52);
}

.terminals-launcher-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.12);
}

body.dark .terminals-launcher-header {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.terminals-launcher-header h3 {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
}

.terminals-launcher-close {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(15, 23, 42, 0.24);
  border-radius: 7px;
  color: inherit;
  cursor: pointer;
  width: 30px;
  height: 28px;
  font-size: 18px;
  line-height: 1;
}

body.dark .terminals-launcher-close {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.terminals-launcher-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 10px 14px 12px;
  min-height: 0;
