<html>
<head>
<title>Pinokio Terminal Sessions</title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/style.css" rel="stylesheet"/>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<script src="/sweetalert2.js"></script>
<style>
:root {
  --terminals-viewport-height: 100dvh;
}

html,
body,
main,
#terminals-main {
  width: 100%;
  max-width: 100%;
}

html,
body {
  margin: 0;
  height: 100%;
}

body {
  overflow: hidden;
}

main {
  display: flex;
  min-height: 0;
  height: var(--terminals-viewport-height);
  max-height: var(--terminals-viewport-height);
  overflow: hidden;
}

.terminals-page,
main > .container.terminals-page,
.container.terminals-page {
  min-height: 0;
}

.container.terminals-page,
main > .container.terminals-page {
  height: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
}

#terminals-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 0;
  padding: 8px;
  height: auto;
  overflow: hidden;
  gap: 0;
  box-sizing: border-box;
}

.container.terminals-page > form.search {
  flex: 0 0 auto;
  padding: 10px 10px 0;
}

.terminals-search-form {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
}

.terminals-top-search-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.terminals-top-session {
  display: none;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.terminals-top-session.hidden {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-search-controls {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-session {
  display: flex;
}

.terminals-top-session h4 {
  margin: 0;
  font-size: 13px;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.terminals-search-form .home-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 0;
  padding: 0;
  height: 25px;
  border: 1px solid rgba(0, 0, 0, 0.14);
  border-radius: 6px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

body.dark .terminals-search-form .home-mode-switch {
  border-color: rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.06);
}

.terminals-search-form .home-mode-switch .mode-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 100%;
  padding: 0 10px;
  border-radius: 0;
  text-decoration: none;
  color: inherit;
  border: none;
  border-right: 1px solid rgba(0, 0, 0, 0.14);
  background: transparent;
  font-weight: 400;
  font-size: 12px;
  opacity: 1;
  line-height: 1;
  box-sizing: border-box;
}

.terminals-search-form .home-mode-switch .mode-link:last-child {
  border-right: none;
}

body.dark .terminals-search-form .home-mode-switch .mode-link {
  border-right-color: rgba(255, 255, 255, 0.05);
}

body.dark .terminals-search-form .home-mode-switch .mode-link:last-child {
  border-right: none;
}

.terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(0, 0, 0, 0.08);
}

body.dark .terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(255, 255, 255, 0.14);
}

.terminals-search-form .home-mode-switch .mode-link.selected,
.terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

body.dark .terminals-search-form .home-mode-switch .mode-link.selected,
body.dark .terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

#terminals-empty-main {
  border: 1px dashed rgba(127, 127, 127, 0.4);
  border-radius: 10px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 16px;
  box-sizing: border-box;
}

#terminals-empty-main.hidden {
  display: none;
}

.terminals-columns {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  gap: 8px;
  box-sizing: border-box;
}

.terminals-columns-rail {
  flex: 1;
  min-height: 0;
  display: flex;
  width: 100%;
  max-width: 100%;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  align-items: stretch;
  scrollbar-gutter: stable;
  padding-bottom: 0;
  box-sizing: border-box;
}

.terminals-columns.hidden {
  display: none;
}

.terminals-list-intro {
  margin: 10px 12px 8px;
  padding: 10px 12px;
  border: 1px solid rgba(127, 127, 127, 0.22);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.02);
  position: relative;
  overflow: hidden;
}

body.dark .terminals-list-intro {
  border-color: rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.03);
}

.terminals-list-intro-head {
  display: flex;
  align-items: center;
  gap: 8px;
}

.terminals-list-intro-title {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.terminals-list-intro h2 {
  margin: 0;
  font-size: 14px;
  line-height: 1.2;
}

.terminals-list-intro p {
  margin: 4px 0 0;
  font-size: 12px;
  line-height: 1.35;
  opacity: 0.86;
}

.terminals-list-intro-refresh {
  display: none;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  line-height: 1;
  opacity: 0.9;
  white-space: nowrap;
  color: #1d4ed8;
  background: rgba(29, 78, 216, 0.12);
  border: 1px solid rgba(29, 78, 216, 0.28);
  border-radius: 999px;
  padding: 3px 8px;
  flex: 0 0 auto;
}

.terminals-list-intro.is-loading .terminals-list-intro-refresh {
  display: inline-flex;
}

.terminals-list-intro-progress {
  position: absolute;
  left: 0;
  top: 0;
  width: 38%;
  height: 2px;
  opacity: 0;
  pointer-events: none;
  background: linear-gradient(90deg, rgba(29, 78, 216, 0), rgba(29, 78, 216, 0.95), rgba(29, 78, 216, 0));
  transform: translateX(-140%);
}

.terminals-list-intro.is-loading .terminals-list-intro-progress {
  opacity: 1;
  animation: terminalsIntroRefreshBar 1.1s linear infinite;
}

.terminals-list-intro-refresh i {
  font-size: 11px;
}

body.dark .terminals-list-intro-refresh {
  color: #93c5fd;
  background: rgba(37, 99, 235, 0.22);
  border-color: rgba(96, 165, 250, 0.4);
}

@keyframes terminalsIntroRefreshBar {
  0% {
    transform: translateX(-140%);
  }
  100% {
    transform: translateX(280%);
  }
}

.terminals-column {
  flex: 0 0 100%;
  border: 1px solid rgba(127, 127, 127, 0.2);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.02);
  height: 100%;
  min-height: 0;
  min-width: 0;
}
.terminals-column.terminals-column-chooser {
  border: none;
}

.terminals-column header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-bottom: 1px solid rgba(127, 127, 127, 0.2);
  min-height: 35px;
}

.terminals-column h4 {
  margin: 0;
  font-size: 13px;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.terminals-column.terminals-column-chooser h4 {
  flex: 0 0 auto;
}

.terminals-chooser-content {
  display: flex;
  flex-direction: column;
  min-height: 0;
  flex: 1;
}

.terminals-launcher-modal {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.terminals-launcher-modal.hidden {
  display: none;
}

.terminals-launcher-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.34);
  backdrop-filter: blur(2px);
}

body.dark .terminals-launcher-backdrop {
  background: rgba(8, 10, 16, 0.55);
}

.terminals-launcher-panel {
  position: relative;
  width: min(760px, calc(100vw - 24px));
  max-height: min(78vh, 700px);
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(15, 23, 42, 0.15);
  border-radius: 10px;
  overflow: hidden;
  background: #f8fafc;
  color: #0f172a;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
  --terminals-launcher-control-height: 34px;
}

body.dark .terminals-launcher-panel {
  border: 1px solid rgba(127, 127, 127, 0.28);
  background: #111319;
  color: #f3f4f6;
  box-shadow: 0 18px 70px rgba(0, 0, 0, 0.52);
}

.terminals-launcher-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.12);
}

body.dark .terminals-launcher-header {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.terminals-launcher-header h3 {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
}

.terminals-launcher-close {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(15, 23, 42, 0.24);
  border-radius: 7px;
  color: inherit;
  cursor: pointer;
  width: 30px;
  height: 28px;
  font-size: 18px;
  line-height: 1;
}

body.dark .terminals-launcher-close {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.terminals-launcher-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 10px 14px 12px;
  min-height: 0;
}

.terminals-launcher-view {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 0;
}

.terminals-launcher-view.hidden {
  display: none;
}

.terminals-launcher-main-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.terminals-launcher-main-row {
  display: grid;
  grid-template-columns: 80px minmax(0, 1fr);
  align-items: start;
  gap: 10px;
}

.terminals-launcher-main-label {
  font-size: 12px;
  font-weight: 600;
  opacity: 0.84;
  line-height: 1.15;
}

.terminals-launcher-main-label-title {
  font-size: 12px;
  font-weight: 700;
}

.terminals-launcher-main-label-subtitle {
  margin-top: 2px;
  font-size: 11px;
  opacity: 0.68;
}

.terminals-launcher-main-value {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  min-width: 0;
}

.terminals-launcher-row-meta {
  font-size: 12px;
  opacity: 0.78;
}

.terminals-launcher-main-value .terminals-launcher-selected,
.terminals-launcher-main-value .terminals-launcher-upload-list {
  width: 100%;
  margin-top: 2px;
}

.terminals-launcher-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: var(--terminals-launcher-control-height);
  padding: 0 11px;
  border-radius: 7px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
}

body.dark .terminals-launcher-secondary {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: transparent;
}

.terminals-launcher-secondary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-launcher-secondary.is-primary {
  border-color: royalblue;
  background: royalblue;
  color: #fff;
}

.terminals-launcher-skills-header {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 8px;
}

.terminals-launcher-skills-title {
  font-size: 13px;
  font-weight: 700;
  text-align: center;
}

.terminals-launcher-search {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  background: #ffffff;
  color: inherit;
  outline: none;
  font-size: 14px;
}

body.dark .terminals-launcher-search {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.08);
}

.terminals-launcher-search:focus {
  border-color: rgba(65, 105, 225, 0.75);
  box-shadow: 0 0 0 2px rgba(65, 105, 225, 0.25);
}

.terminals-launcher-provider-options {
  display: flex;
  gap: 6px;
  flex-wrap: nowrap;
}

.terminals-launcher-provider {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  justify-content: flex-start;
  height: var(--terminals-launcher-control-height);
  padding: 0 11px;
  border-radius: 7px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease, transform 0.12s ease;
}

body.dark .terminals-launcher-provider {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: transparent;
}

.terminals-launcher-provider img {
  width: 16px;
  height: 16px;
  object-fit: contain;
  border-radius: 3px;
}

.terminals-launcher-radio {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  border: 1px solid currentColor;
  opacity: 0.75;
  position: relative;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.terminals-launcher-provider.active .terminals-launcher-radio::after {
  content: "";
  position: absolute;
  inset: 2px;
  border-radius: 999px;
  background: currentColor;
}

.terminals-launcher-provider.active {
  border-color: rgba(65, 105, 225, 0.72);
  background: rgba(65, 105, 225, 0.12);
  color: inherit;
}

.terminals-launcher-provider:not(.active):hover {
  border-color: rgba(65, 105, 225, 0.7);
  background: rgba(65, 105, 225, 0.06);
}

body.dark .terminals-launcher-provider.active {
  border-color: rgba(95, 130, 235, 0.75);
  background: rgba(95, 130, 235, 0.14);
}

.terminals-launcher-files-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  height: var(--terminals-launcher-control-height);
  padding: 0 12px;
  border-radius: 8px;
  border: 1px solid rgba(15, 23, 42, 0.22);
  background: rgba(15, 23, 42, 0.05);
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 700;
}

body.dark .terminals-launcher-files-toggle {
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.08);
}

.terminals-launcher-files-toggle.active {
  border-color: royalblue;
  color: royalblue;
}

.terminals-launcher-file-input {
  display: none;
}

.terminals-launcher-skill-section {
  display: flex;
  flex-direction: column;
  min-height: 0;
  gap: 8px;
}

.terminals-launcher-selected {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.terminals-launcher-selected.hidden {
  display: none;
}

.terminals-launcher-upload {
  border: 1px dashed rgba(15, 23, 42, 0.28);
  border-radius: 8px;
  padding: 8px;
  margin-top: 8px;
  background: rgba(15, 23, 42, 0.02);
}

body.dark .terminals-launcher-upload {
  border: 1px dashed rgba(255, 255, 255, 0.26);
  background: rgba(255, 255, 255, 0.03);
}

.terminals-launcher-upload.hidden {
  display: none;
}

.terminals-launcher-upload-dropzone {
  width: 100%;
  border: 1px dashed rgba(65, 105, 225, 0.55);
  background: rgba(65, 105, 225, 0.08);
  color: inherit;
  border-radius: 7px;
  padding: 10px;
  text-align: left;
  cursor: pointer;
  font-size: 12px;
}

body.dark .terminals-launcher-upload-dropzone {
  background: rgba(65, 105, 225, 0.18);
}

.terminals-launcher-upload-dropzone.dragover {
  border-color: royalblue;
  background: rgba(65, 105, 225, 0.18);
}

.terminals-launcher-upload-list {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.terminals-launcher-upload-list.hidden {
  display: none;
}

.terminals-launcher-upload-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  font-size: 12px;
}

.terminals-launcher-upload-item button {
  border: 0;
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
}

.terminals-launcher-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid rgba(65, 105, 225, 0.65);
  border-radius: 999px;
  background: rgba(65, 105, 225, 0.2);
  font-size: 12px;
  padding: 4px 9px;
}

.terminals-launcher-chip button {
  background: transparent;
  border: 0;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
  padding: 0;
}

.terminals-launcher-skill-list {
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 10px;
  max-height: min(46vh, 430px);
  overflow: auto;
}

body.dark .terminals-launcher-skill-list {
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.terminals-launcher-skill-row {
  width: 100%;
  text-align: left;
  border: 0;
  border-bottom: 1px solid rgba(15, 23, 42, 0.1);
  background: transparent;
  color: inherit;
  cursor: pointer;
  padding: 10px 12px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.terminals-launcher-skill-row:last-child {
  border-bottom: 0;
}

.terminals-launcher-skill-row:hover {
  background: rgba(15, 23, 42, 0.05);
}

body.dark .terminals-launcher-skill-row {
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

body.dark .terminals-launcher-skill-row:hover {
  background: rgba(255, 255, 255, 0.06);
}

.terminals-launcher-skill-row.selected {
  background: rgba(65, 105, 225, 0.25);
}

.terminals-launcher-skill-text {
  min-width: 0;
}

.terminals-launcher-skill-name {
  font-size: 13px;
  font-weight: 700;
}

.terminals-launcher-skill-desc {
  margin-top: 2px;
  font-size: 12px;
  opacity: 0.78;
}

.terminals-search-highlight {
  background: rgba(59, 130, 246, 0.38);
  border-radius: 2px;
  color: #ffffff;
  font-weight: 700;
  padding: 0 3px;
}

body.dark .terminals-search-highlight {
  background: #f59e0b;
  color: #111827;
  font-weight: 800;
  box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.35);
}

.terminals-launcher-skill-meta {
  margin-top: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.terminals-launcher-skill-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  font-size: 11px;
  opacity: 0.95;
}

body.dark .terminals-launcher-skill-tag {
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.terminals-launcher-skill-tag.is-provider {
  border-color: rgba(65, 105, 225, 0.75);
  background: rgba(65, 105, 225, 0.28);
}

.terminals-launcher-skill-tag.is-version {
  border-color: rgba(75, 85, 99, 0.7);
  background: rgba(75, 85, 99, 0.2);
}

.terminals-launcher-skill-check {
  font-size: 14px;
  opacity: 0.92;
  flex-shrink: 0;
}

.terminals-launcher-empty {
  padding: 16px 12px;
  font-size: 12px;
  opacity: 0.8;
}

.terminals-launcher-start {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--terminals-launcher-control-height);
  min-width: 92px;
  padding: 0 12px;
  border-radius: 7px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
}

.terminals-launcher-start {
  border: 1px solid rgba(65, 105, 225, 0.82);
  background: royalblue;
  color: #fff;
}

.terminals-launcher-start:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-launcher-footer {
  display: flex;
  justify-content: flex-end;
  padding: 10px 14px 12px;
