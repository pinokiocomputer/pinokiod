          sessionSearchInput.value = ""
        }
        setWorkspaceViewMode("workspaces")
        refreshChooserRows()
        void refreshSessionItems({
          query: "",
          workspaceKey: ""
        }).then((loaded) => {
          if (loaded || hasAttemptedSessionLoad) {
            refreshChooserRows()
          }
        })
      })
    })

    const createWorkspaceButton = topListIntro.querySelector("[data-list-action='create-workspace']")
    if (createWorkspaceButton) {
      createWorkspaceButton.addEventListener("click", async (event) => {
        event.preventDefault()
        if (createWorkspaceButton.disabled) {
          return
        }
        createWorkspaceButton.disabled = true
        try {
          await openCreateWorkspaceFromTopAction()
        } finally {
          if (createWorkspaceButton.isConnected) {
            createWorkspaceButton.disabled = false
          }
        }
      })
    }

    const chatButton = topListIntro.querySelector("[data-list-action='chat']")
    if (chatButton) {
      chatButton.addEventListener("click", (event) => {
        event.preventDefault()
        const chooser = getOrCreateChooserColumn()
        const activeWorkspace = getCurrentWorkspaceItem()
        if (!chooser || !activeWorkspace || !activeWorkspace.cwd) {
          return
        }
        openLauncherModal(chooser, activeWorkspace.cwd)
      })
    }

    const refreshButtons = topListIntro.querySelectorAll("[data-list-action='refresh']")
    refreshButtons.forEach((refreshButton) => {
      refreshButton.addEventListener("click", async (event) => {
        event.preventDefault()
        if (refreshButton.disabled) {
          return
        }
        refreshButton.disabled = true
        try {
          const refreshed = await refreshSessionItems({
            sync: true,
            limit: getCurrentSessionRefreshLimit(),
            query: sessionMode ? "" : getSessionSearchQuery(),
            workspaceKey: sessionMode ? workspaceViewState.key : ""
          })
          if (refreshed || hasAttemptedSessionLoad) {
            refreshChooserRows()
          }
        } finally {
          if (refreshButton.isConnected) {
            refreshButton.disabled = false
          }
        }
      })
    })
  }

  const buildRows = (column, query = "") => {
    const list = column.querySelector(".terminals-list")
    const placeholder = column.querySelector(".terminals-empty")
    const listWrap = column.querySelector(".terminals-list-wrap")
    const workspacesHeader = column.querySelector(".terminals-workspaces-header")
    const normalized = normalizeIndex(query).toLowerCase()
    if (!list) {
      return
    }
    if (workspacesHeader) {
      workspacesHeader.classList.toggle("hidden", workspaceViewState.mode !== "workspaces")
    }
    const showPlaceholder = (state, details = {}) => {
      if (!placeholder) {
        return
      }
      setPlaceholderState(placeholder, state, details)
      placeholder.classList.remove("hidden")
      if (listWrap) {
        listWrap.classList.add("hidden")
      }
    }
    const hidePlaceholder = () => {
      if (!placeholder) {
        return
      }
      placeholder.classList.add("hidden")
      if (listWrap) {
        listWrap.classList.remove("hidden")
      }
    }
    const showInlinePlaceholder = (state, details = {}) => {
      hidePlaceholder()
      const inline = document.createElement("div")
      inline.className = "terminals-empty terminals-empty-inline"
      inline.setAttribute("aria-live", "polite")
      setPlaceholderState(inline, state, details)
      list.appendChild(inline)
    }
    list.replaceChildren()
    const workspaceItems = buildWorkspaceItems()
    if (workspaceViewState.mode === "sessions" && workspaceViewState.key) {
      const exists = workspaceItems.some((workspace) => workspace && workspace.key === workspaceViewState.key)
      if (!exists) {
        setWorkspaceViewMode("workspaces")
      }
    }
    let visible = 0
    if (workspaceViewState.mode === "sessions") {
      const workspace = getCurrentWorkspaceItem()
      const workspaceSessions = workspace && Array.isArray(workspace.sessions) ? workspace.sessions : []
      for (let i = 0; i < workspaceSessions.length; i++) {
        const session = workspaceSessions[i]
        const haystack = `${session.name} ${getSessionDescription(session)} ${session.uri}`.toLowerCase()
        if (normalized && !haystack.includes(normalized)) {
          continue
        }
        const row = makeSessionRowNode(session, normalized)
        const resumeAvailable = canSessionResume(session)
        row.classList.toggle("is-disabled", !resumeAvailable)
        row.setAttribute("role", "group")
        row.setAttribute("aria-disabled", resumeAvailable ? "false" : "true")
        row.addEventListener("click", (event) => {
          event.preventDefault()
          if (!resumeAvailable) {
            return
          }
          openItemInColumn(column, session)
        })
        row.setAttribute("aria-label", resumeAvailable ? `${session.name}. Resume session.` : `${session.name}. Resume unavailable.`)
        list.appendChild(row)
        visible += 1
      }
    } else {
      for (let i = 0; i < workspaceItems.length; i++) {
        const workspace = workspaceItems[i]
        if (!workspace) {
          continue
        }
        const haystack = `${workspace.name} ${workspace.cwd} ${workspace.lastMessage}`.toLowerCase()
        if (normalized && !haystack.includes(normalized)) {
          continue
        }
        const row = makeWorkspaceRowNode(workspace, normalized)
        row.setAttribute("role", "group")
        row.addEventListener("click", (event) => {
          event.preventDefault()
          if (sessionSearchInput) {
            sessionSearchInput.value = ""
          }
          setWorkspaceViewMode("sessions", workspace.key)
          buildRows(column, "")
          void refreshSessionItems({
            query: "",
            workspaceKey: workspace.key
          }).then((loaded) => {
            if (loaded || hasAttemptedSessionLoad) {
              refreshChooserRows()
            }
          })
        })
        row.setAttribute("aria-label", `${workspace.name}. Open workspace sessions.`)
        list.appendChild(row)
        visible += 1
      }
    }
    if (visible > 0 && (sessionAppendInProgress || sessionHasMore)) {
      const loadMoreRow = document.createElement("div")
      loadMoreRow.className = "terminals-load-more-indicator"
      if (sessionAppendInProgress) {
        loadMoreRow.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin" aria-hidden="true"></i><span>Loading more sessions...</span>`
      } else {
        loadMoreRow.innerHTML = `<span>Scroll to load more sessions.</span>`
      }
      list.appendChild(loadMoreRow)
    }

    if (!hasAttemptedSessionLoad) {
      if (workspaceViewState.mode === "sessions") {
        showInlinePlaceholder("loading", {
          title: "Loading sessions",
          message: "Checking this workspace for discovered sessions.",
          hint: "You can start a new one with Start chat."
        })
      } else {
        showPlaceholder("loading", {
          title: "Loading workspaces",
          message: "Finding recent Codex, Claude, and Gemini sessions.",
          hint: "You can continue using Pinokio while this finishes."
        })
      }
      return
    }

    if (visible === 0) {
      if (lastSessionLoadFailed && sessionItems.length === 0 && !normalized && workspaceViewState.mode === "workspaces") {
        showPlaceholder("error", {
          title: "Could not load workspaces",
          message: "Session history is temporarily unavailable.",
          hint: "Click Refresh to retry."
        })
        return
      }
      if (workspaceViewState.mode === "sessions") {
        const workspace = getCurrentWorkspaceItem()
        const totalSessions = workspace && Array.isArray(workspace.sessions) ? workspace.sessions.length : 0
        if (normalized && totalSessions > 0) {
          showInlinePlaceholder("search-empty", {
            title: "No matching sessions",
            message: "No sessions matched your current search.",
            hint: "Try a provider name, session topic, or path keyword."
          })
        } else if (totalSessions === 0) {
          showInlinePlaceholder("empty", {
            title: "No sessions yet",
            message: "No sessions have been discovered for this workspace yet.",
            hint: "Click Start chat to create the first agent session."
          })
        } else {
          showInlinePlaceholder("empty", {
            title: "No sessions available",
            message: "No resumable sessions are currently available.",
            hint: ""
          })
        }
        return
      }
      if (normalized && workspaceItems.length > 0) {
        if (sessionHasMore || sessionAppendInProgress) {
          showPlaceholder("loading", {
            title: "Searching more workspaces",
            message: sessionAppendInProgress
              ? "Loading additional sessions for your search."
              : "Scroll to load more results."
          })
        } else {
          showPlaceholder("search-empty", {
            title: "No matching workspaces",
            message: "No workspaces matched your current search.",
            hint: "Try a provider name, session topic, or path keyword."
          })
        }
      } else if (workspaceItems.length === 0) {
        showPlaceholder("empty", {
          title: "No workspaces yet",
          message: "No workspaces were found.",
          hint: "Create a workspace to start chatting with an agent."
        })
      } else {
        showPlaceholder("empty", {
          title: "No workspaces available",
          message: "No workspaces are currently available.",
          hint: ""
        })
      }
    } else {
      hidePlaceholder()
    }
  }

  const refreshChooserRows = (options = {}) => {
    renderChooserTopBar()
    const query = getSessionSearchQuery()
    const shouldAutoLoad = Boolean(options && options.autoLoad)
    const chooserColumns = columns.querySelectorAll(".terminals-column[data-state='chooser']")
    chooserColumns.forEach((chooserColumn) => {
      buildRows(chooserColumn, query)
      if (shouldAutoLoad) {
        maybeLoadMoreSessionsForColumn(chooserColumn)
      }
    })
  }

  const setupChooserColumn = (column, showClose = false, refreshOptions = null) => {
    column.className = "terminals-column terminals-column-chooser"
    column.dataset.state = "chooser"
    delete column.dataset.sessionIndex
    column.innerHTML = `
      ${showClose ? `
      <header>
        <div class="flexible"></div>
        <div class="terminals-chooser-actions">
          <button class="close-column" type="button" aria-label="Close workspace list">×</button>
        </div>
      </header>` : ""}
      <div class="terminals-chooser-content">
        <div class="terminals-empty" data-state="loading" aria-live="polite"></div>
        <div class="terminals-list-wrap">
          <section class="terminals-workspaces-header" aria-label="Agent workspaces intro">
            <h2>Agent Workspaces</h2>
            <p>Work with AI agents on existing workspaces or create new ones</p>
          </section>
          <div class="terminals-list"></div>
        </div>
      </div>
    `
    const closeButton = column.querySelector(".close-column")
    const listWrap = column.querySelector(".terminals-list-wrap")

    if (closeButton) {
      closeButton.addEventListener("click", () => {
        removeColumn(column)
      })
    }
    if (listWrap) {
      listWrap.addEventListener("scroll", () => {
        maybeLoadMoreSessionsForColumn(column)
      })
    }

    const resolvedRefreshOptions = refreshOptions && typeof refreshOptions === "object" ? refreshOptions : {}
    const refreshQuery = workspaceViewState.mode === "sessions" ? "" : getSessionSearchQuery()
    const resolvedRequestOptions = {
      ...resolvedRefreshOptions,
      query: refreshQuery
    }
    buildRows(column, getSessionSearchQuery())
    refreshSessionItems(resolvedRequestOptions).then(() => {
      if (!column.isConnected || column.dataset.state !== "chooser") {
        return
      }
      buildRows(column, getSessionSearchQuery())
      maybeLoadMoreSessionsForColumn(column)
      if (launcherState.open) {
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      }
    })
    syncActiveStates()
    ensureLayout()
    return null
  }

  const setupTerminalColumn = (column, session) => {
    const sessionName = session.name || `Session ${session.index}`
    const safeName = escapeHtml(sessionName)
    const sessionUrl = session && session.url ? session.url : "#"
    const safeSessionUrl = escapeHtml(sessionUrl || "#")
    const providerKey = getProviderKey(session) || "provider"
    const headerIconSrc = getProviderIconSrc(session)
    column.className = "terminals-column"
    column.dataset.state = "terminal"
    column.dataset.sessionIndex = normalizeIndex(session.index)
    column.dataset.sessionName = sessionName
    column.dataset.sessionCwd = session && session.cwd ? session.cwd : ""
    column.dataset.sessionUri = session && session.uri ? session.uri : ""
    column.dataset.sessionUrl = sessionUrl || ""
    column.dataset.sessionProviderLabel = session && (session.providerLabel || session.provider_label) ? (session.providerLabel || session.provider_label) : providerKey
    column.dataset.sessionProviderKey = providerKey
    column.dataset.sessionProviderIcon = headerIconSrc || ""
    column.innerHTML = `<iframe src="${safeSessionUrl}" loading="eager" allow="fullscreen *;" allowfullscreen title="${safeName}" tabindex="-1"></iframe>`
    const frame = column.querySelector("iframe")
    column.addEventListener("pointerdown", () => {
      setActiveTerminalColumn(column)
    })
    if (frame) {
      frame.addEventListener("load", () => {
        setActiveTerminalColumn(column)
        requestTerminalFocus(frame)
      })
      frame.addEventListener("focus", () => {
        setActiveTerminalColumn(column)
      })
      requestTerminalFocus(frame)
    }
  }

  const ensureLayout = () => {
    if (columns.children.length === 0) {
      emptyMain.classList.remove("hidden")
      columnsWrap.classList.add("hidden")
      renderTopSessionBar()
      return
    }
    columnsWrap.classList.remove("hidden")
    emptyMain.classList.add("hidden")
    renderTopSessionBar()
  }

  const addChooserColumn = (refreshOptions = null) => {
    const column = document.createElement("section")
    const shouldShowClose = columns.children.length > 0
    columns.appendChild(column)
    const input = setupChooserColumn(column, shouldShowClose, refreshOptions)
    setColumnLayout()
    if (input) {
      requestAnimationFrame(() => {
        input.focus()
      })
    }
  }

  const closeColumn = (column) => {
    if (!column || !column.parentElement) {
      return
    }
    const index = normalizeIndex(column.dataset.sessionIndex)
    if (index) {
      setOpenState(index, "remove", column)
    }

    const terminalCount = columns.querySelectorAll(".terminals-column[data-state='terminal']").length
    const hasOtherChooser = Array.from(columns.querySelectorAll(".terminals-column[data-state='chooser']"))
      .some((candidate) => candidate && candidate !== column)
    if (terminalCount <= 1 && !hasOtherChooser) {
      setupChooserColumn(column, false)
    } else {
      column.remove()
      if (columns.children.length === 0) {
        addChooserColumn()
      }
    }

    setColumnLayout()
    ensureLayout()
    setActiveTerminalColumn(null)
    focusLatestTerminal()
  }

  const setColumnLayout = () => {
    const columnCount = Math.max(columns.children.length, 1)
    const columnsStyle = window.getComputedStyle(columns)
    const rawGap = columnsStyle.getPropertyValue("gap") || columnsStyle.getPropertyValue("column-gap") || "10px"
    const parsedGap = parseFloat(rawGap)
    const gap = Number.isNaN(parsedGap) ? 10 : parsedGap
    const measuredWidth = columns.getBoundingClientRect().width
    const parentWidth = columns.parentElement ? columns.parentElement.getBoundingClientRect().width : 0
    const wrapWidth = columnsWrap ? columnsWrap.getBoundingClientRect().width : 0
    const directWidth = columnsWrap ? columnsWrap.clientWidth : 0
    let containerWidth = Math.max(directWidth || 0, wrapWidth || 0, parentWidth || 0, measuredWidth || 0, columns.clientWidth || 0)
    if (!(containerWidth > 0)) {
      containerWidth = window.innerWidth || 0
    }
    if (!(containerWidth > 0)) {
      return
    }
    const available = Math.max(0, containerWidth - (gap * Math.max(columnCount - 1, 0)))
    const width = `${Math.max(1, available / columnCount)}px`
    Array.from(columns.children).forEach((col) => {
      col.style.flex = `0 0 ${width}`
    })
  }

  const removeColumn = (column) => {
    if (!column || !column.parentElement) {
      return
    }
    const index = normalizeIndex(column.dataset.sessionIndex)
    if (index) {
      setOpenState(index, "remove", column)
    }
    column.remove()
    if (columns.children.length === 0) {
      addChooserColumn()
    }
    setColumnLayout()
    ensureLayout()
    setActiveTerminalColumn(null)
    focusLatestTerminal()
  }

  const openItemInColumn = (column, session) => {
    if (!canSessionResume(session)) {
      return
    }
    const existingColumn = getOpenColumnByIndex(session.index)
    if (existingColumn && existingColumn !== column) {
      existingColumn.scrollIntoView({ behavior: "smooth", inline: "end" })
      setActiveTerminalColumn(existingColumn)
      const existingFrame = existingColumn.querySelector("iframe")
      requestTerminalFocus(existingFrame)
      return
    }

    const currentIndex = normalizeIndex(column.dataset.sessionIndex)
    if (currentIndex) {
      setOpenState(currentIndex, "remove", column)
    }
    setupTerminalColumn(column, session)
    setOpenState(session.index, "add", column)
    syncLocalOnlineState(session, true)
    void persistSessionOnlineState(session, true)
    setActiveTerminalColumn(column)
    syncActiveStates()
    setColumnLayout()
    ensureLayout()
    focusLatestTerminal()
    setTimeout(() => {
      const frame = column.querySelector("iframe")
      requestTerminalFocus(frame)
    }, 40)
  }

  const getOrCreateChooserColumn = () => {
    let chooser = columns.querySelector(".terminals-column[data-state='chooser']")
    if (!chooser) {
      addChooserColumn()
      chooser = columns.querySelector(".terminals-column[data-state='chooser']")
    }
    return chooser
  }

  const openLauncherFromTopAction = () => {
    const chooser = getOrCreateChooserColumn()
    const workspace = getCurrentWorkspaceItem()
    if (!chooser || !workspace || !workspace.cwd) {
      return false
    }
    openLauncherModal(chooser, workspace.cwd)
    return true
  }

  const returnToWorkspaceSessionsFromActiveSession = (workspacePath = "") => {
    const activeColumn = getActiveTerminalColumn()
    if (!isTerminalColumn(activeColumn)) {
      return false
    }
    const targetWorkspaceKey = normalizeCwdKey(workspacePath || activeColumn.dataset.sessionCwd || "")
    if (!targetWorkspaceKey) {
      return returnToWorkspaceListFromActiveSession()
    }
    const activeIndex = normalizeIndex(activeColumn.dataset.sessionIndex)
    if (activeIndex) {
      setOpenState(activeIndex, "remove", activeColumn)
    }
    setWorkspaceViewMode("sessions", targetWorkspaceKey)
    if (sessionSearchInput) {
      sessionSearchInput.value = ""
    }
    setupChooserColumn(activeColumn, false)
    setActiveTerminalColumn(null)
    syncActiveStates()
    setColumnLayout()
    ensureLayout()
    refreshChooserRows()
    void refreshSessionItems({
      query: "",
      workspaceKey: targetWorkspaceKey
    }).then((loaded) => {
      if (loaded || hasAttemptedSessionLoad) {
        refreshChooserRows()
      }
    })
    return true
  }

  const returnToWorkspaceListFromActiveSession = () => {
    const activeColumn = getActiveTerminalColumn()
    if (!isTerminalColumn(activeColumn)) {
      return false
    }
    const activeIndex = normalizeIndex(activeColumn.dataset.sessionIndex)
    if (activeIndex) {
      setOpenState(activeIndex, "remove", activeColumn)
    }
    setWorkspaceViewMode("workspaces")
    if (sessionSearchInput) {
      sessionSearchInput.value = ""
    }
    setupChooserColumn(activeColumn, false)
    setActiveTerminalColumn(null)
    syncActiveStates()
    setColumnLayout()
    ensureLayout()
    refreshChooserRows()
    return true
  }

  const suggestWorkspaceName = async () => {
    try {
      const response = await fetch("/terminals/workspaces/suggest", {
        method: "GET",
        headers: {
          "Accept": "application/json"
        }
      })
      if (!response.ok) {
        return ""
      }
      const payload = await response.json()
      return payload && payload.folder ? String(payload.folder) : ""
    } catch (error) {
      return ""
    }
  }

  const createWorkspace = async (folderName) => {
    const response = await fetch("/terminals/workspaces/create", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        folderName: typeof folderName === "string" ? folderName : ""
      })
    })
    let payload = null
    try {
      payload = await response.json()
    } catch (error) {
    }
    if (!response.ok || !payload || !payload.ok) {
      const message = payload && payload.error ? payload.error : "Failed to create workspace."
      throw new Error(message)
    }
    return payload
  }

  const addWorkspaceToLocalList = (workspace) => {
    if (!workspace || !workspace.cwd) {
      return
    }
    const key = normalizeCwdKey(workspace.cwd)
    const existing = Array.isArray(workspaceFolders) ? workspaceFolders.slice() : []
    const next = existing.filter((entry) => normalizeCwdKey(entry && entry.cwd ? entry.cwd : "") !== key)
    next.unshift({
      name: workspace.name || getWorkspaceNameFromPath(workspace.cwd),
      cwd: workspace.cwd
    })
    workspaceFolders = next
  }

  const openCreateWorkspaceModal = async () => {
    const suggested = await suggestWorkspaceName()
    let defaultName = suggested || `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`
    if (!suggested) {
      const existingNames = new Set((Array.isArray(workspaceFolders) ? workspaceFolders : [])
        .map((workspace) => String((workspace && workspace.name) || "").trim())
        .filter(Boolean))
      let attempt = 0
      while (existingNames.has(defaultName) && attempt < 32) {
        defaultName = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 8)}`
        attempt += 1
      }
    }
    if (typeof Swal === "undefined" || !Swal || typeof Swal.fire !== "function") {
      const typed = window.prompt("Create workspace name:", defaultName)
      if (typed === null) {
        return false
      }
      const folderName = String(typed || "").trim()
      if (!folderName) {
        return false
      }
      try {
        const payload = await createWorkspace(folderName)
        addWorkspaceToLocalList({
          name: payload.folder || folderName,
          cwd: payload.cwd || ""
        })
        if (sessionSearchInput) {
          sessionSearchInput.value = ""
        }
        setWorkspaceViewMode("sessions", normalizeCwdKey(payload.cwd || ""))
        refreshChooserRows()
        void refreshSessionItems({
          sync: true,
          query: "",
          workspaceKey: normalizeCwdKey(payload.cwd || "")
        }).then(() => {
          refreshChooserRows()
        })
        return true
      } catch (error) {
        window.alert(error && error.message ? error.message : "Failed to create workspace.")
        return false
      }
    }

    const result = await Swal.fire({
      title: "Create workspace",
      input: "text",
      inputLabel: "Workspace folder name",
      inputValue: defaultName,
      inputPlaceholder: "workspace-name",
      showCancelButton: true,
      confirmButtonText: "Create",
      showLoaderOnConfirm: true,
      preConfirm: async (value) => {
        const folderName = String(value || "").trim()
        if (!folderName) {
          Swal.showValidationMessage("Enter a workspace folder name.")
          return false
        }
        try {
          const payload = await createWorkspace(folderName)
          return payload
        } catch (error) {
          Swal.showValidationMessage(error && error.message ? error.message : "Failed to create workspace.")
          return false
        }
      },
      customClass: {
        popup: "terminals-confirm-modal"
      }
    })
    if (!result || !result.isConfirmed || !result.value) {
      return false
    }
    const created = result.value
    addWorkspaceToLocalList({
      name: created.folder || defaultName,
      cwd: created.cwd || ""
    })
    if (sessionSearchInput) {
      sessionSearchInput.value = ""
    }
    setWorkspaceViewMode("sessions", normalizeCwdKey(created.cwd || ""))
    refreshChooserRows()
    void refreshSessionItems({
      sync: true,
      query: "",
      workspaceKey: normalizeCwdKey(created.cwd || "")
    }).then(() => {
      refreshChooserRows()
    })
    return true
  }

  const openCreateWorkspaceFromTopAction = async () => {
    const chooser = getOrCreateChooserColumn()
    if (chooser) {
      await openCreateWorkspaceModal()
    }
  }

  if (launcherSearchForm) {
    launcherSearchForm.addEventListener("submit", (event) => {
      event.preventDefault()
    })
  }

  if (launcherSearchInput) {
    launcherSearchInput.addEventListener("input", () => {
      launcherState.query = launcherSearchInput.value || ""
      renderLauncherSkillList()
    })
  }

  if (launcherStartButton) {
    launcherStartButton.addEventListener("click", () => {
      startFromLauncher()
    })
  }

  if (launcherAddSkillsButton) {
    launcherAddSkillsButton.addEventListener("click", () => {
      ensureLauncherSkillsLoaded(false)
      setLauncherView("skills")
    })
  }

  if (launcherBackButton) {
    launcherBackButton.addEventListener("click", () => {
      setLauncherView("main")
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  if (launcherSkillsDoneButton) {
    launcherSkillsDoneButton.addEventListener("click", () => {
      setLauncherView("main")
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  if (launcherAddFilesButton) {
    launcherAddFilesButton.addEventListener("click", () => {
      if (launcherFileInput && !launcherState.busy) {
        launcherFileInput.click()
      }
    })
  }

  if (launcherFileInput) {
    launcherFileInput.addEventListener("change", () => {
      addLauncherFiles(launcherFileInput.files)
      launcherFileInput.value = ""
    })
  }

  if (launcherCloseButton) {
    launcherCloseButton.addEventListener("click", () => {
      closeLauncherModal()
    })
  }

  if (launcherModal) {
    launcherModal.addEventListener("click", (event) => {
      const target = event.target
      if (target && target.dataset && target.dataset.launcherClose === "1") {
        closeLauncherModal()
      }
    })
  }

  if (topSessionRefreshButton) {
    topSessionRefreshButton.addEventListener("click", async (event) => {
      event.preventDefault()
      if (topSessionRefreshButton.disabled) {
        return
      }
      const activeColumn = getActiveTerminalColumn()
      const workspaceKey = normalizeCwdKey(
        activeColumn && activeColumn.dataset && activeColumn.dataset.sessionCwd
          ? activeColumn.dataset.sessionCwd
          : (workspaceViewState.mode === "sessions" ? workspaceViewState.key : "")
      )
      topSessionRefreshButton.disabled = true
      try {
        const refreshed = await refreshSessionItems({
          sync: true,
          limit: getCurrentSessionRefreshLimit(),
          query: "",
          workspaceKey
        })
        if (refreshed || hasAttemptedSessionLoad) {
          refreshChooserRows()
        }
      } finally {
        if (topSessionRefreshButton.isConnected) {
          topSessionRefreshButton.disabled = false
        }
      }
    })
  }

  if (sessionSearchInput) {
    sessionSearchInput.addEventListener("input", () => {
      if (sessionSearchDebounceTimer) {
        clearTimeout(sessionSearchDebounceTimer)
      }
      const nextQuery = sessionSearchInput.value || ""
      refreshChooserRows()
      if (workspaceViewState.mode === "sessions") {
        return
      }
      sessionSearchDebounceTimer = setTimeout(() => {
        sessionSearchDebounceTimer = null
        void refreshSessionItems({ query: nextQuery }).then((loaded) => {
          if (loaded || hasAttemptedSessionLoad) {
            refreshChooserRows()
          }
        })
      }, SESSION_SEARCH_DEBOUNCE_MS)
    })
  }

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && launcherState.open) {
      event.preventDefault()
      if (launcherState.view === "skills") {
        setLauncherView("main")
        if (launcherStartButton) {
          launcherStartButton.focus()
        }
      } else {
        closeLauncherModal()
      }
      return
    }
    const key = String(event.key || "").toLowerCase()
    if (!(event.metaKey || event.ctrlKey) || key !== "k") {
      return
    }
    event.preventDefault()
    const openedChat = openLauncherFromTopAction()
    if (!openedChat) {
      void openCreateWorkspaceFromTopAction()
    }
  })

  setWorkspaceViewMode("workspaces")

  const setViewport = () => {
    closeTopSessionOverflowMenu()
    setColumnLayout()
  }

  setViewport()
  window.addEventListener("resize", setViewport)
  document.addEventListener("pinokio:header-state", setViewport)
  document.addEventListener("pinokio:header-minimized", setViewport)
  document.addEventListener("pinokio:header-restored", setViewport)
  if (window.visualViewport) {
    window.visualViewport.addEventListener("resize", setViewport)
    window.visualViewport.addEventListener("scroll", setViewport)
  }

  addChooserColumn()
  refreshChooserRows()
  if (sessionSearchInput) {
    requestAnimationFrame(() => {
      if (!searchForm || searchForm.classList.contains("has-active-session")) {
        return
      }
      sessionSearchInput.focus()
    })
  }

  if (typeof MutationObserver !== "undefined") {
    const observer = new MutationObserver(() => {
      setColumnLayout()
      setViewport()
    })
    observer.observe(columns, { childList: true, subtree: false })
  }

  setColumnLayout()
  requestAnimationFrame(setViewport)
})()
</script>
</body>
</html>
