<html>
<head>
<title>Pinokio Terminal Sessions</title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/style.css" rel="stylesheet"/>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<script src="/sweetalert2.js"></script>
<style>
:root {
  --terminals-viewport-height: 100dvh;
}

html,
body,
main,
#terminals-main {
  width: 100%;
  max-width: 100%;
}

html,
body {
  margin: 0;
  height: 100%;
}

body {
  overflow: hidden;
  display: flex !important;
  flex-direction: column !important;
  align-items: stretch;
}

main {
  display: flex;
  flex: 1 1 auto;
  min-height: 0;
  height: auto;
  max-height: none;
  overflow: hidden;
}

.terminals-page,
main > .container.terminals-page,
.container.terminals-page {
  min-height: 0;
}

.container.terminals-page,
main > .container.terminals-page {
  height: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
}

#terminals-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 0;
  padding: 0;
  height: auto;
  overflow: hidden;
  gap: 0;
  box-sizing: border-box;
}

@media only screen and (max-width: 768px) {
  body {
    flex-direction: column !important;
  }
  header.navheader {
    display: block;
    align-self: auto;
    overflow: visible;
    width: 100%;
    min-width: 0;
    max-width: none;
    height: auto;
  }
  header.navheader h1 {
    display: flex;
    flex-direction: row;
    align-items: center;
    overflow-x: auto;
    overflow-y: hidden;
    flex-wrap: nowrap;
  }
}

.container.terminals-page > form.search {
  flex: 0 0 auto;
  padding: 10px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.1);
}

body.dark .container.terminals-page > form.search {
  border-bottom-color: rgba(148, 163, 184, 0.22);
}

.terminals-workspaces-header,
.terminals-workspace-sessions-header {
  margin: 0;
  padding: 8px 12px 8px;
}

.terminals-workspaces-header h2,
.terminals-workspace-sessions-header h2 {
  margin: 0;
  font-size: 18px;
  line-height: 1.2;
  font-weight: 700;
  color: #0f172a;
}

.terminals-workspaces-header p,
.terminals-workspace-sessions-header p {
  margin: 4px 0 0;
  font-size: 12px;
  line-height: 1.35;
  color: rgba(15, 23, 42, 0.7);
  word-break: break-word;
}

.terminals-workspaces-header .terminals-workspace-header-breadcrumb,
.terminals-workspace-sessions-header .terminals-workspace-header-breadcrumb {
  order: initial;
  flex: 0 1 auto;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  min-width: 0;
  max-width: 100%;
  color: #0f172a;
  font-size: 18px;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 0;
}

.terminals-workspace-sessions-header .terminals-workspace-header-breadcrumb {
  margin-top: 0;
}

.terminals-workspace-sessions-header .terminals-workspace-header-breadcrumb .terminals-list-intro-separator {
  font-size: 12px;
}

.terminals-workspace-header-actions {
  margin-top: 4px;
  display: inline-flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  min-width: 0;
}

.terminals-workspaces-header-access {
  margin-top: 0;
  display: inline-flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  min-width: 0;
}

.terminals-workspaces-header-access .qr {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
}

.terminals-workspaces-header-access .qr > a {
  display: inline-flex !important;
  align-items: center;
  gap: 5px;
  height: var(--terminals-top-control-height, 25px);
  min-height: var(--terminals-top-control-height, 25px);
  padding: 0 10px;
  border: 1px solid rgba(127, 127, 127, 0.3);
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.8);
  text-decoration: none !important;
  color: inherit !important;
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  cursor: pointer;
  box-sizing: border-box;
}

.terminals-workspaces-header-access .qr img {
  display: none;
}

.terminals-workspaces-header-access .qr .caption {
  display: block;
  margin: 0;
  font-size: 11px;
  line-height: 1.25;
  font-weight: 700;
  width: auto !important;
  text-align: left;
  white-space: nowrap;
  word-break: normal;
}

.terminals-workspaces-header-access .peer-access-trigger-icon {
  font-size: 11px;
  line-height: 1;
}

.terminals-workspaces-header-access .qr .caption:last-child {
  display: none;
}

.terminals-workspace-header-actions .terminals-session-action {
  border: 1px solid rgba(127, 127, 127, 0.3);
  background: rgba(255, 255, 255, 0.8);
  color: inherit;
  border-radius: 4px;
  height: var(--terminals-top-control-height, 25px);
  min-height: var(--terminals-top-control-height, 25px);
  padding: 0 10px;
  font-size: 11px;
  line-height: 1;
  font-weight: 700;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  box-sizing: border-box;
}

.terminals-workspace-header-actions .terminals-session-action i {
  font-size: 11px;
  line-height: 1;
}

.terminals-workspace-header-actions .terminals-session-action:hover {
  background: rgba(65, 105, 225, 0.12);
}

.terminals-workspace-header-actions .terminals-workspace-create-btn,
.terminals-workspace-header-actions .terminals-workspace-start-chat {
  border: 1px solid royalblue;
  background: royalblue;
  color: #f8fbff;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
}

.terminals-workspace-header-actions .terminals-workspace-create-btn:hover,
.terminals-workspace-header-actions .terminals-workspace-start-chat:hover {
  border-color: #315cd8;
  background: #315cd8;
}

.terminals-workspace-header-actions .terminals-session-action:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.terminals-workspace-header-actions .terminals-workspace-git-wrap {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
}

.terminals-workspace-header-actions .terminals-workspace-git-btn {
  min-width: 148px;
  justify-content: center;
}

.terminals-workspace-header-actions .terminals-workspace-git-btn .terminals-workspace-git-label {
  white-space: nowrap;
}

.terminals-workspace-header-actions .terminals-workspace-git-btn .terminals-workspace-git-badge {
  min-width: 18px;
  height: 18px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.18);
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 700;
  line-height: 18px;
  text-align: center;
  padding: 0 5px;
}

.terminals-workspace-header-actions .terminals-workspace-git-btn .terminals-workspace-git-badge.hidden {
  display: none;
}

.terminals-workspace-header-actions .terminals-workspace-git-btn.is-init {
  border-color: rgba(37, 99, 235, 0.45);
  background: rgba(37, 99, 235, 0.1);
}

.terminals-workspace-header-actions .terminals-workspace-git-btn.is-error {
  border-color: rgba(239, 68, 68, 0.5);
}

.terminals-workspace-header-actions .terminals-workspace-git-menu {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  z-index: 14;
  min-width: 260px;
  max-width: min(70vw, 420px);
  border-radius: 0;
  border: 1px solid rgba(148, 163, 184, 0.4);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.2);
  overflow: hidden;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu.hidden {
  display: none;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-item {
  width: 100%;
  border: 0;
  border-bottom: 1px solid rgba(226, 232, 240, 0.9);
  background: transparent;
  color: inherit;
  text-align: left;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  font-size: 12px;
  line-height: 1.35;
  padding: 10px 12px;
  cursor: pointer;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-item:last-child {
  border-bottom: 0;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-item:hover {
  background: rgba(37, 99, 235, 0.1);
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-item:focus-visible {
  outline: 2px solid rgba(59, 130, 246, 0.7);
  outline-offset: -2px;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-title {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.terminals-workspace-header-actions .terminals-workspace-git-menu-meta {
  color: rgba(71, 85, 105, 0.8);
  font-size: 11px;
  font-weight: 700;
  white-space: nowrap;
}

.terminals-workspace-header-actions .terminals-workspace-git-inline-error {
  margin-top: 4px;
  max-width: min(420px, 70vw);
  color: #b91c1c;
  font-size: 11px;
  line-height: 1.25;
  text-align: left;
}

.terminals-workspace-header-actions .terminals-workspace-git-inline-error.hidden {
  display: none;
}

.terminals-workspaces-header.hidden,
.terminals-workspace-sessions-header.hidden {
  display: none;
}

body.dark .terminals-workspaces-header,
body.dark .terminals-workspace-sessions-header {
  border-bottom-color: rgba(255, 255, 255, 0.14);
}

body.dark .terminals-workspaces-header h2,
body.dark .terminals-workspace-sessions-header h2 {
  color: rgba(241, 245, 249, 0.96);
}

body.dark .terminals-workspaces-header p,
body.dark .terminals-workspace-sessions-header p {
  color: rgba(203, 213, 225, 0.86);
}

body.dark .terminals-workspaces-header .terminals-workspace-header-breadcrumb,
body.dark .terminals-workspace-sessions-header .terminals-workspace-header-breadcrumb {
  color: rgba(241, 245, 249, 0.96);
}

body.dark .terminals-workspace-header-actions .terminals-session-action {
  background: rgba(15, 23, 42, 0.55);
  border-color: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.9);
}

body.dark .terminals-workspace-header-actions .terminals-session-action:hover {
  background: rgba(65, 105, 225, 0.34);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-create-btn,
body.dark .terminals-workspace-header-actions .terminals-workspace-start-chat {
  border-color: royalblue;
  background: royalblue;
  color: rgba(248, 250, 252, 0.98);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-create-btn:hover,
body.dark .terminals-workspace-header-actions .terminals-workspace-start-chat:hover {
  border-color: #315cd8;
  background: #315cd8;
}

body.dark .terminals-workspaces-header-access .qr {
  border-color: transparent;
  background: transparent;
}

body.dark .terminals-workspaces-header-access .qr > a {
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(15, 23, 42, 0.55);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-btn .terminals-workspace-git-badge {
  background: rgba(96, 165, 250, 0.22);
  color: rgba(224, 242, 254, 0.95);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-btn.is-init {
  border-color: rgba(96, 165, 250, 0.55);
  background: rgba(30, 64, 175, 0.24);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-btn.is-error {
  border-color: rgba(248, 113, 113, 0.6);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-menu {
  border-color: rgba(51, 65, 85, 0.9);
  background: rgba(15, 23, 42, 0.98);
  box-shadow: 0 20px 44px rgba(2, 6, 23, 0.7);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-menu-item {
  border-bottom-color: rgba(51, 65, 85, 0.9);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-menu-item:hover {
  background: rgba(59, 130, 246, 0.2);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-menu-meta {
  color: rgba(148, 163, 184, 0.88);
}

body.dark .terminals-workspace-header-actions .terminals-workspace-git-inline-error {
  color: rgba(252, 165, 165, 0.95);
}

.terminals-search-form {
  --terminals-top-control-height: 25px;
  --terminals-top-control-radius: 6px;
  --terminals-top-toolbar-bg: rgba(255, 255, 255, 0.76);
  --terminals-top-toolbar-border: rgba(15, 23, 42, 0.14);
  --terminals-top-toolbar-strong: #0f172a;
  --terminals-top-toolbar-muted: rgba(15, 23, 42, 0.72);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
}

body.dark .terminals-search-form {
  --terminals-top-toolbar-bg: rgba(15, 23, 42, 0.34);
  --terminals-top-toolbar-border: rgba(148, 163, 184, 0.24);
  --terminals-top-toolbar-strong: rgba(241, 245, 249, 0.96);
  --terminals-top-toolbar-muted: rgba(203, 213, 225, 0.86);
}

.terminals-top-search-controls {
  display: block;
  flex: 1;
  min-width: 0;
}

.terminals-top-session {
  display: none;
  align-items: center;
  gap: 9px;
  flex: 1;
  min-width: 0;
  margin: 0;
  min-height: var(--terminals-top-control-height);
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: var(--terminals-top-toolbar-strong);
  box-sizing: border-box;
}

.terminals-top-session.hidden {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-search-controls {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-session {
  display: flex;
}

.terminals-top-session h4 {
  order: 1;
  margin: 0;
  font-size: 12px;
  font-weight: 650;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--terminals-top-toolbar-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.terminals-top-session-leading-actions {
  order: 0;
  flex: 0 0 auto;
}

.terminals-top-session-search-spacer {
  order: 2;
  flex: 0 0 0;
  min-width: 0;
  max-width: 0;
}

@media only screen and (max-width: 1200px) {
  .terminals-top-session-search-spacer {
    flex-basis: 0;
    max-width: 0;
  }
}

@media only screen and (max-width: 1080px) {
  .terminals-top-session-search-spacer {
    display: none;
  }
}

.terminals-top-session-path {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 0 1 auto;
}

.terminals-top-session-crumb {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-thickness: 1px;
  opacity: 1;
}

.terminals-top-session-crumb-root {
  flex: 0 0 auto;
}

.terminals-top-session-crumb-workspace {
  flex: 1 1 auto;
  min-width: 6ch;
}

.terminals-top-session-crumb-link {
  border: none;
  background: transparent;
  padding: 0;
  margin: 0;
  color: inherit;
  font: inherit;
  line-height: inherit;
  cursor: pointer;
}

.terminals-top-session-crumb-link:hover {
  color: inherit;
  opacity: 0.82;
}

.terminals-top-session-crumb-link:focus-visible {
  outline: none;
  color: inherit;
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.28);
  border-radius: 4px;
}

.terminals-top-session-separator {
  font-size: 10px;
  color: var(--terminals-top-toolbar-muted);
  opacity: 0.7;
  flex: 0 0 auto;
}

.terminals-top-session-current {
  min-width: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex: 1 1 auto;
}

.terminals-top-session-current-label {
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 650;
  text-decoration: none;
}

.terminals-search-form .home-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 0;
  padding: 0;
  height: var(--terminals-top-control-height);
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: var(--terminals-top-control-radius);
  overflow: hidden;
  background: rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

body.dark .terminals-search-form .home-mode-switch {
  border-color: rgba(255, 255, 255, 0.05);
  background: rgba(255, 255, 255, 0.06);
}

.terminals-search-form .home-mode-switch .mode-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 100%;
  padding: 0 10px;
  border-radius: 0;
  text-decoration: none;
  color: inherit;
  border: none;
  background: transparent;
  font-weight: 400;
  font-size: 12px;
  opacity: 1;
  line-height: 1;
  box-sizing: border-box;
}

.terminals-search-form .home-mode-switch .mode-link + .mode-link {
  border-left: 1px solid rgba(0, 0, 0, 0.14);
}

body.dark .terminals-search-form .home-mode-switch .mode-link + .mode-link {
  border-left-color: rgba(255, 255, 255, 0.05);
}

.terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}

body.dark .terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}

.terminals-search-form .home-mode-switch .mode-link.selected,
.terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

body.dark .terminals-search-form .home-mode-switch .mode-link.selected,
body.dark .terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

#terminals-empty-main {
  border: 1px dashed rgba(127, 127, 127, 0.4);
  border-radius: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 16px;
  box-sizing: border-box;
}

#terminals-empty-main.hidden {
  display: none;
}

.terminals-columns {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  gap: 8px;
  box-sizing: border-box;
}

.terminals-columns-rail {
  flex: 1;
  min-height: 0;
  display: flex;
  width: 100%;
  max-width: 100%;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  align-items: stretch;
  scrollbar-gutter: stable;
  padding-bottom: 0;
  box-sizing: border-box;
}

.terminals-columns.hidden {
  display: none;
}

.terminals-list-intro {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  position: relative;
  overflow: visible;
}

body.dark .terminals-list-intro {
  border: none;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.terminals-list-intro-toolbar {
  display: flex;
  align-items: center;
  gap: 9px;
  width: 100%;
  min-height: var(--terminals-top-control-height);
  min-width: 0;
  border: none;
  border-radius: 0;
  background: transparent;
  color: var(--terminals-top-toolbar-strong);
  padding: 0;
  box-sizing: border-box;
}

.terminals-list-intro-search {
  order: 2;
  flex: 1 1 auto;
  min-width: 0;
  max-width: none;
  margin-left: 0;
}

.terminals-list-intro-search input[type="search"] {
  width: 100%;
}

.terminals-list-intro-breadcrumb {
  order: 1;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
  flex: 1 1 auto;
  font-size: 12px;
  font-weight: 650;
  letter-spacing: 0.005em;
  color: inherit;
}

.terminals-list-intro-toolbar.has-actions .terminals-list-intro-breadcrumb {
  margin-left: 0;
  padding-left: 0;
  border-left: none;
}

.terminals-list-intro-crumb {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.terminals-list-intro-crumb-root {
  color: inherit;
  opacity: 1;
}

.terminals-list-intro-crumb-link {
  border: none;
  background: transparent;
  padding: 0;
  margin: 0;
  color: inherit;
  font: inherit;
  line-height: inherit;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 2px;
  text-decoration-thickness: 1px;
}

.terminals-list-intro-crumb-link:hover {
  opacity: 0.82;
}

.terminals-list-intro-crumb-link:focus-visible {
  outline: none;
  color: inherit;
