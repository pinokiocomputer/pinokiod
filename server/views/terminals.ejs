  }
  const syncLocalOnlineState = (targetSession, nextOnline) => {
    const normalizedOnline = Boolean(nextOnline)
    const targetIndex = normalizeIndex(targetSession && targetSession.index)
    const targetUri = targetSession && targetSession.uri ? String(targetSession.uri) : ""
    let changed = false
    for (let i = 0; i < sessionItems.length; i++) {
      const session = sessionItems[i]
      if (!session) {
        continue
      }
      const sessionIndex = normalizeIndex(session.index)
      const sessionUri = session.uri ? String(session.uri) : ""
      if (!((targetIndex && sessionIndex && targetIndex === sessionIndex) || (targetUri && sessionUri && targetUri === sessionUri))) {
        continue
      }
      if (parseOnlineFlag(session.online) !== normalizedOnline) {
        session.online = normalizedOnline
        changed = true
      }
    }
    if (targetSession && parseOnlineFlag(targetSession.online) !== normalizedOnline) {
      targetSession.online = normalizedOnline
      changed = true
    }
    if (changed) {
      refreshChooserRows()
    }
  }
  const persistSessionOnlineState = async (session, nextOnline) => {
    const uri = session && typeof session.uri === "string" ? session.uri.trim() : ""
    const index = session && (typeof session.index === "string" || typeof session.index === "number")
      ? String(session.index).trim()
      : ""
    if (!uri && !index) {
      return false
    }
    try {
      const response = await fetch("/terminals/sessions/state", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          uri,
          index,
          online: Boolean(nextOnline)
        })
      })
      return response.ok
    } catch (error) {
      return false
    }
  }
  const compareSessionsForChooser = (a, b) => {
    const aOnline = isSessionOnlineNow(a) ? 1 : 0
    const bOnline = isSessionOnlineNow(b) ? 1 : 0
    if (aOnline !== bOnline) {
      return bOnline - aOnline
    }
    const ta = parseTimestamp(a && a.timestamp ? a.timestamp : null) || 0
    const tb = parseTimestamp(b && b.timestamp ? b.timestamp : null) || 0
    if (ta !== tb) {
      return tb - ta
    }
    const an = (a && a.name ? String(a.name) : "").toLowerCase()
    const bn = (b && b.name ? String(b.name) : "").toLowerCase()
    return an.localeCompare(bn)
  }
  const getWorkspacePathFromSession = (session) => {
    if (!session || typeof session !== "object") {
      return ""
    }
    if (typeof session.workspacePath === "string" && session.workspacePath.trim().length > 0) {
      return session.workspacePath.trim()
    }
    if (typeof session.cwd === "string" && session.cwd.trim().length > 0) {
      return session.cwd.trim()
    }
    return ""
  }
  const getWorkspaceNameFromPath = (workspacePath) => {
    const normalizedPath = normalizeIndex(workspacePath)
    if (!normalizedPath) {
      return "workspace"
    }
    const chunks = normalizedPath.split(/[\\/]/).filter(Boolean)
    return chunks.length > 0 ? chunks[chunks.length - 1] : normalizedPath
  }
  const buildWorkspaceItems = () => {
    const byKey = new Map()
    const fallbackFolders = Array.isArray(workspaceFolders) ? workspaceFolders : []
    for (let i = 0; i < fallbackFolders.length; i++) {
      const fallback = fallbackFolders[i]
      const cwd = fallback && typeof fallback.cwd === "string" ? fallback.cwd : ""
      const key = normalizeCwdKey(cwd)
      if (!key) {
        continue
      }
      if (!byKey.has(key)) {
        byKey.set(key, {
          key,
          cwd,
          name: fallback && fallback.name ? fallback.name : getWorkspaceNameFromPath(cwd),
          sessions: [],
          online: false,
          updatedAt: parseTimestamp(fallback && Object.prototype.hasOwnProperty.call(fallback, "updatedAt") ? fallback.updatedAt : (fallback && fallback.updated_at ? fallback.updated_at : null)),
          timestamp: null,
          lastMessage: ""
        })
      }
    }
    for (let i = 0; i < sessionItems.length; i++) {
      const session = sessionItems[i]
      const workspacePath = getWorkspacePathFromSession(session)
      const key = normalizeCwdKey(workspacePath)
      if (!key) {
        continue
      }
      if (!byKey.has(key)) {
        byKey.set(key, {
          key,
          cwd: workspacePath,
          name: session && session.workspaceName ? session.workspaceName : getWorkspaceNameFromPath(workspacePath),
          sessions: [],
          online: false,
          updatedAt: parseTimestamp(session && session.timestamp ? session.timestamp : null),
          timestamp: null,
          lastMessage: ""
        })
      }
      const entry = byKey.get(key)
      entry.sessions.push(session)
      const ts = parseTimestamp(session && session.timestamp ? session.timestamp : null) || 0
      if (!parseTimestamp(entry && entry.updatedAt ? entry.updatedAt : null) && ts > 0) {
        entry.updatedAt = ts
      }
      const currentTs = parseTimestamp(entry.timestamp) || 0
      if (ts >= currentTs) {
        entry.timestamp = session.timestamp || null
        entry.lastMessage = session && session.summary ? session.summary : (session && session.name ? session.name : "")
      }
      if (isSessionOnlineNow(session)) {
        entry.online = true
      }
    }
    const items = Array.from(byKey.values())
    items.forEach((workspace) => {
      workspace.sessions.sort(compareSessionsForChooser)
    })
    items.sort((a, b) => {
      const aUpdatedAt = parseTimestamp(a && a.updatedAt ? a.updatedAt : null) || 0
      const bUpdatedAt = parseTimestamp(b && b.updatedAt ? b.updatedAt : null) || 0
      if (aUpdatedAt !== bUpdatedAt) {
        return bUpdatedAt - aUpdatedAt
      }
      return String(a && a.name ? a.name : "").localeCompare(String(b && b.name ? b.name : ""))
    })
    return items
  }
  const getCurrentWorkspaceItem = () => {
    if (workspaceViewState.mode !== "sessions" || !workspaceViewState.key) {
      return null
    }
    const workspaces = buildWorkspaceItems()
    for (let i = 0; i < workspaces.length; i++) {
      const workspace = workspaces[i]
      if (workspace && workspace.key === workspaceViewState.key) {
        return workspace
      }
    }
    return null
  }
  const setWorkspaceViewMode = (mode, workspaceKey = "") => {
    const normalizedMode = mode === "sessions" ? "sessions" : "workspaces"
    workspaceViewState.mode = normalizedMode
    workspaceViewState.key = normalizedMode === "sessions" ? normalizeCwdKey(workspaceKey) : ""
    if (sessionSearchInput) {
