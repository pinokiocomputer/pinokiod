  transform: none;
}

.terminals-list-intro-action[data-label]::after {
  content: attr(data-label);
  position: absolute;
  top: calc(100% + 7px);
  left: 50%;
  transform: translate(-50%, -2px);
  opacity: 0;
  pointer-events: none;
  padding: 4px 7px;
  border-radius: 6px;
  background: rgba(15, 23, 42, 0.93);
  color: #f8fafc;
  font-size: 10px;
  line-height: 1;
