  border: none;
  background: transparent;
  color: var(--terminals-top-toolbar-muted);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  cursor: pointer;
  transition: background-color 130ms ease, color 130ms ease, transform 130ms ease;
}

