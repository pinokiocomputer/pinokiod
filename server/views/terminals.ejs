<html>
<head>
<title>Pinokio Terminal Sessions</title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/style.css" rel="stylesheet"/>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<script src="/sweetalert2.js"></script>
<style>
:root {
  --terminals-viewport-height: 100dvh;
}

html,
body,
main,
#terminals-main {
  width: 100%;
  max-width: 100%;
}

html,
body {
  margin: 0;
  height: 100%;
}

body {
  overflow: hidden;
}

main {
  display: flex;
  min-height: 0;
  height: var(--terminals-viewport-height);
  max-height: var(--terminals-viewport-height);
  overflow: hidden;
}

.terminals-page,
main > .container.terminals-page,
.container.terminals-page {
  min-height: 0;
}

.container.terminals-page,
main > .container.terminals-page {
  height: 100%;
  max-height: 100%;
  display: flex;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
}

#terminals-main {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 0;
  padding: 8px;
  height: auto;
  overflow: hidden;
  gap: 0;
  box-sizing: border-box;
}

.container.terminals-page > form.search {
  flex: 0 0 auto;
  padding: 10px 10px 0;
}

.terminals-search-form {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
}

.terminals-top-search-controls {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.terminals-top-session {
  display: none;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 0;
}

.terminals-top-session.hidden {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-search-controls {
  display: none;
}

.terminals-search-form.has-active-session .terminals-top-session {
  display: flex;
}

.terminals-top-session h4 {
  margin: 0;
  font-size: 13px;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.terminals-search-form .home-mode-switch {
  display: inline-flex;
  align-items: center;
  gap: 0;
  padding: 0;
  height: 25px;
  border: 1px solid rgba(0, 0, 0, 0.14);
  border-radius: 6px;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.02);
  box-sizing: border-box;
}

body.dark .terminals-search-form .home-mode-switch {
  border-color: rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.02);
}

.terminals-search-form .home-mode-switch .mode-link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 100%;
  padding: 0 10px;
  border-radius: 0;
  text-decoration: none;
  color: inherit;
  border: none;
  border-right: 1px solid rgba(0, 0, 0, 0.14);
  background: transparent;
  font-weight: 400;
  font-size: 12px;
  opacity: 1;
  line-height: 1;
  box-sizing: border-box;
}

.terminals-search-form .home-mode-switch .mode-link:last-child {
  border-right: none;
}

body.dark .terminals-search-form .home-mode-switch .mode-link {
  border-right-color: rgba(255, 255, 255, 0.22);
}

body.dark .terminals-search-form .home-mode-switch .mode-link:last-child {
  border-right: none;
}

.terminals-search-form .home-mode-switch .mode-link:hover {
  background: rgba(65, 105, 225, 0.12);
}

.terminals-search-form .home-mode-switch .mode-link.selected,
.terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

body.dark .terminals-search-form .home-mode-switch .mode-link.selected,
body.dark .terminals-search-form .home-mode-switch .mode-link[aria-current="page"] {
  background: royalblue !important;
  color: #fff !important;
}

#terminals-empty-main {
  border: 1px dashed rgba(127, 127, 127, 0.4);
  border-radius: 10px;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 16px;
  box-sizing: border-box;
}

#terminals-empty-main.hidden,
#terminals-session-bank.hidden {
  display: none;
}

.terminals-columns {
  flex: 1;
  min-height: 0;
  display: flex;
  width: 100%;
  max-width: 100%;
  gap: 10px;
  overflow-x: auto;
  overflow-y: hidden;
  align-items: stretch;
  scrollbar-gutter: stable;
  padding-bottom: 0;
  box-sizing: border-box;
}

.terminals-columns.hidden {
  display: none;
}

.terminals-column {
  flex: 0 0 100%;
  border: 1px solid rgba(127, 127, 127, 0.2);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.02);
  height: 100%;
  min-height: 0;
  min-width: 0;
}
.terminals-column.terminals-column-chooser {
  border: none;
}

.terminals-column header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-bottom: 1px solid rgba(127, 127, 127, 0.2);
  min-height: 35px;
}

.terminals-column h4 {
  margin: 0;
  font-size: 13px;
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.terminals-column.terminals-column-chooser h4 {
  flex: 0 0 auto;
}

.terminals-chooser-content {
  display: flex;
  flex-direction: column;
  min-height: 0;
  flex: 1;
}

.terminals-launcher-modal {
  position: fixed;
  inset: 0;
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.terminals-launcher-modal.hidden {
  display: none;
}

.terminals-launcher-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(15, 23, 42, 0.34);
  backdrop-filter: blur(2px);
}

body.dark .terminals-launcher-backdrop {
  background: rgba(8, 10, 16, 0.55);
}

.terminals-launcher-panel {
  position: relative;
  width: min(760px, calc(100vw - 24px));
  max-height: min(78vh, 700px);
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(15, 23, 42, 0.15);
  border-radius: 10px;
  overflow: hidden;
  background: #f8fafc;
  color: #0f172a;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
  --terminals-launcher-control-height: 34px;
}

body.dark .terminals-launcher-panel {
  border: 1px solid rgba(127, 127, 127, 0.28);
  background: #111319;
  color: #f3f4f6;
  box-shadow: 0 18px 70px rgba(0, 0, 0, 0.52);
}

.terminals-launcher-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(15, 23, 42, 0.12);
}

body.dark .terminals-launcher-header {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.terminals-launcher-header h3 {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
}

.terminals-launcher-close {
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(15, 23, 42, 0.24);
  border-radius: 7px;
  color: inherit;
  cursor: pointer;
  width: 30px;
  height: 28px;
  font-size: 18px;
  line-height: 1;
}

body.dark .terminals-launcher-close {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.terminals-launcher-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 10px 14px 12px;
  min-height: 0;
}

.terminals-launcher-view {
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 0;
}

.terminals-launcher-view.hidden {
  display: none;
}

.terminals-launcher-main-grid {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.terminals-launcher-main-row {
  display: grid;
  grid-template-columns: 80px minmax(0, 1fr);
  align-items: start;
  gap: 10px;
}

.terminals-launcher-main-label {
  font-size: 12px;
  font-weight: 600;
  opacity: 0.84;
  line-height: 1.15;
}

.terminals-launcher-main-label-title {
  font-size: 12px;
  font-weight: 700;
}

.terminals-launcher-main-label-subtitle {
  margin-top: 2px;
  font-size: 11px;
  opacity: 0.68;
}

.terminals-launcher-main-value {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  min-width: 0;
}

.terminals-launcher-row-meta {
  font-size: 12px;
  opacity: 0.78;
}

.terminals-launcher-main-value .terminals-launcher-selected,
.terminals-launcher-main-value .terminals-launcher-upload-list {
  width: 100%;
  margin-top: 2px;
}

.terminals-launcher-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: var(--terminals-launcher-control-height);
  padding: 0 11px;
  border-radius: 7px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
}

body.dark .terminals-launcher-secondary {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: transparent;
}

.terminals-launcher-secondary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-launcher-secondary.is-primary {
  border-color: royalblue;
  background: royalblue;
  color: #fff;
}

.terminals-launcher-skills-header {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 8px;
}

.terminals-launcher-skills-title {
  font-size: 13px;
  font-weight: 700;
  text-align: center;
}

.terminals-launcher-search {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  background: #ffffff;
  color: inherit;
  outline: none;
  font-size: 14px;
}

body.dark .terminals-launcher-search {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.08);
}

.terminals-launcher-search:focus {
  border-color: rgba(65, 105, 225, 0.75);
  box-shadow: 0 0 0 2px rgba(65, 105, 225, 0.25);
}

.terminals-launcher-provider-options {
  display: flex;
  gap: 6px;
  flex-wrap: nowrap;
}

.terminals-launcher-provider {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  justify-content: flex-start;
  height: var(--terminals-launcher-control-height);
  padding: 0 11px;
  border-radius: 7px;
  border: 1px solid rgba(15, 23, 42, 0.16);
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease, transform 0.12s ease;
}

body.dark .terminals-launcher-provider {
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: transparent;
}

.terminals-launcher-provider img {
  width: 16px;
  height: 16px;
  object-fit: contain;
  border-radius: 3px;
}

.terminals-launcher-radio {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  border: 1px solid currentColor;
  opacity: 0.75;
  position: relative;
  box-sizing: border-box;
  flex: 0 0 auto;
}

.terminals-launcher-provider.active .terminals-launcher-radio::after {
  content: "";
  position: absolute;
  inset: 2px;
  border-radius: 999px;
  background: currentColor;
}

.terminals-launcher-provider.active {
  border-color: rgba(65, 105, 225, 0.72);
  background: rgba(65, 105, 225, 0.12);
  color: inherit;
}

.terminals-launcher-provider:not(.active):hover {
  border-color: rgba(65, 105, 225, 0.7);
  background: rgba(65, 105, 225, 0.06);
}

body.dark .terminals-launcher-provider.active {
  border-color: rgba(95, 130, 235, 0.75);
  background: rgba(95, 130, 235, 0.14);
}

.terminals-launcher-files-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  height: var(--terminals-launcher-control-height);
  padding: 0 12px;
  border-radius: 8px;
  border: 1px solid rgba(15, 23, 42, 0.22);
  background: rgba(15, 23, 42, 0.05);
  color: inherit;
  cursor: pointer;
  font-size: 12px;
  font-weight: 700;
}

body.dark .terminals-launcher-files-toggle {
  border: 1px solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.08);
}

.terminals-launcher-files-toggle.active {
  border-color: royalblue;
  color: royalblue;
}

.terminals-launcher-file-input {
  display: none;
}

.terminals-launcher-skill-section {
  display: flex;
  flex-direction: column;
  min-height: 0;
  gap: 8px;
}

.terminals-launcher-selected {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.terminals-launcher-selected.hidden {
  display: none;
}

.terminals-launcher-upload {
  border: 1px dashed rgba(15, 23, 42, 0.28);
  border-radius: 8px;
  padding: 8px;
  margin-top: 8px;
  background: rgba(15, 23, 42, 0.02);
}

body.dark .terminals-launcher-upload {
  border: 1px dashed rgba(255, 255, 255, 0.26);
  background: rgba(255, 255, 255, 0.03);
}

.terminals-launcher-upload.hidden {
  display: none;
}

.terminals-launcher-upload-dropzone {
  width: 100%;
  border: 1px dashed rgba(65, 105, 225, 0.55);
  background: rgba(65, 105, 225, 0.08);
  color: inherit;
  border-radius: 7px;
  padding: 10px;
  text-align: left;
  cursor: pointer;
  font-size: 12px;
}

body.dark .terminals-launcher-upload-dropzone {
  background: rgba(65, 105, 225, 0.18);
}

.terminals-launcher-upload-dropzone.dragover {
  border-color: royalblue;
  background: rgba(65, 105, 225, 0.18);
}

.terminals-launcher-upload-list {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.terminals-launcher-upload-list.hidden {
  display: none;
}

.terminals-launcher-upload-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  font-size: 12px;
}

.terminals-launcher-upload-item button {
  border: 0;
  background: transparent;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
}

.terminals-launcher-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border: 1px solid rgba(65, 105, 225, 0.65);
  border-radius: 999px;
  background: rgba(65, 105, 225, 0.2);
  font-size: 12px;
  padding: 4px 9px;
}

.terminals-launcher-chip button {
  background: transparent;
  border: 0;
  color: inherit;
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
  padding: 0;
}

.terminals-launcher-skill-list {
  border: 1px solid rgba(15, 23, 42, 0.14);
  border-radius: 10px;
  max-height: min(46vh, 430px);
  overflow: auto;
}

body.dark .terminals-launcher-skill-list {
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.terminals-launcher-skill-row {
  width: 100%;
  text-align: left;
  border: 0;
  border-bottom: 1px solid rgba(15, 23, 42, 0.1);
  background: transparent;
  color: inherit;
  cursor: pointer;
  padding: 10px 12px;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.terminals-launcher-skill-row:last-child {
  border-bottom: 0;
}

.terminals-launcher-skill-row:hover {
  background: rgba(15, 23, 42, 0.05);
}

body.dark .terminals-launcher-skill-row {
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

body.dark .terminals-launcher-skill-row:hover {
  background: rgba(255, 255, 255, 0.06);
}

.terminals-launcher-skill-row.selected {
  background: rgba(65, 105, 225, 0.25);
}

.terminals-launcher-skill-text {
  min-width: 0;
}

.terminals-launcher-skill-name {
  font-size: 13px;
  font-weight: 700;
}

.terminals-launcher-skill-desc {
  margin-top: 2px;
  font-size: 12px;
  opacity: 0.78;
}

.terminals-search-highlight {
  background: rgba(59, 130, 246, 0.38);
  border-radius: 2px;
  color: #ffffff;
  font-weight: 700;
  padding: 0 3px;
}

body.dark .terminals-search-highlight {
  background: #f59e0b;
  color: #111827;
  font-weight: 800;
  box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.35);
}

.terminals-launcher-skill-meta {
  margin-top: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.terminals-launcher-skill-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 999px;
  border: 1px solid rgba(15, 23, 42, 0.2);
  font-size: 11px;
  opacity: 0.95;
}

body.dark .terminals-launcher-skill-tag {
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.terminals-launcher-skill-tag.is-provider {
  border-color: rgba(65, 105, 225, 0.75);
  background: rgba(65, 105, 225, 0.28);
}

.terminals-launcher-skill-tag.is-version {
  border-color: rgba(75, 85, 99, 0.7);
  background: rgba(75, 85, 99, 0.2);
}

.terminals-launcher-skill-check {
  font-size: 14px;
  opacity: 0.92;
  flex-shrink: 0;
}

.terminals-launcher-empty {
  padding: 16px 12px;
  font-size: 12px;
  opacity: 0.8;
}

.terminals-launcher-start {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--terminals-launcher-control-height);
  min-width: 92px;
  padding: 0 12px;
  border-radius: 7px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
}

.terminals-launcher-start {
  border: 1px solid rgba(65, 105, 225, 0.82);
  background: royalblue;
  color: #fff;
}

.terminals-launcher-start:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-launcher-footer {
  display: flex;
  justify-content: flex-end;
  padding: 10px 14px 12px;
  border-top: 1px solid rgba(15, 23, 42, 0.1);
}

body.dark .terminals-launcher-footer {
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}
.terminals-create-toggle {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  height: 25px;
  padding: 0 10px;
  border-radius: 5px;
  border: 1px solid royalblue;
  background: royalblue;
  color: white;
  cursor: pointer;
  font-weight: 400;
  font-size: 12px;
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
}

#terminals-session-search {
  height: 25px;
  min-height: 25px;
  box-sizing: border-box;
  padding: 0 10px;
  border-radius: 5px;
  font-size: 12px;
  font-weight: 400;
  line-height: 1;
}
.terminals-create-toggle:hover {
  background: #305ed4;
}
.terminals-create-toggle.active {
  background: #274eb0;
}
.terminals-create-toggle:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-column .terminals-provider-option:disabled,
.terminals-column .terminals-starter-cancel:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.terminals-column .terminals-provider-option.provider-active,
body.dark .terminals-column .terminals-provider-option.provider-active {
  border-color: rgba(65, 105, 225, 0.8);
  background: rgba(65, 105, 225, 0.18);
}

@media (max-width: 760px) {
  .terminals-launcher-panel {
    width: calc(100vw - 18px);
    max-height: calc(100vh - 16px);
  }
  .terminals-search-form {
    flex-wrap: wrap;
    gap: 8px;
  }
  .terminals-launcher-main-row {
    grid-template-columns: 1fr;
    gap: 4px;
  }
  .terminals-launcher-main-label {
    line-height: 1.2;
  }
  .terminals-launcher-provider-options {
    flex-wrap: wrap;
  }
}

.terminals-column .terminals-search {
  display: block;
  flex: 0 0 auto;
  margin: 10px;
  padding: 0;
}
.terminals-column .terminals-search.terminals-search-header {
  margin: 0;
  flex: 1;
  min-width: 180px;
}

.terminals-column .terminals-search input[type="search"] {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 10px 12px;
  border-radius: 8px;
  border: 1px solid rgba(127, 127, 127, 0.28);
  background: rgba(0, 0, 0, 0.05);
  color: inherit;
  font-size: 14px;
  line-height: 1.35;
  outline: none;
}
.terminals-column .terminals-search.terminals-search-header input[type="search"] {
  padding: 8px 10px;
  font-size: 13px;
}

.terminals-column .terminals-search input[type="search"]::placeholder {
  opacity: 0.65;
}

.terminals-column .terminals-search input[type="search"]:focus {
  border-color: rgba(79, 70, 229, 0.65);
  box-shadow: 0 0 0 2px rgba(79, 70, 229, 0.16);
}

body.dark .terminals-column .terminals-search input[type="search"] {
  border-color: rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.09);
  color: #fff;
}

.terminals-column .terminals-list-wrap {
  flex: 1;
  overflow: auto;
  min-height: 0;
}

.terminals-column .terminals-empty {
  margin-top: 8px;
}

.terminals-list {
  margin: 0;
  padding: 0;
}

.terminals-list .line {
  margin: 0;
  display: block;
  padding: 10px 12px;
  border: 0;
  border-bottom: 1px solid rgba(127, 127, 127, 0.22);
  border-radius: 0;
  background: transparent;
  text-decoration: none;
  cursor: pointer;
  color: inherit;
}

.terminals-list .line:last-child {
  border-bottom: 0;
}

.terminals-list .line:hover {
  background: rgba(79, 70, 229, 0.06);
}

.terminals-list .line.active {
  background: rgba(79, 70, 229, 0.1);
  box-shadow: inset 2px 0 0 #4f46e5;
}

body.dark .terminals-list .line {
  border-bottom-color: rgba(255, 255, 255, 0.14);
}

body.dark .terminals-list .line:hover {
  background: rgba(129, 140, 248, 0.14);
}

body.dark .terminals-list .line.active {
  background: rgba(129, 140, 248, 0.22);
  box-shadow: inset 2px 0 0 #818cf8;
}

.terminals-list .line h3 {
  margin: 0;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.25;
  display: flex;
  align-items: center;
  gap: 8px;
}

.terminals-list .line h3 > span:first-of-type {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.terminals-list .line .terminals-session-status {
  margin-left: auto;
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  border-radius: 999px;
  padding: 2px 7px;
  border: 1px solid rgba(127, 127, 127, 0.35);
  color: rgba(0, 0, 0, 0.62);
  background: rgba(127, 127, 127, 0.12);
  white-space: nowrap;
  flex-shrink: 0;
}
.terminals-list .line .terminals-session-status::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: currentColor;
  opacity: 0.85;
}
.terminals-list .line .terminals-session-status.is-online {
  color: #0d8f4d;
  border-color: rgba(13, 143, 77, 0.35);
  background: rgba(13, 143, 77, 0.14);
}
.terminals-list .line .terminals-session-status.is-offline {
  color: rgba(0, 0, 0, 0.56);
  border-color: rgba(127, 127, 127, 0.32);
  background: rgba(127, 127, 127, 0.1);
}
body.dark .terminals-list .line .terminals-session-status {
  color: rgba(255, 255, 255, 0.72);
  border-color: rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.08);
}
body.dark .terminals-list .line .terminals-session-status.is-online {
  color: #65d695;
  border-color: rgba(101, 214, 149, 0.4);
  background: rgba(24, 137, 75, 0.28);
}
body.dark .terminals-list .line .terminals-session-status.is-offline {
  color: rgba(255, 255, 255, 0.66);
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.06);
}

.terminals-list .line .terminals-provider-icon {
  width: 26px !important;
  height: 26px !important;
  min-width: 26px;
  min-height: 26px;
  padding: 0 !important;
  border-radius: 4px !important;
  object-fit: contain;
  flex-shrink: 0;
}

.terminals-column header .terminals-provider-icon {
  width: 24px !important;
  height: 24px !important;
  min-width: 24px;
  min-height: 24px;
  padding: 0 !important;
  border-radius: 4px !important;
  object-fit: contain;
  flex-shrink: 0;
}

.terminals-top-session .terminals-provider-icon {
  width: 22px !important;
  height: 22px !important;
  min-width: 22px;
  min-height: 22px;
  padding: 0 !important;
  border-radius: 4px !important;
  object-fit: contain;
  flex-shrink: 0;
}

.terminals-list .description {
  margin-top: 4px;
  font-size: 11px;
  line-height: 1.25;
  opacity: 0.82;
}

.terminals-list .line.has-provider-icon .description {
  padding-left: 34px;
}

.terminals-column .close-column,
.terminals-top-session .close-column {
  background: transparent;
  border: 1px solid rgba(127, 127, 127, 0.25);
  color: inherit;
  border-radius: 6px;
  padding: 2px 8px;
  cursor: pointer;
}

.terminals-column .terminals-open-folder,
.terminals-top-session .terminals-open-folder {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  border: 1px solid rgba(127, 127, 127, 0.25);
  color: inherit;
  border-radius: 6px;
  padding: 4px 8px;
  cursor: pointer;
  font-size: 12px;
  white-space: nowrap;
}

.terminals-column .terminals-open-folder:disabled,
.terminals-top-session .terminals-open-folder:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.terminals-column .terminals-chooser-actions,
.terminals-top-session .terminals-chooser-actions {
  display: flex;
  gap: 6px;
}

.terminals-column iframe {
  width: 100%;
  flex: 1;
  min-height: 0;
  height: 100%;
  border: 0;
  background: white;
}

@media (max-width: 980px) {
  .terminals-column {
    min-width: 0;
  }
}

.terminals-column-empty-state {
  padding: 0 10px;
}

.terminals-column-chooser .line:hover {
  background: rgba(255, 255, 255, 0.04);
}

.swal2-popup.terminals-confirm-modal {
  border-radius: 10px;
  padding: 18px 18px 14px 18px;
  background: #fdfdfd;
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.12);
  text-align: left;
}

body.dark .swal2-popup.terminals-confirm-modal {
  background: #1f1f25;
  box-shadow: 0 10px 36px rgba(0, 0, 0, 0.45);
}

.swal2-popup.terminals-confirm-modal .swal2-title {
  text-align: left !important;
  font-size: 16px;
  font-weight: 700;
  color: #111;
  margin: 0 0 6px 0;
}

body.dark .swal2-popup.terminals-confirm-modal .swal2-title {
  color: #f5f5f5;
}

.swal2-popup.terminals-confirm-modal .swal2-html-container {
  font-size: 14px;
  color: #333;
  margin: 0 0 10px 0;
  text-align: left;
}

body.dark .swal2-popup.terminals-confirm-modal .swal2-html-container {
  color: rgba(255, 255, 255, 0.8);
}

.swal2-popup.terminals-confirm-modal .swal2-actions {
  margin-top: 4px;
  gap: 8px;
  justify-content: flex-end !important;
}

.swal2-popup.terminals-confirm-modal .swal2-styled.swal2-confirm {
  background: #4a4ae0;
  color: #fff;
  border-radius: 6px;
  padding: 8px 16px;
  font-weight: 600;
  border: none;
}

.swal2-popup.terminals-confirm-modal .swal2-styled.swal2-cancel {
  background: transparent;
  color: #555;
  border: 1px solid rgba(0, 0, 0, 0.15);
  border-radius: 6px;
  padding: 8px 16px;
}

body.dark .swal2-popup.terminals-confirm-modal .swal2-styled.swal2-cancel {
  color: rgba(255, 255, 255, 0.8);
  border-color: rgba(255, 255, 255, 0.2);
}
</style>
</head>
<body class="<%= theme %>" data-agent="<%= agent %>">
<header class="navheader grabbable">
<h1>
<a class="home" href="/home"><img class="icon" src="/pinokio-black.png"></a>
<button class="btn2" id="minimize-header" data-tippy-content="fullscreen" title="fullscreen">
  <div><i class="fa-solid fa-expand"></i></div>
</button>
<button class="btn2" id="back" data-tippy-content="back"><div><i class="fa-solid fa-chevron-left"></i></div></button>
<button class="btn2" id="forward" data-tippy-content="forward"><div><i class="fa-solid fa-chevron-right"></i></div></button>
<button class="btn2" id="refresh-page" data-tippy-content="refresh"><div><i class="fa-solid fa-rotate-right"></i></div></button>
<button class="btn2" id="screenshot" data-tippy-content="screen capture"><i class="fa-solid fa-camera"></i></button>
<button class="btn2" id="inspector" data-tippy-content="X-ray mode"><i class="fa-solid fa-eye"></i></button>
<div class="flexible"></div>
<a class="btn2" href="/columns" data-tippy-content="split into 2 columns">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class="btn2" href="/rows" data-tippy-content="split into 2 rows">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class="btn2" id="new-window" data-tippy-content="open a new window" title="open a new window" data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class="btn2 hidden" id="close-window" data-tippy-content="close this section">
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<main>
  <div class='container terminals-page'>
    <form class='search terminals-search-form'>
      <div class="home-mode-switch" role="tablist" aria-label="Home modes">
        <a class="mode-link" href="/home">
          <i class="fa-solid fa-box"></i>
          <span>Apps</span>
        </a>
        <a class="mode-link selected" href="/home?mode=terminals" aria-current="page">
          <i class="fa-solid fa-robot"></i>
          <span>Agents</span>
        </a>
      </div>
      <div class="terminals-top-search-controls" id="terminals-top-search-controls">
        <input id="terminals-session-search" type='search' class="flexible" placeholder='Search sessions'>
        <button class="terminals-create-toggle" id="terminals-create-session-button" type="button" aria-label="Chat" aria-expanded="false">
          <i class="fa-solid fa-plus"></i><span>Chat</span>
        </button>
      </div>
      <div class="terminals-top-session hidden" id="terminals-top-session" aria-live="polite">
        <h4 id="terminals-top-session-title" title=""></h4>
        <div class="terminals-chooser-actions">
          <button class="terminals-open-folder" id="terminals-top-open-folder" type="button" aria-label="Open in File Explorer" disabled><i class="fa-solid fa-folder-open"></i><span>Open in File Explorer</span></button>
          <button class="close-column" id="terminals-top-close-session" type="button" aria-label="Close selected session">×</button>
        </div>
      </div>
    </form>
    <section id='terminals-main'>
      <div id='terminals-empty-main'>
        <div>
          <h2>Terminal sessions.</h2>
          <br>
          <div>No resumable Codex, Claude, or Gemini sessions were found.</div>
          <span>Run one from your terminal and come back here to continue.</span>
        </div>
      </div>
      <div id='terminals-columns' class='terminals-columns hidden'></div>
    </section>
  </div>

  <div id='terminals-session-bank' class='hidden'>
    <div class='terminals-list'>
      <% (items || []).forEach((item, index) => { %>
        <a href="#" role="button" data-description="<%=item.description%>" data-provider-label="<%=item.provider_label || ''%>" data-cwd="<%=item.cwd || ''%>" data-timestamp="<%=item.timestamp || ''%>" data-index="<%=index%>" data-name="<%=item.name%>" data-uri="<%=item.uri%>" data-url="<%=item.browser_url%>" data-online="<%=item.online ? '1' : '0'%>" class='line'>
          <h3><%=item.name%></h3>
          <div class='description'><%=item.description%></div>
        </a>
      <% }) %>
    </div>
  </div>

  <div id="terminals-launcher-modal" class="terminals-launcher-modal hidden" aria-hidden="true">
    <div class="terminals-launcher-backdrop" data-launcher-close="1"></div>
    <section class="terminals-launcher-panel" role="dialog" aria-modal="true" aria-labelledby="terminals-launcher-title">
      <header class="terminals-launcher-header">
        <h3 id="terminals-launcher-title">Start an agent</h3>
        <button class="terminals-launcher-close" type="button" aria-label="Close launcher">×</button>
      </header>
      <div class="terminals-launcher-body">
        <div class="terminals-launcher-view terminals-launcher-view-main" data-view="main">
          <div class="terminals-launcher-main-grid">
            <div class="terminals-launcher-main-row">
              <div class="terminals-launcher-main-label">
                <div class="terminals-launcher-main-label-title">Agent</div>
              </div>
              <div class="terminals-launcher-main-value">
                <div class="terminals-launcher-provider-options" role="group" aria-label="CLI providers"></div>
              </div>
            </div>
            <div class="terminals-launcher-main-row">
              <div class="terminals-launcher-main-label">
                <div class="terminals-launcher-main-label-title">Skills</div>
                <div class="terminals-launcher-main-label-subtitle">Optional</div>
              </div>
              <div class="terminals-launcher-main-value">
                <button class="terminals-launcher-secondary terminals-launcher-add-skills" type="button"><i class="fa-solid fa-wand-magic-sparkles"></i><span>Add skills</span></button>
                <span class="terminals-launcher-row-meta terminals-launcher-summary-skills">Skills: 0</span>
                <div class="terminals-launcher-selected hidden"></div>
              </div>
            </div>
            <div class="terminals-launcher-main-row">
              <div class="terminals-launcher-main-label">
                <div class="terminals-launcher-main-label-title">Files</div>
                <div class="terminals-launcher-main-label-subtitle">Optional</div>
              </div>
              <div class="terminals-launcher-main-value">
                <button class="terminals-launcher-secondary terminals-launcher-add-files" type="button"><i class="fa-solid fa-paperclip"></i><span>Add files</span></button>
                <input class="terminals-launcher-file-input" type="file" multiple>
                <span class="terminals-launcher-row-meta terminals-launcher-summary-files">Files: 0</span>
                <div class="terminals-launcher-upload-list hidden"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="terminals-launcher-view terminals-launcher-view-skills hidden" data-view="skills">
          <div class="terminals-launcher-skills-header">
            <button class="terminals-launcher-secondary terminals-launcher-back" type="button"><i class="fa-solid fa-chevron-left"></i><span>Back</span></button>
            <div class="terminals-launcher-skills-title">Add skills</div>
            <button class="terminals-launcher-secondary terminals-launcher-skills-done" type="button">Done</button>
          </div>
          <form class="terminals-launcher-search-form">
            <input class="terminals-launcher-search" type="search" placeholder="Search skills..." autocomplete="off">
          </form>
          <div class="terminals-launcher-skill-list"></div>
        </div>
      </div>
      <footer class="terminals-launcher-footer">
        <button class="terminals-launcher-start" type="button">Start</button>
      </footer>
    </section>
  </div>
</main>
<script src="/window_storage.js"></script>
<script src="/popper.min.js"></script>
<script src="/tippy-bundle.umd.min.js"></script>
<script src="/hotkeys.min.js"></script>
<script src="/common.js"></script>
<script src="/nav.js"></script>
<script>
(() => {
  const navHeader = document.querySelector("header.navheader")
  const root = document.documentElement
  const columns = document.querySelector("#terminals-columns")
  const emptyMain = document.querySelector("#terminals-empty-main")
  const searchForm = document.querySelector(".terminals-search-form")
  const sessionSearchInput = document.querySelector("#terminals-session-search")
  const topCreateButton = document.querySelector("#terminals-create-session-button")
  const topSessionContainer = document.querySelector("#terminals-top-session")
  const topSessionTitle = document.querySelector("#terminals-top-session-title")
  const topSessionOpenFolderButton = document.querySelector("#terminals-top-open-folder")
  const topSessionCloseButton = document.querySelector("#terminals-top-close-session")
  const startProviders = <%-JSON.stringify(providers || [])%>
  const initialSkills = <%-JSON.stringify(skills || [])%>
  let availableSkills = Array.isArray(initialSkills) ? initialSkills : []
  let launcherSkillsLoading = false
  let launcherSkillsLoaded = Array.isArray(initialSkills) && initialSkills.length > 0
  let launcherSkillsPromise = null
  const launcherModal = document.querySelector("#terminals-launcher-modal")
  const launcherMainView = launcherModal ? launcherModal.querySelector(".terminals-launcher-view-main") : null
  const launcherSkillsView = launcherModal ? launcherModal.querySelector(".terminals-launcher-view-skills") : null
  const launcherSearchForm = launcherModal ? launcherModal.querySelector(".terminals-launcher-search-form") : null
  const launcherSearchInput = launcherModal ? launcherModal.querySelector(".terminals-launcher-search") : null
  const launcherProviderOptions = launcherModal ? launcherModal.querySelector(".terminals-launcher-provider-options") : null
  const launcherAddSkillsButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-add-skills") : null
  const launcherAddFilesButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-add-files") : null
  const launcherBackButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-back") : null
  const launcherSkillsDoneButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-skills-done") : null
  const launcherSummarySkills = launcherModal ? launcherModal.querySelector(".terminals-launcher-summary-skills") : null
  const launcherSummaryFiles = launcherModal ? launcherModal.querySelector(".terminals-launcher-summary-files") : null
  const launcherSelected = launcherModal ? launcherModal.querySelector(".terminals-launcher-selected") : null
  const launcherSkillList = launcherModal ? launcherModal.querySelector(".terminals-launcher-skill-list") : null
  const launcherUploadList = launcherModal ? launcherModal.querySelector(".terminals-launcher-upload-list") : null
  const launcherFileInput = launcherModal ? launcherModal.querySelector(".terminals-launcher-file-input") : null
  const launcherCloseButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-close") : null
  const launcherFooter = launcherModal ? launcherModal.querySelector(".terminals-launcher-footer") : null
  const launcherStartButton = launcherModal ? launcherModal.querySelector(".terminals-launcher-start") : null
  const launcherState = {
    open: false,
    busy: false,
    column: null,
    provider: String(startProviders && startProviders[0] && startProviders[0].key ? startProviders[0].key : "codex").trim().toLowerCase(),
    view: "main",
    query: "",
    selectedSkills: new Set(),
    pendingFiles: []
  }
  const parseOnlineFlag = (value) => {
    if (value === true || value === 1) {
      return true
    }
    if (typeof value === "string") {
      const normalized = value.trim().toLowerCase()
      return normalized === "1" || normalized === "true" || normalized === "online" || normalized === "running" || normalized === "yes"
    }
    return false
  }

  const rootItems = Array.from(document.querySelectorAll("#terminals-session-bank .line"))
  let sessionItems = rootItems.map((item) => {
    const index = item.getAttribute("data-index") || ""
    const name = item.getAttribute("data-name") || "Session"
    const description = item.getAttribute("data-description") || ""
    const providerLabel = item.getAttribute("data-provider-label") || ""
    const cwd = item.getAttribute("data-cwd") || ""
    const timestamp = item.getAttribute("data-timestamp") || ""
    const uri = item.getAttribute("data-uri") || ""
    const url = item.getAttribute("data-url") || "#"
    const online = parseOnlineFlag(item.getAttribute("data-online"))
    return {
      index,
      name,
      description,
      providerLabel,
      cwd,
      timestamp,
      uri,
      url,
      online,
    }
  })

  const normalizeSessionItem = (item, indexFallback = 0) => {
    const index = normalizeIndex(item && typeof item.index !== "undefined" ? item.index : indexFallback)
    const name = item && item.name ? item.name : "Session"
    const description = item && item.description ? item.description : ""
    const providerLabel = item && (item.provider_label || item.providerLabel) ? (item.provider_label || item.providerLabel) : ""
    const cwd = item && item.cwd ? item.cwd : ""
    const timestamp = parseTimestamp(item && item.timestamp ? item.timestamp : null)
    const uri = item && item.uri ? item.uri : ""
    const url = item && (item.browser_url || item.url) ? (item.browser_url || item.url) : "#"
    const online = parseOnlineFlag(item && typeof item.online !== "undefined" ? item.online : false)
    return {
      index,
      name,
      description,
      providerLabel,
      cwd,
      timestamp,
      uri,
      url,
      online
    }
  }

  const openSessions = new Map()
  let activeTerminalColumn = null

  const escapeHtml = (raw = "") => {
    return String(raw).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll("\"", "&quot;")
  }

  const normalizeIndex = (value) => {
    return String(value || "").trim()
  }

  const isTerminalColumn = (column) => {
    return Boolean(column && column.isConnected && column.dataset && column.dataset.state === "terminal")
  }

  const getLastTerminalColumn = () => {
    return Array.from(columns.querySelectorAll(".terminals-column[data-state='terminal']")).pop() || null
  }

  const getActiveTerminalColumn = () => {
    if (isTerminalColumn(activeTerminalColumn)) {
      return activeTerminalColumn
    }
    activeTerminalColumn = getLastTerminalColumn()
    return activeTerminalColumn
  }

  const renderTopSessionBar = () => {
    if (!searchForm || !topSessionContainer || !topSessionTitle) {
      return
    }
    const activeColumn = getActiveTerminalColumn()
    const hasActiveSession = Boolean(activeColumn)
    searchForm.classList.toggle("has-active-session", hasActiveSession)
    topSessionContainer.classList.toggle("hidden", !hasActiveSession)

    if (!hasActiveSession) {
      topSessionTitle.innerHTML = ""
      topSessionTitle.title = ""
      if (topSessionOpenFolderButton) {
        topSessionOpenFolderButton.disabled = true
      }
      return
    }

    const sessionName = activeColumn.dataset.sessionName || "Session"
    const sessionCwd = activeColumn.dataset.sessionCwd || ""
    const providerKey = activeColumn.dataset.sessionProviderKey || "provider"
    const iconSrc = activeColumn.dataset.sessionProviderIcon || ""
    topSessionTitle.innerHTML = ""
    if (iconSrc) {
      const icon = document.createElement("img")
      icon.className = "terminals-provider-icon"
      icon.src = iconSrc
      icon.alt = providerKey
      topSessionTitle.appendChild(icon)
    }
    const label = document.createElement("span")
    label.textContent = sessionName
    topSessionTitle.appendChild(label)
    topSessionTitle.title = sessionName
    if (topSessionOpenFolderButton) {
      topSessionOpenFolderButton.disabled = !sessionCwd
    }
  }

  const setActiveTerminalColumn = (column) => {
    activeTerminalColumn = isTerminalColumn(column) ? column : null
    renderTopSessionBar()
  }

  const getSessionSearchQuery = () => {
    return sessionSearchInput ? (sessionSearchInput.value || "") : ""
  }

  const parseTimestamp = (value) => {
    if (value === null || typeof value === "undefined" || value === "") {
      return null
    }
    const num = Number(value)
    if (Number.isFinite(num) && num > 0) {
      return num
    }
    const parsed = Date.parse(String(value))
    if (Number.isFinite(parsed) && parsed > 0) {
      return parsed
    }
    return null
  }

  const formatTimeAgo = (timestamp) => {
    const ts = parseTimestamp(timestamp)
    if (!ts) {
      return ""
    }
    const seconds = Math.floor((Date.now() - ts) / 1000)
    if (seconds >= 0 && seconds < 5) {
      return "just now"
    }
    const abs = Math.abs(seconds)
    const units = [
      ["year", 31536000],
      ["month", 2592000],
      ["week", 604800],
      ["day", 86400],
      ["hour", 3600],
      ["minute", 60],
      ["second", 1]
    ]
    for (let i = 0; i < units.length; i++) {
      const unit = units[i]
      const size = unit[1]
      if (abs >= size || size === 1) {
        const count = Math.max(1, Math.floor(abs / size))
        const label = count === 1 ? unit[0] : `${unit[0]}s`
        return seconds >= 0 ? `${count} ${label} ago` : `in ${count} ${label}`
      }
    }
    return ""
  }

  const escapeRegExp = (value) => {
    return String(value || "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
  }

  const highlightMatches = (text, query) => {
    const safeText = escapeHtml(text)
    const rawQuery = normalizeIndex(query).trim()
    if (!rawQuery) {
      return safeText
    }
    const pattern = escapeRegExp(rawQuery)
    if (!pattern) {
      return safeText
    }
    const regex = new RegExp(`(${pattern})`, "ig")
    return safeText.replace(regex, `<span class="terminals-search-highlight">$1</span>`)
  }

  const getSessionDescription = (session) => {
    const parts = []
    const providerLabel = session && session.providerLabel ? session.providerLabel : ""
    const cwd = session && session.cwd ? session.cwd : ""
    const timeAgo = formatTimeAgo(session && session.timestamp ? session.timestamp : null)

    if (providerLabel) {
      parts.push(providerLabel)
    }
    parts.push(cwd || "cwd unavailable")
    if (timeAgo) {
      parts.push(timeAgo)
    }

    if (parts.length > 0) {
      return parts.join(" · ")
    }
    return session && session.description ? session.description : ""
  }

  const getProviderKey = (session) => {
    const uri = session && session.uri ? String(session.uri) : ""
    if (uri.includes(":")) {
      const keyFromUri = uri.split(":")[0].trim().toLowerCase()
      if (keyFromUri) {
        return keyFromUri
      }
    }
    const label = session && session.providerLabel ? String(session.providerLabel).toLowerCase() : ""
    if (label.includes("codex")) return "codex"
    if (label.includes("claude")) return "claude"
    if (label.includes("gemini")) return "gemini"
    return ""
  }

  const getProviderIconSrc = (session) => {
    const providerKey = getProviderKey(session)
    if (providerKey === "claude") return "/claude.png"
    if (providerKey === "codex") return "/openai.webp"
    if (providerKey === "gemini") return "/gemini.jpeg"
    return ""
  }

  const getProviderIconByKey = (providerKey) => {
    const key = normalizeIndex(providerKey).toLowerCase()
    if (key === "claude") return "/claude.png"
    if (key === "codex") return "/openai.webp"
    if (key === "gemini") return "/gemini.jpeg"
    return ""
  }

  const normalizeProviderKey = (value) => {
    return String(value || "").trim().toLowerCase()
  }
  const compareSessionsForChooser = (a, b) => {
    const aOnline = parseOnlineFlag(a && typeof a.online !== "undefined" ? a.online : false) ? 1 : 0
    const bOnline = parseOnlineFlag(b && typeof b.online !== "undefined" ? b.online : false) ? 1 : 0
    if (aOnline !== bOnline) {
      return bOnline - aOnline
    }
    const ta = parseTimestamp(a && a.timestamp ? a.timestamp : null) || 0
    const tb = parseTimestamp(b && b.timestamp ? b.timestamp : null) || 0
    if (ta !== tb) {
      return tb - ta
    }
    const an = (a && a.name ? String(a.name) : "").toLowerCase()
    const bn = (b && b.name ? String(b.name) : "").toLowerCase()
    return an.localeCompare(bn)
  }
  const getExistingOnlineSessionByProvider = (providerKey) => {
    const normalizedProvider = normalizeProviderKey(providerKey)
    if (!normalizedProvider) {
      return null
    }
    for (let i = 0; i < sessionItems.length; i++) {
      const session = sessionItems[i]
      if (!session || !session.online) {
        continue
      }
      if (getProviderKey(session) === normalizedProvider) {
        return session
      }
    }
    return null
  }

  if (!launcherState.provider && startProviders && startProviders[0] && startProviders[0].key) {
    launcherState.provider = normalizeProviderKey(startProviders[0].key)
  }

  const setLauncherView = (view) => {
    const normalized = view === "skills" ? "skills" : "main"
    launcherState.view = normalized
    if (launcherMainView) {
      launcherMainView.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherSkillsView) {
      launcherSkillsView.classList.toggle("hidden", normalized !== "skills")
    }
    if (launcherFooter) {
      launcherFooter.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherStartButton) {
      launcherStartButton.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherSkillsDoneButton) {
      launcherSkillsDoneButton.classList.toggle("is-primary", normalized === "skills")
    }
    if (normalized === "skills" && launcherSearchInput) {
      requestAnimationFrame(() => {
        if (launcherSearchInput) {
          launcherSearchInput.focus()
          launcherSearchInput.select()
        }
      })
    }
  }

  const renderLauncherSummary = () => {
    const skillCount = launcherState.selectedSkills.size
    const fileCount = launcherState.pendingFiles.length
    if (launcherSummarySkills) {
      launcherSummarySkills.textContent = `Skills: ${skillCount}`
    }
    if (launcherSummaryFiles) {
      launcherSummaryFiles.textContent = `Files: ${fileCount}`
    }
  }

  const setLauncherBusy = (busy) => {
    launcherState.busy = Boolean(busy)
    if (launcherStartButton) {
      launcherStartButton.disabled = launcherState.busy
    }
    if (launcherCloseButton) {
      launcherCloseButton.disabled = launcherState.busy
    }
    if (launcherSearchInput) {
      launcherSearchInput.disabled = launcherState.busy
    }
    if (launcherFileInput) {
      launcherFileInput.disabled = launcherState.busy
    }
    if (launcherAddSkillsButton) {
      launcherAddSkillsButton.disabled = launcherState.busy
    }
    if (launcherAddFilesButton) {
      launcherAddFilesButton.disabled = launcherState.busy
    }
    if (launcherBackButton) {
      launcherBackButton.disabled = launcherState.busy
    }
    if (launcherSkillsDoneButton) {
      launcherSkillsDoneButton.disabled = launcherState.busy
    }
    if (launcherProviderOptions) {
      const providerButtons = launcherProviderOptions.querySelectorAll(".terminals-launcher-provider")
      providerButtons.forEach((button) => {
        button.disabled = launcherState.busy
      })
    }
    if (launcherSkillList) {
      const skillButtons = launcherSkillList.querySelectorAll(".terminals-launcher-skill-row")
      skillButtons.forEach((button) => {
        button.disabled = launcherState.busy
      })
    }
  }

  const renderLauncherSelectedChips = () => {
    if (!launcherSelected) {
      return
    }
    launcherSelected.replaceChildren()
    const selectedIds = Array.from(launcherState.selectedSkills)
    if (selectedIds.length === 0) {
      launcherSelected.classList.add("hidden")
      renderLauncherSummary()
      return
    }
    launcherSelected.classList.remove("hidden")
    for (let i = 0; i < selectedIds.length; i++) {
      const id = selectedIds[i]
      const skill = availableSkills.find((entry) => normalizeIndex(entry && entry.id) === id)
      const chip = document.createElement("span")
      chip.className = "terminals-launcher-chip"
      chip.innerHTML = `<span>${escapeHtml(skill && skill.label ? skill.label : id)}</span><button type="button" aria-label="Remove skill">×</button>`
      const removeButton = chip.querySelector("button")
      removeButton.addEventListener("click", () => {
        launcherState.selectedSkills.delete(id)
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      })
      launcherSelected.appendChild(chip)
    }
    renderLauncherSummary()
  }

  const formatFileSize = (value) => {
    const size = Number(value)
    if (!Number.isFinite(size) || size < 0) {
      return ""
    }
    if (size < 1024) return `${size} B`
    if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`
    return `${(size / (1024 * 1024)).toFixed(1)} MB`
  }

  const getFileKey = (file) => {
    if (!file) return ""
    return `${file.name || ""}::${file.size || 0}::${file.lastModified || 0}`
  }

  const addLauncherFiles = (incomingFiles) => {
    if (!incomingFiles || typeof incomingFiles.length === "undefined") {
      return
    }
    const existing = new Set(launcherState.pendingFiles.map((file) => getFileKey(file)))
    for (let i = 0; i < incomingFiles.length; i++) {
      const file = incomingFiles[i]
      if (!file || !file.name) {
        continue
      }
      const key = getFileKey(file)
      if (existing.has(key)) {
        continue
      }
      existing.add(key)
      launcherState.pendingFiles.push(file)
    }
    renderLauncherFiles()
  }

  const renderLauncherFiles = () => {
    const hasFiles = launcherState.pendingFiles.length > 0
    if (launcherUploadList) {
      launcherUploadList.replaceChildren()
      launcherUploadList.classList.toggle("hidden", !hasFiles)
      if (hasFiles) {
        for (let i = 0; i < launcherState.pendingFiles.length; i++) {
          const file = launcherState.pendingFiles[i]
          const row = document.createElement("div")
          row.className = "terminals-launcher-upload-item"
          row.innerHTML = `<span>${escapeHtml(file.name)}${file.size ? ` (${escapeHtml(formatFileSize(file.size))})` : ""}</span><button type="button" aria-label="Remove file">×</button>`
          const removeButton = row.querySelector("button")
          removeButton.addEventListener("click", () => {
            launcherState.pendingFiles.splice(i, 1)
            renderLauncherFiles()
          })
          launcherUploadList.appendChild(row)
        }
      }
    }
    renderLauncherSummary()
  }

  const uploadLauncherFiles = async () => {
    if (!Array.isArray(launcherState.pendingFiles) || launcherState.pendingFiles.length === 0) {
      return { uploadToken: "", files: [] }
    }
    const formData = new FormData()
    for (let i = 0; i < launcherState.pendingFiles.length; i++) {
      const file = launcherState.pendingFiles[i]
      if (!file) {
        continue
      }
      formData.append("files", file, file.name || `file-${i + 1}`)
    }
    const response = await fetch("/create-upload", {
      method: "POST",
      body: formData
    })
    let payload = null
    try {
      payload = await response.json()
    } catch (error) {
    }
    if (!response.ok || !payload || !payload.uploadToken) {
      const message = payload && payload.error ? payload.error : "Failed to upload files"
      throw new Error(message)
    }
    return payload
  }

  const renderLauncherProviderOptions = () => {
    if (!launcherProviderOptions) {
      return
    }
    launcherProviderOptions.replaceChildren()
    if (!Array.isArray(startProviders) || startProviders.length === 0) {
      if (launcherStartButton) {
        launcherStartButton.disabled = true
      }
      return
    }
    const availableProviderKeys = startProviders
      .filter((provider) => provider && provider.key)
      .map((provider) => normalizeProviderKey(provider.key))
    if (!availableProviderKeys.includes(launcherState.provider) && availableProviderKeys.length > 0) {
      launcherState.provider = availableProviderKeys[0]
    }
    for (let i = 0; i < startProviders.length; i++) {
      const provider = startProviders[i]
      if (!provider || !provider.key) {
        continue
      }
      const key = normalizeProviderKey(provider.key)
      const button = document.createElement("button")
      button.type = "button"
      button.className = "terminals-launcher-provider"
      button.dataset.provider = key
      const icon = getProviderIconByKey(key)
      button.innerHTML = `<span class="terminals-launcher-radio" aria-hidden="true"></span>${icon ? `<img src="${icon}" alt="${escapeHtml(provider.label || key)}">` : ""}<span>${escapeHtml(provider.label || key)}</span>`
      if (key === launcherState.provider) {
        button.classList.add("active")
      }
      button.setAttribute("aria-pressed", key === launcherState.provider ? "true" : "false")
      button.addEventListener("click", () => {
        launcherState.provider = key
        renderLauncherProviderOptions()
      })
      launcherProviderOptions.appendChild(button)
    }
    if (launcherStartButton) {
      launcherStartButton.disabled = launcherState.busy ? true : false
    }
  }

  const renderLauncherSkillList = () => {
    if (!launcherSkillList) {
      return
    }
    launcherSkillList.replaceChildren()
    if (launcherSkillsLoading && availableSkills.length === 0) {
      const loading = document.createElement("div")
      loading.className = "terminals-launcher-empty"
      loading.textContent = "Loading skills..."
      launcherSkillList.appendChild(loading)
      return
    }
    const query = normalizeIndex(launcherState.query).toLowerCase()
    let visibleCount = 0
    for (let i = 0; i < availableSkills.length; i++) {
      const skill = availableSkills[i]
      if (!skill || !skill.id) {
        continue
      }
      const haystack = `${skill.label || ""} ${skill.description || ""} ${skill.id}`.toLowerCase()
      if (query && !haystack.includes(query)) {
        continue
      }
      visibleCount += 1
      const id = normalizeIndex(skill.id)
      const isSelected = launcherState.selectedSkills.has(id)
      const tags = Array.isArray(skill.tags) ? skill.tags.filter(Boolean).slice(0, 4) : []
      const metaChunks = []
      if (skill.provider) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag is-provider">${escapeHtml(skill.provider)}</span>`)
      }
      if (skill.version) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag is-version">v${escapeHtml(skill.version)}</span>`)
      }
      for (let t = 0; t < tags.length; t++) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag">${escapeHtml(tags[t])}</span>`)
      }
      const desc = skill.description || ""
      const sourceText = skill.source ? `Source: ${skill.source}` : ""
      const secondary = desc || sourceText || "No description"
      const highlightedName = highlightMatches(skill.label || id, query)
      const highlightedSecondary = highlightMatches(secondary, query)
      const row = document.createElement("button")
      row.type = "button"
      row.className = `terminals-launcher-skill-row${isSelected ? " selected" : ""}`
      row.dataset.skillId = id
      row.setAttribute("aria-pressed", isSelected ? "true" : "false")
      if (skill.source) {
        row.title = skill.source
      }
      row.innerHTML = `
        <div class="terminals-launcher-skill-text">
          <div class="terminals-launcher-skill-name">${highlightedName}</div>
          <div class="terminals-launcher-skill-desc">${highlightedSecondary}</div>
          ${metaChunks.length > 0 ? `<div class="terminals-launcher-skill-meta">${metaChunks.join("")}</div>` : ""}
        </div>
        <span class="terminals-launcher-skill-check">${isSelected ? "✓" : ""}</span>
      `
      row.addEventListener("click", () => {
        if (launcherState.selectedSkills.has(id)) {
          launcherState.selectedSkills.delete(id)
        } else {
          launcherState.selectedSkills.add(id)
        }
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      })
      launcherSkillList.appendChild(row)
    }
    if (visibleCount === 0) {
      const empty = document.createElement("div")
      empty.className = "terminals-launcher-empty"
      empty.textContent = query ? "No matching skills." : "No skills found in configured skill roots."
      launcherSkillList.appendChild(empty)
    }
  }

  const ensureLauncherSkillsLoaded = async (force = false) => {
    if (!force && launcherSkillsLoaded) {
      return true
    }
    if (launcherSkillsPromise) {
      return launcherSkillsPromise
    }
    launcherSkillsLoading = true
    renderLauncherSkillList()
    launcherSkillsPromise = (async () => {
      try {
        const response = await fetch("/home?mode=terminals&fetch=1&skills=1", {
          method: "GET",
          headers: {
            "Accept": "application/json"
          }
        })
        if (!response.ok) {
          return false
        }
        const payload = await response.json()
        if (payload && Array.isArray(payload.skills)) {
          availableSkills = payload.skills.slice()
          launcherSkillsLoaded = true
        }
        return true
      } catch (error) {
        return false
      } finally {
        launcherSkillsLoading = false
        launcherSkillsPromise = null
        if (launcherState.open) {
          renderLauncherSkillList()
          renderLauncherSelectedChips()
        }
      }
    })()
    return launcherSkillsPromise
  }

  const closeLauncherModal = () => {
    if (!launcherModal || launcherState.busy) {
      return
    }
    launcherState.open = false
    launcherState.column = null
    launcherState.view = "main"
    launcherState.query = ""
    if (launcherSearchInput) {
      launcherSearchInput.value = ""
    }
    setLauncherView("main")
    launcherModal.classList.add("hidden")
    launcherModal.setAttribute("aria-hidden", "true")
  }

  const openLauncherModal = (column) => {
    if (!launcherModal || !column) {
      return
    }
    launcherState.open = true
    launcherState.column = column
    launcherState.view = "main"
    launcherState.query = ""
    launcherState.pendingFiles = []
    launcherModal.classList.remove("hidden")
    launcherModal.setAttribute("aria-hidden", "false")
    setLauncherBusy(false)
    if (launcherSearchInput) {
      launcherSearchInput.value = ""
    }
    if (launcherFileInput) {
      launcherFileInput.value = ""
    }
    setLauncherView("main")
    renderLauncherProviderOptions()
    renderLauncherSelectedChips()
    renderLauncherSkillList()
    renderLauncherFiles()
    ensureLauncherSkillsLoaded(false)
    requestAnimationFrame(() => {
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  const startFromLauncher = async () => {
    if (!launcherState.open || launcherState.busy) {
      return
    }
    const column = launcherState.column
    if (!column || !column.isConnected || column.dataset.state !== "chooser") {
      closeLauncherModal()
      return
    }
    const provider = normalizeProviderKey(launcherState.provider || (startProviders[0] && startProviders[0].key) || "")
    if (!provider) {
      return
    }
    const selectedSkillIds = Array.from(launcherState.selectedSkills)
    setLauncherBusy(true)
    let shouldClose = false
    try {
      await refreshSessionItems()
      refreshChooserRows()
      const existingSession = getExistingOnlineSessionByProvider(provider)
      if (existingSession) {
        openItemInColumn(column, existingSession)
        shouldClose = true
        return
      }
      let uploadToken = ""
      if (launcherState.pendingFiles.length > 0) {
        const uploaded = await uploadLauncherFiles()
        uploadToken = uploaded && uploaded.uploadToken ? uploaded.uploadToken : ""
      }
      const started = await startProviderSession(column, provider, launcherStartButton, null, selectedSkillIds, uploadToken)
      if (started) {
        launcherState.pendingFiles = []
        renderLauncherFiles()
        shouldClose = true
      }
    } catch (error) {
      const message = error && error.message ? error.message : "Failed to prepare files"
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Could not prepare files",
          text: message,
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      } else {
        window.alert(message)
      }
    } finally {
      setLauncherBusy(false)
      if (shouldClose) {
        closeLauncherModal()
      }
    }
  }

  const getOpenColumnByIndex = (index) => {
    const key = normalizeIndex(index)
    const set = openSessions.get(key)
    if (!set || set.size === 0) {
      return null
    }
    return Array.from(set)[0] || null
  }

  const isSessionOpen = (index) => {
    const key = normalizeIndex(index)
    return openSessions.has(key) && openSessions.get(key).size > 0
  }

  const registerOpenSession = (column, index) => {
    const key = normalizeIndex(index)
    if (!openSessions.has(key)) {
      openSessions.set(key, new Set())
    }
    openSessions.get(key).add(column)
  }

  const unregisterOpenSession = (column, index) => {
    const key = normalizeIndex(index)
    const list = openSessions.get(key)
    if (!list) {
      return
    }
    list.delete(column)
    if (list.size === 0) {
      openSessions.delete(key)
    }
  }

  const setOpenState = (index, action, column) => {
    const key = normalizeIndex(index)
    if (action === "add") {
      registerOpenSession(column, key)
    } else {
      unregisterOpenSession(column, key)
    }
    syncActiveStates()
  }

  const syncActiveStates = () => {
    const chooserRows = document.querySelectorAll(".terminals-column[data-state='chooser'] .line")
    chooserRows.forEach((row) => {
      const index = normalizeIndex(row.getAttribute("data-session-index"))
      row.classList.toggle("active", isSessionOpen(index))
    })
    renderTopSessionBar()
  }

  const requestTerminalFocus = (frame) => {
    if (!frame) {
      return
    }
    try {
      frame.focus()
    } catch (error) {}
    try {
      if (frame.contentWindow && typeof frame.contentWindow.focus === "function") {
        frame.contentWindow.focus()
      }
    } catch (error) {}
    setTimeout(() => {
      try {
        frame.focus()
      } catch (error) {}
    }, 40)
  }

  const requestShellStop = (frame) => {
    return new Promise((resolve) => {
      if (!frame || !frame.contentWindow) {
        resolve(false)
        return
      }
      const requestId = `stop-${Date.now()}-${Math.random().toString(16).slice(2)}`
      let done = false
      const finish = (ok) => {
        if (done) {
          return
        }
        done = true
        window.removeEventListener("message", onMessage)
        clearTimeout(timer)
        resolve(Boolean(ok))
      }
      const onMessage = (event) => {
        if (!event || event.source !== frame.contentWindow) {
          return
        }
        const data = event.data || {}
        if (data.action === "pinokio:stop-shell-result" && data.requestId === requestId) {
          finish(data.ok)
        }
      }
      const timer = setTimeout(() => {
        finish(false)
      }, 5000)
      window.addEventListener("message", onMessage)
      try {
        frame.contentWindow.postMessage({
          action: "pinokio:request-stop-shell",
          requestId
        }, "*")
      } catch (error) {
        finish(false)
      }
    })
  }

  const openInFileExplorer = async (cwdPath) => {
    const targetPath = typeof cwdPath === "string" ? cwdPath.trim() : ""
    if (!targetPath) {
      return false
    }
    try {
      const response = await fetch("/openfs", {
        method: "post",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          path: targetPath,
          mode: "open"
        })
      })
      return response.ok
    } catch (error) {
      return false
    }
  }

  if (topSessionOpenFolderButton) {
    topSessionOpenFolderButton.addEventListener("click", async () => {
      const activeColumn = getActiveTerminalColumn()
      if (!activeColumn) {
        return
      }
      const cwd = activeColumn.dataset.sessionCwd || ""
      if (!cwd) {
        return
      }
      topSessionOpenFolderButton.disabled = true
      await openInFileExplorer(cwd)
      if (topSessionOpenFolderButton.isConnected) {
        topSessionOpenFolderButton.disabled = false
      }
    })
  }

  if (topSessionCloseButton) {
    topSessionCloseButton.addEventListener("click", async () => {
      const activeColumn = getActiveTerminalColumn()
      if (!activeColumn) {
        return
      }
      await confirmAndCloseTerminalColumn(activeColumn)
    })
  }

  const isFrameSessionAlreadyStopped = (frame) => {
    if (!frame) {
      return false
    }
    try {
      const doc = frame.contentDocument || (frame.contentWindow ? frame.contentWindow.document : null)
      if (!doc) {
        return false
      }
      const stopBtn = doc.querySelector(".stop-btn")
      const playBtn = doc.querySelector(".play-btn")
      const stoppedBtn = doc.querySelector(".stopped-btn")
      const stopHidden = !stopBtn || stopBtn.classList.contains("hidden")
      const playVisible = Boolean(playBtn && !playBtn.classList.contains("hidden"))
      const stoppedVisible = Boolean(stoppedBtn && !stoppedBtn.classList.contains("hidden"))
      if (stoppedVisible) {
        return true
      }
      if (stopHidden && playVisible) {
        return true
      }
    } catch (error) {
    }
    return false
  }

  let refreshSessionPromise = null
  const refreshSessionItems = async () => {
    if (refreshSessionPromise) {
      return refreshSessionPromise
    }
    refreshSessionPromise = (async () => {
      try {
        const response = await fetch("/home?mode=terminals&fetch=1", {
          method: "GET",
          headers: {
            "Accept": "application/json"
          }
        })
        if (!response.ok) {
          return false
        }
        const payload = await response.json()
        const items = Array.isArray(payload && payload.items) ? payload.items : []
        sessionItems = items.map((item, index) => normalizeSessionItem(item, index))
        for (let i = 0; i < sessionItems.length; i++) {
          sessionItems[i].index = i
        }
        if (payload && Array.isArray(payload.skills)) {
          availableSkills = payload.skills.slice()
        }
        return true
      } catch (error) {
        return false
      } finally {
        refreshSessionPromise = null
      }
    })()
    return refreshSessionPromise
  }
  let refreshOnlineStatePromise = null
  const refreshSessionOnlineStates = async () => {
    if (refreshOnlineStatePromise) {
      return refreshOnlineStatePromise
    }
    refreshOnlineStatePromise = (async () => {
      try {
        const response = await fetch("/home?mode=terminals&fetch=1", {
          method: "GET",
          headers: {
            "Accept": "application/json"
          }
        })
        if (!response.ok) {
          return false
        }
        const payload = await response.json()
        const remoteItems = Array.isArray(payload && payload.items) ? payload.items : []
        const onlineByUri = new Map()
        for (let i = 0; i < remoteItems.length; i++) {
          const normalized = normalizeSessionItem(remoteItems[i], i)
          if (normalized && normalized.uri) {
            onlineByUri.set(String(normalized.uri), Boolean(normalized.online))
          }
        }
        let changed = false
        for (let i = 0; i < sessionItems.length; i++) {
          const session = sessionItems[i]
          const uri = session && session.uri ? String(session.uri) : ""
          if (!uri || !onlineByUri.has(uri)) {
            continue
          }
          const nextOnline = Boolean(onlineByUri.get(uri))
          if (parseOnlineFlag(session.online) !== nextOnline) {
            session.online = nextOnline
            changed = true
          }
        }
        if (changed) {
          refreshChooserRows()
        }
        return true
      } catch (error) {
        return false
      } finally {
        refreshOnlineStatePromise = null
      }
    })()
    return refreshOnlineStatePromise
  }
  let lastForegroundRefreshAt = 0
  const refreshOnForeground = () => {
    const now = Date.now()
    if (now - lastForegroundRefreshAt < 1500) {
      return
    }
    lastForegroundRefreshAt = now
    refreshSessionOnlineStates()
  }

  const startProviderSession = async (column, providerKey, startButton, providerSelect, selectedSkillIds = [], uploadToken = "") => {
    const normalizedProvider = normalizeIndex(providerKey).toLowerCase()
    if (!normalizedProvider) {
      return false
    }
    if (startButton) {
      startButton.disabled = true
    }
    if (providerSelect) {
      providerSelect.disabled = true
    }
    try {
      const response = await fetch("/terminals/start", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          provider: normalizedProvider,
          skills: Array.isArray(selectedSkillIds) ? selectedSkillIds : [],
          uploadToken: typeof uploadToken === "string" ? uploadToken : ""
        })
      })
      let payload = null
      try {
        payload = await response.json()
      } catch (error) {
      }
      if (!response.ok || !payload || !payload.url) {
        const message = payload && payload.error ? payload.error : `Failed to start ${normalizedProvider}`
        throw new Error(message)
      }
      const uniqueIndex = `new-${normalizedProvider}-${Date.now()}-${Math.random().toString(16).slice(2)}`
      const session = {
        index: uniqueIndex,
        name: payload.name || `${payload.label || normalizedProvider} session`,
        description: `${payload.label || normalizedProvider} · ${payload.cwd || "cwd unavailable"}`,
        provider_label: payload.label || normalizedProvider,
        cwd: payload.cwd || "",
        timestamp: Date.now(),
        uri: `${normalizedProvider}:${uniqueIndex}`,
        url: payload.url,
        online: true
      }
      sessionItems.unshift(normalizeSessionItem(session, 0))
      for (let i = 0; i < sessionItems.length; i++) {
        sessionItems[i].index = i
      }
      openItemInColumn(column, session)
      refreshSessionOnlineStates()
      return true
    } catch (error) {
      const message = error && error.message ? error.message : `Failed to start ${normalizedProvider}`
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Could not start session",
          text: message,
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      } else {
        window.alert(message)
      }
      return false
    } finally {
      if (startButton && startButton.isConnected) {
        startButton.disabled = false
      }
      if (providerSelect && providerSelect.isConnected) {
        providerSelect.disabled = false
      }
    }
  }

  const confirmAndCloseTerminalColumn = async (column) => {
    if (!column || !column.parentElement) {
      return
    }

    let confirmed = false
    if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
      const result = await Swal.fire({
        title: "Close session?",
        text: "This will stop the running session and close this column.",
        showCancelButton: true,
        confirmButtonText: "Stop and close",
        cancelButtonText: "Cancel",
        reverseButtons: true,
        customClass: {
          popup: "terminals-confirm-modal"
        }
      })
      confirmed = Boolean(result && result.isConfirmed)
    } else {
      confirmed = window.confirm("Stop this running session and close this column?")
    }

    if (!confirmed) {
      return
    }
    const frame = column.querySelector("iframe")
    const stopped = await requestShellStop(frame)
    if (!stopped) {
      if (isFrameSessionAlreadyStopped(frame)) {
        closeColumn(column)
        refreshSessionOnlineStates()
        return
      }
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Could not close session",
          text: "Could not confirm stop. The column was left open.",
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      } else {
        window.alert("Could not confirm that the session stopped. The column will stay open.")
      }
      return
    }
    closeColumn(column)
    refreshSessionOnlineStates()
  }

  const focusLatestTerminal = () => {
    const lastTerminal = Array.from(columns.querySelectorAll(".terminals-column[data-state='terminal']")).pop()
    if (!lastTerminal) {
      setActiveTerminalColumn(null)
      return
    }
    setActiveTerminalColumn(lastTerminal)
    const frame = lastTerminal.querySelector("iframe")
    requestTerminalFocus(frame)
  }

  const makeRowNode = (session, query = "") => {
    const row = document.createElement("a")
    row.className = "line"
    row.href = "#"
    row.setAttribute("role", "button")
    row.dataset.sessionIndex = normalizeIndex(session.index)
    const title = document.createElement("h3")
    const iconSrc = getProviderIconSrc(session)
    if (iconSrc) {
      const icon = document.createElement("img")
      icon.className = "terminals-provider-icon"
      icon.src = iconSrc
      icon.alt = getProviderKey(session) || "provider"
      title.appendChild(icon)
      row.classList.add("has-provider-icon")
    }
    const titleText = document.createElement("span")
    titleText.innerHTML = highlightMatches(session.name, query)
    title.appendChild(titleText)
    const status = document.createElement("span")
    status.className = `terminals-session-status ${session.online ? "is-online" : "is-offline"}`
    status.textContent = session.online ? "Online" : "Offline"
    title.appendChild(status)
    const description = document.createElement("div")
    description.className = "description"
    description.innerHTML = highlightMatches(getSessionDescription(session), query)
    row.appendChild(title)
    row.appendChild(description)
    row.classList.toggle("active", isSessionOpen(session.index))
    return row
  }

  const buildRows = (column, query = "") => {
    const list = column.querySelector(".terminals-list")
    const placeholder = column.querySelector(".terminals-empty")
    const normalized = normalizeIndex(query).toLowerCase()
    if (!list) {
      return
    }
    list.replaceChildren()

    const visibleSessions = []
    for (let i = 0; i < sessionItems.length; i++) {
      const session = sessionItems[i]
      const haystack = `${session.name} ${getSessionDescription(session)} ${session.uri}`.toLowerCase()
      if (normalized && !haystack.includes(normalized)) {
        continue
      }
      visibleSessions.push(session)
    }
    visibleSessions.sort(compareSessionsForChooser)
    let visible = 0
    for (let i = 0; i < visibleSessions.length; i++) {
      const session = visibleSessions[i]
      const row = makeRowNode(session, normalized)
      row.addEventListener("click", (event) => {
        event.preventDefault()
        openItemInColumn(column, session)
      })
      list.appendChild(row)
      visible += 1
    }

    if (!placeholder) {
      return
    }

    if (sessionItems.length === 0 || visible === 0) {
      const title = placeholder.querySelector("h1")
      const message = placeholder.querySelector("div")
      if (normalized && sessionItems.length > 0) {
        if (title) title.innerText = "No matches."
        if (message) message.innerText = "No sessions matched your search."
      } else if (sessionItems.length === 0) {
        if (title) title.innerText = "Terminal sessions."
        if (message) message.innerText = "No resumable Codex, Claude, or Gemini sessions were found."
      } else {
        if (title) title.innerText = "Terminal sessions."
        if (message) message.innerText = "No resumable Codex, Claude, or Gemini sessions were found."
      }
      placeholder.classList.remove("hidden")
    } else {
      placeholder.classList.add("hidden")
    }
  }

  const refreshChooserRows = () => {
    const query = getSessionSearchQuery()
    const chooserColumns = columns.querySelectorAll(".terminals-column[data-state='chooser']")
    chooserColumns.forEach((chooserColumn) => {
      buildRows(chooserColumn, query)
    })
  }

  const setupChooserColumn = (column, showClose = false) => {
    column.className = "terminals-column terminals-column-chooser"
    column.dataset.state = "chooser"
    delete column.dataset.sessionIndex
    column.innerHTML = `
      ${showClose ? `
      <header>
        <div class="flexible"></div>
        <div class="terminals-chooser-actions">
          <button class="close-column" type="button" aria-label="Close session list">×</button>
        </div>
      </header>` : ""}
      <div class="terminals-chooser-content">
        <div class="terminals-empty">
          <h1>Terminal sessions.</h1>
          <br>
          <div>No resumable Codex, Claude, or Gemini sessions were found.</div>
          <span>Run one from your terminal and come back here to continue.</span>
        </div>
        <div class="terminals-list-wrap">
          <div class="terminals-list"></div>
        </div>
      </div>
    `
    const closeButton = column.querySelector(".close-column")

    if (closeButton) {
      closeButton.addEventListener("click", () => {
        removeColumn(column)
      })
    }

    buildRows(column, getSessionSearchQuery())
    refreshSessionItems().then(() => {
      if (!column.isConnected || column.dataset.state !== "chooser") {
        return
      }
      buildRows(column, getSessionSearchQuery())
      if (launcherState.open) {
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      }
    })
    syncActiveStates()
    ensureLayout()
    return null
  }

  const setupTerminalColumn = (column, session) => {
    const sessionName = session.name || `Session ${session.index}`
    const safeName = escapeHtml(sessionName)
    const providerKey = getProviderKey(session) || "provider"
    const headerIconSrc = getProviderIconSrc(session)
    column.className = "terminals-column"
    column.dataset.state = "terminal"
    column.dataset.sessionIndex = normalizeIndex(session.index)
    column.dataset.sessionName = sessionName
    column.dataset.sessionCwd = session && session.cwd ? session.cwd : ""
    column.dataset.sessionProviderKey = providerKey
    column.dataset.sessionProviderIcon = headerIconSrc || ""
    column.innerHTML = `<iframe src="${session.url}" loading="eager" allow="fullscreen *;" allowfullscreen title="${safeName}" tabindex="-1"></iframe>`
    const frame = column.querySelector("iframe")
    column.addEventListener("pointerdown", () => {
      setActiveTerminalColumn(column)
    })
    if (frame) {
      frame.addEventListener("load", () => {
        setActiveTerminalColumn(column)
        requestTerminalFocus(frame)
      })
      frame.addEventListener("focus", () => {
        setActiveTerminalColumn(column)
      })
      requestTerminalFocus(frame)
    }
  }

  const ensureLayout = () => {
    if (columns.children.length === 0) {
      emptyMain.classList.remove("hidden")
      columns.classList.add("hidden")
      renderTopSessionBar()
      return
    }
    columns.classList.remove("hidden")
    emptyMain.classList.add("hidden")
    renderTopSessionBar()
  }

  const addChooserColumn = () => {
    const column = document.createElement("section")
    const shouldShowClose = columns.children.length > 0
    columns.appendChild(column)
    const input = setupChooserColumn(column, shouldShowClose)
    setColumnLayout()
    if (input) {
      requestAnimationFrame(() => {
        input.focus()
      })
    }
  }

  const closeColumn = (column) => {
    if (!column || !column.parentElement) {
      return
    }
    const index = normalizeIndex(column.dataset.sessionIndex)
    if (index) {
      setOpenState(index, "remove", column)
    }

    const terminalCount = columns.querySelectorAll(".terminals-column[data-state='terminal']").length
    if (terminalCount <= 1) {
      setupChooserColumn(column, false)
    } else {
      column.remove()
      if (columns.children.length === 0) {
        addChooserColumn()
      }
    }

    setColumnLayout()
    ensureLayout()
    setActiveTerminalColumn(null)
    focusLatestTerminal()
  }

  const setColumnLayout = () => {
    const columnCount = Math.max(columns.children.length, 1)
    const columnsStyle = window.getComputedStyle(columns)
    const rawGap = columnsStyle.getPropertyValue("gap") || columnsStyle.getPropertyValue("column-gap") || "10px"
    const parsedGap = parseFloat(rawGap)
    const gap = Number.isNaN(parsedGap) ? 10 : parsedGap
    const available = Math.max(0, columns.clientWidth - (gap * Math.max(columnCount - 1, 0)))
    const width = `${Math.max(0, available / columnCount)}px`
    Array.from(columns.children).forEach((col) => {
      col.style.flex = `0 0 ${width}`
    })
  }

  const removeColumn = (column) => {
    if (!column || !column.parentElement) {
      return
    }
    const index = normalizeIndex(column.dataset.sessionIndex)
    if (index) {
      setOpenState(index, "remove", column)
    }
    column.remove()
    if (columns.children.length === 0) {
      addChooserColumn()
    }
    setColumnLayout()
    ensureLayout()
    setActiveTerminalColumn(null)
    focusLatestTerminal()
  }

  const openItemInColumn = (column, session) => {
    const existingColumn = getOpenColumnByIndex(session.index)
    if (existingColumn && existingColumn !== column) {
      existingColumn.scrollIntoView({ behavior: "smooth", inline: "end" })
      setActiveTerminalColumn(existingColumn)
      const existingFrame = existingColumn.querySelector("iframe")
      requestTerminalFocus(existingFrame)
      return
    }

    const currentIndex = normalizeIndex(column.dataset.sessionIndex)
    if (currentIndex) {
      setOpenState(currentIndex, "remove", column)
    }
    setupTerminalColumn(column, session)
    setOpenState(session.index, "add", column)
    setActiveTerminalColumn(column)
    syncActiveStates()
    setColumnLayout()
    focusLatestTerminal()
    setTimeout(() => {
      const frame = column.querySelector("iframe")
      requestTerminalFocus(frame)
    }, 40)
  }

  const openLauncherFromTopAction = () => {
    let chooser = columns.querySelector(".terminals-column[data-state='chooser']")
    if (!chooser) {
      addChooserColumn()
      chooser = columns.querySelector(".terminals-column[data-state='chooser']")
    }
    if (chooser) {
      openLauncherModal(chooser)
    }
  }

  if (launcherSearchForm) {
    launcherSearchForm.addEventListener("submit", (event) => {
      event.preventDefault()
    })
  }

  if (launcherSearchInput) {
    launcherSearchInput.addEventListener("input", () => {
      launcherState.query = launcherSearchInput.value || ""
      renderLauncherSkillList()
    })
  }

  if (launcherStartButton) {
    launcherStartButton.addEventListener("click", () => {
      startFromLauncher()
    })
  }

  if (launcherAddSkillsButton) {
    launcherAddSkillsButton.addEventListener("click", () => {
      ensureLauncherSkillsLoaded(false)
      setLauncherView("skills")
    })
  }

  if (launcherBackButton) {
    launcherBackButton.addEventListener("click", () => {
      setLauncherView("main")
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  if (launcherSkillsDoneButton) {
    launcherSkillsDoneButton.addEventListener("click", () => {
      setLauncherView("main")
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  if (launcherAddFilesButton) {
    launcherAddFilesButton.addEventListener("click", () => {
      if (launcherFileInput && !launcherState.busy) {
        launcherFileInput.click()
      }
    })
  }

  if (launcherFileInput) {
    launcherFileInput.addEventListener("change", () => {
      addLauncherFiles(launcherFileInput.files)
      launcherFileInput.value = ""
    })
  }

  if (launcherCloseButton) {
    launcherCloseButton.addEventListener("click", () => {
      closeLauncherModal()
    })
  }

  if (launcherModal) {
    launcherModal.addEventListener("click", (event) => {
      const target = event.target
      if (target && target.dataset && target.dataset.launcherClose === "1") {
        closeLauncherModal()
      }
    })
  }

  if (sessionSearchInput) {
    sessionSearchInput.addEventListener("input", () => {
      refreshChooserRows()
    })
  }

  if (topCreateButton) {
    const canCreate = Array.isArray(startProviders) && startProviders.some((provider) => provider && provider.key)
    topCreateButton.disabled = !canCreate
    if (canCreate) {
      topCreateButton.addEventListener("click", (event) => {
        event.preventDefault()
        openLauncherFromTopAction()
      })
    }
  }

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && launcherState.open) {
      event.preventDefault()
      if (launcherState.view === "skills") {
        setLauncherView("main")
        if (launcherStartButton) {
          launcherStartButton.focus()
        }
      } else {
        closeLauncherModal()
      }
      return
    }
    const key = String(event.key || "").toLowerCase()
    if (!(event.metaKey || event.ctrlKey) || key !== "k") {
      return
    }
    event.preventDefault()
    openLauncherFromTopAction()
  })

  const setViewport = () => {
    const viewportHeight = window.visualViewport ? window.visualViewport.height : window.innerHeight
    const headerHeight = navHeader ? navHeader.getBoundingClientRect().height : 0
    const frameHeight = Math.max(0, viewportHeight - headerHeight)
    root.style.setProperty("--terminals-viewport-height", `${frameHeight}px`)
    setColumnLayout()
  }

  setViewport()
  window.addEventListener("resize", setViewport)
  document.addEventListener("pinokio:header-state", setViewport)
  document.addEventListener("pinokio:header-minimized", setViewport)
  document.addEventListener("pinokio:header-restored", setViewport)
  if (window.visualViewport) {
    window.visualViewport.addEventListener("resize", setViewport)
    window.visualViewport.addEventListener("scroll", setViewport)
  }

  addChooserColumn()
  refreshChooserRows()
  if (sessionSearchInput) {
    requestAnimationFrame(() => {
      if (!searchForm || searchForm.classList.contains("has-active-session")) {
        return
      }
      sessionSearchInput.focus()
    })
  }

  if (typeof MutationObserver !== "undefined") {
    const observer = new MutationObserver(() => {
      setColumnLayout()
      setViewport()
    })
    observer.observe(columns, { childList: true, subtree: false })
  }

  setColumnLayout()
  requestAnimationFrame(setViewport)
  refreshSessionOnlineStates()
  window.addEventListener("focus", () => {
    if (document.visibilityState === "hidden") {
      return
    }
    refreshOnForeground()
  })
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "visible") {
      refreshOnForeground()
    }
  })
})()
</script>
</body>
</html>
