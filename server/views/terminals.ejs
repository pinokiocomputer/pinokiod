    const controller = new AbortController()
    sessionFetchAbortController = controller
    const params = new URLSearchParams()
    params.set("mode", "terminals")
    params.set("fetch", "1")
    params.set("limit", String(pageSize))
    if (append && sessionNextCursor > 0) {
      params.set("cursor", String(sessionNextCursor))
    }
    if (currentSessionQuery) {
      params.set("q", currentSessionQuery)
    }
    if (workspaceScopeKey) {
      params.set("workspace", workspaceScopeKey)
    }
    if (includeSkills) {
      params.set("skills", "1")
    }
    const endpoint = `/home?${params.toString()}`
    const trackIntroRefreshActivity = syncRefresh
    if (trackIntroRefreshActivity) {
      adjustSessionRefreshActivity(1)
    }
    refreshSessionPromise = (async () => {
      let requestSucceeded = false
      let shouldMarkError = false
      let aborted = false
      try {
        const response = await fetch(endpoint, {
          method: "GET",
          signal: controller.signal,
          headers: {
            "Accept": "application/json"
          }
        })
        if (!response.ok) {
          shouldMarkError = !append
          return false
        }
        const payload = await response.json()
        if (requestId !== sessionFetchRequestId || controller.signal.aborted) {
          aborted = true
          return false
        }
        if (payload && Array.isArray(payload.workspaces)) {
          workspaceFolders = payload.workspaces
            .map((workspace) => ({
              name: workspace && workspace.name ? String(workspace.name) : "",
              cwd: workspace && workspace.cwd ? String(workspace.cwd) : "",
              updatedAt: parseTimestamp(workspace && (workspace.updated_at || workspace.updatedAt) ? (workspace.updated_at || workspace.updatedAt) : null)
            }))
            .filter((workspace) => workspace.cwd)
        }
        const items = Array.isArray(payload && payload.items) ? payload.items : []
        if (append) {
