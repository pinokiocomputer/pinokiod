    }
    const chunks = normalizedPath.split(/[\\/]/).filter(Boolean)
    return chunks.length > 0 ? chunks[chunks.length - 1] : normalizedPath
  }
  const buildWorkspaceItems = () => {
    const byKey = new Map()
    const managedWorkspaceKeys = new Set()
    const fallbackFolders = Array.isArray(workspaceFolders) ? workspaceFolders : []
    for (let i = 0; i < fallbackFolders.length; i++) {
      const fallback = fallbackFolders[i]
      const cwd = fallback && typeof fallback.cwd === "string" ? fallback.cwd : ""
      const key = normalizeCwdKey(cwd)
      if (!key) {
        continue
      }
      const fallbackManaged = parseBooleanFlag(
        fallback && Object.prototype.hasOwnProperty.call(fallback, "managed")
          ? fallback.managed
          : (fallback && Object.prototype.hasOwnProperty.call(fallback, "isManaged")
            ? fallback.isManaged
            : false),
        false
      )
      if (fallbackManaged) {
        managedWorkspaceKeys.add(key)
      }
      if (!byKey.has(key)) {
        byKey.set(key, {
          key,
          cwd,
          name: fallback && fallback.name ? fallback.name : getWorkspaceNameFromPath(cwd),
          sessions: [],
          updatedAt: parseTimestamp(fallback && Object.prototype.hasOwnProperty.call(fallback, "updatedAt") ? fallback.updatedAt : (fallback && fallback.updated_at ? fallback.updated_at : null)),
          timestamp: null,
          lastMessage: "",
          isManaged: fallbackManaged
        })
      }
    }
    const displaySessions = getDisplaySessionItems()
    for (let i = 0; i < displaySessions.length; i++) {
      const session = displaySessions[i]
      const workspacePath = getWorkspacePathFromSession(session)
      const key = normalizeCwdKey(workspacePath)
      if (!key) {
        continue
      }
      if (!byKey.has(key)) {
        byKey.set(key, {
          key,
          cwd: workspacePath,
          name: session && session.workspaceName ? session.workspaceName : getWorkspaceNameFromPath(workspacePath),
          sessions: [],
          updatedAt: parseTimestamp(session && session.timestamp ? session.timestamp : null),
          timestamp: null,
          lastMessage: "",
          isManaged: managedWorkspaceKeys.has(key)
        })
      }
      const entry = byKey.get(key)
      entry.sessions.push(session)
      const ts = parseTimestamp(session && session.timestamp ? session.timestamp : null) || 0
      if (!parseTimestamp(entry && entry.updatedAt ? entry.updatedAt : null) && ts > 0) {
        entry.updatedAt = ts
      }
      const currentTs = parseTimestamp(entry.timestamp) || 0
      if (ts >= currentTs) {
        entry.timestamp = session.timestamp || null
        entry.lastMessage = session && session.summary ? session.summary : (session && session.name ? session.name : "")
      }
    }
    const items = Array.from(byKey.values())
    items.forEach((workspace) => {
      workspace.sessions.sort(compareSessionsForChooser)
    })
    items.sort((a, b) => {
      const aUpdatedAt = parseTimestamp(a && a.updatedAt ? a.updatedAt : null) || 0
      const bUpdatedAt = parseTimestamp(b && b.updatedAt ? b.updatedAt : null) || 0
      if (aUpdatedAt !== bUpdatedAt) {
        return bUpdatedAt - aUpdatedAt
      }
      return String(a && a.name ? a.name : "").localeCompare(String(b && b.name ? b.name : ""))
    })
    return items
  }
  const getCurrentWorkspaceItem = () => {
    if (workspaceViewState.mode !== "sessions" || !workspaceViewState.key) {
      return null
    }
    const workspaces = buildWorkspaceItems()
    for (let i = 0; i < workspaces.length; i++) {
      const workspace = workspaces[i]
      if (workspace && workspace.key === workspaceViewState.key) {
        return workspace
      }
    }
    return null
  }
  const setWorkspaceViewMode = (mode, workspaceKey = "") => {
    const normalizedMode = mode === "sessions" ? "sessions" : "workspaces"
    const normalizedWorkspaceKey = normalizedMode === "sessions" ? normalizeCwdKey(workspaceKey) : ""
    workspaceViewState.mode = normalizedMode
    workspaceViewState.key = normalizedWorkspaceKey
    if (autoLauncherPromptedWorkspaceKey && (normalizedMode !== "sessions" || normalizedWorkspaceKey !== autoLauncherPromptedWorkspaceKey)) {
      autoLauncherPromptedWorkspaceKey = ""
    }
    if (sessionSearchInput) {
      sessionSearchInput.placeholder = normalizedMode === "sessions" ? "Search sessions" : "Search workspaces"
    }
    renderChooserTopBar()
  }
  if (!launcherState.provider && startProviders && startProviders[0] && startProviders[0].key) {
    launcherState.provider = normalizeProviderKey(startProviders[0].key)
  }

  const setLauncherView = (view) => {
    const normalized = view === "skills" ? "skills" : "main"
    launcherState.view = normalized
    if (launcherMainView) {
      launcherMainView.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherSkillsView) {
      launcherSkillsView.classList.toggle("hidden", normalized !== "skills")
    }
    if (launcherFooter) {
      launcherFooter.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherStartButton) {
      launcherStartButton.classList.toggle("hidden", normalized !== "main")
    }
    if (launcherSkillsDoneButton) {
      launcherSkillsDoneButton.classList.toggle("is-primary", normalized === "skills")
    }
    if (normalized === "skills" && launcherSearchInput) {
      requestAnimationFrame(() => {
        if (launcherSearchInput) {
          launcherSearchInput.focus()
          launcherSearchInput.select()
        }
      })
    }
  }

  const renderLauncherSummary = () => {
    const skillCount = launcherState.selectedSkills.size
    const fileCount = launcherState.pendingFiles.length
    const launchMode = normalizeLaunchMode(launcherState.launchMode, LAUNCH_MODE_GUARDED)
    if (launcherSummarySkills) {
      launcherSummarySkills.textContent = `Skills: ${skillCount}`
    }
    if (launcherSummaryFiles) {
      launcherSummaryFiles.textContent = `Files: ${fileCount}`
    }
    if (launcherModeMeta) {
      launcherModeMeta.textContent = launchMode === LAUNCH_MODE_YOLO
        ? "YOLO: run without approvals"
        : "Guarded: provider default approval/sandbox."
    }
  }

  const setLauncherBusy = (busy) => {
    launcherState.busy = Boolean(busy)
    if (launcherStartButton) {
      launcherStartButton.disabled = launcherState.busy
    }
    if (launcherCloseButton) {
      launcherCloseButton.disabled = launcherState.busy
    }
    if (launcherSearchInput) {
      launcherSearchInput.disabled = launcherState.busy
    }
    if (launcherFileInput) {
      launcherFileInput.disabled = launcherState.busy
    }
    if (launcherAddSkillsButton) {
      launcherAddSkillsButton.disabled = launcherState.busy
    }
    if (launcherAddFilesButton) {
      launcherAddFilesButton.disabled = launcherState.busy
    }
    if (launcherBackButton) {
      launcherBackButton.disabled = launcherState.busy
    }
    if (launcherSkillsDoneButton) {
      launcherSkillsDoneButton.disabled = launcherState.busy
    }
    if (launcherProviderOptions) {
      const providerButtons = launcherProviderOptions.querySelectorAll(".terminals-launcher-provider")
      providerButtons.forEach((button) => {
        button.disabled = launcherState.busy
      })
    }
    if (launcherModeOptions) {
      const modeButtons = launcherModeOptions.querySelectorAll(".terminals-launcher-mode")
      modeButtons.forEach((button) => {
        button.disabled = launcherState.busy
      })
    }
    if (launcherSkillList) {
      const skillButtons = launcherSkillList.querySelectorAll(".terminals-launcher-skill-row")
      skillButtons.forEach((button) => {
        button.disabled = launcherState.busy
      })
    }
  }

  const renderLauncherSelectedChips = () => {
    if (!launcherSelected) {
      return
    }
    launcherSelected.replaceChildren()
    const selectedIds = Array.from(launcherState.selectedSkills)
    if (selectedIds.length === 0) {
      launcherSelected.classList.add("hidden")
      renderLauncherSummary()
      return
    }
    launcherSelected.classList.remove("hidden")
    for (let i = 0; i < selectedIds.length; i++) {
      const id = selectedIds[i]
      const skill = availableSkills.find((entry) => normalizeIndex(entry && entry.id) === id)
      const chip = document.createElement("span")
      chip.className = "terminals-launcher-chip"
      chip.innerHTML = `<span>${escapeHtml(skill && skill.label ? skill.label : id)}</span><button type="button" aria-label="Remove skill">×</button>`
      const removeButton = chip.querySelector("button")
      removeButton.addEventListener("click", () => {
        launcherState.skillsTouched = true
        launcherState.selectedSkills.delete(id)
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      })
      launcherSelected.appendChild(chip)
    }
    renderLauncherSummary()
  }

  const formatFileSize = (value) => {
    const size = Number(value)
    if (!Number.isFinite(size) || size < 0) {
      return ""
    }
    if (size < 1024) return `${size} B`
    if (size < 1024 * 1024) return `${Math.round(size / 1024)} KB`
    return `${(size / (1024 * 1024)).toFixed(1)} MB`
  }

  const getFileKey = (file) => {
    if (!file) return ""
    return `${file.name || ""}::${file.size || 0}::${file.lastModified || 0}`
  }

  const addLauncherFiles = (incomingFiles) => {
    if (!incomingFiles || typeof incomingFiles.length === "undefined") {
      return
    }
    const existing = new Set(launcherState.pendingFiles.map((file) => getFileKey(file)))
    for (let i = 0; i < incomingFiles.length; i++) {
      const file = incomingFiles[i]
      if (!file || !file.name) {
        continue
      }
      const key = getFileKey(file)
      if (existing.has(key)) {
        continue
      }
      existing.add(key)
      launcherState.pendingFiles.push(file)
    }
    renderLauncherFiles()
  }

  const renderLauncherFiles = () => {
    const hasFiles = launcherState.pendingFiles.length > 0
    if (launcherUploadList) {
      launcherUploadList.replaceChildren()
      launcherUploadList.classList.toggle("hidden", !hasFiles)
      if (hasFiles) {
        for (let i = 0; i < launcherState.pendingFiles.length; i++) {
          const file = launcherState.pendingFiles[i]
          const row = document.createElement("div")
          row.className = "terminals-launcher-upload-item"
          row.innerHTML = `<span>${escapeHtml(file.name)}${file.size ? ` (${escapeHtml(formatFileSize(file.size))})` : ""}</span><button type="button" aria-label="Remove file">×</button>`
          const removeButton = row.querySelector("button")
          removeButton.addEventListener("click", () => {
            launcherState.pendingFiles.splice(i, 1)
            renderLauncherFiles()
          })
          launcherUploadList.appendChild(row)
        }
      }
    }
    renderLauncherSummary()
  }

  const uploadLauncherFiles = async () => {
    if (!Array.isArray(launcherState.pendingFiles) || launcherState.pendingFiles.length === 0) {
      return { uploadToken: "", files: [] }
    }
    const formData = new FormData()
    for (let i = 0; i < launcherState.pendingFiles.length; i++) {
      const file = launcherState.pendingFiles[i]
      if (!file) {
        continue
      }
      formData.append("files", file, file.name || `file-${i + 1}`)
    }
    const response = await fetch("/create-upload", {
      method: "POST",
      body: formData
    })
    let payload = null
    try {
      payload = await response.json()
    } catch (error) {
    }
    if (!response.ok || !payload || !payload.uploadToken) {
      const message = payload && payload.error ? payload.error : "Failed to upload files"
      throw new Error(message)
    }
    return payload
  }

  const renderLauncherProviderOptions = () => {
    if (!launcherProviderOptions) {
      return
    }
    launcherProviderOptions.replaceChildren()
    if (!Array.isArray(startProviders) || startProviders.length === 0) {
      if (launcherStartButton) {
        launcherStartButton.disabled = true
      }
      return
    }
    const availableProviderKeys = startProviders
      .filter((provider) => provider && provider.key)
      .map((provider) => normalizeProviderKey(provider.key))
    if (!availableProviderKeys.includes(launcherState.provider) && availableProviderKeys.length > 0) {
      launcherState.provider = availableProviderKeys[0]
    }
    for (let i = 0; i < startProviders.length; i++) {
      const provider = startProviders[i]
      if (!provider || !provider.key) {
        continue
      }
      const key = normalizeProviderKey(provider.key)
      const button = document.createElement("button")
      button.type = "button"
      button.className = "terminals-launcher-provider"
      button.dataset.provider = key
      const icon = getProviderIconByKey(key)
      button.innerHTML = `<span class="terminals-launcher-radio" aria-hidden="true"></span>${icon ? `<img src="${icon}" alt="${escapeHtml(provider.label || key)}">` : ""}<span>${escapeHtml(provider.label || key)}</span>`
      if (key === launcherState.provider) {
        button.classList.add("active")
      }
      button.setAttribute("aria-pressed", key === launcherState.provider ? "true" : "false")
      button.addEventListener("click", () => {
        launcherState.provider = key
        renderLauncherProviderOptions()
      })
      launcherProviderOptions.appendChild(button)
    }
    if (launcherStartButton) {
      launcherStartButton.disabled = launcherState.busy ? true : false
    }
  }

  const renderLauncherModeOptions = () => {
    if (!launcherModeOptions) {
      return
    }
    launcherState.launchMode = normalizeLaunchMode(launcherState.launchMode, LAUNCH_MODE_GUARDED)
    const modeButtons = launcherModeOptions.querySelectorAll(".terminals-launcher-mode")
    modeButtons.forEach((button) => {
      const mode = normalizeLaunchMode(button && button.dataset ? button.dataset.launchMode : "", LAUNCH_MODE_GUARDED)
      const isActive = mode === launcherState.launchMode
      button.classList.toggle("active", isActive)
      button.setAttribute("aria-pressed", isActive ? "true" : "false")
      button.disabled = launcherState.busy
      button.onclick = () => {
        if (launcherState.busy) {
          return
        }
        launcherState.launchMode = mode
        renderLauncherModeOptions()
      }
    })
    renderLauncherSummary()
  }

  const renderLauncherSkillList = () => {
    if (!launcherSkillList) {
      return
    }
    launcherSkillList.replaceChildren()
    if (launcherSkillsLoading && availableSkills.length === 0) {
      const loading = document.createElement("div")
      loading.className = "terminals-launcher-empty"
      loading.textContent = "Loading skills..."
      launcherSkillList.appendChild(loading)
      return
    }
    const query = normalizeIndex(launcherState.query).toLowerCase()
    let visibleCount = 0
    for (let i = 0; i < availableSkills.length; i++) {
      const skill = availableSkills[i]
      if (!skill || !skill.id) {
        continue
      }
      const haystack = `${skill.label || ""} ${skill.description || ""} ${skill.id}`.toLowerCase()
      if (query && !haystack.includes(query)) {
        continue
      }
      visibleCount += 1
      const id = normalizeIndex(skill.id)
      const isSelected = launcherState.selectedSkills.has(id)
      const tags = Array.isArray(skill.tags) ? skill.tags.filter(Boolean).slice(0, 4) : []
      const metaChunks = []
      if (skill.provider) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag is-provider">${escapeHtml(skill.provider)}</span>`)
      }
      if (skill.version) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag is-version">v${escapeHtml(skill.version)}</span>`)
      }
      for (let t = 0; t < tags.length; t++) {
        metaChunks.push(`<span class="terminals-launcher-skill-tag">${escapeHtml(tags[t])}</span>`)
      }
      const desc = skill.description || ""
      const sourceText = skill.source ? `Source: ${skill.source}` : ""
      const secondary = desc || sourceText || "No description"
      const highlightedName = highlightMatches(skill.label || id, query)
      const highlightedSecondary = highlightMatches(secondary, query)
      const row = document.createElement("button")
      row.type = "button"
      row.className = `terminals-launcher-skill-row${isSelected ? " selected" : ""}`
      row.dataset.skillId = id
      row.setAttribute("aria-pressed", isSelected ? "true" : "false")
      if (skill.source) {
        row.title = skill.source
      }
      row.innerHTML = `
        <div class="terminals-launcher-skill-text">
          <div class="terminals-launcher-skill-name">${highlightedName}</div>
          <div class="terminals-launcher-skill-desc">${highlightedSecondary}</div>
          ${metaChunks.length > 0 ? `<div class="terminals-launcher-skill-meta">${metaChunks.join("")}</div>` : ""}
        </div>
        <span class="terminals-launcher-skill-check">${isSelected ? "✓" : ""}</span>
      `
      row.addEventListener("click", () => {
        launcherState.skillsTouched = true
        if (launcherState.selectedSkills.has(id)) {
          launcherState.selectedSkills.delete(id)
        } else {
          launcherState.selectedSkills.add(id)
        }
        renderLauncherSelectedChips()
        renderLauncherSkillList()
      })
      launcherSkillList.appendChild(row)
    }
    if (visibleCount === 0) {
      const empty = document.createElement("div")
      empty.className = "terminals-launcher-empty"
      empty.textContent = query ? "No matching skills." : "No skills found in configured skill roots."
      launcherSkillList.appendChild(empty)
    }
  }

  const ensureLauncherSkillsLoaded = async (force = false) => {
    if (!force && launcherSkillsLoaded) {
      return true
    }
    if (launcherSkillsPromise) {
      return launcherSkillsPromise
    }
    launcherSkillsLoading = true
    renderLauncherSkillList()
    launcherSkillsPromise = (async () => {
      try {
        const response = await fetch("/home?mode=terminals&fetch=1&skills=1", {
          method: "GET",
          headers: {
            "Accept": "application/json"
          }
        })
        if (!response.ok) {
          return false
        }
        const payload = await response.json()
        if (payload && Array.isArray(payload.skills)) {
          availableSkills = payload.skills.slice()
          launcherSkillsLoaded = true
        }
        return true
      } catch (error) {
        return false
      } finally {
        launcherSkillsLoading = false
        launcherSkillsPromise = null
        if (launcherState.open) {
          applyLauncherDefaultSkills(false)
          renderLauncherSkillList()
          renderLauncherSelectedChips()
        }
      }
    })()
    return launcherSkillsPromise
  }

  const closeLauncherModal = () => {
    if (!launcherModal || launcherState.busy) {
      return
    }
    launcherState.open = false
    launcherState.column = null
    launcherState.workspaceCwd = ""
    launcherState.view = "main"
    launcherState.query = ""
    if (launcherSearchInput) {
      launcherSearchInput.value = ""
    }
    setLauncherView("main")
    launcherModal.classList.add("hidden")
    launcherModal.setAttribute("aria-hidden", "true")
  }

  const openLauncherModal = (column, workspaceCwd = "") => {
    if (!launcherModal || !column) {
      return
    }
    const normalizedWorkspaceCwd = normalizeIndex(workspaceCwd)
    if (!normalizedWorkspaceCwd) {
      return
    }
    launcherState.open = true
    launcherState.column = column
    launcherState.workspaceCwd = normalizedWorkspaceCwd
    launcherState.view = "main"
    launcherState.query = ""
    launcherState.selectedSkills = new Set()
    launcherState.skillsTouched = false
    applyLauncherDefaultSkills(true)
    launcherState.pendingFiles = []
    launcherModal.classList.remove("hidden")
    launcherModal.setAttribute("aria-hidden", "false")
    setLauncherBusy(false)
    if (launcherSearchInput) {
      launcherSearchInput.value = ""
    }
    if (launcherFileInput) {
      launcherFileInput.value = ""
    }
    setLauncherView("main")
    renderLauncherProviderOptions()
    renderLauncherModeOptions()
    renderLauncherSelectedChips()
    renderLauncherSkillList()
    renderLauncherFiles()
    ensureLauncherSkillsLoaded(false)
    requestAnimationFrame(() => {
      if (launcherStartButton) {
        launcherStartButton.focus()
      }
    })
  }

  const startFromLauncher = async () => {
    if (!launcherState.open || launcherState.busy) {
      return
    }
    const column = launcherState.column
    if (!column || !column.isConnected || column.dataset.state !== "chooser") {
      closeLauncherModal()
      return
    }
    const provider = normalizeProviderKey(launcherState.provider || (startProviders[0] && startProviders[0].key) || "")
    const workspaceCwd = normalizeIndex(launcherState.workspaceCwd)
    if (!provider) {
      return
    }
    if (!workspaceCwd) {
      return
    }
    const launchMode = normalizeLaunchMode(launcherState.launchMode, LAUNCH_MODE_GUARDED)
    const selectedSkillIds = Array.from(launcherState.selectedSkills)
    setLauncherBusy(true)
    let shouldClose = false
    try {
      let uploadToken = ""
      if (launcherState.pendingFiles.length > 0) {
        const uploaded = await uploadLauncherFiles()
        uploadToken = uploaded && uploaded.uploadToken ? uploaded.uploadToken : ""
      }
      const started = await startProviderSession(column, provider, launchMode, launcherStartButton, null, selectedSkillIds, uploadToken, workspaceCwd)
      if (started) {
        launcherState.pendingFiles = []
        renderLauncherFiles()
        shouldClose = true
      }
    } catch (error) {
      const message = error && error.message ? error.message : "Failed to prepare files"
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Could not prepare files",
          text: message,
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      } else {
        window.alert(message)
      }
    } finally {
      setLauncherBusy(false)
      if (shouldClose) {
        closeLauncherModal()
      }
    }
  }

  const getOpenColumnBySession = (session) => {
    const key = getSessionIdentityKey(session)
    const set = openSessions.get(key)
    if (!set || set.size === 0) {
      return null
    }
    return Array.from(set)[0] || null
  }

  const isSessionOpenByKey = (key) => {
    const normalizedKey = normalizeIndex(key)
    return normalizedKey.length > 0 && openSessions.has(normalizedKey) && openSessions.get(normalizedKey).size > 0
  }

  const isSessionOpen = (session) => {
    const key = getSessionIdentityKey(session)
    return isSessionOpenByKey(key)
  }

  const registerOpenSession = (column, session) => {
    const key = getSessionIdentityKey(session)
    if (!key) {
      return
    }
    if (!openSessions.has(key)) {
      openSessions.set(key, new Set())
    }
    openSessions.get(key).add(column)
  }

  const unregisterOpenSession = (column, session) => {
    const key = getSessionIdentityKey(session)
    if (!key) {
      return
    }
    const list = openSessions.get(key)
    if (!list) {
      return
    }
    list.delete(column)
    if (list.size === 0) {
      openSessions.delete(key)
    }
  }

  const setOpenState = (session, action, column) => {
    const key = getSessionIdentityKey(session)
    if (!key) {
      return
    }
    if (action === "add") {
      registerOpenSession(column, session)
    } else {
      unregisterOpenSession(column, session)
    }
    syncActiveStates()
  }

  const getColumnSessionIdentity = (column) => {
    if (!column || !column.dataset) {
      return ""
    }
    return getSessionIdentityKey({
      terminalId: column.dataset.sessionTerminalId || "",
      index: column.dataset.sessionIndex || "",
      uri: column.dataset.sessionUri || ""
    })
  }

  const syncActiveStates = () => {
    const chooserRows = document.querySelectorAll(".terminals-column[data-state='chooser'] .line")
    chooserRows.forEach((row) => {
      const key = normalizeIndex(row.getAttribute("data-session-key"))
      row.classList.toggle("active", isSessionOpenByKey(key))
    })
    renderTopSessionBar()
  }

  const requestTerminalFocus = (frame) => {
    if (!frame) {
      return
    }
    try {
      frame.focus()
    } catch (error) {}
    try {
      if (frame.contentWindow && typeof frame.contentWindow.focus === "function") {
        frame.contentWindow.focus()
      }
    } catch (error) {}
    setTimeout(() => {
      try {
        frame.focus()
      } catch (error) {}
    }, 40)
  }

  const requestShellStop = (frame) => {
    return new Promise((resolve) => {
      if (!frame || !frame.contentWindow) {
        resolve(false)
        return
      }
      const requestId = `stop-${Date.now()}-${Math.random().toString(16).slice(2)}`
      let done = false
      const finish = (ok) => {
        if (done) {
          return
        }
        done = true
        window.removeEventListener("message", onMessage)
        clearTimeout(timer)
        resolve(Boolean(ok))
      }
      const onMessage = (event) => {
        if (!event || event.source !== frame.contentWindow) {
          return
        }
        const data = event.data || {}
        if (data.action === "pinokio:stop-shell-result" && data.requestId === requestId) {
          finish(data.ok)
        }
      }
      const timer = setTimeout(() => {
        finish(false)
      }, 5000)
      window.addEventListener("message", onMessage)
      try {
        frame.contentWindow.postMessage({
          action: "pinokio:request-stop-shell",
          requestId
        }, "*")
      } catch (error) {
        finish(false)
      }
    })
  }

  const openInFileExplorer = async (cwdPath, mode = "open") => {
    const targetPath = typeof cwdPath === "string" ? cwdPath.trim() : ""
    if (!targetPath) {
      return false
    }
    try {
      const response = await fetch("/openfs", {
        method: "post",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          path: targetPath,
          mode
        })
      })
      return response.ok
    } catch (error) {
      return false
    }
  }

  const getWorkspaceGitCacheKey = (workspacePath) => {
    return normalizeCwdKey(workspacePath)
  }

  const getWorkspaceGitBindings = (workspacePath) => {
    const key = getWorkspaceGitCacheKey(workspacePath)
    if (!key) {
      return []
    }
    const existing = Array.isArray(workspaceGitBindings.get(key)) ? workspaceGitBindings.get(key) : []
    const connected = existing.filter((binding) => binding && binding.button && binding.button.isConnected)
    if (connected.length > 0) {
      workspaceGitBindings.set(key, connected)
    } else {
      workspaceGitBindings.delete(key)
    }
    return connected
  }

  const detachTopSessionGitBinding = () => {
    if (!topSessionGitBinding || !topSessionGitWorkspaceKey) {
      topSessionGitWorkspaceKey = ""
      return
    }
    if (activeWorkspaceGitMenu && activeWorkspaceGitMenu.button === topSessionGitButton) {
      if (topSessionGitMenu) {
        topSessionGitMenu.classList.add("hidden")
      }
      if (topSessionGitButton) {
        topSessionGitButton.setAttribute("aria-expanded", "false")
      }
      activeWorkspaceGitMenu = null
    }
    const existing = Array.isArray(workspaceGitBindings.get(topSessionGitWorkspaceKey))
      ? workspaceGitBindings.get(topSessionGitWorkspaceKey)
      : []
    const filtered = existing.filter((binding) => binding && binding !== topSessionGitBinding && binding.button && binding.button.isConnected)
    if (filtered.length > 0) {
      workspaceGitBindings.set(topSessionGitWorkspaceKey, filtered)
    } else {
      workspaceGitBindings.delete(topSessionGitWorkspaceKey)
    }
    topSessionGitWorkspaceKey = ""
  }

  const resetTopSessionGitBindingUi = () => {
    if (!topSessionGitBinding || !topSessionGitButton) {
      return
    }
    const labelEl = topSessionGitBinding.label || topSessionGitButton.querySelector(".terminals-workspace-git-label")
    const badgeEl = topSessionGitBinding.badge || topSessionGitButton.querySelector(".terminals-workspace-git-badge")
    if (labelEl) {
      labelEl.textContent = "Changes"
    }
    if (badgeEl) {
      badgeEl.textContent = ""
      badgeEl.classList.add("hidden")
    }
    topSessionGitButton.classList.remove("is-init", "is-error")
    topSessionGitButton.setAttribute("aria-expanded", "false")
    topSessionGitButton.title = "Open changes"
    if (topSessionGitMenu) {
      topSessionGitMenu.classList.add("hidden")
      topSessionGitMenu.innerHTML = ""
    }
    if (topSessionGitError) {
      topSessionGitError.textContent = ""
      topSessionGitError.classList.add("hidden")
    }
  }

  const syncTopSessionGitBinding = (workspacePath) => {
    if (!topSessionGitBinding) {
      return
    }
    const nextKey = getWorkspaceGitCacheKey(workspacePath)
    if (!nextKey) {
      detachTopSessionGitBinding()
      resetTopSessionGitBindingUi()
      return
    }
    if (topSessionGitWorkspaceKey && topSessionGitWorkspaceKey !== nextKey) {
      detachTopSessionGitBinding()
    }
    const existing = Array.isArray(workspaceGitBindings.get(nextKey)) ? workspaceGitBindings.get(nextKey) : []
    if (!existing.includes(topSessionGitBinding)) {
      existing.push(topSessionGitBinding)
      workspaceGitBindings.set(nextKey, existing)
    }
    topSessionGitWorkspaceKey = nextKey
    applyWorkspaceGitState(workspacePath)
    void fetchWorkspaceGitStatus(workspacePath).catch(() => {
    })
  }

  const setWorkspaceGitInlineError = (workspacePath, message = "") => {
    const key = getWorkspaceGitCacheKey(workspacePath)
    if (!key) {
      return
    }
    const trimmed = normalizeIndex(message)
    if (trimmed) {
      workspaceGitInlineErrors.set(key, trimmed)
    } else {
      workspaceGitInlineErrors.delete(key)
    }
    applyWorkspaceGitState(workspacePath)
  }

  const closeActiveWorkspaceGitMenu = () => {
    if (!activeWorkspaceGitMenu) {
      return
    }
    const { menu, button } = activeWorkspaceGitMenu
    if (menu) {
      menu.classList.add("hidden")
    }
    if (button) {
      button.setAttribute("aria-expanded", "false")
    }
    activeWorkspaceGitMenu = null
  }

  const getWorkspacePathForRepo = (repoPath) => {
    const normalizedRepoPath = normalizeIndex(repoPath)
    if (!normalizedRepoPath) {
      return ""
    }
    const workspaceItems = buildWorkspaceItems()
    for (let i = 0; i < workspaceItems.length; i++) {
      const workspace = workspaceItems[i]
      if (!workspace || !workspace.cwd) {
        continue
      }
      const workspacePath = normalizeIndex(workspace.cwd)
      if (!workspacePath) {
        continue
      }
      if (normalizedRepoPath === workspacePath || normalizedRepoPath.startsWith(`${workspacePath}/`) || normalizedRepoPath.startsWith(`${workspacePath}\\`)) {
        return workspacePath
      }
    }
    return ""
  }

  const normalizeTerminalGitStatusPayload = (payload, workspacePath = "") => {
    const reposRaw = Array.isArray(payload && payload.repos) ? payload.repos : []
    const repos = reposRaw
      .map((repo) => {
        const repoKey = normalizeIndex(repo && (repo.repoKey || repo.repoDir || repo.path || ""))
        if (!repoKey) {
          return null
        }
        return {
          name: repo && repo.name ? String(repo.name) : getWorkspaceNameFromPath(repoKey),
          main: Boolean(repo && repo.main),
          repoKey,
          repoDir: repoKey,
          changeCount: Number.isFinite(repo && repo.changeCount) ? Number(repo.changeCount) : (Array.isArray(repo && repo.changes) ? repo.changes.length : 0),
          changes: Array.isArray(repo && repo.changes) ? repo.changes : [],
          git_commit_url: repo && typeof repo.git_commit_url === "string" ? repo.git_commit_url : "",
          git_history_url: repo && typeof repo.git_history_url === "string" ? repo.git_history_url : "",
          git_fork_url: repo && typeof repo.git_fork_url === "string" ? repo.git_fork_url : "",
          git_push_url: repo && typeof repo.git_push_url === "string" ? repo.git_push_url : "",
          hasHead: Boolean(repo && repo.hasHead),
          gitDirExists: Boolean(repo && repo.gitDirExists),
          url: repo && typeof repo.url === "string" ? repo.url : "",
        }
      })
      .filter(Boolean)
      .sort((a, b) => {
        if (Boolean(a.main) === Boolean(b.main)) {
          return String(a.name || "").localeCompare(String(b.name || ""))
        }
        return a.main ? -1 : 1
      })
    const totalChanges = Number.isFinite(payload && payload.totalChanges)
      ? Number(payload.totalChanges)
      : repos.reduce((sum, repo) => sum + (repo.changeCount || 0), 0)
    const resolvedWorkspace = normalizeIndex(payload && payload.workspace ? payload.workspace : workspacePath)
    return {
      workspace: resolvedWorkspace,
      totalChanges,
      repos,
      loadedAt: Date.now(),
      error: ""
    }
  }

  const applyWorkspaceGitState = (workspacePath) => {
    const key = getWorkspaceGitCacheKey(workspacePath)
    if (!key) {
      return
    }
    const status = workspaceGitStatusCache.get(key) || null
    const repos = status && Array.isArray(status.repos) ? status.repos : []
    const totalChanges = status && Number.isFinite(status.totalChanges)
      ? Number(status.totalChanges)
      : repos.reduce((sum, repo) => sum + (repo.changeCount || 0), 0)
    const label = status ? (repos.length === 0 ? "Start tracking changes" : "Changes") : "Changes"
    const inlineError = workspaceGitInlineErrors.get(key) || ""
    const bindings = getWorkspaceGitBindings(workspacePath)
    bindings.forEach((binding) => {
      const button = binding.button
      if (!button || !button.isConnected) {
        return
      }
      const labelEl = binding.label || button.querySelector(".terminals-workspace-git-label")
      const badgeEl = binding.badge || button.querySelector(".terminals-workspace-git-badge")
      if (labelEl) {
        labelEl.textContent = label
      }
      if (badgeEl) {
        const hasChanges = totalChanges > 0
        badgeEl.textContent = hasChanges ? String(totalChanges) : ""
        badgeEl.classList.toggle("hidden", !hasChanges)
      }
      button.classList.toggle("is-init", Boolean(status) && repos.length === 0)
      button.classList.toggle("is-error", Boolean(inlineError))
      if (!status) {
        button.title = "Check repository status"
      } else if (repos.length === 0) {
        button.title = "Initialize git in this workspace"
      } else if (repos.length === 1) {
        button.title = repos[0].name || "Open changes"
      } else {
        button.title = "Select a repository"
      }
      button.setAttribute("aria-expanded", activeWorkspaceGitMenu && activeWorkspaceGitMenu.button === button ? "true" : "false")
      if (binding.error) {
        if (inlineError) {
          binding.error.textContent = inlineError
          binding.error.classList.remove("hidden")
        } else {
          binding.error.textContent = ""
          binding.error.classList.add("hidden")
        }
      }
    })
  }

  const fetchWorkspaceGitStatus = async (workspacePath, options = {}) => {
    const key = getWorkspaceGitCacheKey(workspacePath)
    if (!key) {
      return null
    }
    const forceRefresh = Boolean(options && options.force)
    if (!forceRefresh && workspaceGitStatusCache.has(key)) {
      return workspaceGitStatusCache.get(key)
    }
    if (workspaceGitStatusRequests.has(key)) {
      return workspaceGitStatusRequests.get(key)
    }
    const requestPromise = (async () => {
      const url = new URL("/terminals/git/status", window.location.origin)
      url.searchParams.set("workspace", workspacePath)
      const response = await fetch(url.toString(), {
        method: "GET",
        headers: {
          "Accept": "application/json"
        }
      })
      let payload = null
      try {
        payload = await response.json()
      } catch (error) {
      }
      if (!response.ok || !payload || payload.ok !== true) {
        const message = payload && payload.error ? payload.error : "Failed to load git status."
        throw new Error(message)
      }
      const normalized = normalizeTerminalGitStatusPayload(payload, workspacePath)
      workspaceGitStatusCache.set(key, normalized)
      normalized.repos.forEach((repo) => {
        terminalRepoCache.set(repo.repoKey, { ...repo })
      })
      applyWorkspaceGitState(workspacePath)
      return normalized
    })()
    workspaceGitStatusRequests.set(key, requestPromise)
    try {
      return await requestPromise
    } finally {
      workspaceGitStatusRequests.delete(key)
    }
  }

  const isUntrackedStatus = (status) => {
    const normalizedStatus = String(status || "").toLowerCase()
    return normalizedStatus.includes("new") || normalizedStatus.includes("add") || normalizedStatus.includes("untracked")
  }

  const escapePathForShell = (value) => {
    if (typeof value !== "string") return ""
    const escaped = value.replace(/(["`$\\])/g, "\\$1")
    return `"${escaped}"`
  }

  const buildPathArgs = (paths) => {
    if (!Array.isArray(paths) || paths.length === 0) {
      return ""
    }
    return paths
      .filter(Boolean)
      .map((entry) => escapePathForShell(String(entry)))
      .join(" ")
  }

  const resolveRepoHistoryUrl = (repoPath, repoData = null, explicitUrl = "") => {
    const explicit = normalizeIndex(explicitUrl)
    if (explicit) {
      return explicit
    }
    const repoHistory = normalizeIndex(repoData && repoData.git_history_url ? repoData.git_history_url : "")
    if (repoHistory) {
      return repoHistory
    }
    const key = normalizeIndex(repoPath)
    if (!key) {
      return ""
    }
    return `/terminals/git/info?repo=${encodeURIComponent(key)}&ref=HEAD`
  }

  const resolveRepoDisplayName = (repoPath, repoData = null, fallbackName = "") => {
    if (fallbackName && String(fallbackName).trim()) {
      return String(fallbackName).trim()
    }
    if (repoData && repoData.name && String(repoData.name).trim()) {
      return String(repoData.name).trim()
    }
    return getWorkspaceNameFromPath(repoPath)
  }

  const renderWorkspaceGitRepoMenu = (workspace, binding, repos) => {
    if (!binding || !binding.menu) {
      return
    }
    const menu = binding.menu
    menu.innerHTML = ""
    if (!Array.isArray(repos) || repos.length === 0) {
      const empty = document.createElement("div")
      empty.className = "terminals-workspace-git-menu-item"
      empty.textContent = "No repositories detected"
      menu.appendChild(empty)
      return
    }
    const fragment = document.createDocumentFragment()
    repos.forEach((repo) => {
      const repoKey = normalizeIndex(repo && repo.repoKey ? repo.repoKey : "")
      if (!repoKey) {
        return
      }
      const item = document.createElement("button")
      item.type = "button"
      item.className = "terminals-workspace-git-menu-item"
      const name = repo && repo.name ? repo.name : getWorkspaceNameFromPath(repoKey)
      const changeCount = Number.isFinite(repo && repo.changeCount) ? Number(repo.changeCount) : (Array.isArray(repo && repo.changes) ? repo.changes.length : 0)
      item.innerHTML = `
        <span class="terminals-workspace-git-menu-title">
          <i class="fa-solid fa-code-branch" aria-hidden="true"></i>
          <span class="terminals-workspace-git-menu-name">${escapeHtml(name)}</span>
        </span>
        <span class="terminals-workspace-git-menu-meta">${changeCount > 0 ? `${changeCount} changed` : "Clean"}</span>
      `
      item.addEventListener("click", async (event) => {
        event.preventDefault()
        event.stopPropagation()
        closeActiveWorkspaceGitMenu()
        await showGitDiffModal({
          repoPath: repoKey,
          repoName: name,
          forceRefresh: true
        })
      })
      fragment.appendChild(item)
    })
    menu.appendChild(fragment)
  }

  const toggleWorkspaceGitRepoMenu = (workspace, binding, repos) => {
    if (!binding || !binding.menu || !binding.button) {
      return
    }
    if (activeWorkspaceGitMenu && activeWorkspaceGitMenu.menu === binding.menu) {
      closeActiveWorkspaceGitMenu()
      return
    }
    closeActiveWorkspaceGitMenu()
    renderWorkspaceGitRepoMenu(workspace, binding, repos)
    binding.menu.classList.remove("hidden")
    binding.button.setAttribute("aria-expanded", "true")
    activeWorkspaceGitMenu = {
      menu: binding.menu,
      button: binding.button
    }
  }

  const confirmWorkspaceGitInitialization = async (workspaceLabel) => {
    const name = normalizeIndex(workspaceLabel) || "this workspace"
    if (typeof Swal === "undefined" || !Swal || typeof Swal.fire !== "function") {
      return window.confirm(`Initialize Git in ${name}?`)
    }
    const result = await Swal.fire({
      html: `
        <div class="pinokio-modal-surface">
          <div class="pinokio-modal-header">
            <div class="pinokio-modal-icon"><i class="fa-solid fa-code-branch"></i></div>
            <div class="pinokio-modal-heading">
              <div class="pinokio-modal-title">Start tracking changes</div>
              <div class="pinokio-modal-subtitle">Initialize Git in ${escapeHtml(name)} to track file changes, commits, history, and rollbacks.</div>
            </div>
          </div>
          <div class="pinokio-modal-body">
            <p class="pinokio-modal-note">This runs <code>git init</code> in the workspace root.</p>
          </div>
        </div>
      `,
      showCancelButton: true,
      confirmButtonText: "Initialize Git",
      cancelButtonText: "Cancel",
      showCloseButton: true,
      buttonsStyling: false,
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(500px, 92vw)",
      customClass: {
        popup: "pinokio-modern-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close",
        confirmButton: "pinokio-modern-confirm",
        cancelButton: "pinokio-modern-cancel"
      }
    })
    return Boolean(result && result.isConfirmed)
  }

  const initializeWorkspaceGit = async (workspacePath) => {
    const response = await fetch("/terminals/git/init", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        workspacePath
      })
    })
    let payload = null
    try {
      payload = await response.json()
    } catch (error) {
    }
    if (!response.ok || !payload || payload.ok !== true) {
      const message = payload && payload.error ? payload.error : "Failed to initialize git."
      throw new Error(message)
    }
    return payload
  }

  const refreshWorkspaceGitForRepo = async (repoPath, options = {}) => {
    const workspacePath = getWorkspacePathForRepo(repoPath)
    if (!workspacePath) {
      return null
    }
    return fetchWorkspaceGitStatus(workspacePath, options)
  }

  const handleWorkspaceGitButtonClick = async (event, workspace, binding) => {
    event.preventDefault()
    event.stopPropagation()
    closeActiveWorkspaceGitMenu()
    const workspacePath = workspace && workspace.cwd ? String(workspace.cwd) : ""
    if (!workspacePath) {
      return
    }
    setWorkspaceGitInlineError(workspacePath, "")
    if (binding && binding.button && binding.button.disabled) {
      return
    }
    if (binding && binding.button) {
      binding.button.disabled = true
    }
    try {
      let status = await fetchWorkspaceGitStatus(workspacePath, { force: true })
      const repos = status && Array.isArray(status.repos) ? status.repos : []
      if (repos.length === 0) {
        const confirmed = await confirmWorkspaceGitInitialization(workspace && workspace.name ? workspace.name : getWorkspaceNameFromPath(workspacePath))
        if (!confirmed) {
          return
        }
        const payload = await initializeWorkspaceGit(workspacePath)
        status = normalizeTerminalGitStatusPayload(payload, workspacePath)
        workspaceGitStatusCache.set(getWorkspaceGitCacheKey(workspacePath), status)
        status.repos.forEach((repo) => {
          terminalRepoCache.set(repo.repoKey, { ...repo })
        })
        applyWorkspaceGitState(workspacePath)
        const initRepos = Array.isArray(status.repos) ? status.repos : []
        if (initRepos.length === 0) {
          setWorkspaceGitInlineError(workspacePath, "Git initialized, but no repository status was detected yet.")
          return
        }
        const targetRepo = initRepos.find((repo) => repo && repo.main) || initRepos[0]
        await showGitDiffModal({
          repoPath: targetRepo.repoKey,
          repoName: targetRepo.name,
          forceRefresh: true
        })
        return
      }
      if (repos.length === 1) {
        await showGitDiffModal({
          repoPath: repos[0].repoKey,
          repoName: repos[0].name,
          forceRefresh: true
        })
        return
      }
      toggleWorkspaceGitRepoMenu(workspace, binding, repos)
    } catch (error) {
      setWorkspaceGitInlineError(workspacePath, error && error.message ? error.message : "Failed to load git status.")
    } finally {
      if (binding && binding.button && binding.button.isConnected) {
        binding.button.disabled = false
      }
      applyWorkspaceGitState(workspacePath)
    }
  }

  const registerWorkspaceGitBinding = (workspace, binding) => {
    if (!workspace || !binding || !binding.button) {
      return
    }
    const workspacePath = workspace.cwd || ""
    const key = getWorkspaceGitCacheKey(workspacePath)
    if (!key) {
      return
    }
    const existing = Array.isArray(workspaceGitBindings.get(key)) ? workspaceGitBindings.get(key) : []
    existing.push(binding)
    workspaceGitBindings.set(key, existing)
    binding.button.addEventListener("click", (event) => {
      handleWorkspaceGitButtonClick(event, workspace, binding)
    })
    applyWorkspaceGitState(workspacePath)
    void fetchWorkspaceGitStatus(workspacePath).catch(() => {
    })
  }

  const showIframeView = (src) => {
    const iframeMarkup = `<iframe src="${src}" frameborder="0" allow="fullscreen *;" allowfullscreen></iframe>`
    const diffBody = document.querySelector(".pinokio-modal-body--diff")
    if (diffBody) {
      diffBody.classList.remove("pinokio-modal-body--diff")
      diffBody.classList.add("pinokio-modal-body--iframe")
      diffBody.innerHTML = iframeMarkup
    } else {
      const fallbackHtml = `
        <div class="pinokio-modal-surface pinokio-modal-surface--iframe">
          <div class="pinokio-modal-body pinokio-modal-body--iframe">${iframeMarkup}</div>
        </div>
      `
      Swal.fire({
        html: fallbackHtml,
        customClass: {
          popup: "pinokio-modern-modal",
          htmlContainer: "pinokio-modern-html",
          closeButton: "pinokio-modern-close"
        },
        backdrop: "rgba(9,11,15,0.65)",
        width: "min(760px, 92vw)",
        showConfirmButton: false,
        showCloseButton: true,
        buttonsStyling: false
      }).then(() => {})
    }
    const commitFooter = document.querySelector(".pinokio-modal-footer--commit")
    if (commitFooter && commitFooter.parentNode) {
      commitFooter.parentNode.removeChild(commitFooter)
    }

    if (terminalGitMessageListener) {
      window.removeEventListener("message", terminalGitMessageListener)
    }

    terminalGitMessageListener = (event) => {
      if (!event || !event.data || typeof event.data.callback !== "string" || !event.data.callback.startsWith("$")) {
        return
      }
      const activeRepo = activeTerminalRepoKey
      if (activeRepo) {
        void refreshWorkspaceGitForRepo(activeRepo, { force: true }).catch(() => {})
      }
      if (terminalGitReopenDiffOnCallback && activeRepo) {
        terminalGitReopenDiffOnCallback = false
        void showGitDiffModal({
          repoPath: activeRepo,
          forceRefresh: true
        })
      } else {
        terminalGitReopenDiffOnCallback = false
      }
      Swal.close()
      if (terminalGitMessageListener) {
        window.removeEventListener("message", terminalGitMessageListener)
        terminalGitMessageListener = null
      }
    }
    window.addEventListener("message", terminalGitMessageListener)
  }

  const normalizeResetPathList = (paths) => {
    if (!Array.isArray(paths) || paths.length === 0) {
      return []
    }
    const seen = new Set()
    const normalized = []
    paths.forEach((entry) => {
      if (typeof entry !== "string") {
        return
      }
      const value = entry.trim()
      if (!value || seen.has(value)) {
        return
      }
      seen.add(value)
      normalized.push(value)
    })
    return normalized
  }

  const formatResetFileCountLabel = (count) => {
    const safeCount = Number.isFinite(count) && count > 0 ? count : 0
    return `${safeCount} file${safeCount === 1 ? "" : "s"}`
  }

  const showResetSelectedFilesConfirmModal = async (selectionCount) => {
    const fileLabel = formatResetFileCountLabel(selectionCount)
    const html = `
      <div class="pinokio-modal-surface">
        <div class="pinokio-modal-header">
          <div class="pinokio-modal-icon pinokio-modal-icon--warning"><i class="fa-solid fa-circle-exclamation"></i></div>
          <div class="pinokio-modal-heading">
            <div class="pinokio-modal-title">Reset ${escapeHtml(fileLabel)}?</div>
            <div class="pinokio-modal-subtitle">This will discard local changes for the selected files.</div>
          </div>
        </div>
        <div class="pinokio-modal-body">
          <p class="pinokio-modal-note">Untracked files are deleted. Tracked files are restored to their Git state.</p>
        </div>
      </div>
    `
    const result = await Swal.fire({
      html,
      customClass: {
        popup: "pinokio-modern-modal pinokio-reset-confirm-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close",
        confirmButton: "pinokio-modern-confirm",
        cancelButton: "pinokio-modern-cancel"
      },
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(560px, 92vw)",
      showConfirmButton: true,
      showCancelButton: true,
      showCloseButton: true,
      buttonsStyling: false,
      focusCancel: true,
      reverseButtons: true,
      confirmButtonText: "Reset selected",
      cancelButtonText: "Cancel"
    })
    return Boolean(result && result.isConfirmed)
  }

  const resetSelectedGitFilesWithProgress = async ({ cwd, trackedPaths, untrackedPaths, selectionCount }) => {
    const repoCwd = typeof cwd === "string" ? cwd.trim() : ""
    const tracked = normalizeResetPathList(trackedPaths)
    const untrackedSet = new Set(tracked)
    const untracked = normalizeResetPathList(untrackedPaths).filter((entry) => !untrackedSet.has(entry))
    if (!repoCwd || (tracked.length === 0 && untracked.length === 0)) {
      throw new Error("No files selected to reset.")
    }

    const fileCount = Number.isFinite(selectionCount) && selectionCount > 0
      ? selectionCount
      : tracked.length + untracked.length
    const fileLabel = formatResetFileCountLabel(fileCount)
    Swal.fire({
      html: `
        <div class="pinokio-modal-surface">
          <div class="pinokio-modal-header">
            <div class="pinokio-modal-icon"><i class="fa-solid fa-arrow-rotate-left"></i></div>
            <div class="pinokio-modal-heading">
              <div class="pinokio-modal-title">Resetting ${escapeHtml(fileLabel)}</div>
              <div class="pinokio-modal-subtitle">Applying your selection now...</div>
            </div>
          </div>
          <div class="pinokio-modal-body">
            <p class="pinokio-modal-note pinokio-reset-progress-line"><i class="fa-solid fa-spinner fa-spin"></i> Discarding selected changes</p>
          </div>
        </div>
      `,
      customClass: {
        popup: "pinokio-modern-modal pinokio-reset-progress-modal",
        htmlContainer: "pinokio-modern-html"
      },
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(560px, 92vw)",
      allowOutsideClick: false,
      allowEscapeKey: false,
      showConfirmButton: false,
      showCloseButton: false,
      buttonsStyling: false
    })

    let response = null
    let payload = null
    try {
      response = await fetch("/terminals/git/reset-files", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({
          cwd: repoCwd,
          tracked_paths: tracked,
          untracked_paths: untracked
        })
      })
      try {
        payload = await response.json()
      } catch (_) {
        payload = null
      }
    } finally {
      Swal.close()
    }
    if (!response || !response.ok || !payload || payload.ok !== true) {
      const message = payload && payload.error ? payload.error : "Failed to reset selected files."
      throw new Error(message)
    }
    return payload
  }

  const generateCommitMessage = (changes) => {
    if (!Array.isArray(changes) || changes.length === 0) {
      return "Update files"
    }
    const added = []
    const modified = []
    const deleted = []
    const renamed = []
    changes.forEach((change) => {
      const status = String(change && change.status ? change.status : "").toLowerCase()
      const name = change && change.file ? String(change.file) : "file"
      if (status.includes("new") || status.includes("add")) {
        added.push(name)
      } else if (status.includes("delete") || status.includes("remove")) {
        deleted.push(name)
      } else if (status.includes("rename") || status.includes("moved")) {
        renamed.push(name)
      } else {
        modified.push(name)
      }
    })
    const chunks = []
    if (added.length > 0) chunks.push(added.length === 1 ? `Add ${added[0]}` : `Add ${added.length} files`)
    if (modified.length > 0) chunks.push(modified.length === 1 ? `Update ${modified[0]}` : `Update ${modified.length} files`)
    if (deleted.length > 0) chunks.push(deleted.length === 1 ? `Delete ${deleted[0]}` : `Delete ${deleted.length} files`)
    if (renamed.length > 0) chunks.push(renamed.length === 1 ? `Rename ${renamed[0]}` : `Rename ${renamed.length} files`)
    if (chunks.length === 0) {
      return changes.length === 1 ? `Update ${changes[0].file}` : `Update ${changes.length} files`
    }
    return chunks.join(", ")
  }

  const createCommitItem = (commitData) => {
    const commit = commitData && commitData.commit ? commitData.commit : null
    const oid = commitData && commitData.oid ? String(commitData.oid) : ""
    const info = commitData && commitData.info ? String(commitData.info) : ""
    const author = commit && commit.author ? commit.author : { name: "Unknown", timestamp: 0 }
    const rawMessage = commit && commit.message ? String(commit.message) : "Commit"
    const shortMessage = rawMessage.trim().split("\n")[0] || "Commit"
    const timestampMs = Number(author && author.timestamp ? author.timestamp : 0) * 1000
    const timeAgo = formatTimeAgo(timestampMs) || new Date(timestampMs || Date.now()).toLocaleString()
    return `
      <button type="button" class="pinokio-git-commit-item" data-commit-info="${escapeHtml(info)}">
        <div class="pinokio-git-commit-avatar"><i class="fa-solid fa-code-commit" aria-hidden="true"></i></div>
        <div class="pinokio-git-commit-content">
          <div class="pinokio-git-commit-message" title="${escapeHtml(rawMessage)}">${escapeHtml(shortMessage)}</div>
          <div class="pinokio-git-commit-meta">
            <span class="pinokio-git-commit-author">${escapeHtml(author && author.name ? author.name : "Unknown")}</span>
            <span class="pinokio-git-commit-time">${escapeHtml(timeAgo)}</span>
            ${oid ? `<span class="pinokio-git-commit-hash" title="${escapeHtml(oid)}">${escapeHtml(oid.slice(0, 7))}</span>` : ""}
          </div>
        </div>
      </button>
    `
  }

  const renderDiff = (diffData, container) => {
    const lines = diffData && Array.isArray(diffData.diff) ? diffData.diff : []
    if (!lines.length) {
      container.innerHTML = '<div class="pinokio-git-diff-empty-state">No changes to display</div>'
      return
    }
    const formatLineNumber = (value) => (value === null || typeof value === "undefined" ? "" : String(value))
    const html = lines.map((line) => {
      const oldNumber = formatLineNumber(line.lineOld)
      const newNumber = formatLineNumber(line.lineNew)
      let cssClass = "pinokio-diff-code-line"
      if (line.type === "add") {
        cssClass += " pinokio-diff-code-line-addition"
      } else if (line.type === "del") {
        cssClass += " pinokio-diff-code-line-deletion"
      } else {
        cssClass += " pinokio-diff-code-line-context"
      }
      const escapedLine = String(line.line || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
      return `
        <div class="${cssClass}">
          <span class="pinokio-diff-code-line-numbers">
            <span class="pinokio-diff-line-number pinokio-diff-line-number--old">${oldNumber}</span>
            <span class="pinokio-diff-line-number pinokio-diff-line-number--new">${newNumber}</span>
          </span>
          <span class="pinokio-diff-code-line-content">${escapedLine}</span>
        </div>
      `
    }).join("")
    container.innerHTML = html
  }

  const openCheckoutTerminal = (src) => {
    const overlay = document.createElement("div")
    overlay.className = "pinokio-custom-terminal-overlay"
    overlay.innerHTML = `
      <div class="pinokio-custom-terminal-modal">
        <div class="pinokio-custom-terminal-header">
          <h3>Git Checkout</h3>
          <button class="pinokio-custom-terminal-close" type="button" aria-label="Close">x</button>
        </div>
        <div class="pinokio-custom-terminal-body">
          <iframe src="${src}" frameborder="0" allow="fullscreen *;" allowfullscreen></iframe>
        </div>
      </div>
    `
    const cleanup = () => {
      document.removeEventListener("keydown", onEsc)
      if (overlay.parentNode) {
        overlay.parentNode.removeChild(overlay)
      }
    }
    const closeBtn = overlay.querySelector(".pinokio-custom-terminal-close")
    if (closeBtn) {
      closeBtn.addEventListener("click", cleanup)
    }
    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) {
        cleanup()
      }
    })
    const onEsc = (event) => {
      if (event.key === "Escape") {
        cleanup()
      }
    }
    document.addEventListener("keydown", onEsc)
    document.body.appendChild(overlay)
  }

  const showCommitDiffModalQueued = async (diffData) => {
    const changes = diffData && Array.isArray(diffData.changes) ? diffData.changes : []
    if (!changes.length) {
      return
    }
    const commitOid = typeof diffData.oid === "string"
      ? diffData.oid
      : (Array.isArray(changes) && changes[0] && typeof changes[0].ref === "string" ? changes[0].ref : "")
    let commitCheckoutCwd = ""
    try {
      const commitUrlValue = diffData && typeof diffData.git_commit_url === "string" ? diffData.git_commit_url : ""
      if (commitUrlValue) {
        const commitUrlObj = new URL(commitUrlValue, window.location.origin)
        commitCheckoutCwd = commitUrlObj.searchParams.get("cwd") || ""
      }
    } catch (error) {
      commitCheckoutCwd = ""
    }
    const checkoutUrl = commitOid && commitCheckoutCwd
      ? `/run/scripts/git/checkout.json?cwd=${encodeURIComponent(commitCheckoutCwd)}&commit=${encodeURIComponent(commitOid)}&callback_target=parent&callback=$location.href`
      : ""

    const overlay = document.createElement("div")
    overlay.className = "pinokio-custom-commit-overlay"
    overlay.innerHTML = `
      <div class="pinokio-custom-commit-modal">
        <div class="pinokio-custom-commit-header">
          <h3>Commit Changes</h3>
          <button class="pinokio-custom-commit-close" type="button" aria-label="Close">x</button>
        </div>
        <div class="pinokio-custom-commit-content">
          <div class="pinokio-git-diff-main-container">
            <div class="pinokio-git-diff-file-list-panel">
              ${changes.map((change, index) => `
                <div class="pinokio-git-diff-file-item-row" role="button" tabindex="0" data-index="${index}" data-diffpath="${escapeHtml(change.diffpath || "")}" data-filepath="${escapeHtml(change.file || "")}" data-abspath="${escapeHtml(change.path || "")}" data-status="${escapeHtml(change.status || "")}">
                  <span class="pinokio-git-diff-file">${escapeHtml(change.file || "")}</span>
                  <span class="pinokio-git-diff-status">${escapeHtml(change.status || "")}</span>
                </div>
              `).join("")}
            </div>
            <div class="pinokio-git-diff-viewer-panel">
              <div class="pinokio-git-diff-empty-state">Select a file to view its changes</div>
            </div>
          </div>
          ${checkoutUrl ? `
            <div class="pinokio-git-commit-actions">
              <button type="button" class="pinokio-git-commit-switch-btn">
                <i class="fa-solid fa-clock-rotate-left"></i> Switch to this version
              </button>
            </div>
          ` : ""}
        </div>
      </div>
    `
    document.body.appendChild(overlay)
    const closeBtn = overlay.querySelector(".pinokio-custom-commit-close")
    const cleanup = () => {
      document.removeEventListener("keydown", onEsc)
      if (overlay.parentNode) {
        overlay.parentNode.removeChild(overlay)
      }
    }
    if (closeBtn) {
      closeBtn.addEventListener("click", cleanup)
    }
    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) {
        cleanup()
      }
    })
    const onEsc = (event) => {
      if (event.key === "Escape") {
        cleanup()
      }
    }
    document.addEventListener("keydown", onEsc)
    const fileItems = overlay.querySelectorAll(".pinokio-git-diff-file-item-row")
    const diffViewer = overlay.querySelector(".pinokio-git-diff-viewer-panel")
    fileItems.forEach((item) => {
      item.addEventListener("click", async (event) => {
        event.preventDefault()
        event.stopPropagation()
        fileItems.forEach((entry) => entry.classList.remove("pinokio-active-file-item"))
        item.classList.add("pinokio-active-file-item")
        const diffPath = item.getAttribute("data-diffpath") || ""
        const filePath = item.getAttribute("data-filepath") || ""
        const headerHtml = `
          <div class="pinokio-git-diff-viewer-header">
            <div class="pinokio-git-diff-viewer-title">${escapeHtml(filePath || "Selected file")}</div>
          </div>
        `
        if (diffViewer) {
          diffViewer.innerHTML = `${headerHtml}<div class="pinokio-git-diff-viewer-body"><div class="pinokio-git-diff-empty-state">Loading...</div></div>`
        }
        const diffBody = diffViewer ? diffViewer.querySelector(".pinokio-git-diff-viewer-body") : null
        try {
          const diffResponse = await fetch(diffPath)
          if (!diffResponse.ok) {
            throw new Error(`HTTP ${diffResponse.status}`)
          }
          const payload = await diffResponse.json()
          if (diffBody) {
            renderDiff(payload, diffBody)
          }
        } catch (error) {
          if (diffBody) {
            diffBody.innerHTML = '<div class="pinokio-git-diff-empty-state">Error loading diff</div>'
          }
        }
      })
    })
    if (checkoutUrl) {
      const switchBtn = overlay.querySelector(".pinokio-git-commit-switch-btn")
      if (switchBtn) {
        switchBtn.addEventListener("click", () => {
          cleanup()
          showIframeView(checkoutUrl)
        })
      }
    }
  }

  const showCommitDiffModal = async (commitInfoUrl) => {
    const url = normalizeIndex(commitInfoUrl)
    if (!url) {
      return
    }
    try {
      const response = await fetch(url)
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`)
      }
      const payload = await response.json()
      await showCommitDiffModalQueued(payload)
    } catch (error) {
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Error",
          text: error && error.message ? error.message : "Failed to load commit changes.",
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      }
    }
  }

  const displayGitHistory = (historyData, options = {}) => {
    const repoPath = normalizeIndex(options && options.repoPath ? options.repoPath : "")
    const repoName = normalizeIndex(options && options.repoName ? options.repoName : "")
    const repoData = options && typeof options === "object" ? options.repoData : null
    const commits = Array.isArray(historyData && historyData.log) ? historyData.log : []
    const remote = historyData && historyData.remote ? historyData.remote : ""
    const currentRef = historyData && historyData.ref ? historyData.ref : "HEAD"
    const branchEntries = Array.isArray(historyData && historyData.branches) ? historyData.branches : []
    const isOid = (value) => typeof value === "string" && /^[0-9a-f]{7,40}$/i.test(value)
    const realBranchEntries = branchEntries.filter((entry) => entry && typeof entry.branch === "string" && entry.branch.length > 0 && !isOid(entry.branch))
    const selectedBranchName = (historyData && typeof historyData.branch === "string" && !isOid(historyData.branch)) ? historyData.branch : null
    const subtitle = `${commits.length} commit${commits.length === 1 ? "" : "s"}`
    const historyTitle = repoName ? `${repoName} history` : "Repository history"
    const metaBadges = [`<span class="pinokio-pill"><i class="fa-solid fa-code-branch"></i>${escapeHtml(currentRef)}</span>`]
    if (remote) {
      metaBadges.push(`<span class="pinokio-pill"><i class="fa-solid fa-cloud-arrow-up"></i>${escapeHtml(remote)}</span>`)
    }
    const html = `
      <div class="pinokio-modal-surface pinokio-modal-surface--history">
        <div class="pinokio-modal-header">
          <div class="pinokio-modal-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
          <div class="pinokio-modal-heading">
            <div class="pinokio-modal-title">${escapeHtml(historyTitle)}</div>
            <div class="pinokio-modal-subtitle">${escapeHtml(subtitle)}</div>
          </div>
        </div>
        ${metaBadges.length ? `<div class="pinokio-history-meta">${metaBadges.join("")}</div>` : ""}
        <div class="pinokio-history-latest-banner" data-history-latest-banner>
          <div class="pinokio-history-latest-text">Currently viewing ${escapeHtml(currentRef)}</div>
          <div class="pinokio-history-actions">
            <button type="button" class="pinokio-history-latest-btn" data-history-return-head>
              <i class="fa-solid fa-arrow-rotate-left"></i> Return to newest commit
            </button>
            ${realBranchEntries.length ? `
              <select class="pinokio-modal-input pinokio-history-branch-select" data-history-branch-select aria-label="Select branch">
                ${realBranchEntries.map((entry) => `
                  <option value="${escapeHtml(entry.branch)}"${selectedBranchName === entry.branch ? " selected" : ""}>${escapeHtml(entry.branch)}</option>
                `).join("")}
              </select>
              <button type="button" class="pinokio-history-latest-btn" data-history-branch-switch>
                <i class="fa-solid fa-code-branch"></i> Switch
              </button>
            ` : ""}
          </div>
        </div>
        <div class="pinokio-modal-body pinokio-modal-body--history">
          ${commits.length === 0
            ? '<div class="pinokio-history-empty">No commits found</div>'
            : `<div class="pinokio-git-history-list">${commits.map((commit) => createCommitItem(commit)).join("")}</div>`
          }
        </div>
      </div>
    `
    Swal.fire({
      html,
      customClass: {
        popup: "pinokio-modern-modal pinokio-history-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close"
      },
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(900px, 94vw)",
      showConfirmButton: false,
      showCloseButton: true,
      buttonsStyling: false,
      didOpen: () => {
        const commitItems = document.querySelectorAll(".pinokio-git-commit-item[data-commit-info]")
        commitItems.forEach((item) => {
          item.addEventListener("click", async () => {
            const info = item.getAttribute("data-commit-info") || ""
            if (info) {
              await showCommitDiffModal(info)
            }
          })
        })
        const banner = document.querySelector("[data-history-latest-banner]")
        const returnBtn = document.querySelector("[data-history-return-head]")
        const branchSelect = document.querySelector("[data-history-branch-select]")
        const branchSwitchBtn = document.querySelector("[data-history-branch-switch]")
        const checkoutCwd = normalizeIndex(historyData && historyData.dir ? historyData.dir : repoPath)
        if (branchSelect && checkoutCwd) {
          branchSelect.addEventListener("change", () => {
            const branch = normalizeIndex(branchSelect.value)
            if (!branch) {
              return
            }
            const url = `/run/scripts/git/checkout.json?cwd=${encodeURIComponent(checkoutCwd)}&commit=${encodeURIComponent(branch)}&callback_target=parent&callback=$location.href`
            openCheckoutTerminal(url)
          })
        }
        if (branchSwitchBtn && branchSelect && checkoutCwd) {
          branchSwitchBtn.addEventListener("click", () => {
            const branch = normalizeIndex(branchSelect.value)
            if (!branch) {
              return
            }
            const url = `/run/scripts/git/checkout.json?cwd=${encodeURIComponent(checkoutCwd)}&commit=${encodeURIComponent(branch)}&callback_target=parent&callback=$location.href`
            openCheckoutTerminal(url)
          })
        }
        if (returnBtn) {
          const realBranches = realBranchEntries
            .map((entry) => entry && entry.branch ? entry.branch : "")
            .filter(Boolean)
          let checkoutTarget = ""
          if (repoData && typeof repoData.branch === "string" && repoData.branch.length > 0 && !isOid(repoData.branch)) {
            checkoutTarget = repoData.branch
          } else if (historyData && typeof historyData.branch === "string" && historyData.branch.length > 0 && !isOid(historyData.branch)) {
            checkoutTarget = historyData.branch
          } else if (realBranches.length > 0) {
            const preferred = ["main", "master", "develop", "dev"]
            checkoutTarget = preferred.find((branch) => realBranches.includes(branch)) || realBranches[0]
          }
          if (checkoutCwd && checkoutTarget) {
            const checkoutUrl = `/run/scripts/git/checkout.json?cwd=${encodeURIComponent(checkoutCwd)}&commit=${encodeURIComponent(checkoutTarget)}&callback_target=parent&callback=$location.href`
            returnBtn.addEventListener("click", () => {
              openCheckoutTerminal(checkoutUrl)
            })
          } else {
            returnBtn.disabled = true
            if (banner) {
              banner.classList.add("pinokio-history-latest-banner--disabled")
            }
          }
        }
      }
    })
  }

  const showGitHistoryModal = async (options = {}) => {
    const repoPath = normalizeIndex(options && options.repoPath ? options.repoPath : activeTerminalRepoKey)
    if (!repoPath) {
      return
    }
    const repoData = terminalRepoCache.get(repoPath) || null
    const repoName = resolveRepoDisplayName(repoPath, repoData, options && options.repoName ? options.repoName : "")
    const historyUrl = resolveRepoHistoryUrl(repoPath, repoData, options && options.historyUrl ? options.historyUrl : "")
    if (!historyUrl) {
      return
    }
    try {
      const response = await fetch(historyUrl)
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`)
      }
      const historyData = await response.json()
      displayGitHistory(historyData, {
        repoPath,
        repoName,
        repoData
      })
    } catch (error) {
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "Error",
          text: error && error.message ? error.message : "Failed to load git history.",
          icon: "error",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      }
    }
  }

  const showGitDiffModal = async (options = {}) => {
    const repoPath = normalizeIndex(options && options.repoPath ? options.repoPath : activeTerminalRepoKey)
      || normalizeIndex(Array.from(terminalRepoCache.keys())[0] || "")
    if (!repoPath) {
      if (typeof Swal !== "undefined" && Swal && typeof Swal.fire === "function") {
        await Swal.fire({
          title: "No repositories",
          text: "No Git repositories were detected for this workspace.",
          icon: "info",
          customClass: {
            popup: "terminals-confirm-modal"
          }
        })
      }
      return
    }
    activeTerminalRepoKey = repoPath
    let repoData = terminalRepoCache.get(repoPath) || {
      repoKey: repoPath,
      repoDir: repoPath,
      name: getWorkspaceNameFromPath(repoPath),
      changes: [],
      changeCount: 0,
      git_commit_url: "",
      git_history_url: ""
    }
    let repoName = resolveRepoDisplayName(repoPath, repoData, options && options.repoName ? options.repoName : "")
    let changes = Array.isArray(repoData.changes) ? repoData.changes.slice() : []
    let commitUrl = normalizeIndex(repoData.git_commit_url)
    let historyUrl = resolveRepoHistoryUrl(repoPath, repoData)
    let hasHead = Boolean(repoData.hasHead)
    const forceRefresh = Boolean(options && options.forceRefresh)

    try {
      if (forceRefresh || changes.length === 0) {
        const commitEndpoint = `/terminals/git/commit?repo=${encodeURIComponent(repoPath)}&ref=HEAD`
        const commitResponse = await fetch(commitEndpoint)
        if (commitResponse.ok) {
          const commitPayload = await commitResponse.json()
          changes = Array.isArray(commitPayload && commitPayload.changes) ? commitPayload.changes : []
          commitUrl = normalizeIndex(commitPayload && commitPayload.git_commit_url ? commitPayload.git_commit_url : commitUrl)
        }
      }
      const infoEndpoint = `/terminals/git/info?repo=${encodeURIComponent(repoPath)}&ref=HEAD`
      const infoResponse = await fetch(infoEndpoint)
      if (infoResponse.ok) {
        const infoPayload = await infoResponse.json()
        hasHead = Boolean(infoPayload && infoPayload.hasHead)
        historyUrl = resolveRepoHistoryUrl(repoPath, repoData, infoPayload && infoPayload.git_history_url ? infoPayload.git_history_url : historyUrl)
        if (!commitUrl) {
          commitUrl = normalizeIndex(infoPayload && infoPayload.git_commit_url ? infoPayload.git_commit_url : "")
        }
        repoData = {
          ...repoData,
          ...infoPayload
        }
        repoName = resolveRepoDisplayName(repoPath, repoData, repoName)
      }
    } catch (error) {
    }

    repoData = {
      ...repoData,
      repoKey: repoPath,
      repoDir: repoPath,
      name: repoName,
      changes,
      changeCount: changes.length,
      git_commit_url: commitUrl,
      git_history_url: historyUrl,
      hasHead: Boolean(hasHead)
    }
    terminalRepoCache.set(repoPath, repoData)
    await refreshWorkspaceGitForRepo(repoPath, { force: true }).catch(() => {})

    if ((!changes || changes.length === 0) && hasHead) {
      await showGitHistoryModal({
        repoPath,
        repoName,
        historyUrl
      })
      return
    }

    const title = `File Changes${repoName ? ` - ${repoName}` : ""}`
    const changeSummary = changes && changes.length > 0
      ? `${changes.length} file${changes.length === 1 ? "" : "s"} changed`
      : "No tracked changes yet"
    const firstCommitNote = !hasHead
      ? `<div class="pinokio-git-first-commit-note">No commits yet. Save your first commit to unlock history and rollback features.</div>`
      : ""
    const showCommitFooter = Boolean(options && Object.prototype.hasOwnProperty.call(options, "showSaveButton"))
      ? Boolean(options.showSaveButton)
      : true
    const commitSection = showCommitFooter ? `
      <div class="pinokio-modal-footer pinokio-modal-footer--commit">
        <div class="pinokio-commit-message-container">
          <input type="text" class="pinokio-modal-input pinokio-commit-message-input" placeholder="Enter commit message..." value="${escapeHtml(generateCommitMessage(changes))}">
          <div class="pinokio-commit-actions">
            <button type="button" class="pinokio-save-version-btn"${changes.length === 0 ? " disabled" : ""}>Save selected</button>
          </div>
        </div>
      </div>
    ` : ""
    const historyTabDisabled = historyUrl ? "" : " disabled"
    const modalHtml = `
      <div class="pinokio-modal-surface pinokio-modal-surface--diff">
        <div class="pinokio-modal-header">
          <div class="pinokio-modal-icon"><i class="fa-solid fa-code-branch"></i></div>
          <div class="pinokio-modal-heading">
            <div class="pinokio-modal-title">${escapeHtml(title)}</div>
            <div class="pinokio-modal-subtitle">${escapeHtml(changeSummary)}</div>
          </div>
        </div>
        ${firstCommitNote}
        <div class="pinokio-modal-tabs">
          <button type="button" class="pinokio-modal-tab pinokio-modal-tab--active" data-tab-target="changes">
            <i class="fa-solid fa-code-compare"></i> Changes
          </button>
          <button type="button" class="pinokio-modal-tab"${historyTabDisabled} data-tab-target="history">
            <i class="fa-solid fa-clock-rotate-left"></i> History
          </button>
        </div>
        <div class="pinokio-modal-body pinokio-modal-body--diff" data-tab-panel="changes">
          <div class="pinokio-git-diff-main-container">
            <div class="pinokio-git-diff-file-list-panel">
              <div class="pinokio-git-diff-file-item-row pinokio-git-diff-select-all">
                <input type="checkbox" class="pinokio-git-diff-file-checkbox" data-select-all checked>
                <span class="pinokio-git-diff-file">Select all</span>
                <span></span>
              </div>
              ${changes.map((change, index) => `
                <div class="pinokio-git-diff-file-item-row" role="button" tabindex="0" data-index="${index}" data-diffpath="${escapeHtml(change.diffpath || "")}" data-filepath="${escapeHtml(change.file || "")}" data-abspath="${escapeHtml(change.path || "")}" data-status="${escapeHtml(change.status || "")}">
                  <input type="checkbox" class="pinokio-git-diff-file-checkbox" data-file-checkbox data-index="${index}" checked>
                  <span class="pinokio-git-diff-file">${escapeHtml(change.file || "")}</span>
                  <span class="pinokio-git-diff-status">${escapeHtml(change.status || "")}</span>
                </div>
              `).join("")}
            </div>
            <div class="pinokio-git-diff-viewer-panel">
              <div class="pinokio-git-diff-empty-state">${changes.length > 0 ? "Select a file to view its changes" : "No files to show yet."}</div>
            </div>
          </div>
        </div>
        <div class="pinokio-modal-body pinokio-modal-body--history" data-tab-panel="history" style="display:none">
          <div class="pinokio-git-diff-empty-state">${historyUrl ? "Loading history..." : "History unavailable"}</div>
        </div>
        ${commitSection}
      </div>
    `

    await Swal.fire({
      html: modalHtml,
      customClass: {
        popup: "pinokio-modern-modal pinokio-diff-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close"
      },
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(980px, 96vw)",
      showCloseButton: true,
      showConfirmButton: false,
      showCancelButton: false,
      buttonsStyling: false,
      willClose: () => {
        if (terminalGitMessageListener) {
          window.removeEventListener("message", terminalGitMessageListener)
          terminalGitMessageListener = null
        }
      },
      didOpen: () => {
        const container = Swal.getHtmlContainer()
        if (!container) {
          return
        }
        const fileItems = container.querySelectorAll(".pinokio-git-diff-file-item-row[data-index]")
        const fileCheckboxes = container.querySelectorAll("[data-file-checkbox]")
        const selectAllCheckbox = container.querySelector("[data-select-all]")
        const diffViewer = container.querySelector(".pinokio-git-diff-viewer-panel")
        const tabButtons = container.querySelectorAll(".pinokio-modal-tab")
        const tabPanels = container.querySelectorAll("[data-tab-panel]")
        const historyPanel = container.querySelector('[data-tab-panel="history"]')
        const commitFooter = container.querySelector(".pinokio-modal-footer--commit")
        let historyLoaded = false
        let repoCwd = repoPath
        if (diffViewer && repoCwd) {
          diffViewer.setAttribute("data-repo-cwd", repoCwd)
        }
        const saveBtn = container.querySelector(".pinokio-save-version-btn")
        const commitMessageInput = container.querySelector(".pinokio-commit-message-input")
        const getCommitMessage = () => commitMessageInput ? String(commitMessageInput.value || "").trim() : ""
        const fileItemsArray = Array.from(fileItems)
        const checkboxMap = new Map()
        fileCheckboxes.forEach((checkbox) => {
          const idx = Number(checkbox.getAttribute("data-index") || "-1")
          checkboxMap.set(idx, checkbox)
        })
        const selectedIndices = new Set(fileItemsArray.map((item) => Number(item.getAttribute("data-index") || "-1")))
        const getSelectedEntries = () => {
          const entries = []
          fileItemsArray.forEach((item) => {
            const idx = Number(item.getAttribute("data-index") || "-1")
            if (!selectedIndices.has(idx)) {
              return
            }
            const statusText = item.getAttribute("data-status") || ""
            const filePath = item.getAttribute("data-filepath") || ""
            const absolutePath = item.getAttribute("data-abspath") || ""
            const selectedPath = absolutePath || filePath
            if (!selectedPath) {
              return
            }
            entries.push({
              status: statusText,
              filePath,
              path: selectedPath
            })
          })
          return entries
        }
        const fileListPanel = container.querySelector(".pinokio-git-diff-file-list-panel")
        const bulkResetButton = document.createElement("button")
        bulkResetButton.type = "button"
        bulkResetButton.className = "pinokio-git-diff-revert-btn pinokio-git-diff-bulk-btn"
        bulkResetButton.disabled = true
        bulkResetButton.textContent = "Reset selected"
        const bulkResetContainer = document.createElement("div")
        bulkResetContainer.className = "pinokio-git-diff-bulk-bar"
        bulkResetContainer.setAttribute("data-bulk-bar", "true")
        bulkResetContainer.appendChild(bulkResetButton)
        if (fileListPanel) {
          fileListPanel.insertBefore(bulkResetContainer, fileListPanel.firstChild)
        }

        const applySelectionClasses = () => {
          fileItemsArray.forEach((item) => {
            const idx = Number(item.getAttribute("data-index") || "-1")
            const selected = selectedIndices.has(idx)
            item.classList.toggle("pinokio-active-file-item", selected)
            const checkbox = checkboxMap.get(idx)
            if (checkbox) {
              checkbox.checked = selected
            }
          })
          if (selectAllCheckbox) {
            const total = fileItemsArray.length
            const selectedCount = selectedIndices.size
            selectAllCheckbox.indeterminate = selectedCount > 0 && selectedCount < total
            selectAllCheckbox.checked = selectedCount === total
          }
          updateBulkBar()
        }

        const updateBulkBar = () => {
          const selectedEntries = getSelectedEntries()
          const selectionCount = selectedEntries.length
          const trackedPaths = []
          const untrackedPaths = []
          selectedEntries.forEach((entry) => {
            if (isUntrackedStatus(entry.status)) {
              untrackedPaths.push(entry.path)
            } else {
              trackedPaths.push(entry.path)
            }
          })
          const viewerCwd = (diffViewer && diffViewer.getAttribute("data-repo-cwd")) || repoCwd || ""
          const hasTarget = Boolean(viewerCwd && (trackedPaths.length > 0 || untrackedPaths.length > 0) && selectionCount > 0)
          bulkResetButton.textContent = `Reset selected (${selectionCount})`
          bulkResetButton.disabled = selectionCount === 0
          bulkResetButton.onclick = null
          bulkResetButton.onclick = async () => {
            if (!hasTarget) {
              return
            }
            const confirmed = await showResetSelectedFilesConfirmModal(selectionCount)
            if (!confirmed) {
              return
            }
            try {
              await resetSelectedGitFilesWithProgress({
                cwd: viewerCwd,
                trackedPaths,
                untrackedPaths,
                selectionCount
              })
              await refreshWorkspaceGitForRepo(repoPath, { force: true }).catch(() => {})
              await showGitDiffModal({
                repoPath,
                forceRefresh: true
              })
            } catch (error) {
              await Swal.fire({
                icon: "error",
                title: "Reset failed",
                text: error && error.message ? error.message : "Failed to reset selected files."
              })
            }
          }
        }

        const renderFileDiff = async (item) => {
          const diffPath = item.getAttribute("data-diffpath")
          const filePath = item.getAttribute("data-filepath") || ""
          const absolutePath = item.getAttribute("data-abspath") || ""
          const headerHtml = `
            <div class="pinokio-git-diff-viewer-header">
              <div class="pinokio-git-diff-viewer-title">${escapeHtml(filePath || "Selected file")}</div>
              ${absolutePath ? `
                <button type="button" class="pinokio-git-diff-open-file" data-open-path="${escapeHtml(absolutePath)}">
                  <i class="fa-solid fa-folder-open"></i>
                  Open in explorer
                </button>
              ` : ""}
            </div>
          `
          if (diffViewer) {
            diffViewer.innerHTML = `${headerHtml}<div class="pinokio-git-diff-viewer-body"><div class="pinokio-git-diff-empty-state">Loading...</div></div>`
          }
          const diffBody = diffViewer ? diffViewer.querySelector(".pinokio-git-diff-viewer-body") : null
          try {
            const response = await fetch(diffPath)
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`)
            }
            const payload = await response.json()
            if (diffBody) {
              renderDiff(payload, diffBody)
            }
            const openButton = diffViewer ? diffViewer.querySelector(".pinokio-git-diff-open-file") : null
            if (openButton) {
              openButton.addEventListener("click", async (event) => {
                event.preventDefault()
                event.stopPropagation()
                const pathToOpen = openButton.getAttribute("data-open-path") || ""
                if (!pathToOpen) {
                  return
                }
                await openInFileExplorer(pathToOpen, "view")
              })
            }
          } catch (error) {
            if (diffBody) {
              diffBody.innerHTML = '<div class="pinokio-git-diff-empty-state">Error loading diff</div>'
            }
          }
        }

        fileItemsArray.forEach((item) => {
          item.addEventListener("click", async (event) => {
            const targetIsCheckbox = event.target && event.target.hasAttribute && event.target.hasAttribute("data-file-checkbox")
            if (!targetIsCheckbox) {
              event.preventDefault()
              event.stopPropagation()
            }
            const index = Number(item.getAttribute("data-index") || "-1")
            if (!targetIsCheckbox) {
              await renderFileDiff(item)
              return
            }
            const checkbox = checkboxMap.get(index)
            const checked = checkbox ? checkbox.checked : selectedIndices.has(index)
            if (checked) {
              selectedIndices.add(index)
            } else {
              selectedIndices.delete(index)
            }
            applySelectionClasses()
            await renderFileDiff(item)
          })
        })

        fileCheckboxes.forEach((checkbox) => {
          checkbox.addEventListener("click", (event) => {
            event.stopPropagation()
          })
          checkbox.addEventListener("change", async () => {
            const index = Number(checkbox.getAttribute("data-index") || "-1")
            if (checkbox.checked) {
              selectedIndices.add(index)
            } else {
              selectedIndices.delete(index)
            }
            applySelectionClasses()
            const item = fileItemsArray.find((entry) => Number(entry.getAttribute("data-index") || "-1") === index)
            if (item) {
              await renderFileDiff(item)
            }
          })
        })

        if (selectAllCheckbox) {
          selectAllCheckbox.addEventListener("change", () => {
            if (selectAllCheckbox.checked) {
              fileItemsArray.forEach((item) => {
                const index = Number(item.getAttribute("data-index") || "-1")
                selectedIndices.add(index)
              })
            } else {
              selectedIndices.clear()
            }
            applySelectionClasses()
            const activeItem = fileItemsArray.find((entry) => entry.classList.contains("pinokio-active-file-item"))
            if (activeItem) {
              void renderFileDiff(activeItem)
            }
          })
          selectAllCheckbox.addEventListener("click", (event) => {
            event.stopPropagation()
          })
        }

        applySelectionClasses()

        if (saveBtn) {
          saveBtn.addEventListener("click", () => {
            const selectedEntries = getSelectedEntries()
            if (!selectedEntries.length) {
              return
            }
            const trackedPaths = []
            const untrackedPaths = []
            selectedEntries.forEach((entry) => {
              if (isUntrackedStatus(entry.status)) {
                untrackedPaths.push(entry.path)
              } else {
                trackedPaths.push(entry.path)
              }
            })
            const trackedArg = buildPathArgs(trackedPaths)
            const untrackedArg = buildPathArgs(untrackedPaths)
            if (!trackedArg && !untrackedArg) {
              return
            }
            const viewerCwd = repoCwd || repoPath
            const commitMessage = getCommitMessage()
            const parts = [`/run/scripts/git/commit_files.json?cwd=${encodeURIComponent(viewerCwd)}`]
            if (commitMessage) {
              parts.push(`message=${encodeURIComponent(commitMessage)}`)
            }
            if (trackedArg) {
              parts.push(`paths=${encodeURIComponent(trackedArg)}`)
            }
            if (untrackedArg) {
              parts.push(`untracked_paths=${encodeURIComponent(untrackedArg)}`)
            }
            parts.push("callback_target=parent")
            parts.push("callback=$location.href")
            const url = parts.join("&")
            showIframeView(url)
          })
        }

        const renderHistoryInline = (historyData) => {
          if (!historyPanel) {
            return
          }
          const commits = Array.isArray(historyData && historyData.log) ? historyData.log : []
          const remoteName = historyData && historyData.remote ? historyData.remote : ""
          const currentRef = historyData && historyData.ref ? historyData.ref : "HEAD"
          const badges = [`<span class="pinokio-pill"><i class="fa-solid fa-code-branch"></i>${escapeHtml(currentRef)}</span>`]
          if (remoteName) {
            badges.push(`<span class="pinokio-pill"><i class="fa-solid fa-cloud-arrow-up"></i>${escapeHtml(remoteName)}</span>`)
          }
          const commitMarkup = commits.length
            ? `<div class="pinokio-git-history-list">${commits.map((commit) => createCommitItem(commit)).join("")}</div>`
            : '<div class="pinokio-history-empty">No commits found</div>'
          historyPanel.innerHTML = `
            <div class="pinokio-history-inline-head">
              <div class="pinokio-history-meta">${badges.join("")}</div>
              <div class="pinokio-history-inline-actions">
                <button type="button" class="pinokio-history-inline-btn" data-open-full-history>
                  <i class="fa-solid fa-up-right-from-square"></i> Open full history
                </button>
              </div>
            </div>
            ${commitMarkup}
          `
          historyPanel.querySelectorAll(".pinokio-git-commit-item").forEach((item) => {
            item.addEventListener("click", async () => {
              const info = item.getAttribute("data-commit-info")
              if (info) {
                await showCommitDiffModal(info)
              }
            })
          })
          const fullHistoryBtn = historyPanel.querySelector("[data-open-full-history]")
          if (fullHistoryBtn) {
            if (!historyUrl) {
              fullHistoryBtn.disabled = true
            } else {
              fullHistoryBtn.addEventListener("click", () => {
                Swal.close()
                void showGitHistoryModal({
                  repoPath,
                  repoName,
                  historyUrl
                })
              })
            }
          }
        }

        const loadHistory = async () => {
          if (historyLoaded || !historyPanel) {
            return
          }
          if (!historyUrl) {
            historyPanel.innerHTML = '<div class="pinokio-git-diff-empty-state">History unavailable</div>'
            return
          }
          historyPanel.innerHTML = '<div class="pinokio-git-diff-empty-state">Loading history...</div>'
          try {
            const response = await fetch(historyUrl)
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`)
            }
            const payload = await response.json()
            historyLoaded = true
            renderHistoryInline(payload)
          } catch (error) {
            historyLoaded = false
            historyPanel.innerHTML = '<div class="pinokio-git-diff-empty-state">Unable to load history</div>'
          }
        }

        const setActiveTab = (tabName) => {
          tabButtons.forEach((button) => {
            const active = button.getAttribute("data-tab-target") === tabName
            button.classList.toggle("pinokio-modal-tab--active", active)
          })
          tabPanels.forEach((panel) => {
            const isTarget = panel.getAttribute("data-tab-panel") === tabName
            panel.style.display = isTarget ? "" : "none"
          })
          if (commitFooter) {
            commitFooter.style.display = tabName === "changes" ? "" : "none"
          }
          if (tabName === "history") {
            void loadHistory()
          }
        }

        tabButtons.forEach((button) => {
          if (button.disabled) {
            return
          }
          button.addEventListener("click", () => {
            const target = button.getAttribute("data-tab-target") || "changes"
            setActiveTab(target)
          })
        })

        setActiveTab("changes")
        if (fileItemsArray.length > 0) {
          const first = fileItemsArray[0]
          const index = Number(first.getAttribute("data-index") || "-1")
          if (!selectedIndices.has(index)) {
            selectedIndices.add(index)
            applySelectionClasses()
          }
          void renderFileDiff(first)
        }
      }
    })
  }

  document.addEventListener("click", (event) => {
    const target = event && event.target ? event.target : null
    if (!target) {
      return
    }
    if (activeWorkspaceGitMenu) {
      const withinGitMenu = target.closest && target.closest(".terminals-workspace-git-menu")
      const withinGitButton = target.closest && target.closest(".terminals-workspace-git-btn")
      if (!withinGitMenu && !withinGitButton) {
        closeActiveWorkspaceGitMenu()
      }
    }
  })

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeActiveWorkspaceGitMenu()
    }
  })

  const deployLocalCopy = async ({ folderName, terminalId, sessionUri, sessionCwd }) => {
    try {
      const response = await fetch("/terminals/deploy/local", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          folderName,
          terminal_id: terminalId,
          sessionUri,
          sessionCwd
        })
      })
      let payload = null
      try {
        payload = await response.json()
      } catch (error) {
      }
      if (!response.ok) {
        const message = payload && payload.error ? payload.error : "Failed to deploy locally."
        return {
          ok: false,
          error: message
        }
      }
      return payload
    } catch (error) {
      return {
        ok: false,
        error: error && error.message ? error.message : "Failed to deploy locally."
      }
    }
  }

  const openDeployLocalModal = async (column) => {
    if (!column || !column.dataset) {
      return false
    }
    const sessionCwd = column.dataset.sessionCwd || ""
    const terminalId = normalizeTerminalId(column.dataset.sessionTerminalId || "")
    const sessionUri = column.dataset.sessionUri || ""
    if (!sessionCwd) {
      return false
    }
    if (typeof Swal === "undefined" || !Swal || typeof Swal.fire !== "function") {
      const folderName = window.prompt("Deploy to ~/pinokio/api/<folder-name>. Enter folder name:")
      if (!folderName) {
        return false
      }
      const result = await deployLocalCopy({
        folderName,
        terminalId,
        sessionUri,
        sessionCwd
      })
      if (result && result.code === "exists") {
        window.alert("Folder already exists.")
        return false
      }
      if (!result || result.ok !== true) {
        window.alert(result && result.error ? result.error : "Failed to deploy locally.")
        return false
      }
      return true
    }

    const result = await Swal.fire({
      html: `
        <div class="pinokio-modal-surface">
          <div class="pinokio-modal-header">
            <div class="pinokio-modal-icon"><i class="fa-solid fa-rocket"></i></div>
            <div class="pinokio-modal-heading">
              <div class="pinokio-modal-title">Deploy locally</div>
              <div class="pinokio-modal-subtitle">Copy this active session workspace to a new local project folder.</div>
            </div>
          </div>
          <div class="pinokio-modal-body">
            <p class="pinokio-modal-note">This will copy the current workspace to <code>~/pinokio/api/&lt;folder-name&gt;</code>.</p>
            <label class="pinokio-modal-label" for="terminals-deploy-folder-input">New folder name</label>
            <input id="terminals-deploy-folder-input" class="pinokio-modal-input" placeholder="my-local-workspace" autocomplete="off">
          </div>
        </div>
      `,
      showCancelButton: true,
      confirmButtonText: "Create",
      cancelButtonText: "Cancel",
      showCloseButton: true,
      buttonsStyling: false,
      backdrop: "rgba(9,11,15,0.65)",
      width: "min(520px, 90vw)",
      focusConfirm: false,
      showLoaderOnConfirm: true,
      allowOutsideClick: () => !Swal.isLoading(),
      customClass: {
        popup: "pinokio-modern-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close",
        confirmButton: "pinokio-modern-confirm",
        cancelButton: "pinokio-modern-cancel"
      },
      didOpen: () => {
        const input = Swal.getPopup().querySelector("#terminals-deploy-folder-input")
        if (input) {
          input.focus()
        }
      },
      preConfirm: async () => {
        const input = Swal.getPopup().querySelector("#terminals-deploy-folder-input")
        const folderName = input ? String(input.value || "").trim() : ""
        if (!folderName) {
          Swal.showValidationMessage("Enter a folder name.")
          return false
        }
        if (folderName === "." || folderName === ".." || /[\\/]/.test(folderName) || folderName.includes("\0")) {
          Swal.showValidationMessage("Folder name cannot include path separators.")
          return false
        }
        const payload = await deployLocalCopy({
          folderName,
          terminalId,
          sessionUri,
          sessionCwd
        })
        if (payload && payload.code === "exists") {
          window.alert("Folder already exists.")
          return false
        }
        if (!payload || payload.ok !== true) {
          Swal.showValidationMessage(payload && payload.error ? payload.error : "Failed to deploy locally.")
          return false
        }
        return payload
      }
    })

    if (!result || !result.isConfirmed || !result.value || result.value.ok !== true) {
      return false
    }
    await Swal.fire({
      title: "Created",
      text: `Created /api/${result.value.folder || ""}`,
      icon: "success",
      buttonsStyling: false,
      customClass: {
        popup: "pinokio-modern-modal",
        htmlContainer: "pinokio-modern-html",
        closeButton: "pinokio-modern-close",
        confirmButton: "pinokio-modern-confirm"
      }
    })
    return true
  }

  const getSessionFromColumn = (column) => {
    if (!column || !column.dataset) {
      return null
    }
    const sessionTerminalId = normalizeTerminalId(column.dataset.sessionTerminalId)
    if (sessionTerminalId) {
      const items = getDisplaySessionItems()
      for (let i = 0; i < items.length; i++) {
        const item = items[i]
        if (normalizeTerminalId(item && item.terminalId) === sessionTerminalId) {
          return item
        }
      }
    }
    const sessionIndex = normalizeIndex(column.dataset.sessionIndex)
    if (sessionIndex) {
      const items = getDisplaySessionItems()
      for (let i = 0; i < items.length; i++) {
        const item = items[i]
        if (normalizeIndex(item && item.index) === sessionIndex) {
          return item
        }
      }
    }
    const providerLabel = column.dataset.sessionProviderLabel || column.dataset.sessionProviderKey || ""
    const sessionName = column.dataset.sessionName || "Session"
    const sessionCwd = column.dataset.sessionCwd || ""
    const sessionUri = column.dataset.sessionUri || ""
    const sessionUrl = column.dataset.sessionUrl || ""
    if (!sessionUrl || sessionUrl === "#") {
      return null
    }
    return normalizeSessionItem({
      index: sessionIndex || `active-${Date.now()}`,
      name: sessionName,
      provider_label: providerLabel,
