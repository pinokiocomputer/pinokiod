  flex-grow: 1;
  min-width: 0;
  word-wrap: break-word;
}
body.dark .btn {
  background: rgba(255,255,255,0.05) !important;
}
.app-btns .btn {
  border-radius: 4px;
  padding: 8px 10px;
  width: 70px;
  /*
  padding: 6px 10px;
  */
  text-align: center;
}
body.dark .context-menu .btn {
  color: white;
}
.context-menu.collapsed {
/*
  max-height: 0; 
  */
  display: none;
}
body.dark .open-menu, body.dark .browse {
