  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<style>
.line2 {
  display: flex;
  align-items: center;
  cursor: pointer;
  background: rgba(0,0,100,0.04);
}
.line2 a {
  text-decoration: none;
  color: black;
}
a.explain {
  color: royalblue;
  text-decoration: underline; 
  cursor: pointer;
}
.status {
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}
.status.offline {
  background: silver;
}
.status.online {
  background: yellowgreen;
}
.switch {
  padding: 10px;
  margin: 10px 0;
}
.switch[data-online=true] {
  color: yellowgreen;
}
.button {
  padding: 10px;
}
.on, .off {
  display: flex;
  align-items: center;
}
header .runner {
  padding: 10px 0 0;
}
.proxy {
  padding: 0 10px;
  text-align: right;
}
.proxy a {
  text-decoration: none;
  display: inline-block;
  padding: 5px 10px;
  border-radius: 2px;
  background: black;
  color: white;
}
.browser-options-btns {
  display: flex;
  padding-top: 5px;
}
.browser-options-row {
/*
  border-top: 1px solid rgba(0,0,0,0.1);
  border-bottom: 1px solid rgba(0,0,0,0.1);
  */
  display: flex;
  padding: 10px;
  align-items: flex-start;
}
.browser-options-row h3 {
  margin: 0;
  font-size: 14px;
  margin-bottom: 3px;
}
.browser-options-row .btn.disabled {
  opacity: 0.7;
}
.browser-options-row .btn {
  font-weight: bold;
  width: 100px;
  text-align: center;
  display: block;
  margin-right: 10px;
  flex-shrink: 0;
  padding: 5px;
}
.badge {
  font-size: 12px;
  padding: 5px 10px;
  background: rgba(0,0,100,0.1);
  border-radius: 5px;
  display: inline-block;
  margin-top: 5px;
}
a.badge {
  color: royalblue;
  text-decoration: none;
  cursor: pointer;
}
.badge a {
  color: royalblue;
  text-decoration: none;
}
body.dark .btn {
  color: white;
  background: rgba(255,255,255,0.05) !important;
}
body.dark .badge {
  background: rgba(255,255,255,0.1);
}
/*
body.dark .browser-options-row {
  border-top: 1px solid rgba(255,255,255,0.05);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
*/
body.dark .context-menu-wrapper {
  background: rgba(0,0,0,0.9) !important;
  color: white !important;
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 12px 30px rgba(0,0,0,0.45);
}
.context-menu-wrapper {
  background: rgba(0,0,0,0.06) !important;
}
.context-menu {
 /* 
  max-height: 10000px;
  overflow: hidden;
  transition: max-height 1s ease-in-out;
  */
  display: flex;
  margin: 0 5px 0 0;
}
.context-menu .btn:hover {
  color: cornflowerblue !important;
}
.context-menu .btn {
  background: none !important;
  border: none !important;
  display: block;
  width: 80px;
  padding: 6px 10px !important;
  text-align: left;
  color: black;
}
.get-dns-btn {
  margin-top: 10px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  padding: 6px 10px;
  justify-content: center;
  max-width: 200px;
}
.dns-modal .header-description {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.dns-modal .header-description .bubble {
  background: rgba(0,0,0,0.05);
  padding: 12px;
  border-radius: 8px;
  font-size: 13px;
  line-height: 1.4;
}
body.dark .dns-modal .header-description .bubble {
  background: rgba(255,255,255,0.08);
}
.dns-modal .address-section {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-bottom: 15px;
}
.dns-modal .address-section input {
  padding: 10px;
  border-radius: 6px;
  border: 1px solid rgba(0,0,0,0.15);
  font-size: 14px;
}
body.dark .dns-modal .address-section input {
  background: rgba(255,255,255,0.05);
  color: white;
  border-color: rgba(255,255,255,0.18);
}
.dns-modal .address-result {
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-size: 16px;
  padding: 30px 10px;
  background: rgba(0,0,0,0.04);
  border-radius: 8px;
}
body.dark .dns-modal .address-result {
  background: rgba(255,255,255,0.08);
}
.dns-progress-modal {
  margin-top: 15px;
}
.dns-modal-terminal-container {
  width: 100%;
  height: 280px;
  background: #000;
  border-radius: 8px;
  overflow: hidden;
}
.dns-modal-terminal-container .xterm .xterm-viewport {
  width: initial !important;
}
.blank {
  width: 50px;
  height: 50px;
  flex-shrink: 0;
}
body.dark .section-header {
/*
  border-bottom: 1px solid rgba(255,255,255,0.07);
  */
}
.section-header {
/*
  border-bottom: 1px solid rgba(0, 0, 0,0.04);
  */
  font-weight: normal;
  font-size: 14px;
  padding: 15px 5px;
  /*
  margin: 0 0 15px;
  */
}
.section-header h2 {
  font-size: 20px;
}
.section-header .section {
  padding: 0;
}
.section-header .section div {
  font-weight: normal;
  opacity: 0.6;
  font-size: 14px;
}
.section-header h3 {
  display: flex;
  margin: 0;
}
.section-header .col {
  padding-left: 10px;
  flex-grow: 1;
  min-width: 0;
  word-wrap: break-word;
}
body.dark .btn {
  background: rgba(255,255,255,0.05) !important;
}
.app-btns .btn {
  border-radius: 4px;
  padding: 8px 10px;
  width: 70px;
  /*
  padding: 6px 10px;
  */
  text-align: center;
}
body.dark .context-menu .btn {
  color: white;
}
.context-menu.collapsed {
/*
  max-height: 0; 
  */
  display: none;
}
body.dark .open-menu, body.dark .browse {
  border: none !important;
  /*
  background: black !important;
  */
  color: white !important;
}
.open-menu:hover, .browse:hover, body.dark .open-menu:hover, body.dark .browse:hover {
  color: royalblue !important;
}
.open-menu, .browse {
  width: 80px;
  border-radius: 0 !important;
  background: rgba(0,0,0,0.04) !important;
  color: black !important;
  /*
  border: 1px solid rgba(0, 0, 0, 0.3);
  */
}
.open-menu.selected {
  border: none !important;
  /*
  background: none !important;
  */
}
.open-menu.selected span {
  display: none;
}
.sections {
  display: flex;
}
.section {
  display: block;
  width: 100%;
}
.section h2 {
  margin: 0;
}
.section a {
  display: flex;
  align-items: center;
}
.section a span {
  min-width: 0;
}
.line.align-top h3 .col .btn {
  box-sizing: border-box;
  margin-top: 5px;
  width: 100%;
}
.desc {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.7);
  padding: 5px 0;
}
.container {
  margin-left: 20px;
}
.section-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  /*
  grid-template-columns: repeat(3, minmax(0, 1fr));
  */
  gap: 1rem; /* Optional spacing between columns */
}
.section-container > * {
  min-width: 0;
  overflow: hidden;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  gap: 1rem; /* Optional spacing between columns */
}
.grid-1 {
  padding: 10px;
}
.grid-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); /* Responsive columns that wrap */
  gap: 1rem; /* Optional spacing between columns */
  padding: 10px;
}
.grid-3 .section > h2 {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0 0 8px;
  font-size: 12px;
}
.grid-3 > * {
  min-width: 0;
}
.section-header .grid-1, .section-header .grid-2, .section-header .grid-3 {
  background: none !important;
  padding: 0 !important;
}
.grid-1, .grid-2, .grid-3 {
  background: rgba(0,0,0,0.04);
  margin-top: 5px;
}
body.dark .grid-1, body.dark .grid-2, body.dark .grid-3 {
  background: rgba(255,255,255,0.03);
  margin-top: 5px;
}
main {
  display: flex;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
aside .tab i {
  width: 20px;
  text-align: center;
}
body.dark aside .tab {
  color: white;
}
body.dark aside .tab:hover, aside .tab:hover {
  color: royalblue !important;
  opacity: 1;
}
aside .tab {
  display: flex;
  align-items: center;
  gap: 5px;
  color: black;
  text-decoration: none;
  padding: 10px;
  font-size: 12px;
  opacity: 0.5;
  border-left: 10px solid transparent;
}
body.dark aside .tab.selected {
  color: white;
}
aside .selected {
  font-weight: bold;
  opacity: 1;
}
/*
body.dark aside .selected {
  border-left: 10px solid white;
}
aside .selected {
  border-left: 10px solid black;
  font-weight: bold;
  opacity: 1;
}
*/
.submenu .tab {
  padding: 0;
}
body.dark .net:hover, .net:hover {
  color: royalblue;
}
body.dark .net {
/*
  border-left: 3px solid white;
  */
  color: rgba(255,255,255,0.7);
}
.net {
  color: rgba(0,0,0,0.7);
  width: auto;
  margin: 3px 0;
  /*
  padding-left: 5px;
  border-left: 3px solid black;
  */
  font-size: 12px;
  text-decoration: none;
  display: block;
  background: none;
}
.access-point-list {
  list-style: none;
  padding: 0;
  margin: 6px 0 0 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.access-point-list li {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
}
.access-point-list .badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  font-size: 10px;
  border-radius: 999px;
  background: royalblue;
  color: #fff;
  border: 1px solid royalblue;
  text-transform: uppercase;
}
body.dark .access-point-list .badge {
  background: royalblue;
  color: #fff;
  border-color: royalblue;
}
.net .mark {
  background: rgba(0,0,0,0.9);
  border-radius: 3px;
  color: white;
  width: 40px;
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  margin-right: 5px;
  padding: 2px 8px;
  font-size: 12px;
}
body.dark .net .mark {
  background: rgba(255,255,255,0.1);
  color: white;
}
.placeholder-icon {
  font-size: 40px;
  width: 50px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
}
.launch-btns .btn {
  text-transform: capitalize;
}
.launch-btns {
  display: flex;
}
.launch-btns .btn.launch{
  width: 150px !important;
  text-align: center !important;
}
.installed-apps .title i {
  color: silver !important;
}

/*
@media only screen and (max-width: 800px) {
  body {
    display: flex !important;
    flex-direction: row !important;
  }
}
*/
@media only screen and (max-width: 600px) {
  aside {
    width: unset;
    flex-shrink: unset;
  }
  aside {
    padding: 0 10px;
  }
  aside .tab.submenu {
    padding: 10px;
  }
  aside .tab i {
    width: 100%;
  }
  aside .tab .caption {
    display: none;
  }
  aside .tab {
    margin: 0;
    padding: 10px;
    border-left: none;
  }
  aside .btn-tab {
    flex-direction: column;
    padding: 10px 0;
  }
  aside .btn-tab .btn {
    display: flex;
    justify-content: center;
  }
  aside .btn-tab .btn .caption {
    display: none; 
  }
  header .flexible {
    min-width: unset;
  }
}

@media only screen and (max-width: 480px) {
  .btn2 {
    padding: 5px;
    font-size: 11px;
  }
  .nav-btns {
    flex-grow: 1;
    justify-content: center;
    padding: 0;
  }
}
body.net-page .task-container {
  padding: 0;
}
body.net-page .task-shell {
  width: 100%;
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  box-shadow: none;
  overflow: visible;
  backdrop-filter: none;
}
body.net-page .task-shell-header {
  padding: 12px 18px 14px;
}
body.net-page .task-shell-header-main {
  max-width: 720px;
}
body.net-page .task-description {
  max-width: 70ch;
}
body.net-page .task-shell-body {
  padding: 0 28px 28px;
}
body.net-page .container {
  margin: 0;
}
body.net-page .net-routes-section {
  padding-top: 12px;
}
body.net-page .net-section-head {
  display: none;
}
body.net-page .search {
  margin: 0;
  padding: 0;
  width: 100%;
}
body.net-page .net-search-field {
  width: 100%;
  box-sizing: border-box;
  margin: 0;
  min-height: 34px;
  padding: 0;
  border: 0;
  border-radius: 0;
  border-bottom: 1px solid var(--task-border);
  background: transparent;
  gap: 8px;
}
body.net-page .net-search-field:focus-within {
  border-color: var(--task-border-strong);
  box-shadow: none;
  background: transparent;
}
body.net-page .net-search-field > i {
  font-size: 11px;
}
body.net-page .net-search-field .task-library-search-input {
  min-height: 34px;
  font-size: 13px;
  border: 0 !important;
  border-radius: 0 !important;
  background: transparent !important;
  box-shadow: none !important;
}
body.net-page .net-summary {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: flex-end;
  color: var(--task-muted);
  font-size: 12px;
}
body.net-page .net-summary-item {
  display: inline-flex;
  align-items: center;
  min-height: 0;
  box-sizing: border-box;
  padding: 0;
  border: 0;
  border-radius: 0;
  color: var(--task-muted);
  font-size: 12px;
  line-height: 1;
  white-space: nowrap;
}
body.net-page .net-summary-item + .net-summary-item::before {
  content: "";
  width: 1px;
  height: 12px;
  margin-right: 10px;
  background: var(--task-border);
}
body.net-page .net-summary-item strong {
  color: var(--task-text);
  font-weight: 700;
}
body.net-page .running-apps {
  display: grid;
  gap: 0;
}
body.net-page .line {
  box-sizing: border-box;
  padding: 11px 14px;
  border-top: 1px solid var(--task-border);
  border-radius: 6px;
  background: transparent;
  transition: background-color 120ms ease-out;
}
body.net-page .line:hover,
body.net-page .line.selected {
  background: color-mix(in srgb, var(--task-soft) 34%, transparent);
}
body.net-page .line.align-top h3 {
  margin: 0;
  display: grid;
  grid-template-columns: 24px minmax(0, 1fr);
  gap: 9px;
  align-items: start;
  font-size: inherit;
}
body.net-page .placeholder-icon,
body.net-page .line img {
  width: 22px;
  height: 22px;
  border-radius: 5px;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--task-muted);
  font-size: 11px;
}
body.net-page .line img {
  object-fit: cover;
  background: color-mix(in srgb, var(--task-panel) 92%, var(--task-soft));
}
body.net-page .line .col {
  min-width: 0;
  padding-left: 0;
  display: grid;
  grid-template-columns: minmax(160px, 240px) minmax(0, 1fr);
  gap: 4px 18px;
  align-items: start;
}
body.net-page .line .title {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--task-text);
  font-size: 14px;
  font-weight: 700;
  line-height: 1.25;
  margin: 0;
  min-width: 0;
}
body.net-page .line .title i {
  flex: 0 0 auto;
  font-size: 8px;
  color: color-mix(in srgb, #84cc16 75%, var(--task-panel));
}
body.net-page .line .title span {
  min-width: 0;
  overflow-wrap: anywhere;
}
body.net-page .line .description {
  grid-column: 1;
  margin: 2px 0 0;
  padding: 0;
  color: var(--task-muted);
  font-size: 12px;
  line-height: 1.45;
}
body.net-page .line .grid-3,
body.net-page .line .grid-1,
body.net-page .line .launch-btns {
  grid-column: 2;
  grid-row: 1 / span 3;
}
body.net-page .grid-3 {
  display: grid;
  grid-template-columns: minmax(0, 1.15fr) repeat(2, minmax(0, 1fr));
  padding: 4px 0 0;
  gap: 14px;
  background: none !important;
  margin-top: 0;
}
body.net-page .grid-1 {
  padding: 0;
  background: none !important;
  margin-top: 0;
}
body.net-page .line .grid-3 .section,
body.net-page .line .grid-1 .section {
  border: 0;
  border-radius: 0;
  padding: 0;
  background: none;
  min-height: 0;
}
body.net-page .line .grid-3 .section:first-child,
body.net-page .line .grid-1 .section:first-child {
  border-left: 0;
  padding-left: 0;
}
body.net-page .line .grid-3 .section:last-child,
body.net-page .line .grid-1 .section:last-child {
  padding-right: 0;
}
body.net-page .grid-3 .section h2,
body.net-page .grid-1 .section h2 {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0 0 5px;
  font-size: 11px;
  font-weight: 700;
  color: var(--task-text);
  line-height: 1.2;
  letter-spacing: 0;
}
body.net-page .grid-3 .section h2 i,
body.net-page .grid-1 .section h2 i {
  width: 14px;
  color: var(--task-muted);
  text-align: center;
}
body.net-page .net {
  display: flex;
  align-items: center;
  gap: 6px;
  max-width: 100%;
  width: fit-content;
  margin: 0 0 4px;
  padding: 0;
  border: 0;
  color: var(--task-muted);
  line-height: 1.45;
  text-decoration: none;
  overflow-wrap: anywhere;
}
body.dark.net-page .net {
  color: var(--task-muted);
}
body.net-page .net:hover,
body.dark.net-page .net:hover {
  color: var(--task-text);
}
body.net-page .access-point-list {
  list-style: none;
  padding: 0;
  margin-top: 0;
  display: grid;
  gap: 4px;
}
body.net-page .access-point-list li {
  align-items: center;
  gap: 8px;
  min-width: 0;
}
body.net-page .access-point-list .net {
  margin: 0;
  display: inline-flex;
  align-items: center;
}
body.net-page .net .mark {
  background: color-mix(in srgb, var(--task-panel) 88%, var(--task-accent));
  color: var(--task-accent-contrast);
  border-radius: 999px;
}
body.net-page .badge,
body.dark.net-page .badge {
  min-height: 18px;
  padding: 0 6px;
  border: 1px solid color-mix(in srgb, var(--task-accent) 22%, var(--task-border));
  border-radius: 999px;
  background: color-mix(in srgb, var(--task-accent) 10%, var(--task-panel));
  color: color-mix(in srgb, var(--task-accent) 62%, var(--task-text));
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 650;
  line-height: 1;
  transform: translateY(-1px);
}
body.net-page .get-dns-btn,
body.net-page .btn {
  border-radius: 6px;
}
body.net-page .get-dns-btn {
  margin-top: 6px;
  max-width: fit-content;
  background: transparent;
  border: 1px solid var(--task-border);
  color: var(--task-text);
  padding: 0 10px;
  min-height: 30px;
  font-weight: 650;
}
body.net-page .line.align-top h3 .col .get-dns-btn {
  width: auto;
  justify-self: start;
}
body.net-page .section-container {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px;
}
body.net-page .section-col {
  min-width: 0;
}
body.net-page .section-header {
  padding: 0 0 10px;
  background: transparent;
}
body.dark.net-page .section-header {
  background: transparent;
}
body.net-page .section-header h3 {
  margin: 0;
}
body.net-page .section-header .grid-1 {
  padding: 0;
  background: transparent !important;
}
body.net-page .section-header .section {
  border: 0;
  border-radius: 0;
  background: transparent;
  padding: 0;
