  margin-top: 5px;
  width: 100%;
}
.desc {
  font-size: 14px;
  color: rgba(0, 0, 0, 0.7);
  padding: 5px 0;
}
.container {
  margin-left: 20px;
}
.section-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  /*
  grid-template-columns: repeat(3, minmax(0, 1fr));
  */
  gap: 1rem; /* Optional spacing between columns */
}
.section-container > * {
  min-width: 0;
  overflow: hidden;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr); /* Three equal columns */
  gap: 1rem; /* Optional spacing between columns */
}
.grid-1 {
  padding: 10px;
}
.grid-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); /* Responsive columns that wrap */
  gap: 1rem; /* Optional spacing between columns */
  padding: 10px;
}
.grid-3 .section > h2 {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 0 0 8px;
  font-size: 12px;
}
.grid-3 > * {
