}
body.dark .grid-1, body.dark .grid-2, body.dark .grid-3 {
  background: rgba(255,255,255,0.03);
  margin-top: 5px;
}
main {
  display: flex;
}
aside {
  width: 200px;
  display: block;
  flex-shrink: 0;
}
aside .tab i {
  width: 20px;
  text-align: center;
}
body.dark aside .tab {
