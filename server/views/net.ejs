}
body.net-page .dns-modal-popup .swal2-html-container,
body.net-page .dns-progress-popup .swal2-html-container {
  margin: 0;
  padding: 0;
  color: var(--task-text);
  text-align: left;
}
body.net-page .dns-modal-popup .swal2-actions,
body.net-page .dns-progress-popup .swal2-actions {
