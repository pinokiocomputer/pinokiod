  border-radius: 6px;
  border: 1px solid rgba(0,0,0,0.15);
  font-size: 14px;
}
body.dark .dns-modal .address-section input {
  background: rgba(255,255,255,0.05);
  color: white;
  border-color: rgba(255,255,255,0.18);
}
.dns-modal .address-result {
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-size: 16px;
  padding: 30px 10px;
  background: rgba(0,0,0,0.04);
  border-radius: 8px;
}
body.dark .dns-modal .address-result {
  background: rgba(255,255,255,0.08);
}
.dns-progress-modal {
  margin-top: 15px;
}
.dns-modal-terminal-container {
  width: 100%;
  height: 280px;
  background: #000;
  border-radius: 8px;
  overflow: hidden;
}
.dns-modal-terminal-container .xterm .xterm-viewport {
  width: initial !important;
}
.blank {
  width: 50px;
  height: 50px;
  flex-shrink: 0;
}
body.dark .section-header {
/*
  border-bottom: 1px solid rgba(255,255,255,0.07);
  */
}
.section-header {
/*
  border-bottom: 1px solid rgba(0, 0, 0,0.04);
  */
  font-weight: normal;
  font-size: 14px;
  padding: 15px 5px;
  /*
  margin: 0 0 15px;
  */
}
.section-header h2 {
  font-size: 20px;
}
.section-header .section {
  padding: 0;
}
.section-header .section div {
  font-weight: normal;
  opacity: 0.6;
  font-size: 14px;
}
.section-header h3 {
  display: flex;
  margin: 0;
}
.section-header .col {
