  color: black !important;
  /*
  border: 1px solid rgba(0, 0, 0, 0.3);
  */
}
.open-menu.selected {
  border: none !important;
  /*
  background: none !important;
  */
}
.open-menu.selected span {
  display: none;
}
.sections {
  display: flex;
}
.section {
  display: block;
  width: 100%;
}
.section h2 {
  margin: 0;
}
.section a {
  display: flex;
  align-items: center;
}
.section a span {
  min-width: 0;
}
.line.align-top h3 .col .btn {
