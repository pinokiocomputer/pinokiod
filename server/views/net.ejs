<%
  const showStaticRoutes = false
  const visibleStaticRoutes = showStaticRoutes ? static_routes : []
  const routeCount = current_host === host
    ? processes.length + visibleStaticRoutes.length
    : processes.length + installed.length + serverless.length
%>
<body class='<%=theme%> main-sidebar-page task-launcher-page task-page net-page' data-agent="<%=agent%>">
<% if (error) { %>
<nav class='error-message'>
  <div><%=error%></div>
  <div class='flexible'></div>
  <a class='btn' target="_blank" href="<%=install%>">Download</a>
</nav>
<% } %>
<header class='navheader grabbable'>
  <h1>
    <a class='home' href="/home"><img class='icon' src="/pinokio-black.png"></a>
    <button class='btn2' id='minimize-header' data-tippy-content="fullscreen" title='fullscreen'>
      <div><i class="fa-solid fa-expand"></i></div>
    </button>
    <a class='btn2 pinokio-explore-nav-button' href="/home?mode=explore" data-pinokio-explore-nav="true" data-tippy-content="Explore" title="Explore" aria-label="Explore">
      <div><i class="fa-solid fa-globe" aria-hidden="true"></i></div>
    </a>
    <button class='btn2' id='back' data-tippy-content="back"><div><i class="fa-solid fa-chevron-left"></i></div></button>
    <button class='btn2' id='forward' data-tippy-content="forward"><div><i class="fa-solid fa-chevron-right"></i></div></button>
    <button class='btn2' id='refresh-page' data-tippy-content="refresh"><div><i class="fa-solid fa-rotate-right"></i></div></button>
    <button class='btn2' id='screenshot' data-tippy-content="screen capture"><i class="fa-solid fa-camera"></i></button>
    <button class='btn2' id='inspector' data-tippy-content="X-ray mode"><i class="fa-solid fa-eye"></i></button>
    <button class='btn2 mobile-link-button' id='mobile-link-button' data-tippy-content="enter url"><i class="fa-solid fa-link"></i></button>
    <div class='mobile-flexible'></div>
    <form class='urlbar'>
      <div class='url-input-container'>
        <input type='url' placeholder='enter any local url to open in pinokio'>
        <div class='url-dropdown' id='url-dropdown'></div>
      </div>
    </form>
    <%- include('partials/home_server_popover') %>
    <a class='btn2' href="/columns" data-tippy-content="split into 2 columns">
      <div><i class="fa-solid fa-table-columns"></i></div>
    </a>
    <a class='btn2' href="/rows" data-tippy-content="split into 2 rows">
      <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
    </a>
    <button class='btn2' id='new-window' data-tippy-content="open a new window" title='open a new window' data-agent="<%=agent%>">
      <div><i class="fa-solid fa-plus"></i></div>
    </button>
    <button class='btn2 hidden' id='close-window' data-tippy-content='close this section'>
      <div><i class="fa-solid fa-xmark"></i></div>
    </button>
  </h1>
</header>
<%- include('partials/home_server_popover_assets') %>
<main>
<div class='task-container'>
  <section class='task-shell net-shell'>
    <header class='task-shell-header'>
      <div class='task-shell-header-main'>
        <h1 class='task-title'><%= peer && peer.name ? peer.name : host %></h1>
        <p class='task-description'><%= current_host === host ? 'Live local, LAN, and peer routes for apps on this machine.' : 'Available routes and installed apps exposed by this peer.' %></p>
      </div>
      <div class='task-header-actions net-summary'>
        <span class='net-summary-item'><strong><%= routeCount %></strong>&nbsp;<%= routeCount === 1 ? 'entry' : 'entries' %></span>
        <% if (current_host === host) { %>
          <span class='net-summary-item'><strong><%= processes.length %></strong>&nbsp;live</span>
          <% if (showStaticRoutes) { %>
            <span class='net-summary-item'><strong><%= visibleStaticRoutes.length %></strong>&nbsp;static</span>
          <% } %>
        <% } else { %>
          <span class='net-summary-item'><strong><%= processes.length %></strong>&nbsp;online</span>
          <span class='net-summary-item'><strong><%= installed.length %></strong>&nbsp;installed</span>
        <% } %>
      </div>
    </header>
    <div class='task-shell-body net-shell-body'>
<section class='task-section net-routes-section' aria-label="<%= current_host === host ? 'App routes' : 'Peer access' %>">
  <div class='task-section-head net-section-head'>
    <div>
      <h2 class='task-section-title'><%= current_host === host ? 'App routes' : 'Peer access' %></h2>
      <p class='task-section-subcopy'><%= current_host === host ? 'Open local, LAN, or peer URLs for each running app.' : 'Open online routes or launch apps exposed by this peer.' %></p>
    </div>
  </div>
  <div class='container'>
    <form class='search net-toolbar' role='search'>
      <label class='task-library-search-field net-search-field'>
        <i class='fa-solid fa-magnifying-glass' aria-hidden='true'></i>
        <input type='search' class="task-library-search-input flexible" placeholder='Search apps' autocomplete='off'>
      </label>
    </form>
    <div class='running-apps net-route-list'>
    <% if (current_host === host) { %>
      <% if (processes.length === 0 && visibleStaticRoutes.length === 0) { %>
        <div class='task-empty-state'>
          <p class='task-empty-copy'>No live app routes are available on this machine.</p>
        </div>
      <% } %>
      <% processes.forEach((item, index) => { %>
        <div class='index line align-top' data-index="<%=index%>" data-name="<%=item.name%>" data-title="<%=item.name%>" data-description="<%=item.internal_router.join(' ')%> <%=item.port%>">
          <h3>
            <div class='item-icon'>
              <% if (item.icon) { %>
                <div class='placeholder-icon'>
                  <img src="<%=item.icon%>" onerror="this.src='/pinokio-black.png'"/>
                </div>
              <% } else { %>
                <div class='placeholder-icon'>
                  <i class="fa-solid fa-clock-rotate-left"></i>
                </div>
              <% } %>
            </div>
            <div class='col'>
              <div class='title'><i class="fa-solid fa-circle"></i><span><%=item.title || item.name%></span></div>
              <div class='grid-3'>
                <div class='section'>
                  <h2><i class='fas fa-laptop-code'></i> This machine</h2>
                  <% 
                    let default_dns_name = ''
                    if (item.internal_router && item.internal_router.length > 0) {
                      const firstDomain = item.internal_router[0]
                      if (typeof firstDomain === 'string') {
                        if (firstDomain.endsWith('.localhost')) {
                          default_dns_name = firstDomain.replace(/\.localhost$/, '')
                        } else {
                          default_dns_name = firstDomain
                        }
                      }
                    }
                    if (!default_dns_name) {
                      default_dns_name = (item.port ? item.port.toString() : (item.name || '')).toString()
                    }
                    default_dns_name = default_dns_name.toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-+|-+$/g, '')
                    if (!default_dns_name && item.port) {
                      default_dns_name = item.port.toString()
                    }
                  %>
                  <% item.internal_router.forEach((domain) => { %>
                    <a class='net' target="_blank" href="https://<%=domain%>">https://<%=domain%></a>
                  <% }) %>
                  <a class='net' target="_blank" href="http://localhost:<%=item.port%>">http://localhost:<%=item.port%></a>
                  <% if (allow_dns_creation && item.port) { %>
                    <button type='button' class='btn get-dns-btn' data-port="<%=item.port%>" data-default-dns="<%=default_dns_name%>" data-process-title="<%=item.title || item.name%>">
                      <i class="fa-solid fa-globe"></i>
                      <span>Get .localhost domain</span>
                    </button>
                  <% } %>
                </div>
                <div class='section'>
                  <h2><i class="fa-solid fa-wifi"></i> Local network</h2>
                  <%
                    const directHosts = []
                    if (Array.isArray(item.external_hosts)) {
                      const seenHosts = new Set()
                      item.external_hosts.forEach((hostEntry) => {
                        if (!hostEntry || !hostEntry.url) {
                          return
                        }
                        const key = hostEntry.url.toLowerCase()
                        if (seenHosts.has(key)) {
                          return
                        }
                        seenHosts.add(key)
                        const scope = (hostEntry.scope || '').toLowerCase()
                        let badge = ''
                        if (scope === 'lan') badge = 'LAN'
                        else if (scope === 'cgnat') badge = 'VPN'
                        else if (scope === 'public') badge = 'Public'
                        else if (scope === 'loopback') badge = 'Local'
                        else if (scope === 'linklocal') badge = 'Link-Local'
                        directHosts.push({
                          url: hostEntry.url,
                          badge
                        })
                      })
                    }
                  %>
                  <% if (directHosts.length > 0) { %>
                    <ul class="access-point-list">
                      <% directHosts.forEach((point) => {
                           const hasProtocol = /^https?:\/\//i.test(point.url)
                           const hrefValue = hasProtocol ? point.url : `http://${point.url}`
                      %>
                        <li>
                          <a class='net' target="_blank" href="<%= hrefValue %>"><%= point.url %></a>
                          <% if (point.badge) { %>
                            <span class="badge"><%= point.badge %></span>
                          <% } %>
                        </li>
                      <% }) %>
                    </ul>
                  <% } else if (item.external_ip) { %>
                    <a class='net' target="_blank" href="http://<%=item.external_ip%>">http://<%=item.external_ip%></a>
                  <% } %>
                </div>
                <div class='section'>
                  <h2><i class="fa-solid fa-podcast"></i> Peer</h2>
                  <% item.external_router.forEach((domain) => { %>
                    <a class='net' target="_blank" href="https://<%=domain%>">https://<%=domain%></a>
                  <% }) %>
                </div>
              </div>
            </div>
          </h3>
        </div>
      <% }) %>
      <% visibleStaticRoutes.forEach((route, index) => { %>
        <div class='line align-top' data-index="<%=processes.length+index%>" data-name="<%=route.name%>" data-title="<%=route.name%>" data-description="<%=route.internal_router.join(' ')%>">
          <h3>
            <div class='item-icon'>
              <div class='placeholder-icon'>
                <i class="fa-solid fa-clock-rotate-left"></i>
              </div>
            </div>
            <div class='col'>
              <div class='title'><i class="fa-solid fa-circle"></i><span><%=route.name%></span></div>
              <div class='grid-3'>
                <div class='section'>
                  <h2><i class='fas fa-laptop-code'></i> This machine</h2>
                  <% route.internal_router.forEach((domain) => { %>
                    <% if (domain.endsWith(".localhost")) { %>
                      <a class='net' target="_blank" href="https://<%=domain%>">https://<%=domain%></a>
