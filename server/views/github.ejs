<html>
<%
const tr = typeof t === "function" ? t : ((key) => { throw new Error("i18n translator is not initialized") })
const trj = (key, replacements = {}) => JSON.stringify(tr(key, replacements))
%>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link href="/xterm.min.css" rel="stylesheet" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/markdown.css" rel="stylesheet"/>
<link href="/noty.css" rel="stylesheet"/>
<link href="/style.css" rel="stylesheet"/>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<style>
html {
  scroll-behavior: smooth;
  height: 100%;
  overflow: hidden;
}
body {
  height: 100%;
  overflow: auto;
  display: flex;
  flex-direction: column;
}
.line2 {
  display: flex;
  align-items: center;
  cursor: pointer;
  background: rgba(0,0,100,0.04);
}
.line2 a {
  text-decoration: none;
  color: black;
}
.status {
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}
.status.offline {
  background: silver;
}
.status.online {
  background: yellowgreen;
}
.switch {
  padding: 10px;
  margin: 10px 0;
}
.switch[data-online=true] {
  color: yellowgreen;
}
.button {
  padding: 10px;
}
.on, .off {
  display: flex;
  align-items: center;
}
.btn {
  text-align: center;
  padding: 10px;
  background: black;
  color: white;
  text-decoration: none;
  font-weight: normal;
}
.item {
  display: flex;
  align-items: flex-start;
  margin: 10px;
  background: rgba(0,0,0,0.04);
}
.item img {
  width: 100px;
}
.item .title {
  text-decoration: none;
  color: royalblue;
}
.item .col {
  padding: 10px;
}
.item .col > * {
  margin: 5px 0;
}
.item .stat {
  color: rgba(0,0,0,0.8);
  display: flex;
}
.item .stat > * {
  margin-right: 15px;
}
.timestamp {
  color: rgba(0,0,0,0.5);
}
main {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
}
.setup-items {
  display: flex;
  justify-content: center;
  margin: 0 auto;
  /*
  max-width: 800px;
  */
  width: 100%;
  align-items: center;
}
.setup-items .gitconfig .field input {
  padding: 10px;
  box-sizing: border-box;
  border: 1px solid silver;
  width: 100%;

}
.setup-items .gitconfig .field {
  padding-bottom: 15px;
}
.setup-items .gitconfig label {
  display: block;
  margin-bottom: 5px;
}
.setup-items .gitconfig-footer {
  text-align: center;
}
.setup-items .btn {
  width: 100%;
  margin-bottom: 10px;
}
.setup-items .gitconfig {
  flex-grow: 1;
  margin-bottom: 20px;
}
body.dark .setup-items pre, body.dark .setup-items .pre {
  background: rgba(255,255,255,0.04) !important;
}
.setup-items pre, .setup-items .pre {
  box-sizing: border-box;
  margin: 10px 0;
  width: 100%;
  padding: 20px;
  background: rgba(0,0,0,0.04) !important;
}
.head {
  padding: 30px;
  text-align: center;
}
.head .desc {
  opacity: 0.7;
  padding: 10px;
}
.head h3 {
  font-size: 20px;
  text-transform: uppercase;
  margin: 0;
}
.head h3 i {
  font-size: 80px;
}
body.dark .card {
  color: white;
}
.card {
  text-decoration: none;
  width: 200px;
  color: rgba(0,0,0,0.9);
  text-align: center;
  margin: 20px;
}
.card:hover {
  color: royalblue !important;
}
.card .desc {
  opacity: 0.7;
}
.card h3 {
  font-size: 30px;
  letter-spacing: -1px;
}
.card i {
  font-size: 50px;
}
a {
  color: royalblue;
}
body.dark hr {
  background: rgba(255,255,255,0.05);
}
hr {
  background: rgba(0,0,0,0.05);
  height: 4px;
  border: none;
  margin: 40px 0;
}
#readme {
  flex-grow: 1;
}
.cols {
  max-width: 1000px;
  margin: 0 auto;
  display: flex; 
}
body.dark .column {
  background: rgba(0,0,0,0.1);
}
.column {
  background: rgba(0,0,0,0.04);
  margin: 10px;
  width: 50%;
  padding: 20px;
  box-sizing: border-box;
}
.column h1 {
  padding: 5px;
  letter-spacing: -1px;
}
ol {
  padding-inline-start: 20px;
}
</style>
<script src="/popper.min.js"></script>
<script src="/tippy-bundle.umd.min.js"></script>
<script src="/hotkeys.min.js"></script>
<script src="/sweetalert2.js"></script>
<script>
window.PINOKIO_I18N = Object.assign({}, window.PINOKIO_I18N || {}, <%- JSON.stringify(typeof i18nCatalog === "object" && i18nCatalog ? i18nCatalog : {}) %>);
</script>
<script src="/common.js"></script>
<script src="/opener.js"></script>
</head>
<body class='<%=theme%>' data-agent="<%=agent%>">
<header class='navheader grabbable'>
<h1>
<a class='home' href="/home"><img class='icon' src="/pinokio-black.png"></a>
<button class='btn2' id='minimize-header' data-tippy-content="<%=tr("common.fullscreen")%>" title='<%=tr("common.fullscreen")%>'>
  <div><i class="fa-solid fa-expand"></i></div>
</button>
<button class='btn2' id='back' data-tippy-content="<%=tr("common.back")%>"><div><i class="fa-solid fa-chevron-left"></i></div></button>
<button class='btn2' id='forward' data-tippy-content="<%=tr("common.forward")%>"><div><i class="fa-solid fa-chevron-right"></i></div></button>
<button class='btn2' id='refresh-page' data-tippy-content="<%=tr("common.refresh")%>"><div><i class="fa-solid fa-rotate-right"></i></div></button>
<button class='btn2' id='screenshot' data-tippy-content="<%=tr("common.screen_capture")%>"><i class="fa-solid fa-camera"></i></button>
<button class='btn2' id='inspector' data-tippy-content="<%=tr("common.xray_mode")%>"><i class="fa-solid fa-eye"></i></button>
<div class='flexible'></div>
<a class='btn2' href="/columns" data-tippy-content="<%=tr("common.split_columns")%>">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class='btn2' href="/rows" data-tippy-content="<%=tr("common.split_rows")%>">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class='btn2' id='new-window' data-tippy-content="<%=tr("common.open_new_window")%>" title='<%=tr("common.open_new_window")%>' data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class='btn2 hidden' id='close-window' data-tippy-content='<%=tr("common.close_section")%>'>
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<main>
  <div class='head'>
    <h3><i class="fa-brands fa-git-alt"></i><br><br><%= tr("github.configure_git") %></h3>
  </div>
  <div class='cols'>
    <div class='column'>
      <h1><i class="fa-brands fa-github"></i> GitHub</h1>
      <div><%= tr("github.connect_description") %></div>
      <div class='setup-items'>
        <% if (hosts.length > 0) { %>
          <pre><%=hosts%></pre>
        <% } else { %>
          <pre><%= tr("github.not_logged_in") %></pre>
        <% } %>
      </div>
      <div class='setup-items'>
        <% items.forEach((item) => { %>
          <a class='btn' href="<%=item.url%>">
            <i class="<%=item.icon%>"></i> <%=item.title%>
          </a>
        <% }) %>
      </div>
      <div class='setup-items'>
        <div id='readme'><%-readme%></div>
      </div>
    </div>
    <div class='column'>
      <h1><i class="fa-brands fa-square-git"></i> <%= tr("github.git_config") %></h1>
      <div><%= tr("github.credentials_description") %></div>
      <div class='setup-items'>
        <form class='gitconfig'>
          <div class='pre'>
            <div class='field'>
              <label><%= tr("github.username") %></label>
              <input id='username' type='text' value="<%=gitconfig.user && gitconfig.user.name ? gitconfig.user.name : ''%>">
            </div>
            <div class='field'>
              <label><%= tr("github.email") %></label>
              <input id='email' type='text' value="<%=gitconfig.user && gitconfig.user.email ? gitconfig.user.email : ''%>">
            </div>
          </div>
          <div class='gitconfig-footer'>
            <button class='btn'><i class="fa-solid fa-check"></i> <%= tr("common.update") %></button>
            <div><%= tr("github.gitconfig_stored") %></div>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>
<script>
document.querySelector("form.gitconfig").addEventListener("submit", (e) => {
  e.preventDefault()
  e.stopPropagation()
  fetch("/github/config", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      "user.name": document.querySelector("#username").value,
      "user.email": document.querySelector("#email").value
    })
  }).then((res) => {
    return res.json()
  }).then((res) => {
    alert(<%- trj("github.updated") %>)
    location.href = location.href
  })
})
</script>
</body>
</html>
