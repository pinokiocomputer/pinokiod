<!doctype html>
<html lang="en">
<head>
  <%
  const tr = typeof t === "function" ? t : ((key) => { throw new Error("i18n translator is not initialized") })
  %>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= plugin.title %></title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/css/brands.min.css" rel="stylesheet">
  <link href="/noty.css" rel="stylesheet">
  <link href="/urldropdown.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
  <% if (agent === "electron") { %>
    <link href="/electron.css" rel="stylesheet"/>
  <% } %>
  <script src="/plugin-detail.js" defer></script>
</head>
<body class="<%= theme %> main-sidebar-page task-launcher-page task-page plugin-page plugin-detail-page" data-agent="<%= agent %>">
  <% const currentPluginCwd = typeof pluginCwd === "string" ? pluginCwd : ""; %>
  <%- include('partials/app_navheader', { agent }) %>
  <main>
    <div class="task-container">
      <section class="task-shell">
        <header class="task-shell-header">
          <div class="task-shell-header-main">
            <div class="task-shell-topline">
              <p class="task-eyebrow"><%=tr("plugins.title")%></p>
            </div>
            <div class="plugin-detail-title-row">
              <% if (plugin.image) { %>
                <img class="plugin-detail-title-art" src="<%= plugin.image %>" alt="<%= plugin.title %> icon">
              <% } else if (plugin.icon) { %>
                <div class="plugin-detail-title-art plugin-detail-title-art-icon" aria-hidden="true">
                  <i class="<%= plugin.icon %>"></i>
                </div>
              <% } %>
              <h1 class="task-title"><%= plugin.title %></h1>
            </div>
            <% if (plugin.description) { %>
              <p class="task-description"><%= plugin.description %></p>
            <% } %>
            <% if (pluginUi.badges && pluginUi.badges.length) { %>
              <div class="task-badge-row task-header-badges">
                <% pluginUi.badges.forEach((badge) => { %>
                  <span class="task-badge <%= badge.tone ? `task-badge-${badge.tone}` : '' %>"><%= badge.label %></span>
                <% }) %>
              </div>
            <% } %>
          </div>
          <div class="task-header-actions">
            <a class="task-link-button" href="/plugins">
              <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
              <span><%=tr("common.back")%></span>
            </a>
          </div>
        </header>

        <div class="task-shell-body">
          <div class="task-detail-layout">
            <div class="task-detail-main">
              <section class="task-section plugin-detail-actions-section" data-plugin-actions-section>
                <div class="task-section-head">
                  <div>
                    <h2 class="task-section-title"><%=tr("plugin_detail.actions")%></h2>
                    <p class="task-section-subcopy"><%=tr("plugin_detail.actions_subcopy", { summary: pluginUi.launchSummary })%></p>
                  </div>
                </div>
                <div class="plugin-detail-next-step-banner task-hidden" data-plugin-next-step-banner></div>
                <div class="plugin-detail-action-grid">
                  <% if (plugin.pluginPath) { %>
                    <div class="plugin-detail-action-card" data-plugin-action-card="open">
                      <div class="plugin-detail-action-copy">
                        <div class="plugin-detail-action-label"><%=tr("plugin_detail.open_in")%></div>
                        <div class="plugin-detail-action-meta"><%=tr("plugin_detail.open_in_meta")%></div>
                      </div>
                      <button class="task-button primary" type="button" data-plugin-open>
                        <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                        <span><%=tr("plugin_detail.open_in")%></span>
                      </button>
                    </div>
                  <% } %>
                  <div class="plugin-detail-action-card task-hidden" data-plugin-ai-permissions>
                    <div class="plugin-detail-action-copy">
                      <div class="plugin-detail-action-label"><%=tr("plugin_detail.ai_permissions")%></div>
                      <div class="plugin-detail-action-meta"><%=tr("plugin_detail.ai_permissions_meta_prefix")%> <code data-plugin-ai-permission-path><%=currentPluginCwd%></code>.</div>
                      <div class="task-inline-help" data-plugin-ai-permission-status></div>
                    </div>
                    <button class="task-button" type="button" data-plugin-ai-permission-clear>
                      <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                      <span><%=tr("common.clear")%></span>
                    </button>
                  </div>
                  <% if (plugin.hasInstall && plugin.pluginPath && plugin.installed !== true) { %>
                    <div class="plugin-detail-action-card" data-plugin-action-card="install">
                      <div class="plugin-detail-action-copy">
                        <div class="plugin-detail-action-label"><%=tr("common.install")%></div>
                        <div class="plugin-detail-action-meta"><%=tr("plugin_detail.install_flow")%></div>
                      </div>
                      <button class="task-button" type="button" data-plugin-action="install">
                        <i class="fa-solid fa-download" aria-hidden="true"></i>
                        <span><%=tr("common.install")%></span>
                      </button>
                    </div>
                  <% } %>
                  <% if (plugin.hasUpdate && plugin.pluginPath && plugin.installed !== false) { %>
                    <div class="plugin-detail-action-card" data-plugin-action-card="update">
                      <div class="plugin-detail-action-copy">
                        <div class="plugin-detail-action-label"><%=tr("plugin_detail.update")%></div>
                        <div class="plugin-detail-action-meta"><%=tr("plugin_detail.update_meta")%></div>
                      </div>
                      <button class="task-button" type="button" data-plugin-action="update">
                        <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                        <span><%=tr("plugin_detail.update")%></span>
                      </button>
                    </div>
                  <% } %>
                  <% if (plugin.hasUninstall && plugin.pluginPath && plugin.installed !== false) { %>
                    <div class="plugin-detail-action-card" data-plugin-action-card="uninstall">
                      <div class="plugin-detail-action-copy">
                        <div class="plugin-detail-action-label"><%=tr("plugin_detail.uninstall")%></div>
                        <div class="plugin-detail-action-meta"><%=tr("plugin_detail.uninstall_meta")%></div>
                      </div>
                      <button class="task-button danger" type="button" data-plugin-action="uninstall">
                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                        <span><%=tr("plugin_detail.uninstall")%></span>
                      </button>
                    </div>
                  <% } %>
                  <% if (!plugin.pluginPath && !plugin.hasInstall && !plugin.hasUpdate && !plugin.hasUninstall) { %>
                    <div class="task-empty-state">
                      <p class="task-empty-copy"><%=tr("plugin_detail.no_direct_actions")%></p>
                    </div>
                  <% } %>
                </div>
              </section>

              <% if (pluginUi.hasChanges) { %>
                <section class="task-section">
                  <div class="task-section-head">
                    <div>
                      <h2 class="task-section-title"><%=tr("plugin_detail.local_changes")%></h2>
                      <p class="task-section-subcopy"><%- pluginUi.localChangesCopy %></p>
                    </div>
                  </div>
                  <div class="task-change-list">
                    <% pluginUi.changePreview.forEach((change) => { %>
                      <div class="task-change-row">
                        <div class="task-change-copy">
                          <div class="task-change-file"><%= change.file %></div>
                          <div class="task-change-status"><%= change.status %></div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                  <% if (pluginUi.extraChangeCount > 0) { %>
                    <p class="task-inline-help"><%=tr(pluginUi.extraChangeCount === 1 ? "plugin_detail.more_change" : "plugin_detail.more_changes", { count: pluginUi.extraChangeCount })%></p>
                  <% } %>
                </section>
              <% } %>
            </div>

            <aside class="task-share-section task-detail-sidebar">
              <div class="task-section-head">
                <h2 class="task-section-title"><%=tr("plugin_detail.plugin_status")%></h2>
              </div>
              <div class="task-side-stack">
                <div class="task-meta-row task-meta-row-compact">
                  <div class="task-meta-chip">
                    <span class="task-meta-chip-label"><%= pluginUi.sourceLabel %></span>
                    <span class="task-meta-chip-value"><%= pluginUi.sourceValue %></span>
                  </div>
                  <div class="task-meta-chip">
                    <span class="task-meta-chip-label"><%= pluginUi.statusLabel %></span>
                    <span class="task-meta-chip-value"><%= pluginUi.statusValue %></span>
                  </div>
                </div>
                <div class="task-actions task-detail-status-actions">
                  <% if (pluginUi.canOpenFolder) { %>
                    <button class="task-button" type="button" data-filepath="<%= shareState.dir %>">
                      <i class="fa-solid fa-folder-open" aria-hidden="true"></i>
                      <span><%=tr("plugin_detail.open_folder")%></span>
                    </button>
                  <% } %>
                  <% if (plugin.link) { %>
                    <a class="task-link-button" href="<%= plugin.link %>" target="_blank" rel="noopener noreferrer">
                      <i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i>
                      <span><%=tr("plugin_detail.website")%></span>
                    </a>
                  <% } %>
                </div>
              </div>

              <section class="task-side-group">
                <div class="task-section-head">
                  <h2 class="task-section-title"><%= pluginUi.githubPanelTitle %></h2>
                  <div class="task-section-note" data-plugin-share-note></div>
                </div>
                <% if (pluginUi.canManageSource) { %>
                  <div class="task-share-next-step-main">
                    <h3 class="task-share-next-step-title" data-plugin-share-next-title></h3>
                    <p class="task-share-next-step-copy" data-plugin-share-next-copy></p>
                    <div class="task-actions" data-plugin-share-next-actions></div>
                  </div>
                  <form class="task-share-inline-create task-hidden" data-plugin-share-create-form>
                    <div class="task-inline-fields">
                      <label class="task-field">
                        <span class="task-label"><%=tr("app.repository_name")%></span>
                        <input class="task-input" type="text" data-plugin-share-repo-name placeholder="plugin-repo">
                      </label>
                      <label class="task-field task-field-tight">
                        <span class="task-label"><%=tr("plugin_detail.visibility")%></span>
                        <select class="task-select" data-plugin-share-visibility>
                          <option value="public"><%=tr("app.public")%></option>
                          <option value="private"><%=tr("app.private")%></option>
                        </select>
                      </label>
                      <div class="task-actions task-share-inline-create-actions">
                        <button class="task-button" type="button" data-plugin-share-create-cancel><%=tr("common.cancel")%></button>
                        <button class="task-button primary" type="submit">
                          <i class="fa-brands fa-github" aria-hidden="true"></i>
                          <span><%=tr("plugin_detail.continue")%></span>
                        </button>
                      </div>
                    </div>
                  </form>
                  <div class="task-actions plugin-share-static-actions">
                    <a class="task-link-button <%= shareState.remoteWebUrl ? '' : 'task-hidden' %>" href="<%= shareState.remoteWebUrl || '#' %>" target="_blank" rel="noopener noreferrer" data-plugin-share-remote-link>
                      <i class="fa-brands fa-github" aria-hidden="true"></i>
                      <span><%=tr("app.view_on_github")%></span>
                    </a>
                    <button class="task-button" type="button" data-plugin-share-refresh>
                      <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
                      <span><%=tr("plugin_detail.check_again")%></span>
                    </button>
                  </div>
                  <p class="task-help-copy" data-plugin-share-copy></p>
                  <div class="task-share-feedback" data-plugin-share-feedback hidden></div>
                <% } else if (pluginUi.isManagedSource) { %>
                  <div class="task-share-next-step-main">
                    <p class="task-share-next-step-copy"><%- pluginUi.githubPanelCopy %></p>
                  </div>
                <% } else { %>
                  <div class="task-share-next-step-main">
                    <p class="task-share-next-step-copy"><%- pluginUi.githubPanelCopy %></p>
                  </div>
                <% } %>
              </section>
            </aside>
          </div>
        </div>
      </section>
    </div>
    <%- include('partials/main_sidebar', { selected: 'plugins' }) %>
  </main>

  <div class="task-share-overlay task-hidden" data-plugin-share-overlay>
    <div class="task-share-overlay-backdrop" data-plugin-share-overlay-close></div>
    <section class="task-share-overlay-panel" role="dialog" aria-modal="true" aria-labelledby="plugin-share-overlay-title">
      <header class="task-share-overlay-header">
        <div>
          <p class="task-eyebrow"><%=tr("plugin_detail.github_flow")%></p>
          <h2 id="plugin-share-overlay-title" class="task-share-overlay-title" data-plugin-share-overlay-title><%=tr("plugin_detail.publish")%></h2>
          <p class="task-share-overlay-copy" data-plugin-share-overlay-copy><%=tr("plugin_detail.github_flow_copy")%></p>
        </div>
        <button class="task-button icon-only" type="button" data-plugin-share-overlay-close aria-label="<%=tr("common.close")%>">
          <i class="fa-solid fa-xmark" aria-hidden="true"></i>
        </button>
      </header>
      <div class="task-share-overlay-frame-wrap">
        <iframe class="task-share-overlay-frame" src="about:blank" allow="fullscreen *;" allowfullscreen data-plugin-share-overlay-frame></iframe>
      </div>
      <footer class="task-share-overlay-footer">
        <button class="task-button" type="button" data-plugin-share-overlay-close><%=tr("plugin_detail.not_yet")%></button>
        <button class="task-button primary" type="button" data-plugin-share-overlay-refresh>
          <i class="fa-solid fa-rotate-right" aria-hidden="true"></i>
          <span><%=tr("plugin_detail.done_check_again")%></span>
        </button>
      </footer>
    </section>
  </div>

  <script id="plugin-detail-bootstrap" type="application/json"><%- JSON.stringify({
    plugin: {
      title: plugin.title,
      description: plugin.description || "",
      link: plugin.link || "",
      pluginPath: plugin.pluginPath || "",
      cwd: currentPluginCwd,
      extraParams: Array.isArray(plugin.extraParams) ? plugin.extraParams : [],
      defaultCwd: plugin.defaultCwd || "",
      hasInstall: !!plugin.hasInstall,
      hasUninstall: !!plugin.hasUninstall,
      hasUpdate: !!plugin.hasUpdate,
      hasInstalledCheck: !!plugin.hasInstalledCheck,
      installed: typeof plugin.installed === "boolean" ? plugin.installed : null,
      category: plugin.category || "cli"
    },
    share: shareState,
    apps,
    stateUrl: plugin.pluginPath ? `/plugin/share/state?path=${encodeURIComponent(plugin.pluginPath)}` : "",
    i18n: {
      actionInstall: tr("common.install"),
      actionUninstall: tr("plugin_detail.uninstall"),
      actionUpdate: tr("plugin_detail.update"),
      noProjectPermissionContext: tr("plugin_detail.no_project_permission_context"),
      browserStorageUnavailable: tr("plugin_detail.browser_storage_unavailable"),
      savedPermissionExists: tr("plugin_detail.saved_permission_exists"),
      noSavedPermission: tr("plugin_detail.no_saved_permission"),
      aiPermissionCleared: tr("plugin_detail.ai_permission_cleared"),
      unableClearAiPermission: tr("plugin_detail.unable_clear_ai_permission"),
      missingTargetScript: tr("plugin_detail.missing_target_script"),
      run: tr("terminal.run"),
      plugin: tr("plugins.plugin"),
      runPluginTitle: tr("plugin_detail.run_plugin_title"),
      chooseProjectLaunch: tr("plugin_detail.choose_project_launch"),
      filterProjects: tr("plugin_detail.filter_projects"),
      project: tr("plugin_detail.project"),
      noMatchingProjects: tr("plugin_detail.no_matching_projects"),
      tryDifferentProject: tr("plugin_detail.try_different_project"),
      noProjectsFound: tr("plugin_detail.no_projects_found"),
      missingLaunchTarget: tr("plugin_detail.missing_launch_target"),
      selectProjectContinue: tr("plugin_detail.select_project_continue"),
      githubFlow: tr("plugin_detail.github_flow"),
      githubFlowCopy: tr("plugin_detail.github_flow_copy"),
      refreshingStatus: tr("plugin_detail.refreshing_status"),
      statusUpdated: tr("plugin_detail.status_updated"),
      failedRefreshStatus: tr("plugin_detail.failed_refresh_status"),
      failedInitializeGit: tr("plugin_detail.failed_initialize_git"),
      gitTrackingStarted: tr("plugin_detail.git_tracking_started"),
      repositoryNameRequired: tr("app.repository_name_required"),
      connectGithub: tr("plugin_detail.connect_github"),
      connectGithubCopy: tr("plugin_detail.connect_github_copy"),
      openGithub: tr("plugin_detail.open_github"),
      checkAgain: tr("plugin_detail.check_again"),
      startTracking: tr("plugin_detail.start_tracking"),
      startTrackingCopy: tr("plugin_detail.start_tracking_copy"),
      saveFirstVersion: tr("plugin_detail.save_first_version"),
      saveFirstVersionCopy: tr("plugin_detail.save_first_version_copy"),
      saveVersion: tr("plugin_detail.save_version"),
      saveChanges: tr("plugin_detail.save_changes"),
      localChangesCount: tr("plugin_detail.local_changes_count"),
      createGithubRepo: tr("plugin_detail.create_github_repo"),
      chooseRepoNameContinue: tr("plugin_detail.choose_repo_name_continue"),
      createGithubRepoCopy: tr("plugin_detail.create_github_repo_copy"),
      createOnGithub: tr("app.create_on_github"),
      publishFirstVersion: tr("plugin_detail.publish_first_version"),
      publishFirstVersionCopy: tr("plugin_detail.publish_first_version_copy"),
      publishChanges: tr("plugin_detail.publish_changes"),
      localVersionsCount: tr("plugin_detail.local_versions_count"),
      sourceRepoReady: tr("plugin_detail.source_repo_ready"),
      sourceRepoReadyCopy: tr("plugin_detail.source_repo_ready_copy"),
      readOnly: tr("plugin_detail.read_only"),
      remoteCreated: tr("plugin_detail.remote_created"),
      outOfDate: tr("plugin_detail.out_of_date"),
      connected: tr("plugin_detail.connected"),
      localOnly: tr("plugin_detail.local_only"),
      setupNeeded: tr("plugin_detail.setup_needed"),
      createRepoWhenReady: tr("plugin_detail.create_repo_when_ready"),
      publishFirstVersionGithub: tr("plugin_detail.publish_first_version_github"),
      savePublishGithub: tr("plugin_detail.save_publish_github"),
      publishLatestGithub: tr("plugin_detail.publish_latest_github"),
      githubInSync: tr("plugin_detail.github_in_sync"),
      downloadedInstallNext: tr("plugin_detail.downloaded_install_next"),
      installedOpenProject: tr("plugin_detail.installed_open_project"),
      downloadedOpenNext: tr("plugin_detail.downloaded_open_next"),
      downloadedSuccessfully: tr("plugin_detail.downloaded_successfully"),
      needsInstallBeforeRun: tr("plugin_detail.needs_install_before_run"),
      nextOpenProject: tr("plugin_detail.next_open_project"),
      nextStep: tr("plugin_detail.next_step"),
      saveVersionOverlayCopy: tr("plugin_detail.save_version_overlay_copy"),
      createGithubRepository: tr("app.create_github_repository"),
      createGithubRepositoryOverlayCopy: tr("plugin_detail.create_github_repository_overlay_copy"),
      publishChangesOverlayCopy: tr("plugin_detail.publish_changes_overlay_copy")
    }
  }).replace(/</g, '\\u003c') %></script>
  <%- include('partials/app_common_scripts') %>
  <script src="/opener.js"></script>
</body>
</html>
