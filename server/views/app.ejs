  const syncTabs = async () => {
    let tabs = []
    document.querySelectorAll(".temp-menu .frame-link").forEach((el) => {
      if (el.dataset.persist === "false") {
        return
      }
      const rawHref = el.getAttribute("href") || ""
      if (!rawHref) {
        return
      }
      const display = el.querySelector(".display")?.textContent?.trim() || rawHref
      const rawTarget = el.getAttribute("target") || ""
      const entry = {
        href: rawHref,
        label: display,
      }
      if (rawHref.includes("/shell/")) {
        entry.kind = "shell"
      }
      if (rawTarget.startsWith("@")) {
        entry.target = rawTarget
      }
      tabs.push(entry)
    })


    // persist
    await fetch("/pinokio/tabs", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        name: "<%=name%>",
        view: "<%=type%>",
        tabs
      })
    })
