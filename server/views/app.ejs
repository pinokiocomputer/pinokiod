    const resetSelectedGitFilesWithProgress = async ({ cwd, trackedPaths, untrackedPaths, selectionCount }) => {
      const repoCwd = typeof cwd === 'string' ? cwd.trim() : ''
      const tracked = normalizeResetPathList(trackedPaths)
      const trackedSet = new Set(tracked)
      const untracked = normalizeResetPathList(untrackedPaths).filter((entry) => !trackedSet.has(entry))
      if (!repoCwd || (tracked.length === 0 && untracked.length === 0)) {
        throw new Error('No files selected to reset.')
      }

      const fileCount = Number.isFinite(selectionCount) && selectionCount > 0
        ? selectionCount
        : tracked.length + untracked.length
      const fileLabel = formatResetFileCountLabel(fileCount)
      Swal.fire({
