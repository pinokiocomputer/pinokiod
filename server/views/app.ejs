<script>
document.addEventListener("DOMContentLoaded", () => {
  const footer = document.querySelector(".snapshot-footer")
  if (!footer) return
  const saveBtn = footer.querySelector(".snapshot-btn-save")
  const savePanel = footer.querySelector(".snapshot-footer-save")
  const dismissBtn = footer.querySelector(".snapshot-btn-dismiss")
  const howBtn = footer.querySelector(".snapshot-btn-how")
  if (!saveBtn) return
  const workspace = footer.getAttribute("data-workspace")
  if (!workspace) {
    footer.classList.add("hidden")
    return
  }
  footer.classList.add("hidden")
  // Temporarily keep the snapshot footer hidden while we focus on registry check-ins.
  return
  const dismissStorageKey = `pinokio.snapshot-footer.dismissed:${workspace}`
  const getDismissedState = () => {
    try {
      return window.localStorage.getItem(dismissStorageKey) === "1"
    } catch (_) {
      return false
    }
  }
  const setDismissedState = (dismissed) => {
    try {
      if (dismissed) {
        window.localStorage.setItem(dismissStorageKey, "1")
      } else {
        window.localStorage.removeItem(dismissStorageKey)
      }
    } catch (_) {}
  }
  const setDismissedClass = (dismissed) => {
    if (dismissed) {
      document.documentElement.classList.add("snapshot-footer-dismissed")
    } else {
      document.documentElement.classList.remove("snapshot-footer-dismissed")
    }
  }
  const saveOriginal = saveBtn.innerHTML
  const setSaveLoading = (isLoading, primaryText) => {
    saveBtn.disabled = isLoading
    if (primaryText) {
      saveBtn.innerHTML = primaryText
    }
  }
  const applySnapshotStatus = (status) => {
    const hasSnapshots = !!(status && status.hasSnapshots)
    const shouldShow = !hasSnapshots
    if (!shouldShow) {
      setDismissedClass(false)
      footer.classList.add("hidden")
      return
    }
    const dismissed = getDismissedState()
    setDismissedClass(dismissed)
    if (dismissed) {
      footer.classList.add("hidden")
      return
    }
    footer.classList.remove("hidden")
    if (savePanel) savePanel.classList.remove("hidden")
  }
  const loadSnapshotStatus = async () => {
    try {
      const res = await fetch(`/p/${encodeURIComponent(workspace)}/snapshot_status`, {
        method: "GET",
        headers: { "Accept": "application/json" }
      })
      if (!res.ok) return
      const payload = await res.json().catch(() => null)
      if (!payload || !payload.ok) return
      applySnapshotStatus(payload)
    } catch (_) {}
  }
  loadSnapshotStatus()

  const snapshotInfoJson = `{
  "version": 1,
  "root": "https://github.com/org/app",
  "repos": [
    { "path": ".", "repo": "https://github.com/org/app", "commit": "9f2a3c1" },
    { "path": "modules/foo", "repo": "https://github.com/org/foo", "commit": "1ab4d90" }
  ]
}`
  const snapshotInfoHtml = `
    <div class="pinokio-modal-surface">
      <div class="pinokio-modal-header">
        <div class="pinokio-modal-icon"><i class="fa-solid fa-circle-info"></i></div>
        <div class="pinokio-modal-heading">
          <div class="pinokio-modal-title">Checkpoint snapshot</div>
          <div class="pinokio-modal-subtitle">Metadata only, restore exact module versions</div>
        </div>
      </div>
      <div class="pinokio-modal-body">
        <div class="snapshot-info-text">Creates a tiny JSON of exact commit hashes and install paths for installed modules (no files), so you can later restore exact versions from the <a href="/checkpoints">Checkpoints tab</a>. Use after all modules have finished installing.</div>
        <div class="snapshot-info-label">Example snapshot JSON</div>
        <pre class="snapshot-info-code" data-snapshot-json="1"></pre>
        <div class="snapshot-info-label spaced">Example restore UI</div>
        <img class="snapshot-info-image" src="/checkpoint.png" alt="Checkpoint restore UI example" loading="lazy" />
      </div>
    </div>
  `
  const showSnapshotInfo = () => {
    if (typeof Swal === "undefined") return
    Swal.fire({
      html: snapshotInfoHtml,
      backdrop: 'rgba(9,11,15,0.65)',
      width: 'min(560px, 92vw)',
      showConfirmButton: true,
      confirmButtonText: 'Got it',
      showCloseButton: true,
      buttonsStyling: false,
      focusConfirm: false,
      customClass: {
        popup: 'pinokio-modern-modal',
        htmlContainer: 'pinokio-modern-html',
        closeButton: 'pinokio-modern-close',
        confirmButton: 'pinokio-modern-confirm'
      },
      didOpen: () => {
        const container = Swal.getHtmlContainer()
        const codeEl = container ? container.querySelector('[data-snapshot-json="1"]') : null
        if (codeEl) {
          codeEl.textContent = snapshotInfoJson
        }
      }
    })
  }
  if (howBtn) {
    howBtn.addEventListener("click", (event) => {
      event.preventDefault()
      showSnapshotInfo()
    })
  }

  let isSaving = false
  const handleSave = async (event) => {
    event.preventDefault()
    if (isSaving) return
    isSaving = true
    setSaveLoading(true, `<i class="fa-solid fa-circle-notch fa-spin"></i> Saving...`)
    try {
      const infoRes = await fetch(`/info/api/${encodeURIComponent(workspace)}`, {
        method: "GET",
        headers: { "Accept": "application/json" }
      })
      let repos = []
      if (infoRes.ok) {
        try {
          const payload = await infoRes.json()
          repos = Array.isArray(payload && payload.repos) ? payload.repos : []
        } catch (_) {}
      }
      const hasMainWithRemote = repos.some((repo) => repo && repo.main && repo.url)
      if (!hasMainWithRemote) {
        setSaveLoading(false, saveOriginal)
        const modalHtml = `
          <div class="pinokio-modal-surface">
            <div class="pinokio-modal-header">
              <div class="pinokio-modal-icon"><i class="fa-brands fa-github"></i></div>
              <div class="pinokio-modal-heading">
                <div class="pinokio-modal-title">Publish this workspace first</div>
                <div class="pinokio-modal-subtitle">
                  Backups are indexed by git remote. Publish this workspace to GitHub (or add a remote) before creating a snapshot.
                </div>
              </div>
            </div>
            <div class="pinokio-modal-body">
              <p class="pinokio-modal-text">
                We couldn&apos;t find a Git remote for this workspace. Once you publish it, you&apos;ll be able to create snapshots and restore them from the Backups page.
              </p>
            </div>
          </div>
        `
        Swal.fire({
          html: modalHtml,
          customClass: {
            popup: 'pinokio-modern-modal',
            htmlContainer: 'pinokio-modern-html',
            closeButton: 'pinokio-modern-close',
            confirmButton: 'pinokio-modern-confirm',
            cancelButton: 'pinokio-modern-cancel'
          },
          backdrop: 'rgba(9,11,15,0.65)',
          width: 'min(520px, 90vw)',
          buttonsStyling: false,
          showCloseButton: false,
          showConfirmButton: true,
          showCancelButton: true,
          confirmButtonText: 'Open Publish',
          cancelButtonText: 'Cancel',
          focusConfirm: false,
        }).then((result) => {
          if (result && result.isConfirmed) {
            const params = new URLSearchParams(window.location.search || "")
            params.set("pinokio.publish", "1")
            const qs = params.toString()
            const url = `/p/${encodeURIComponent(workspace)}/dev${qs ? `?${qs}` : ""}`
            window.location.href = url
          }
        })
        return
      }
      const params = new URLSearchParams()
      params.set("workspace", workspace)
      const res = await fetch(`/checkpoints/snapshot?${params.toString()}`, {
        method: "POST",
        headers: { "Accept": "application/json" }
      })
      const payload = res.ok ? await res.json().catch(() => null) : null
      if (!payload || !payload.ok) {
        setSaveLoading(false, saveOriginal)
        Swal.fire({ icon: "error", title: "Error", text: "Save failed" })
        return
      }
      const snapshotId = payload && payload.created && payload.created.id ? payload.created.id : null
      if (!snapshotId) {
        setSaveLoading(false, saveOriginal)
        Swal.fire({ icon: "error", title: "Error", text: "Save failed" })
        return
      }
      setSaveLoading(false, `<i class="fa-solid fa-circle-check"></i> Saved`)
      saveBtn.disabled = true
	    } catch (_) {
	      setSaveLoading(false, saveOriginal)
	      Swal.fire({ icon: "error", title: "Error", text: "Save failed" })
	    } finally {
	      isSaving = false
	    }
	  }

  const handleDismiss = (event) => {
    event.preventDefault()
    setDismissedState(true)
    setDismissedClass(true)
    footer.classList.add("hidden")
  }

  saveBtn.addEventListener("click", handleSave)
  if (dismissBtn) dismissBtn.addEventListener("click", handleDismiss)
});

(function() {
  const drawer = document.getElementById("ask-ai-drawer")
  if (!drawer) {
    return
  }
  const appcanvas = document.querySelector(".appcanvas")
  const frame = drawer.querySelector(".ask-ai-frame")
  const empty = drawer.querySelector(".ask-ai-drawer-empty")
  const pickerList = drawer.querySelector(".ask-ai-drawer-picker-list")
  const pickerStatus = drawer.querySelector(".ask-ai-drawer-picker-status")
  const searchInput = drawer.querySelector(".ask-ai-drawer-search-input")
  const locationRow = drawer.querySelector(".ask-ai-drawer-location")
  const locationInput = drawer.querySelector(".ask-ai-drawer-location-input")
  const refreshBtn = drawer.querySelector(".ask-ai-drawer-refresh")
  const externalBtn = drawer.querySelector(".ask-ai-drawer-external")
  const closeBtn = drawer.querySelector(".ask-ai-drawer-close")
  const resizer = document.getElementById("ask-ai-resizer")
  const askAiTrigger = document.getElementById("ask-ai-tab")
  const drawerWorkspace = drawer.dataset.workspace || ""
  const defaultWorkspaceCwd = drawer.dataset.workspaceCwd || ""
  const widthKey = "pinokio.ask_ai.width"
  const ASK_AI_MIN_WIDTH = 240
  let open = false
  let currentUrl = ""
  let askAiWidth = null
  let pickerRequestId = 0
  let askAiTools = null
  let askAiToolsPromise = null
  let askAiToolsKey = ""
  let renderedPickerTools = []
  let renderedPickerWorkspaceCwd = ""

  const setLocation = (value) => {
    const next = typeof value === "string" ? value : ""
    if (locationRow) {
      locationRow.classList.toggle("hidden", !next)
    }
    if (!locationInput) return
    locationInput.value = next
    locationInput.title = next
  }

  const setActionState = (hasUrl) => {
    const enabled = !!hasUrl
    if (refreshBtn) refreshBtn.disabled = !enabled
    if (externalBtn) externalBtn.disabled = !enabled
  }

  const setPickerStatus = (value) => {
    if (!pickerStatus) return
    pickerStatus.textContent = typeof value === "string" ? value : ""
  }

  const clearPickerList = () => {
    if (!pickerList) return
    pickerList.innerHTML = ""
  }

  const setEmptyState = (show) => {
    const shouldShow = !!show
    if (empty) empty.classList.toggle("hidden", !shouldShow)
    if (frame) frame.classList.toggle("hidden", shouldShow)
  }

  const applyDrawerOpenState = () => {
    if (!appcanvas) {
      return
    }
    appcanvas.classList.toggle("panel-open", open)
  }

  const clampWidth = (value) => {
    const numeric = typeof value === "number" ? value : parseInt(value, 10)
    if (Number.isNaN(numeric)) {
      return ASK_AI_MIN_WIDTH
    }
    return Math.max(numeric, ASK_AI_MIN_WIDTH)
  }

  const readWidth = () => {
    try {
      const stored = window.localStorage.getItem(widthKey)
      if (!stored) {
        return null
      }
      const parsed = parseInt(stored, 10)
      return Number.isNaN(parsed) ? null : parsed
    } catch (_) {
      return null
    }
  }

  const persistWidth = (value) => {
    try {
      window.localStorage.setItem(widthKey, String(value))
    } catch (_) {}
  }

  const applyWidth = (value, persist) => {
    const width = clampWidth(value)
    askAiWidth = width
    if (appcanvas) {
      appcanvas.style.setProperty("--ask-ai-width", `${width}px`)
    } else {
      drawer.style.width = `${width}px`
    }
    if (resizer) {
      resizer.setAttribute("aria-valuenow", String(width))
    }
    if (persist) {
      persistWidth(width)
    }
  }

  const initWidth = () => {
    const stored = readWidth()
    const fallback = parseInt(getComputedStyle(drawer).width, 10) || 560
    applyWidth(typeof stored === "number" ? stored : fallback, false)
  }

  const setOpen = (next, opts = {}) => {
    open = !!next
    if (open) {
      const eventDrawer = window.PinokioEventDrawer
      if (eventDrawer && typeof eventDrawer.close === "function") {
        eventDrawer.close()
      }
    }
    applyDrawerOpenState()
    if (askAiTrigger) {
      askAiTrigger.classList.remove("hidden")
      askAiTrigger.classList.toggle("selected", open)
      askAiTrigger.setAttribute("aria-hidden", "false")
      askAiTrigger.setAttribute("aria-expanded", open ? "true" : "false")
    }
    drawer.setAttribute("aria-hidden", open ? "false" : "true")
    if (resizer) {
      resizer.setAttribute("aria-hidden", open ? "false" : "true")
    }
  }

  const normalizeLaunchUrl = (rawUrl, workspaceCwd) => {
    if (!rawUrl) {
      return null
    }
    let parsed
    try {
      parsed = new URL(rawUrl, window.location.origin)
    } catch (_) {
      return null
    }
    if (parsed.origin !== window.location.origin) {
      return null
    }
    if (
      parsed.pathname.startsWith("/run/plugin/")
      || parsed.pathname.startsWith("/pinokio/run/plugin/")
      || (parsed.pathname.startsWith("/run/api/") && /\/pinokio\.js$/i.test(parsed.pathname))
    ) {
      if (workspaceCwd && !parsed.searchParams.has("cwd")) {
        parsed.searchParams.set("cwd", workspaceCwd)
      }
      parsed.searchParams.set("ask_ai", "1")
      parsed.searchParams.delete("prompt")
    }
    return `${parsed.pathname}${parsed.search}${parsed.hash}`
  }

  const resolveWorkspaceCwd = (payload) => {
    const direct = payload && typeof payload.workspaceCwd === "string" ? payload.workspaceCwd.trim() : ""
    if (direct) {
      return direct
    }
    const targetWorkspace = payload && typeof payload.workspace === "string" ? payload.workspace.trim() : ""
    if (!targetWorkspace || targetWorkspace === drawerWorkspace) {
      return defaultWorkspaceCwd
    }
    return defaultWorkspaceCwd
  }

  const normalizeToolValue = (href, label) => {
    const rawHref = typeof href === "string" ? href : ""
    const normalized = rawHref.replace(/^\/run/, "").replace(/^\/+/, "")
    const parts = normalized.split("/").filter(Boolean)
    let value = ""
    if (parts[0] === "plugin" && parts.length >= 3) {
      value = parts.slice(1, -1).join("/")
    } else {
      value = normalized
    }
    if (value.endsWith("/pinokio.js")) {
      value = value.replace(/\/pinokio\.js$/i, "")
    }
    if (value) {
      return value
    }
    return String(label || "")
      .toLowerCase()
      .replace(/[^a-z0-9/]+/g, "-")
      .replace(/^-+|-+$/g, "")
  }

  const buildPluginMenuUrl = (workspaceCwd) => {
    const parsed = new URL("/api/plugin/menu", window.location.origin)
    const normalizedWorkspace = typeof workspaceCwd === "string" ? workspaceCwd.trim() : ""
    if (normalizedWorkspace) {
      parsed.searchParams.set("workspace", normalizedWorkspace)
    }
    return `${parsed.pathname}${parsed.search}`
  }

  const mapPluginMenuToAskAiTools = (menu) => {
    if (!Array.isArray(menu)) {
      return []
    }
    return menu.map((plugin) => {
      if (!plugin || typeof plugin !== "object") {
        return null
      }
      const href = typeof plugin.href === "string" ? plugin.href.trim() : ""
      if (!href) {
        return null
      }
      let parsed
      try {
        parsed = new URL(href, window.location.origin)
      } catch (_) {
        return null
      }
      const isPluginLauncher = parsed.pathname.startsWith("/run/plugin/")
        || parsed.pathname.startsWith("/pinokio/run/plugin/")
        || (parsed.pathname.startsWith("/run/api/") && /\/pinokio\.js$/i.test(parsed.pathname))
      if (parsed.origin !== window.location.origin || !isPluginLauncher) {
        return null
      }
      const label = typeof plugin.title === "string" && plugin.title.trim()
        ? plugin.title.trim()
        : (typeof plugin.text === "string" && plugin.text.trim() ? plugin.text.trim() : href)
      const runs = Array.isArray(plugin.run) ? plugin.run : []
      const hasExec = runs.some((step) => step && step.method === "exec")
      const launchType = typeof plugin.launch_type === "string" ? plugin.launch_type.trim().toLowerCase() : ""
      const explicitCategory = typeof plugin.category === "string" ? plugin.category.trim().toLowerCase() : ""
      const value = normalizeToolValue(href, label)
      if (!value) {
        return null
      }
      let category
      if (explicitCategory === "ide" || launchType === "desktop") {
        category = "IDE"
      } else if (explicitCategory === "cli" || launchType === "terminal") {
        category = "CLI"
      } else {
        category = hasExec ? "IDE" : "CLI"
      }
      return {
        value,
        label,
        href,
        iconSrc: typeof plugin.image === "string" ? plugin.image : null,
        category,
        kind: "plugin",
        isDefault: plugin.default === true
      }
    }).filter(Boolean)
  }

  const mapProjectShellToAskAiTools = (projectShell) => {
    const items = projectShell && Array.isArray(projectShell.items) ? projectShell.items : []
    return items.map((item) => {
      if (!item || typeof item !== "object") {
        return null
      }
      const href = typeof item.href === "string" ? item.href.trim() : ""
      if (!href) {
        return null
      }
      let parsed
      try {
        parsed = new URL(href, window.location.origin)
      } catch (_) {
        return null
      }
      if (parsed.origin !== window.location.origin || !parsed.pathname.startsWith("/shell/")) {
        return null
      }
      const label = typeof item.title === "string" && item.title.trim()
        ? item.title.trim()
        : (typeof item.text === "string" && item.text.trim() ? item.text.trim() : "Shell")
      const value = typeof item.shellId === "string" && item.shellId.trim()
        ? item.shellId.trim()
        : normalizeToolValue(href, label)
      return {
        value,
        label,
        href,
        target: typeof item.target === "string" && item.target.trim() ? item.target.trim() : `@${href}`,
        iconClass: typeof item.icon === "string" && item.icon.trim() ? item.icon.trim() : "fa-solid fa-terminal",
        description: typeof item.subtitle === "string" ? item.subtitle.trim() : "",
        category: "SHELL",
        kind: "shell"
      }
    }).filter(Boolean)
  }

  const mapPluginPayloadToAskAiTools = (payload) => {
    const shellTools = mapProjectShellToAskAiTools(payload && payload.projectShell)
    const pluginTools = mapPluginMenuToAskAiTools(payload && Array.isArray(payload.menu) ? payload.menu : [])
    return shellTools.concat(pluginTools)
  }

  const getAskAiTools = async (workspaceCwd = "") => {
    const cacheKey = typeof workspaceCwd === "string" ? workspaceCwd.trim() : ""
    if (askAiToolsKey === cacheKey && Array.isArray(askAiTools) && askAiTools.length > 0) {
      return askAiTools
    }
    if (askAiToolsKey === cacheKey && askAiToolsPromise) {
      return askAiToolsPromise
    }
    const requestKey = cacheKey
    askAiToolsKey = requestKey
    const requestPromise = fetch(buildPluginMenuUrl(requestKey))
      .then((res) => {
        if (!res.ok) {
          throw new Error(`Failed to load plugin menu: ${res.status}`)
        }
        return res.json()
      })
      .then((payload) => {
        return mapPluginPayloadToAskAiTools(payload || {})
      })
      .catch(() => [])
      .finally(() => {
        if (askAiToolsPromise === requestPromise) {
          askAiToolsPromise = null
        }
      })
    askAiToolsPromise = requestPromise
    const tools = await requestPromise
    if (askAiToolsKey === requestKey) {
      askAiTools = tools
    }
    return tools
  }

  const createAskAiLaunchSession = () => {
    if (typeof createLaunchSession === "function") {
      return createLaunchSession()
    }
    if (typeof crypto !== "undefined" && crypto.randomUUID) {
      return crypto.randomUUID()
    }
    return `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`
  }

  const appendLaunchSessionParam = (value, session) => {
    if (!value || typeof value !== "string" || !session || value.includes("session=")) {
      return value
    }
    const hasTargetPrefix = value.startsWith("@")
    const rawValue = hasTargetPrefix ? value.slice(1) : value
    const delimiter = rawValue.includes("?") ? "&" : "?"
    const next = `${rawValue}${delimiter}session=${encodeURIComponent(session)}`
    return hasTargetPrefix ? `@${next}` : next
  }

  const ensureAskAiShellTab = async (tool, href, target) => {
    if (!href || !target) {
      return null
    }
    let link = findFrameLinkByTarget(target)
    if (link && !link.closest(".temp-menu")) {
      link = null
    }
    if (link) {
      if (link.getAttribute("href") !== href) {
        link.setAttribute("href", href)
        await syncTabs()
      }
      return link
    }
    const tempMenu = document.querySelector(".temp-menu")
    if (!tempMenu) {
      return null
    }
    const index = document.querySelectorAll("aside .s .frame-link").length
    const item = document.createElement("a")
    item.target = target
    item.href = href
    item.setAttribute("data-index", String(index))
    item.className = "btn header-item frame-link"
    item.dataset.shellTab = "1"
    item.dataset.askAiShellTab = "1"
    const displayText = tool && typeof tool.label === "string" && tool.label.trim()
      ? tool.label.trim()
      : "Shell"
    item.innerHTML = `<div class='tab'><i class="fa-solid fa-link"></i><div class='display'>${escapeTabHtml(displayText)}</div><div class='flexible'></div></div>`
    tempMenu.appendChild(item)
    await syncTabs()
    return item
  }

  const openShellTool = async (tool) => {
    if (!tool || typeof tool.href !== "string") {
      return false
    }
    const session = createAskAiLaunchSession()
    const href = appendLaunchSessionParam(tool.href, session)
    const target = appendLaunchSessionParam(tool.target || `@${tool.href}`, session)
    await ensureAskAiShellTab(tool, href, target)
    return openWithUrl(href, { frameName: target })
  }

  const createPickerOption = (tool, workspaceCwd) => {
    const button = document.createElement("button")
    button.type = "button"
    button.className = "ask-ai-drawer-picker-option"
    button.setAttribute("role", "listitem")

    if (tool.iconSrc) {
      const icon = document.createElement("img")
      icon.className = "ask-ai-drawer-picker-icon"
      icon.src = tool.iconSrc
      icon.alt = ""
      icon.loading = "lazy"
      button.appendChild(icon)
    } else {
      const fallback = document.createElement("span")
      fallback.className = "ask-ai-drawer-picker-icon-fallback"
      const iconClass = typeof tool.iconClass === "string" && tool.iconClass.trim()
        ? tool.iconClass.trim()
        : "fa-solid fa-robot"
      const fallbackIcon = document.createElement("i")
      fallbackIcon.className = iconClass
      fallbackIcon.setAttribute("aria-hidden", "true")
      fallback.appendChild(fallbackIcon)
      button.appendChild(fallback)
    }

    const copy = document.createElement("span")
    copy.className = "ask-ai-drawer-picker-copy"
    const name = document.createElement("div")
    name.className = "ask-ai-drawer-picker-name"
    name.textContent = tool.label || tool.value || "Plugin"
    copy.appendChild(name)
    if (tool.description) {
      const meta = document.createElement("div")
      meta.className = "ask-ai-drawer-picker-meta"
      meta.textContent = tool.description
      copy.appendChild(meta)
    }
    button.appendChild(copy)

    button.addEventListener("click", async () => {
      if (tool.kind === "shell") {
        const opened = await openShellTool(tool)
        if (!opened) {
          setPickerStatus("Could not open this shell.")
        }
        return
      }
      if (await redirectToPluginInstallIfNeeded(tool.href)) {
        return
      }
      const opened = openWithUrl(tool.href, { workspaceCwd })
      if (!opened) {
        setPickerStatus("Could not launch this plugin.")
      }
    })
    return button
  }

  const normalizePickerQuery = (value) => String(value || "").trim().toLowerCase()

  const toolMatchesPickerQuery = (tool, query) => {
    if (!query) {
      return true
    }
    const haystack = [
      tool && tool.label,
      tool && tool.value,
      tool && tool.description,
      tool && tool.category,
      tool && tool.kind
    ].filter(Boolean).join(" ").toLowerCase()
    return haystack.includes(query)
  }

  const renderPicker = (tools, workspaceCwd, query = "") => {
    clearPickerList()
    const sourceTools = Array.isArray(tools) ? tools : []
    if (sourceTools.length === 0) {
      setPickerStatus("No shells or plugins available.")
      return
    }
    const normalizedQuery = normalizePickerQuery(query)
    const visibleTools = normalizedQuery
      ? sourceTools.filter((tool) => toolMatchesPickerQuery(tool, normalizedQuery))
      : sourceTools
    if (visibleTools.length === 0) {
      setPickerStatus("No matching shells or plugins.")
      return
    }
    const groups = new Map()
    visibleTools.forEach((tool) => {
      const category = typeof tool.category === "string" && tool.category.trim() ? tool.category.trim() : "Other"
      if (!groups.has(category)) {
        groups.set(category, [])
      }
      groups.get(category).push(tool)
    })
    const ordered = ["SHELL", "CLI", "IDE"].concat(Array.from(groups.keys()).filter((name) => !["SHELL", "CLI", "IDE"].includes(name)))
    let renderedCount = 0
    ordered.forEach((category) => {
      const items = (groups.get(category) || []).slice().sort((a, b) =>
        (a.label || a.value || "").localeCompare(
          (b.label || b.value || ""),
          undefined,
          { sensitivity: "base" }
        )
      )
      if (items.length === 0) {
        return
      }
      const displayCategory = category === "SHELL"
        ? "Project Shell"
        : (category === "IDE" ? "Desktop Plugins" : (category === "CLI" ? "Terminal Plugins" : category))
      const group = document.createElement("div")
      group.className = "ask-ai-drawer-picker-group"
      const label = document.createElement("div")
      label.className = "ask-ai-drawer-picker-group-label"
      label.textContent = displayCategory
      group.appendChild(label)
      items.forEach((tool) => {
        group.appendChild(createPickerOption(tool, workspaceCwd))
        renderedCount += 1
      })
      if (pickerList) {
        pickerList.appendChild(group)
      }
    })
    if (!renderedCount) {
      setPickerStatus("No shells or plugins available.")
      return
    }
    setPickerStatus("")
  }

  const openWithUrl = (rawUrl, opts = {}) => {
    const workspaceCwd = opts && typeof opts.workspaceCwd === "string" ? opts.workspaceCwd : ""
    const frameName = opts && typeof opts.frameName === "string" ? opts.frameName.trim() : ""
    const normalized = normalizeLaunchUrl(rawUrl, workspaceCwd)
    if (!normalized) {
      return false
    }
    pickerRequestId += 1
    currentUrl = normalized
    setLocation(normalized)
    setActionState(true)
    setEmptyState(false)
    if (frame) {
      frame.dataset.loaded = "1"
      if (frameName) {
        frame.name = frameName
        frame.setAttribute("name", frameName)
      } else {
        frame.removeAttribute("name")
      }
      frame.src = normalized
    }
    setOpen(true)
    return true
  }

  const openWithAgent = (payload) => {
    if (!payload || typeof payload.agentHref !== "string" || payload.agentHref.length === 0) {
      return false
    }
    return openWithUrl(payload.agentHref, {
      workspaceCwd: resolveWorkspaceCwd(payload)
    })
  }

  const openPicker = (payload) => {
    const workspaceCwd = resolveWorkspaceCwd(payload)
    pickerRequestId += 1
    const requestId = pickerRequestId
    currentUrl = ""
    setLocation("")
    setActionState(false)
    setEmptyState(true)
    setOpen(true)
    clearPickerList()
    renderedPickerTools = []
    renderedPickerWorkspaceCwd = workspaceCwd
    if (searchInput) {
      searchInput.value = ""
    }
    setPickerStatus("Loading shells and plugins...")
    getAskAiTools(workspaceCwd).then((tools) => {
      if (requestId !== pickerRequestId) {
        return
      }
      renderedPickerTools = Array.isArray(tools) ? tools : []
      renderedPickerWorkspaceCwd = workspaceCwd
      renderPicker(renderedPickerTools, renderedPickerWorkspaceCwd, searchInput ? searchInput.value : "")
    })
    return true
  }

  const isTrustedOrigin = (origin) => {
    if (!origin) {
      return true
    }
    let parsed
    try {
      parsed = new URL(origin)
    } catch (_) {
      return false
    }
    const originPort = parsed.port || "80"
    const currentPort = window.location.port || "80"
    if (String(originPort) === String(currentPort)) {
      return true
    }
    return /https:\/\/.*pinokio\..*(localhost|co)/.test(origin)
  }

  const getBrowserviewFrames = () => Array.from(document.querySelectorAll("main.browserview iframe"))

  const frameContainsSourceWindow = (containerWindow, sourceWindow, depth = 0) => {
    if (!containerWindow || !sourceWindow) {
      return false
    }
    if (containerWindow === sourceWindow) {
      return true
    }
    if (depth > 12) {
      return false
    }
    let childCount = 0
    try {
      childCount = containerWindow.frames ? containerWindow.frames.length : 0
    } catch (_) {
      childCount = 0
    }
    for (let index = 0; index < childCount; index += 1) {
      let childWindow = null
      try {
        childWindow = containerWindow.frames[index]
      } catch (_) {
        childWindow = null
      }
      if (!childWindow) {
        continue
      }
      if (childWindow === sourceWindow) {
        return true
      }
      if (frameContainsSourceWindow(childWindow, sourceWindow, depth + 1)) {
        return true
      }
    }
    return false
  }

  const resolveFrameSourceRecord = (sourceWindow) => {
    if (!sourceWindow) {
      return null
    }
    const frames = getBrowserviewFrames()
    for (const node of frames) {
      if (!node || !node.contentWindow) {
        continue
      }
      if (node.contentWindow === sourceWindow) {
        return {
          root: node,
          exact: node
        }
      }
      if (frameContainsSourceWindow(node.contentWindow, sourceWindow)) {
        return {
          root: node,
          exact: null
        }
      }
    }
    return null
  }

  const isKnownFrameSource = (sourceWindow) => {
    return Boolean(resolveFrameSourceRecord(sourceWindow))
  }

  const resolveFrameUrlFromSource = (sourceWindow) => {
    const record = resolveFrameSourceRecord(sourceWindow)
    if (!record || !record.root) {
      return ""
    }
    return record.root.src || ""
  }

  const dispatchPinokioEvent = async (envelope, sourceWindow) => {
    const eventName = envelope && typeof envelope.event === "string" ? envelope.event.trim() : ""
    if (!eventName) {
      return null
    }
    const payload = envelope && envelope.payload && typeof envelope.payload === "object" ? envelope.payload : {}
    const context = envelope && envelope.context && typeof envelope.context === "object"
      ? { ...envelope.context }
      : {}
    if (!context.frameUrl) {
      const frameUrl = resolveFrameUrlFromSource(sourceWindow)
      if (frameUrl) {
        context.frameUrl = frameUrl
      }
    }
    context.pageUrl = window.location.href
    context.currentUrl = window.location.href
    const response = await fetch("/pinokio/event", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      body: JSON.stringify({
        event: eventName,
        payload,
        context
      })
    })
    if (!response.ok) {
      return null
    }
    const result = await response.json().catch(() => null)
    return result && typeof result === "object" ? result : null
  }

  const openEventLaunch = (launch, runtimeContext = {}) => {
    const eventDrawer = window.PinokioEventDrawer
    if (!eventDrawer || typeof eventDrawer.openEventLaunch !== "function") {
      return false
    }
    return eventDrawer.openEventLaunch(launch, runtimeContext)
  }

  if (refreshBtn) {
    refreshBtn.addEventListener("click", () => {
      if (!frame || !currentUrl) return
      frame.dataset.loaded = "1"
      frame.src = currentUrl
      setLocation(currentUrl)
    })
  }

  if (externalBtn) {
    externalBtn.addEventListener("click", () => {
      if (!currentUrl) return
      window.open(currentUrl, "_blank", "noopener")
    })
  }

  if (closeBtn) {
    closeBtn.addEventListener("click", () => {
      setOpen(false)
    })
  }

  if (frame) {
    frame.addEventListener("load", () => {
      if (frame.src) {
        setLocation(frame.src)
      }
    })
  }

  if (searchInput) {
    searchInput.addEventListener("input", () => {
      renderPicker(renderedPickerTools, renderedPickerWorkspaceCwd, searchInput.value)
    })
  }

  window.addEventListener("message", (event) => {
    if (!event || !event.data || typeof event.data !== "object") {
      return
    }
    const messageType = event.data.e
    const trusted = isTrustedOrigin(event.origin) || (messageType === "pinokio:event" && isKnownFrameSource(event.source))
    if (!trusted) {
      return
    }
    if (messageType === "pinokio:ask-ai-launch") {
      openWithAgent(event.data)
    } else if (messageType === "pinokio:ask-ai-open-url") {
      openWithUrl(event.data.url, {
        workspaceCwd: typeof event.data.workspaceCwd === "string" ? event.data.workspaceCwd : ""
      })
    } else if (messageType === "pinokio:ask-ai-open-picker") {
      openPicker(event.data)
    } else if (messageType === "pinokio:event-panel-status") {
      const eventDrawer = window.PinokioEventDrawer
      if (eventDrawer && typeof eventDrawer.handleStatusMessage === "function") {
        eventDrawer.handleStatusMessage(event)
      }
    } else if (messageType === "pinokio:event") {
      const sourceFrameUrl = resolveFrameUrlFromSource(event.source)
      dispatchPinokioEvent(event.data, event.source).then((result) => {
        if (result && result.ok && result.matched && result.launch) {
          openEventLaunch(result.launch, {
            sourceWindow: event.source,
            sourceFrameUrl
          })
        }
      }).catch(() => {})
    }
  })

  if (resizer) {
    let isResizing = false
    let pointerId = null
    let startX = 0
    let startWidth = 0
    let handlePointerMove = null
    let handlePointerUp = null

    const finishResizing = () => {
      if (!isResizing) {
        return
      }
      isResizing = false
      if (pointerId != null) {
        try {
          resizer.releasePointerCapture(pointerId)
        } catch (_) {}
      }
      pointerId = null
      window.removeEventListener("pointermove", handlePointerMove)
      window.removeEventListener("pointerup", handlePointerUp)
      if (askAiWidth != null) {
        persistWidth(askAiWidth)
      }
    }

    const bindResizeListeners = () => {
      if (!handlePointerMove) {
        handlePointerMove = (event) => {
          if (!isResizing) return
          if (pointerId != null && event.pointerId !== pointerId) return
          event.preventDefault()
          const delta = startX - event.clientX
          applyWidth(startWidth + delta, false)
        }
      }
      if (!handlePointerUp) {
        handlePointerUp = (event) => {
          if (pointerId != null && event.pointerId !== pointerId) return
          finishResizing()
        }
      }
      window.addEventListener("pointermove", handlePointerMove)
      window.addEventListener("pointerup", handlePointerUp, { once: true })
    }

    resizer.addEventListener("pointerdown", (event) => {
      if (!appcanvas || !appcanvas.classList.contains("panel-open")) {
        return
      }
      if (event.button !== 0 && event.pointerType !== "touch") {
        return
      }
      event.preventDefault()
      isResizing = true
      pointerId = event.pointerId
      startX = event.clientX
      startWidth = drawer.getBoundingClientRect().width
      try {
        resizer.setPointerCapture(event.pointerId)
      } catch (_) {}
      bindResizeListeners()
    })
  }

  open = false
  initWidth()
  setLocation("")
  setActionState(false)
  setEmptyState(true)
  setPickerStatus("Choose a shell or plugin to start an agent.")
  setOpen(false)
  window.PinokioAskAiDrawer = {
    openWithAgent,
    openPicker,
    openWithUrl,
    close: () => setOpen(false),
    isOpen: () => open
  }
})();

(function() {
  const drawer = document.getElementById("event-launch-drawer")
  if (!drawer) {
    return
  }
  const appcanvas = document.querySelector(".appcanvas")
  const frame = drawer.querySelector(".event-launch-frame")
  const refreshBtn = drawer.querySelector(".event-launch-drawer-refresh")
  const externalBtn = drawer.querySelector(".event-launch-drawer-external")
  const closeBtn = drawer.querySelector(".event-launch-drawer-close")
  const resizer = document.getElementById("event-launch-resizer")
  const widthKey = "pinokio.event_panel.width"
  const EVENT_PANEL_MIN_WIDTH = 240

  let open = false
  let currentUrl = ""
  let eventPanelWidth = null
  let placement = "sidebar"
  let closeOnSuccess = false
  let refreshOnClose = false
  let sourceWindow = null
  let sourceFrameUrl = ""

  const normalizeRefreshOnClose = (value) => {
    if (value === true) {
      return "source"
    }
    if (typeof value === "string") {
      const normalized = value.trim().toLowerCase()
      if (normalized === "source" || normalized === "root" || normalized === "active") {
        return normalized
      }
    }
    return false
  }

  const getBrowserviewFrames = () => {
    return Array.from(document.querySelectorAll("main.browserview iframe"))
  }

  const getActiveBrowserviewFrame = () => {
    const frames = getBrowserviewFrames()
    if (frames.length === 0) {
      return null
    }
    return frames.find((node) => node && node.classList.contains("selected") && !node.classList.contains("hidden"))
      || frames.find((node) => node && !node.classList.contains("hidden"))
      || frames.find((node) => node && node.classList.contains("selected"))
      || frames[0]
      || null
  }

  const samePath = (left, right) => {
    try {
      const leftUrl = new URL(left, window.location.origin)
      const rightUrl = new URL(right, window.location.origin)
      return leftUrl.pathname === rightUrl.pathname
    } catch (_) {
      return false
    }
  }

  const resolveFrameBySourceUrl = (value, frames) => {
    const sourceUrl = typeof value === "string" ? value.trim() : ""
    if (!sourceUrl) {
      return null
    }
    return frames.find((node) => node && node.src === sourceUrl)
      || frames.find((node) => node && samePath(node.src, sourceUrl))
      || null
  }

  const resolveRefreshTargetFrame = (policy) => {
    const normalizedPolicy = normalizeRefreshOnClose(policy)
    if (!normalizedPolicy) {
      return null
    }
    if (normalizedPolicy === "active") {
      return getActiveBrowserviewFrame()
    }
    const frames = getBrowserviewFrames()
    if (frames.length === 0) {
      return null
    }
    if (sourceWindow) {
      if (normalizedPolicy === "source") {
        const exact = frames.find((node) => node && node.contentWindow === sourceWindow)
        if (exact) {
          return exact
        }
      } else if (normalizedPolicy === "root") {
        let rootWindow = sourceWindow
        try {
          rootWindow = sourceWindow.top || sourceWindow
        } catch (_) {}
        const root = frames.find((node) => node && node.contentWindow === rootWindow)
          || frames.find((node) => node && node.contentWindow === sourceWindow)
        if (root) {
          return root
        }
      }
    }
    return resolveFrameBySourceUrl(sourceFrameUrl, frames)
  }

  const refreshFrameNode = (targetFrame) => {
    if (!targetFrame) {
      return false
    }
    try {
      if (targetFrame.contentWindow && targetFrame.contentWindow.location && typeof targetFrame.contentWindow.location.reload === "function") {
        targetFrame.contentWindow.location.reload()
        return true
      }
    } catch (_) {}
    const currentSrc = targetFrame.getAttribute("src") || targetFrame.src
    if (currentSrc) {
      targetFrame.src = currentSrc
      return true
    }
    return false
  }

  const maybeRefreshOnClose = () => {
    const target = resolveRefreshTargetFrame(refreshOnClose)
    if (!target) {
      return false
    }
    return refreshFrameNode(target)
  }

  const clearEventState = () => {
    closeOnSuccess = false
    refreshOnClose = false
    sourceWindow = null
    sourceFrameUrl = ""
  }

  const setActionState = (hasUrl) => {
    const enabled = !!hasUrl
    if (refreshBtn) refreshBtn.disabled = !enabled
    if (externalBtn) externalBtn.disabled = !enabled
  }

  const applyOpenState = () => {
    if (!appcanvas) {
      return
    }
    appcanvas.classList.toggle("event-drawer-open", open && placement !== "bottom")
    appcanvas.classList.toggle("event-bottom-open", open && placement === "bottom")
  }

  const setPlacement = (nextPlacement) => {
    placement = nextPlacement === "bottom" ? "bottom" : "sidebar"
    drawer.classList.toggle("bottom-mode", placement === "bottom")
    applyOpenState()
  }

  const clampWidth = (value) => {
    const numeric = typeof value === "number" ? value : parseInt(value, 10)
    if (Number.isNaN(numeric)) {
      return EVENT_PANEL_MIN_WIDTH
    }
    return Math.max(numeric, EVENT_PANEL_MIN_WIDTH)
  }

  const readWidth = () => {
    try {
      const stored = window.localStorage.getItem(widthKey)
      if (!stored) {
        return null
      }
      const parsed = parseInt(stored, 10)
      return Number.isNaN(parsed) ? null : parsed
    } catch (_) {
      return null
    }
  }

  const persistWidth = (value) => {
    try {
      window.localStorage.setItem(widthKey, String(value))
    } catch (_) {}
  }

  const applyWidth = (value, persist) => {
    const width = clampWidth(value)
    eventPanelWidth = width
    if (appcanvas) {
      appcanvas.style.setProperty("--event-panel-width", `${width}px`)
    } else {
      drawer.style.width = `${width}px`
    }
    if (resizer) {
      resizer.setAttribute("aria-valuenow", String(width))
    }
    if (persist) {
      persistWidth(width)
    }
  }

  const initWidth = () => {
    const stored = readWidth()
    const fallback = parseInt(getComputedStyle(drawer).width, 10) || 560
    applyWidth(typeof stored === "number" ? stored : fallback, false)
  }

  const setOpen = (next, opts = {}) => {
    const wasOpen = open
    open = !!next
    if (open) {
      const askAiDrawer = window.PinokioAskAiDrawer
      if (askAiDrawer && typeof askAiDrawer.close === "function") {
        askAiDrawer.close()
      }
    }
    applyOpenState()
    drawer.setAttribute("aria-hidden", open ? "false" : "true")
    if (resizer) {
      resizer.setAttribute("aria-hidden", open ? "false" : "true")
    }
    if (wasOpen && !open) {
      if (!(opts && opts.skipEventRefresh === true)) {
        maybeRefreshOnClose()
      }
      clearEventState()
    }
  }

  const normalizeLaunchUrl = (rawUrl) => {
    if (!rawUrl) {
      return null
    }
    try {
      const parsed = new URL(rawUrl, window.location.origin)
      parsed.searchParams.set("__pinokio_event_panel", "1")
      if (parsed.origin !== window.location.origin) {
        return parsed.toString()
      }
      return `${parsed.pathname}${parsed.search}${parsed.hash}`
    } catch (_) {
      return null
    }
  }

  const openLaunchUrl = (launchUrl, opts = {}) => {
    const normalized = normalizeLaunchUrl(launchUrl)
    if (!normalized) {
      return false
    }
    setPlacement(opts && opts.placement === "bottom" ? "bottom" : "sidebar")
    currentUrl = normalized
    setActionState(true)
    if (frame) {
      frame.classList.remove("hidden")
      frame.dataset.loaded = "1"
      frame.src = normalized
    }
    setOpen(true)
    return true
  }

  const openEventLaunch = (launch, runtimeContext = {}) => {
    if (!launch || typeof launch !== "object") {
      return false
    }
    const launchUrl = typeof launch.url === "string" ? launch.url : ""
    if (!launchUrl) {
      return false
    }
    const ui = launch.ui && typeof launch.ui === "object" ? launch.ui : {}
    closeOnSuccess = Boolean(ui.closeOnSuccess)
    refreshOnClose = normalizeRefreshOnClose(ui.refreshOnClose)
    sourceWindow = runtimeContext && runtimeContext.sourceWindow ? runtimeContext.sourceWindow : null
    sourceFrameUrl = runtimeContext && typeof runtimeContext.sourceFrameUrl === "string" ? runtimeContext.sourceFrameUrl : ""
    const mode = typeof ui.mode === "string" ? ui.mode : "background"
    if (mode === "background") {
      const opened = openLaunchUrl(launchUrl, { placement: "sidebar" })
      if (opened) {
        setOpen(false, { skipEventRefresh: true })
      }
      return opened
    }
    return openLaunchUrl(launchUrl, {
      placement: mode === "bottom" ? "bottom" : "sidebar"
    })
  }

  const handleStatusMessage = (event) => {
    if (!event || !event.data || typeof event.data !== "object") {
      return false
    }
    if (!frame || event.source !== frame.contentWindow) {
      return false
    }
    const success = Boolean(event.data.success)
    if (success && closeOnSuccess && open) {
      setOpen(false)
    }
    return true
  }

  if (refreshBtn) {
    refreshBtn.addEventListener("click", () => {
      if (!frame || !currentUrl) {
        return
      }
      frame.dataset.loaded = "1"
      frame.src = currentUrl
    })
  }

  if (externalBtn) {
    externalBtn.addEventListener("click", () => {
      if (!currentUrl) {
        return
      }
      window.open(currentUrl, "_blank", "noopener")
    })
  }

  if (closeBtn) {
    closeBtn.addEventListener("click", () => {
      setOpen(false)
    })
  }

  if (frame) {
    frame.addEventListener("load", () => {
      if (frame.src) {
        currentUrl = frame.src
        setActionState(true)
      }
    })
  }

  if (resizer) {
    let isResizing = false
    let pointerId = null
    let startX = 0
    let startWidth = 0
    let handlePointerMove = null
    let handlePointerUp = null

    const finishResizing = () => {
      if (!isResizing) {
        return
      }
      isResizing = false
      if (pointerId != null) {
        try {
          resizer.releasePointerCapture(pointerId)
        } catch (_) {}
      }
      pointerId = null
      window.removeEventListener("pointermove", handlePointerMove)
      window.removeEventListener("pointerup", handlePointerUp)
      if (eventPanelWidth != null) {
        persistWidth(eventPanelWidth)
      }
    }

    const bindResizeListeners = () => {
      if (!handlePointerMove) {
        handlePointerMove = (event) => {
          if (!isResizing) return
          if (pointerId != null && event.pointerId !== pointerId) return
          event.preventDefault()
          const delta = startX - event.clientX
          applyWidth(startWidth + delta, false)
        }
      }
      if (!handlePointerUp) {
        handlePointerUp = (event) => {
          if (pointerId != null && event.pointerId !== pointerId) return
          finishResizing()
        }
      }
      window.addEventListener("pointermove", handlePointerMove)
      window.addEventListener("pointerup", handlePointerUp, { once: true })
    }

    resizer.addEventListener("pointerdown", (event) => {
      if (!appcanvas || !appcanvas.classList.contains("event-drawer-open")) {
        return
      }
      if (event.button !== 0 && event.pointerType !== "touch") {
        return
      }
      event.preventDefault()
      isResizing = true
      pointerId = event.pointerId
      startX = event.clientX
      startWidth = drawer.getBoundingClientRect().width
      try {
        resizer.setPointerCapture(event.pointerId)
      } catch (_) {}
      bindResizeListeners()
    })
  }

  initWidth()
  setPlacement("sidebar")
  setActionState(false)
  setOpen(false)

  window.PinokioEventDrawer = {
    openEventLaunch,
    handleStatusMessage,
    close: () => setOpen(false),
    isOpen: () => open
  }
})();

(function() {
  const drawer = document.getElementById("app-logs-drawer")
  if (!drawer) {
    return
  }
  const appcanvas = document.querySelector(".appcanvas")
  const toggle = document.getElementById("logs-toggle")
  const mobileToggle = document.querySelector(".mobile-nav-logs")
  const closeBtn = drawer.querySelector(".app-logs-close")
  const refreshBtn = drawer.querySelector(".app-logs-refresh")
  const copyBtn = drawer.querySelector(".app-logs-copy")
  const statusEl = drawer.querySelector(".app-logs-status")
  const outputEl = drawer.querySelector(".app-logs-report-output")
  const sectionList = drawer.querySelector(".app-logs-section-list")
  const sectionsValue = drawer.querySelector('[data-app-logs-summary="sections"]')
  const redactionsValue = drawer.querySelector('[data-app-logs-summary="redactions"]')
  const reportUrl = drawer.dataset.reportUrl || ""
  let open = false
  let loading = false
  let report = null

  const setStatus = (text) => {
    if (statusEl) {
      statusEl.textContent = text
    }
  }

  const updateToggleState = () => {
    const logsPageSelected = !!(window.PinokioIsLogsPageSelected && window.PinokioIsLogsPageSelected())
    const selected = open || logsPageSelected
    if (toggle) {
      toggle.classList.toggle("selected", selected)
      toggle.setAttribute("aria-expanded", open ? "true" : "false")
    }
    if (mobileToggle) {
      mobileToggle.classList.toggle("selected", selected)
      mobileToggle.setAttribute("aria-pressed", selected ? "true" : "false")
    }
  }

  const setOpen = (next, options = {}) => {
    open = !!next
    if (appcanvas) {
      appcanvas.classList.toggle("logs-open", open)
    }
    drawer.setAttribute("aria-hidden", open ? "false" : "true")
    updateToggleState()
    if (open) {
      loadReport(Boolean(options && options.force))
    }
  }

  const countRedactions = (counts) => {
    return Object.values(counts || {}).reduce((total, value) => {
      const numeric = Number(value)
      return total + (Number.isFinite(numeric) ? numeric : 0)
    }, 0)
  }

  const clearSections = () => {
    if (!sectionList) return
    while (sectionList.firstChild) {
      sectionList.removeChild(sectionList.firstChild)
    }
  }

  const renderSections = (sections) => {
    clearSections()
    if (!sectionList) return
    for (const section of sections || []) {
      const chip = document.createElement("div")
      chip.className = "app-logs-section-chip"
      chip.textContent = section.file || section.script || section.source || "log"
      chip.title = chip.textContent
      sectionList.appendChild(chip)
    }
  }

  const renderReport = (payload) => {
    const sections = Array.isArray(payload && payload.sections) ? payload.sections : []
    const redactionCount = countRedactions(payload && payload.redactions)
    if (sectionsValue) {
      sectionsValue.textContent = String(sections.length)
    }
    if (redactionsValue) {
      redactionsValue.textContent = redactionCount > 0 ? `${redactionCount} hidden` : "0"
    }
    renderSections(sections)
    if (outputEl) {
      outputEl.textContent = payload && payload.markdown ? payload.markdown : "No app log files were found."
    }
    if (copyBtn) {
      copyBtn.disabled = !(payload && payload.markdown)
    }
    setStatus(`Basic redaction applied. ${sections.length} latest log file${sections.length === 1 ? "" : "s"} included.`)
  }

  const renderError = (message) => {
    if (sectionsValue) sectionsValue.textContent = "--"
    if (redactionsValue) redactionsValue.textContent = "--"
    clearSections()
    if (outputEl) {
      outputEl.textContent = message
    }
    if (copyBtn) {
      copyBtn.disabled = true
    }
    setStatus("Unable to build log report.")
  }

  async function loadReport(force) {
    if (!reportUrl || loading) {
      return
    }
    if (report && !force) {
      renderReport(report)
      return
    }
    loading = true
    if (refreshBtn) {
      refreshBtn.disabled = true
    }
    setStatus("Building sanitized log report...")
    try {
      const response = await fetch(reportUrl, {
        headers: { "Accept": "application/json" },
        cache: "no-store"
      })
      const payload = await response.json().catch(() => null)
      if (!response.ok) {
        throw new Error(payload && payload.error ? payload.error : `HTTP ${response.status}`)
      }
      report = payload
      renderReport(report)
    } catch (error) {
      renderError(error && error.message ? error.message : String(error || "Unknown error"))
    } finally {
      loading = false
      if (refreshBtn) {
        refreshBtn.disabled = false
      }
    }
  }

  const copyReport = async () => {
    if (!report || !report.markdown) {
      return
    }
    try {
      await navigator.clipboard.writeText(report.markdown)
      setStatus("Report copied.")
    } catch (_) {
      if (outputEl) {
        outputEl.focus()
        const selection = window.getSelection()
        const range = document.createRange()
        range.selectNodeContents(outputEl)
        selection.removeAllRanges()
        selection.addRange(range)
      }
      setStatus("Select the report text to copy.")
    }
  }

  if (toggle) {
    toggle.addEventListener("click", (event) => {
      event.preventDefault()
      if (
        window.PinokioIsLogsPageSelected &&
        typeof window.PinokioIsLogsPageSelected === "function" &&
        window.PinokioIsLogsPageSelected() &&
        window.PinokioCloseLogsPage &&
        typeof window.PinokioCloseLogsPage === "function"
      ) {
        window.PinokioCloseLogsPage()
        return
      }
      if (window.PinokioOpenLogsPage && typeof window.PinokioOpenLogsPage === "function") {
        window.PinokioOpenLogsPage({ view: "latest" })
        return
      }
      setOpen(!open)
    })
  }
  if (closeBtn) {
    closeBtn.addEventListener("click", () => setOpen(false))
  }
  if (refreshBtn) {
    refreshBtn.addEventListener("click", () => loadReport(true))
  }
  if (copyBtn) {
    copyBtn.addEventListener("click", copyReport)
  }
  const communityToggle = document.getElementById("community-toggle")
  if (communityToggle) {
    communityToggle.addEventListener("click", () => {
      if (open) {
        setOpen(false)
      }
    }, { capture: true })
  }

  window.PinokioLogsDrawer = {
    open: (options = {}) => setOpen(true, options),
    close: () => setOpen(false),
    refresh: () => loadReport(true),
    isOpen: () => open
  }

  setOpen(false)
})();

(function() {
  const drawer = document.getElementById("community-drawer")
  if (!drawer) {
    return
  }
  const toggle = document.getElementById("community-toggle")
  const appcanvas = document.querySelector(".appcanvas")
  const communityModeToggle = document.getElementById("community-mode-toggle")
  const frame = drawer.querySelector(".community-frame")
  const connectBtn = drawer.querySelector(".community-drawer-connect")
  const backBtn = drawer.querySelector(".community-drawer-back")
  const forwardBtn = drawer.querySelector(".community-drawer-forward")
  const refreshBtn = drawer.querySelector(".community-drawer-refresh")
  const toggleBtn = drawer.querySelector(".community-drawer-toggle")
  const expandBtn = drawer.querySelector(".community-drawer-expand")
  const closeBtn = drawer.querySelector(".community-drawer-close")
  const homeBtn = drawer.querySelector(".community-drawer-home")
  const locationContainer = drawer.querySelector(".community-drawer-location")
  const locationInput = drawer.querySelector(".community-drawer-location-input")
  const locationOverlay = drawer.querySelector(".community-drawer-location-overlay")
  const locationTextarea = drawer.querySelector(".community-drawer-location-textarea")
  const statusDot = drawer.querySelector(".community-drawer-status")
  const empty = drawer.querySelector(".community-drawer-empty")
  const emptyTitle = drawer.querySelector(".community-drawer-empty-title")
  const emptyNote = drawer.querySelector(".community-drawer-empty-note")
  const resizer = document.getElementById("community-resizer")
  const url = drawer.dataset.communityUrl || ""
  let communityOrigin = ""
  try {
    communityOrigin = url ? new URL(url).origin : ""
  } catch (_) {
    communityOrigin = ""
  }
  const enabledKey = "pinokio.community.enabled"
  const openKey = "pinokio.community.open"
  const widthKey = "pinokio.community.width"

  let enabled = false
  try {
    enabled = window.localStorage && window.localStorage.getItem(enabledKey) === "1"
  } catch (_) {}
  if (!url) {
    enabled = false
  }

  const communityModeQuery = window.matchMedia ? window.matchMedia("(max-width: 768px)") : null
  let communityMode = false

  const setCommunityMode = (next, opts) => {
    if (!appcanvas) {
      return
    }
    const updateUrl = !(opts && opts.updateUrl === false)
    const nextMode = !!next
    if (communityMode === nextMode) {
      return
    }
    communityMode = nextMode
    appcanvas.classList.toggle("community-mode", communityMode)
    if (communityMode) {
      setExpanded(false)
    }
    if (communityModeToggle) {
      communityModeToggle.classList.toggle("selected", communityMode)
      communityModeToggle.setAttribute("aria-pressed", communityMode ? "true" : "false")
    }
    if (updateUrl && typeof URL !== "undefined") {
      try {
        const urlObj = new URL(window.location.href)
        if (communityMode) {
          urlObj.searchParams.set("community", "1")
        } else {
          urlObj.searchParams.delete("community")
        }
        window.history.replaceState(null, "", urlObj.toString())
      } catch (_) {}
    }
  }

  const syncCommunityModeFromUrl = () => {
    if (!communityModeQuery || !communityModeQuery.matches) {
      setCommunityMode(false, { updateUrl: true })
      return
    }
    try {
      const params = new URLSearchParams(window.location.search || "")
