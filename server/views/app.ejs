          }
        } catch (error) {
          console.error('Failed to fetch repo changes:', error)
        }
      }

      activeRepoKey = repoParam
      currentChanges = changes || []
      gitCommitUrl = commitUrl

      const title = modalTitle || `File Changes${repoDisplayName ? ` — ${repoDisplayName}` : ''}`

