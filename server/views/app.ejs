  aria-label="Project feed"
  aria-expanded="false"
  aria-controls="community-drawer">
  <i class="fa-solid fa-rss" aria-hidden="true"></i>
  <span class="nav-action-label">Feed</span>
</button>
<% } %>
<a class='btn2' href="/columns" data-tippy-content="split into 2 columns">
  <div><i class="fa-solid fa-table-columns"></i></div>
</a>
<a class='btn2' href="/rows" data-tippy-content="split into 2 rows">
  <div><i class="fa-solid fa-table-columns fa-rotate-270"></i></div>
</a>
<button class='btn2' id='new-window' data-tippy-content="open a new window" title='open a new window' data-agent="<%=agent%>">
  <div><i class="fa-solid fa-plus"></i></div>
</button>
<button class='btn2 hidden' id='close-window' data-tippy-content='close this section'>
  <div><i class="fa-solid fa-xmark"></i></div>
</button>
</h1>
</header>
<div class='appcanvas vertical <%=type === "browse" ? "dev-workspace" : ""%>' data-page-error="<%= error ? '1' : '0' %>">
  <% if (type !== 'files') { %>
  <aside id='app-sidebar' class='active'>
      <div class='menu-container'>
        <div class='menu-scroller'>
        <div class='workspace-mode-switch' role="tablist" aria-label="Workspace mode">
          <a class="workspace-mode-link <%=type === 'run' ? 'selected' : ''%>" href="<%=run_tab%>" role="tab" aria-selected="<%=type === 'run' ? 'true' : 'false'%>">
            <i class="fa-solid fa-circle-play"></i>
            <span>Run</span>
          </a>
          <a class="workspace-mode-link <%=type === 'browse' || type === 'files' ? 'selected' : ''%>" href="<%=dev_tab%>" role="tab" aria-selected="<%=type === 'browse' || type === 'files' ? 'true' : 'false'%>">
            <i class="fa-solid fa-terminal"></i>
            <span>Dev</span>
          </a>
        </div>
        <div class='mobile-sheet-actions' aria-label="Workspace actions">
          <button type='button' id='menu-mobile-close' class='btn mobile-sheet-action' data-tippy-content="Close menu" aria-label="Close menu" title="Close menu">
            <i class="fa-solid fa-xmark"></i>
          </button>
          <a class='btn mobile-sheet-action' href="/home" aria-label="Home" title="Home">
            <i class="fa-solid fa-house"></i>
          </a>
          <button type='button' class='btn mobile-sheet-action' data-mobile-proxy="#refresh-page" data-mobile-close-menu="true" aria-label="Refresh" title="Refresh">
            <i class="fa-solid fa-rotate-right"></i>
          </button>
          <button type='button' class='btn mobile-sheet-action' data-mobile-proxy="#back" data-mobile-close-menu="true" aria-label="Back" title="Back">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button type='button' class='btn mobile-sheet-action' data-mobile-proxy="#forward" data-mobile-close-menu="true" aria-label="Forward" title="Forward">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
          <a class='btn mobile-sheet-action' href="/columns" aria-label="2 Columns" title="2 Columns">
            <i class="fa-solid fa-table-columns"></i>
          </a>
          <a class='btn mobile-sheet-action' href="/rows" aria-label="2 Rows" title="2 Rows">
            <i class="fa-solid fa-table-columns fa-rotate-270"></i>
          </a>
          <button type='button' class='btn mobile-sheet-action' data-mobile-proxy="#new-window" data-mobile-close-menu="true" aria-label="New Window" title="New Window">
            <i class="fa-solid fa-plus"></i>
          </button>
          <button type='button' class='btn mobile-sheet-action mobile-close-window-action hidden' data-mobile-proxy="#close-window" data-mobile-close-menu="true" aria-label="Close Section" title="Close Section">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
        <%if (type==='browse') { %>
          <div class='m n system' data-type="n">
            <a id='devtab' data-mode="refresh" target="<%=dev_link%>" href="<%=dev_link%>" class="btn frame-link <%=dev_initial_tab === 'files' ? '' : 'selected'%>" data-index="10">
              <div class="tab">
                <i class="fa-solid fa-bars"></i> Plugins
              </div>
            </a>
            <a id='filestab' target="pinokio-files" href="<%=editor_tab%>" class="btn frame-link <%=dev_initial_tab === 'files' ? 'selected' : ''%>" data-index="11">
              <div class="tab">
                <i class="fa-solid fa-file-lines"></i> Files
              </div>
            </a>
            
            <div class="dynamic <%=type==='run' ? '' : 'selected'%>">
              <div class='submenu'>
                <% if (plugin_menu) { %>
                  <%- include('./partials/dynamic', { dynamic: plugin_menu, }) %>
                <% } %>
              </div>
            </div>
          </div>
        <% } %>
        <%if (type === 'run') { %>
          <div class='m h menu' data-type='h'>
            <% if (config.menu) { %>
              <%- include('./partials/menu', { menu: config.menu, }) %>
            <% } %>
            <a id='settings-tab' data-mode="refresh" target="env-settings" href="/env/api/<%=name%>?host=app" class="btn header-item frame-link" data-index="settings" data-static="retain">
              <div class='tab'>
                <i class="fa-solid fa-gear"></i>
                <div class='display'>Settings</div>
                <div class='flexible'></div>
              </div>
            </a>
          </div>
        <% } %>
        <div class='m s temp-menu' data-type='s'>
          <%tabs.forEach((tab, i) => { %>
            <% const tabHref = typeof tab === "string" ? tab : ((tab && typeof tab.href === "string") ? tab.href : "") %>
            <% const tabLabel = typeof tab === "string" ? tab : ((tab && typeof tab.label === "string" && tab.label.trim().length > 0) ? tab.label.trim() : tabHref) %>
            <% const tabTarget = (tab && typeof tab.target === "string" && tab.target.trim().length > 0) ? tab.target.trim() : `s${i}` %>
            <% const tabIsShell = (tab && typeof tab.kind === "string" && tab.kind === "shell") || /\/shell\//.test(tabHref) %>
            <a target="<%=tabTarget%>" href="<%=tabHref%>" class="btn header-item frame-link tab-link-popover-host" data-index="<%=i%>" <%= tabIsShell ? 'data-shell-tab="1"' : '' %>>
              <div class='tab'>
                <i class="fa-solid fa-link"></i><div class='display'><%=tabLabel%></div><div class='flexible'></div><% if (!tabIsShell) { %><button class='btn2 del'><i class="fa-solid fa-xmark"></i></button><% } %>
              </div>
            </a>
          <%})%>
        </div>
      </div>
      <div class='menu-actions <%= type === "browse" ? "dev-menu-actions" : "" %>'>
        <% if (type === 'browse') { %>
          <%- include('./partials/fs_status') %>
        <% } %>
        <button type='button' id='logs-toggle' class="btn header-item" data-tippy-content="logs" aria-expanded="false" aria-controls="app-logs-drawer">
          <div class='tab'>
            <i class="fa-solid fa-laptop-code menu-action-leading-icon"></i>
            <div class='display'>Logs</div>
            <div class='flexible'></div>
            <span class='logs-new-badge hidden' id='logs-new-badge'>New</span>
          </div>
        </button>
        <button type='button' id='sidebar-open-explorer' class="btn header-item" data-filepath="<%=path%>" data-tippy-content="Open in File Explorer">
          <div class='tab'>
            <i class="fa-solid fa-folder-open menu-action-leading-icon"></i>
            <div class='display'>File Explorer</div>
            <div class='flexible'></div>
          </div>
