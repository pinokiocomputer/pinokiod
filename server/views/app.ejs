      const response = await fetch("/autolaunch", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({ app: appId, script: script || "" })
      })
      const data = await response.json()
      if (!response.ok || !data.ok) {
        throw new Error(data.error || "Failed to save autolaunch.")
      }
      syncState(data.app)
      setFeedback(data.app && data.app.autolaunch_enabled ? "Saved." : "Disabled.")
      renderScripts()
    } catch (error) {
      setFeedback(error && error.message ? error.message : "Failed to save autolaunch.", true)
      renderStatus()
    } finally {
      setBusy(false)
    }
  }
  const toggleAutolaunch = async () => {
    if (saving || loadingCandidates) return
    if (state.autolaunch_enabled) {
      await saveScript("")
      return
    }
    if (!candidateState) {
      await loadCandidates()
    }
    const script = selectedScript || chooseInitialScript(candidateState)
    if (!script) {
      setFeedback("Choose a script first.", true)
      return
    }
    selectedScript = script
    await saveScript(script)
  }

  renderStatus()
  renderScripts()

  button.addEventListener("click", (event) => {
    event.preventDefault()
    event.stopPropagation()
    setOpen(modal.classList.contains("hidden"))
  })
  closeButton.addEventListener("click", (event) => {
    event.preventDefault()
    event.stopPropagation()
    setOpen(false)
  })
  switchButton.addEventListener("click", (event) => {
    event.preventDefault()
    event.stopPropagation()
    toggleAutolaunch()
  })
  modal.addEventListener("click", (event) => {
    if (event.target === modal) {
      setOpen(false)
    }
  })
  scriptsEl.addEventListener("change", (event) => {
    const input = event.target && event.target.matches("input[name='app-autolaunch-script']")
      ? event.target
      : null
    if (!input) return
    selectedScript = input.value
    renderScripts()
    if (state.autolaunch_enabled && selectedScript !== state.autolaunch) {
      saveScript(selectedScript)
    }
  })
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !modal.classList.contains("hidden")) {
      setOpen(false)
    }
  })
})()

;(function() {
  const scroller = document.querySelector(".appcanvas > aside .menu-scroller")
  if (!scroller) return
  const updateScrollHints = () => {
    const canScroll = scroller.scrollWidth > scroller.clientWidth + 2
    scroller.classList.toggle("menu-scrollable", canScroll)
    if (!canScroll) {
      scroller.classList.remove("scroll-left", "scroll-right")
      return
    }
    const max = scroller.scrollWidth - scroller.clientWidth
    scroller.classList.toggle("scroll-left", scroller.scrollLeft > 4)
    scroller.classList.toggle("scroll-right", scroller.scrollLeft < max - 4)
  }
  window.PinokioMenuScrollHints = {
    update: updateScrollHints
  }
  updateScrollHints()
  scroller.addEventListener("scroll", updateScrollHints, { passive: true })
  window.addEventListener("resize", updateScrollHints)
  if (typeof ResizeObserver !== "undefined") {
    try {
      const ro = new ResizeObserver(updateScrollHints)
      ro.observe(scroller)
    } catch (_) {}
  }
})()
</script>
</body>
</html>
