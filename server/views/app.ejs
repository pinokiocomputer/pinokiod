  const buildPluginLaunchFromQuery = () => {
    try {
      const pageUrl = new URL(window.location.href)
      const pluginPath = pageUrl.searchParams.get("plugin")
      const isSystemPlugin = pluginPath && pluginPath.startsWith("/pinokio/run/plugin/")
      const isLocalPlugin = pluginPath && (pluginPath.startsWith("/plugin/") || pluginPath.startsWith("/api/"))
      if (!pluginPath || (!isSystemPlugin && !isLocalPlugin)) {
        return null
      }
      const launchUrl = new URL(isSystemPlugin ? pluginPath : `/run${pluginPath}`, window.location.origin)
      if (appWorkspacePath && !launchUrl.searchParams.has("cwd")) {
        launchUrl.searchParams.set("cwd", appWorkspacePath)
      }
      const consumedKeys = ["plugin"]
      const pluginLabel = pageUrl.searchParams.get("plugin_label")
      if (pluginLabel) {
        consumedKeys.push("plugin_label")
      }
      pageUrl.searchParams.forEach((value, key) => {
        if (key === "plugin" || key === "plugin_label") {
          return
        }
        launchUrl.searchParams.set(key, value)
        consumedKeys.push(key)
      })
      launchUrl.searchParams.set("session", createLaunchSession())
      const relativeHref = `${launchUrl.pathname}${launchUrl.search}${launchUrl.hash}`
      return {
        launch: {
          name: `@${relativeHref}`,
          href: relativeHref,
          label: pluginLabel || deriveLaunchLabel({ href: relativeHref })
        },
        consumedKeys: Array.from(new Set(consumedKeys))
      }
    } catch (_) {
      return null
    }
  }
