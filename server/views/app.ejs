<html>
<head>
<title><%=config.title%></title>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
<link href="/css/fontawesome.min.css" rel="stylesheet">
<link href="/css/solid.min.css" rel="stylesheet">
<link href="/css/regular.min.css" rel="stylesheet">
<link href="/css/brands.min.css" rel="stylesheet">
<link href="/markdown.css" rel="stylesheet"/>
<link href="/noty.css" rel="stylesheet"/>
<link href="/filepond.min.css" rel="stylesheet" />
<link href="/filepond-plugin-image-preview.min.css" rel="stylesheet" />
<link href="/filepond-plugin-image-edit.min.css" rel="stylesheet" />
<link href="/style.css" rel="stylesheet"/>
<link href="/urldropdown.css" rel="stylesheet" />
<script src="/modalinput.js"></script>
<script src="/pinokio-touch.js"></script>
<% if (agent === "electron") { %>
  <link href="/electron.css" rel="stylesheet"/>
<% } %>
<style>
:root {
  --assist-surface-light: var(--pinokio-chrome-accent-bg-light);
  --assist-surface-light-open: rgba(15, 23, 42, 0.92);
  --assist-text-light: var(--pinokio-chrome-accent-fg-light);
  --assist-text-light-open: #475569;
  --assist-surface-dark: var(--pinokio-chrome-accent-bg-dark);
  --assist-surface-dark-open: rgba(255, 255, 255, 0.14);
  --assist-text-dark: var(--pinokio-chrome-accent-fg-dark);
  --assist-text-dark-open: rgba(226, 232, 240, 0.84);
}
body.dark #devtab.selected {
  border: none;
  background: var(--pinokio-sidebar-tab-active-bg) !important;
}
.app-header-identity {
  position: relative;
  flex: 1 1 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: auto;
  height: 30px;
  padding: 0 14px;
  min-width: 0;
  max-width: none;
  margin: 0 10px 0 4px;
  box-sizing: border-box;
  border: 1px solid rgba(15, 23, 42, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.7);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.9),
    0 1px 2px rgba(15, 23, 42, 0.04);
  color: #0f172a;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.1;
  pointer-events: none;
  overflow: visible;
}
body.dark .app-header-identity {
  border-color: rgba(255, 255, 255, 0.08);
  background: rgba(16, 18, 24, 0.72);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.06),
    0 1px 2px rgba(2, 6, 23, 0.35);
  color: rgba(248, 250, 252, 0.94);
}
.app-header-identity-icon {
  width: 18px;
  height: 18px;
  flex: 0 0 18px;
  object-fit: contain;
  display: block;
}
.app-header-identity-title {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.app-header-identity-separator {
  width: 3px;
  height: 3px;
  flex: 0 0 3px;
  border-radius: 999px;
  background: rgba(100, 116, 139, 0.48);
}
body.dark .app-header-identity-separator {
  background: rgba(148, 163, 184, 0.6);
}
body.app-page header.navheader h1 > .flexible {
  flex: 0 0 0;
  min-width: 0;
}
body.app-page header.navheader .nav-labeled-action {
  width: auto;
  min-width: 0;
  height: 28px;
  flex: 0 0 auto;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 0 10px;
  border-radius: 6px;
  white-space: nowrap;
  line-height: 1;
  text-transform: none;
}
body.app-page header.navheader .nav-labeled-action i {
  margin: 0;
  padding: 0;
  font-size: 13px;
  line-height: 1;
}
body.app-page .ask-ai-brand-icon {
  display: inline-flex;
  width: 14px;
  height: 14px;
  flex: 0 0 14px;
  background: currentColor;
  -webkit-mask: url('/pinokio-mark.svg') center / contain no-repeat;
  mask: url('/pinokio-mark.svg') center / contain no-repeat;
}
body.app-page header.navheader .nav-labeled-action .nav-action-label {
  display: inline-block;
  font-size: 12px;
  line-height: 1;
  font-weight: 500;
}
body.app-page header.navheader .nav-labeled-action.selected,
body.app-page header.navheader .nav-labeled-action:hover,
body.app-page header.navheader .nav-labeled-action:focus-visible {
  background: var(--pinokio-sidebar-tab-active-bg);
  color: var(--pinokio-sidebar-tab-active-color);
}
.resource-usage {
  position: relative;
  flex: 0 0 auto;
  min-width: 0;
  display: inline-flex;
  align-items: center;
  pointer-events: auto;
}
.resource-usage-trigger {
  appearance: none;
  border: 0;
  background: transparent;
  color: inherit;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  height: 22px;
  min-width: 0;
  padding: 0 7px;
  margin: 0;
  border-radius: 999px;
  font: inherit;
  line-height: 1;
  cursor: pointer;
  transition: background 0.15s ease, color 0.15s ease;
}
.resource-usage-trigger::after {
  content: "";
  width: 0;
  height: 0;
  flex: 0 0 auto;
  margin-left: -2px;
  border-left: 3.5px solid transparent;
  border-right: 3.5px solid transparent;
  border-top: 4px solid rgba(71, 85, 105, 0.58);
  transform-origin: 50% 40%;
  transition: transform 0.15s ease, border-top-color 0.15s ease;
}
.resource-usage-trigger:hover,
.resource-usage-trigger[aria-expanded="true"] {
  background: rgba(15, 23, 42, 0.055);
}
body.dark .resource-usage-trigger:hover,
body.dark .resource-usage-trigger[aria-expanded="true"] {
  background: rgba(255, 255, 255, 0.07);
}
.resource-usage-trigger:hover::after,
.resource-usage-trigger[aria-expanded="true"]::after {
  border-top-color: rgba(71, 85, 105, 0.82);
}
body.dark .resource-usage-trigger::after {
  border-top-color: rgba(203, 213, 225, 0.58);
}
body.dark .resource-usage-trigger:hover::after,
body.dark .resource-usage-trigger[aria-expanded="true"]::after {
  border-top-color: rgba(248, 250, 252, 0.84);
}
.resource-usage-trigger[aria-expanded="true"]::after {
  transform: rotate(180deg);
}
.resource-usage-trigger:focus-visible {
  outline: 2px solid rgba(10, 132, 255, 0.55);
  outline-offset: 4px;
  border-radius: 999px;
}
.resource-chip {
  display: inline-flex;
  align-items: center;
  min-width: 0;
  color: rgba(71, 85, 105, 0.76);
  font-size: 11px;
  font-weight: 650;
  line-height: 1;
  white-space: nowrap;
}
body.dark .resource-chip {
  color: rgba(203, 213, 225, 0.7);
}
.resource-chip--cpu,
.resource-chip--ram,
.resource-chip--vram {
  color: rgba(71, 85, 105, 0.62);
}
body.dark .resource-chip--cpu,
body.dark .resource-chip--ram,
body.dark .resource-chip--vram {
  color: rgba(203, 213, 225, 0.62);
}
.resource-usage-popover {
  position: absolute;
  top: calc(100% + 9px);
  right: 0;
  width: 236px;
  padding: 8px 0;
  border: 1px solid rgba(15, 23, 42, 0.1);
  border-radius: 10px;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 16px 42px rgba(15, 23, 42, 0.14);
  color: #0f172a;
  z-index: 10000020;
}
body.dark .resource-usage-popover {
  border-color: rgba(255, 255, 255, 0.1);
  background: rgba(20, 22, 28, 0.98);
  box-shadow: 0 18px 46px rgba(0, 0, 0, 0.48);
  color: rgba(248, 250, 252, 0.94);
}
.resource-usage-popover.hidden {
  display: none;
}
.resource-usage-popover-head {
  padding: 4px 12px 8px;
  color: rgba(71, 85, 105, 0.72);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}
body.dark .resource-usage-popover-head {
  color: rgba(203, 213, 225, 0.7);
}
.resource-toggle {
  appearance: none;
  border: 0;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12px;
  min-height: 34px;
  padding: 0 12px;
  margin: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  text-align: left;
  cursor: pointer;
}
.resource-toggle:hover {
  background: rgba(15, 23, 42, 0.045);
}
body.dark .resource-toggle:hover {
  background: rgba(255, 255, 255, 0.055);
}
.resource-toggle-label {
  flex: 1 1 auto;
  min-width: 0;
  color: rgba(15, 23, 42, 0.88);
  font-size: 13px;
  font-weight: 650;
}
body.dark .resource-toggle-label {
  color: rgba(248, 250, 252, 0.9);
}
.resource-toggle-track {
  position: relative;
  flex: 0 0 30px;
  width: 30px;
  height: 18px;
  border-radius: 999px;
  background: rgba(100, 116, 139, 0.26);
  transition: background 0.15s ease;
}
.resource-toggle-thumb {
  position: absolute;
  left: 2px;
  top: 2px;
  width: 14px;
  height: 14px;
  border-radius: 999px;
  background: #fff;
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.22);
  transition: transform 0.15s ease;
}
.resource-toggle[aria-checked="true"] .resource-toggle-track {
  background: #25764a;
}
.resource-toggle[aria-checked="true"] .resource-toggle-thumb {
  transform: translateX(12px);
}
.resource-usage-status {
  padding: 8px 12px 3px;
  color: rgba(100, 116, 139, 0.8);
  font-size: 11px;
  font-weight: 600;
  line-height: 1.25;
}
body.dark .resource-usage-status {
  color: rgba(148, 163, 184, 0.82);
}
.config-info {
  display: flex;
  align-items: center;
  font-size: 12px;
  font-weight: bold;
}
body.dark .snapshot-comment {
  color: white;
}
#editortab {
  color: royalblue;
}
#sidebar-toggle {
  color: #0f172a;
  position: relative;
  width: 40px;
  height: 30px;
  padding: 0;
  border-radius: 9px;
  box-sizing: border-box;
}
body.dark #sidebar-toggle {
  color: rgba(248, 250, 252, 0.92);
}
#sidebar-toggle[aria-expanded="true"] {
  background: rgba(15, 23, 42, 0.08);
  box-shadow: inset 0 0 0 1px rgba(15, 23, 42, 0.06);
}
body.dark #sidebar-toggle[aria-expanded="true"] {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
}
.sidebar-toggle-glyph {
  width: 19px;
  height: 15px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.sidebar-toggle-frame {
  position: relative;
  width: 18px;
  height: 14px;
  border: 1.7px solid currentColor;
  border-radius: 3px;
  box-sizing: border-box;
}
.sidebar-toggle-panel {
  position: absolute;
  left: 2px;
  top: 2px;
  bottom: 2px;
  width: 4px;
  border-radius: 1px;
  background: currentColor;
  transition: opacity 0.15s ease, background 0.15s ease, border-color 0.15s ease;
}
.sidebar-toggle-content {
  position: absolute;
  left: 8px;
  right: 3px;
  top: 3px;
  height: 1.5px;
  border-radius: 999px;
  background: currentColor;
  opacity: 0.32;
  box-shadow: 0 3.8px 0 currentColor, 0 7.6px 0 currentColor;
}
#sidebar-toggle[aria-expanded="false"] .sidebar-toggle-panel {
  background: transparent;
  outline: 1.5px solid currentColor;
  outline-offset: -1px;
  opacity: 0.35;
}
#devtab {
  align-items: center;
  justify-content: center;
  display: flex;
  padding: 5px 10px;
  box-sizing: border-box;
  min-width: 0;
  flex-shrink: 0;
  border-radius: var(--sidebar-tab-radius);
  color: var(--pinokio-sidebar-tab-active-color);
  background: none;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-bottom: none;
}
#devtab .loader {
  padding: 10px;
}
#devtab .tab {
  padding: 0;
}
#devtab img {
/*
  width: 50px;
  height: 50px;
  margin-right: 10px;
  */
  margin-right: 10px;
  width: 20px;
  height: 20px;
}
.menu-container {
  overflow: hidden;
}
body.dark .mode-display {
  background: rgba(255,255,255,0.04);
  color: rgba(255,255,255,0.7);
}
.mode-display {
  padding: 5px 10px;
  background: rgba(0,0,0,0.04);
  /*
  text-align: center;
  color: royalblue;
  */
  color: rgba(0, 0, 0, 0.7);
  font-size: 12px;
  font-weight: bold;
}
.online {
  width: 10px;
  height: 10px;
  background: yellowgreen;
  border-radius: 10px;
}
#menu {
  display: flex;
}
#menu i {
  display: block;
}
#menu img {
  display: none;
  height: 30px;
  object-fit: contain;
  /*
  border-radius: 20px
  */
}
#menu.margin {
/*
  padding: 5px;
  */
}
#menu.margin i {
  display: none;
}
#menu.margin img {
  display: block;
}
html, body {
  width: 100%;
  height: 100%;
  margin: 0;
}
body {
  display: flex;
  flex-direction: column;
}
body.app-page {
  --app-page-accent: var(--pinokio-chrome-accent-fg-light);
  --app-page-canvas-bg: #ffffff;
  --app-page-selected-item-color: #111827;
  --app-page-shell-bg: rgba(250, 251, 253, 0.78);
  --app-page-shell-bg-strong: rgba(248, 250, 252, 0.9);
  --app-page-panel-bg: rgba(248, 250, 252, 0.92);
  --app-page-border: rgba(15, 23, 42, 0.12);
  --app-page-selected-item-bg: rgba(15, 23, 42, 0.045);
  --app-page-surface-soft: color-mix(in srgb, var(--app-page-shell-bg-strong) 4%, transparent);
  --app-page-surface-active: color-mix(in srgb, var(--app-page-shell-bg-strong) 6%, transparent);
  --app-page-shell-gradient:
    radial-gradient(circle at top left, color-mix(in srgb, var(--app-page-accent) 10%, transparent), transparent 24rem),
    linear-gradient(180deg, #fafbfd 0%, #f3f5f8 100%);
  background: none;
  min-height: 100vh;
  position: relative;
  isolation: isolate;
}
body.dark.app-page {
  --app-page-accent: var(--pinokio-chrome-accent-fg-dark);
  --app-page-canvas-bg: #1b1c1d;
  --app-page-selected-item-color: rgba(248, 250, 252, 0.94);
  --app-page-shell-bg: rgba(10, 12, 16, 0.78);
  --app-page-shell-bg-strong: rgba(12, 15, 21, 0.9);
  --app-page-panel-bg: rgba(12, 15, 21, 0.92);
  --app-page-border: rgba(255, 255, 255, 0.08);
  --app-page-selected-item-bg: rgba(255, 255, 255, 0.055);
  --app-page-surface-soft: color-mix(in srgb, var(--app-page-shell-bg-strong) 4%, transparent);
  --app-page-surface-active: color-mix(in srgb, var(--app-page-shell-bg-strong) 6%, transparent);
  --app-page-shell-gradient:
    radial-gradient(circle at top left, color-mix(in srgb, var(--app-page-accent) 16%, transparent), transparent 24rem),
    linear-gradient(180deg, #0a0c10 0%, #07090d 100%);
  background: none;
}
body.app-page::before {
  content: "";
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background: var(--app-page-shell-gradient);
}
body.dark.app-page::before {
  background:
    radial-gradient(circle at top left, color-mix(in srgb, var(--app-page-accent) 16%, transparent), transparent 24rem),
    linear-gradient(180deg, #0a0c10 0%, #07090d 100%);
}
body.app-page > header.navheader,
body.app-page > header.navheader.minimized,
body.app-page .navheader {
  background: var(--app-page-canvas-bg) !important;
  background-color: var(--app-page-canvas-bg) !important;
  background-image: none !important;
  border-bottom: 1px solid var(--pinokio-sidebar-separator);
  backdrop-filter: none;
  box-shadow: none;
  isolation: isolate;
}
.menu {
  overflow: auto;
}
/*
body.dark .m {
  border-top: 1px solid rgba(255,255,255,0.04);
}
.m {
  border-top: 1px solid rgba(0,0,0,0.04);
}
*/
.container {
  position: relative;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}
.browserview-shell {
  display: flex;
  flex: 1 1 auto;
  min-width: 0;
  min-height: 0;
  position: relative;
}
main.browserview {
  flex: 1 1 auto;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
}
.community-drawer {
  display: none;
  flex: 0 0 auto;
  width: var(--community-width, 360px);
  min-width: 240px;
  min-height: 0;
  border-left: 1px solid rgba(0,0,0,0.08);
  background: #f7f8fa;
}
body.dark .community-drawer {
  border-left-color: rgba(255,255,255,0.08);
  background: #0f1115;
}
.community-resizer {
  display: none;
  flex: 0 0 7px;
  align-items: stretch;
  justify-content: center;
  cursor: col-resize;
  touch-action: none;
  outline: none;
  background: transparent;
}
.community-resizer::before {
  content: '';
  width: 1px;
  border-radius: 0;
  margin: 0;
  background: var(--pinokio-sidebar-separator, rgba(0,0,0,0.08));
  transition: background 120ms ease;
}
.community-resizer:hover::before {
  background: var(--pinokio-sidebar-separator-hover, rgba(0,0,0,0.14));
}
.community-resizer:focus-visible::before {
  background: var(--pinokio-sidebar-separator-focus, rgba(59, 130, 246, 0.45));
}
body.dark .community-resizer::before {
  background: var(--pinokio-sidebar-separator, rgba(255,255,255,0.08));
}
body.dark .community-resizer:hover::before {
  background: var(--pinokio-sidebar-separator-hover, rgba(255,255,255,0.14));
}
body.dark .community-resizer:focus-visible::before {
  background: var(--pinokio-sidebar-separator-focus, rgba(96, 165, 250, 0.6));
}
.appcanvas.community-open .community-resizer {
  display: flex;
}
.appcanvas.community-open .community-drawer {
  display: flex;
}
.appcanvas.community-expanded .community-resizer {
  display: none;
}
.appcanvas.community-expanded .community-drawer {
  position: absolute;
  inset: 0;
  width: 100%;
  min-width: 0;
  max-width: none;
  border-left: 0;
  z-index: 10;
  box-shadow: 0 24px 60px rgba(0,0,0,0.35);
}
body.dark .appcanvas.community-expanded .community-drawer {
  box-shadow: 0 24px 60px rgba(0,0,0,0.6);
}
.community-drawer-inner {
  display: flex;
  flex-direction: column;
  min-height: 0;
  flex: 1 1 auto;
}
.community-drawer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 8px 10px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(6px);
}
body.dark .community-drawer-bar {
  border-bottom-color: rgba(255,255,255,0.08);
  background: rgba(15, 17, 21, 0.7);
}
.community-drawer-title {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 700;
}
.community-drawer-home {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0;
  border: 0;
  background: none;
  font: inherit;
  color: inherit;
  cursor: pointer;
}
.community-drawer-home:disabled {
  cursor: not-allowed;
  opacity: 0.6;
}
.community-drawer-home:focus-visible {
  outline: 2px solid rgba(59, 130, 246, 0.5);
  outline-offset: 2px;
  border-radius: 6px;
}
.community-drawer-status {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #94a3b8;
  box-shadow: 0 0 0 1px rgba(0,0,0,0.18);
}
.community-drawer-status[data-state="online"] {
  background: #22c55e;
}
.community-drawer-status[data-state="offline"] {
  background: #94a3b8;
}
.community-drawer-status[data-state="unavailable"] {
  background: #f97316;
}
body.dark .community-drawer-status {
  box-shadow: 0 0 0 1px rgba(255,255,255,0.2);
}
.community-drawer-actions {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.community-drawer-actions .btn2 {
  padding: 4px;
  font-size: 12px;
  min-width: 28px;
  height: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-direction: row;
}
.community-drawer-actions .btn2 i {
  margin: 0;
  font-size: 12px;
}
.community-drawer-actions .btn2[disabled] {
  opacity: 0.5;
  cursor: not-allowed;
}
.community-drawer-location {
  position: relative;
  padding: 6px 10px;
  border-bottom: 1px solid rgba(0,0,0,0.08);
  background: rgba(255,255,255,0.7);
  cursor: text;
}
body.dark .community-drawer-location {
  border-bottom-color: rgba(255,255,255,0.08);
  background: rgba(15, 17, 21, 0.75);
}
.community-drawer-location-input {
  width: 100%;
  border: 1px solid rgba(0,0,0,0.12);
  border-radius: 6px;
  padding: 4px 6px;
  font-size: 11px;
  font-family: inherit;
  color: transparent;
  caret-color: transparent;
  background: rgba(255,255,255,0.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.community-drawer-location-input::placeholder {
