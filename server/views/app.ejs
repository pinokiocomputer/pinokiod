      if (showSaveButton) {
        swalClass.confirmButton = 'pinokio-modern-confirm'
        swalClass.cancelButton = 'pinokio-modern-cancel'
      }

      await Swal.fire({
        html: modalHtml,
        customClass: swalClass,
        backdrop: 'rgba(9,11,15,0.65)',
