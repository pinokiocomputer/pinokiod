            method: "kernel.api.stop",
            params: {
              uri: action.uri//"~" + location.pathname
            }
          }, (packet) => {
            if (packet.type === "result") {
              socket.close()
  //              location.href = location.href
            }
          })
        }
      } else if (target.getAttribute("data-filepath")) {
        return
      } else if (target.target === "_blank") {
        // nothing
      } else {
        if (target.classList.contains("reveal")) {
          // nested menu
          e.preventDefault()
          e.stopPropagation()
          const fsDropdown = target.closest("#fs-status .fs-status-dropdown")
          if (fsDropdown) {
            const menu = fsDropdown.querySelector(".fs-dropdown-menu")
            if (menu) {
              closeStatusDropdowns(menu)
              const isHidden = menu.classList.toggle("hidden")
              setDropdownState(target, !isHidden)
            }
            return
          }
          <% if (type === 'run') { %>
            if (target.closest(".dynamic")) {
              // clicked dev mode menu => switch to dev
              // run mode => switch to dev mode
              location.hash = ""
              if (location.pathname.endsWith("/")) {
                location.pathname = location.pathname + "dev"
              } else {
                location.pathname = location.pathname + "/dev"
              }
            } else {
              // regular menu
              const submenu = target.closest(".nested-menu").querySelector(".submenu")
              const isHidden = submenu.classList.toggle("hidden")
              setDropdownState(target, !isHidden)
            }
          <% } else { %>
            // dev mode => already dev. reveal the hidden menu
            if (target.closest(".dynamic")) {
              target.closest(".dynamic").classList.add("selected")
              const submenu = target.closest(".nested-menu").querySelector(".submenu")
              const isHidden = submenu.classList.toggle("hidden")
              setDropdownState(target, !isHidden)
            } else {
              const submenu = target.closest(".nested-menu").querySelector(".submenu")
              const isHidden = submenu.classList.toggle("hidden")
              setDropdownState(target, !isHidden)
            }
          <% } %>
          return
        } else {


          if (target.closest(".h")) {
            if (target.target) {
              location.hash = target.target
            }
          } else {
            let index = target.getAttribute("data-index")
            let typeSource = target.closest(".m") || target.closest("[data-type]")
            let type
            if (typeSource) {
              type = typeSource.getAttribute("data-type") || typeSource.dataset.type
            }
            if (!type) {
              type = target.getAttribute("data-type")
            }

            if (type && index !== null) {
              location.hash = type + index
            }
          }

          document.querySelectorAll(".frame-link").forEach((el) => {
            el.classList.remove("selected")
          })
          target.classList.add("selected")

          renderSelection(e)
        }
      }
    }
  }

