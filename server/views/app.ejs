.appcanvas > aside .menu-actions #logs-toggle .tab {
  width: 100%;
  position: relative;
  z-index: 1;
}
.appcanvas > aside .menu-actions #logs-toggle.has-new {
  position: relative;
  overflow: hidden;
}
.appcanvas > aside .menu-actions #logs-toggle.has-new::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  border-radius: inherit;
  background: var(--pinokio-sidebar-notice-flash-bg);
  opacity: 0;
  animation: logsAttentionFlash 1.2s cubic-bezier(0.25, 1, 0.5, 1) infinite;
}
.logs-new-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  box-sizing: border-box;
  min-width: 24px;
  height: 16px;
  max-height: 16px;
  margin-left: auto;
  border: 1px solid rgba(255,255,255,0.28);
  border-radius: 5px;
  padding: 0 5px;
  background: #b91c1c;
  color: #fff;
  font-size: 9px;
  line-height: 14px;
  font-weight: 750;
  letter-spacing: 0;
  text-transform: uppercase;
  box-shadow: none;
}
body.dark .logs-new-badge {
  background: #dc2626;
  color: #fff;
  border-color: rgba(255,255,255,0.22);
}
.mobile-nav-logs.has-new {
  position: relative;
  animation: logsMobileAttentionFlashLight 1.05s steps(2, end) infinite;
}
body.dark .mobile-nav-logs.has-new {
  animation-name: logsMobileAttentionFlashDark;
}
.mobile-nav-logs.has-new::after {
  content: "";
  position: absolute;
  top: 7px;
  right: 7px;
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #dc2626;
  box-shadow: 0 0 0 2px #fff;
  transform-origin: center;
}
body.dark .mobile-nav-logs.has-new::after {
  box-shadow: 0 0 0 2px #0f1115;
}
@keyframes logsAttentionFlash {
  0%, 100% { opacity: 0; }
  45%, 55% { opacity: 1; }
}
@keyframes logsMobileAttentionFlashLight {
  0%, 100% {
    background: transparent;
    color: #64748b;
  }
  50% {
    background: #64748b;
    color: #fff;
  }
}
@keyframes logsMobileAttentionFlashDark {
  0%, 100% {
    background: transparent;
    color: rgba(148, 163, 184, 0.9);
  }
  50% {
    background: rgba(148, 163, 184, 0.9);
    color: #0f1115;
  }
}
@media (prefers-reduced-motion: reduce) {
  .appcanvas > aside .menu-actions #logs-toggle.has-new,
  .mobile-nav-logs.has-new {
    animation: none;
  }
  .appcanvas > aside .menu-actions #logs-toggle.has-new::before {
    animation: none;
    opacity: 1;
  }
  .mobile-nav-logs.has-new {
    background: #64748b;
    color: #fff;
  }
  body.dark .mobile-nav-logs.has-new {
    background: rgba(148, 163, 184, 0.9);
    color: #0f1115;
  }
}
