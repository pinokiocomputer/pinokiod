            } catch (_) {
              isShellLaunch = typeof event.data.launch.href === "string" && event.data.launch.href.includes("/shell/")
            }
            if (isShellLaunch) {
              const launched = await handleLaunchRequest(event.data.launch)
              if (launched) {
