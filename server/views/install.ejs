}
[data-install-spinner-variant="flip-2x2"] .install-status-grid-tile {
  display: block;
}
[data-install-spinner-variant="flip-2x2"] .install-status-grid-tile-1 {
  animation: pinokio-grid-flip-1 1.06s cubic-bezier(0.68, 0, 0.24, 1) infinite;
}
[data-install-spinner-variant="flip-2x2"] .install-status-grid-tile-2 {
  animation: pinokio-grid-flip-2 1.06s cubic-bezier(0.68, 0, 0.24, 1) infinite;
}
[data-install-spinner-variant="flip-2x2"] .install-status-grid-tile-3 {
  animation: pinokio-grid-flip-3 1.06s cubic-bezier(0.68, 0, 0.24, 1) infinite;
}
[data-install-spinner-variant="flip-2x2"] .install-status-grid-tile-4 {
  animation: pinokio-grid-flip-4 1.06s cubic-bezier(0.68, 0, 0.24, 1) infinite;
}
[data-install-spinner-variant="stack-ripple"] .install-status-grid-tile {
  display: block;
  animation: pinokio-stack-ripple 1.15s ease-in-out infinite;
}
[data-install-spinner-variant="stack-ripple"] .install-status-grid-tile-2 {
  animation-delay: -0.16s;
}
[data-install-spinner-variant="stack-ripple"] .install-status-grid-tile-3 {
  animation-delay: -0.32s;
}
[data-install-spinner-variant="stack-ripple"] .install-status-grid-tile-4 {
  animation-delay: -0.48s;
}
[data-install-spinner-variant="pixel-orbit"] .install-status-grid-anchor {
  display: block;
  width: 4px;
  height: 4px;
  border-radius: 1px;
