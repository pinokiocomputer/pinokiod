<style>
html {
  height: 100%;
}
body.install-page {
  --install-status-bg: var(--pinokio-chrome-accent-bg-light);
  --install-spinner-fg: rgba(0,0,0,0.8);
  --install-status-fg: var(--pinokio-chrome-accent-fg-light);
  --install-status-fg-soft: rgba(225, 178, 97, 0.34);
  --install-status-border: rgba(15, 23, 42, 0.12);
  --install-status-detail: rgba(0, 0, 0, 0.6);
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  /*
  background: rgb(44, 29, 22);
  */
  display: flex;
  flex-direction: column !important;
  align-items: stretch;
}
@supports (height: 100dvh) {
  body.install-page {
    height: 100dvh;
    min-height: 100dvh;
  }
}
body.install-page.dark {
  --install-status-bg: var(--pinokio-chrome-accent-bg-dark);
  --install-spinner-fg: white;
  --install-status-fg: var(--pinokio-chrome-accent-fg-dark);
  --install-status-fg-soft: rgba(194, 178, 138, 0.28);
  --install-status-border: rgba(255, 255, 255, 0.08);
  --install-status-detail: rgba(239, 233, 214, 0.76);
}
body.install-page > header.grabbable {
  flex: 0 0 auto;
}
body.install-page > .terminal-container {
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
}
#terminal {
  flex-grow: 1;
  height: 100%;
  min-height: 0;
}
body.install-page #terminal .xterm {
  padding-top: 10px !important;
}
.line2 {
  display: flex;
  align-items: center;
  cursor: pointer;
  background: rgba(0,0,100,0.04);
}
.line2 a {
  text-decoration: none;
  color: black;
}
.status {
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}
.status.offline {
  background: silver;
}
.status.online {
  background: yellowgreen;
}
.switch {
  padding: 10px;
  margin: 10px 0;
}
.switch[data-online=true] {
  color: yellowgreen;
}
.button {
  padding: 10px;
}
.on, .off {
  display: flex;
  align-items: center;
}
.btn {
  margin-right: 5px;
  font-weight: normal;
}
.item {
  display: flex;
  align-items: flex-start;
  margin: 10px;
}
.item img {
  width: 100px;
}
.item .title {
  text-decoration: none;
  color: royalblue;
}
.item .col {
  padding: 10px;
}
.item .col > * {
  margin: 5px 0;
}
.item .stat {
  color: rgba(0,0,0,0.8);
  display: flex;
}
.item .stat > * {
  margin-right: 15px;
}
.timestamp {
  color: rgba(0,0,0,0.5);
}
#status-screen {
  flex: 0 0 auto;
  padding: 14px 18px;
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  width: 100%;
  margin: 0;
  overflow: hidden;
}
#status-screen code {
  font-family: "RobotoMono", monospace;
}
.install-status-shell {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  min-height: 44px;
}
.install-status-copy {
  min-width: 0;
  flex: 1;
}
.install-status-title {
  font-size: 15px;
  line-height: 1.2;
  font-weight: 700;
}
.install-status-detail {
  margin-top: 4px;
  color: var(--install-status-detail);
  font-size: 12px;
  line-height: 1.35;
  word-break: break-word;
}
.install-status-detail > *:first-child {
  margin-top: 0;
}
.install-status-detail > *:last-child {
  margin-bottom: 0;
}
.install-status-icon,
.install-status-spinner {
  width: 18px;
  height: 18px;
  flex: 0 0 18px;
  margin-top: 1px;
}
.install-status-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--install-status-fg);
  font-size: 15px;
}
.install-status-spinner {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.install-status-grid-anchor,
.install-status-grid-tile,
.install-status-grid-chaser,
.install-status-grid-pixel {
  position: absolute;
  top: 0;
  left: 0;
  box-sizing: border-box;
  display: none;
  transform-origin: center;
}
.install-status-grid-anchor,
.install-status-grid-tile,
.install-status-grid-chaser {
  width: 7px;
  height: 7px;
  border-radius: 2px;
}
.install-status-grid-anchor {
  opacity: 0.16;
}
.install-status-grid-anchor,
.install-status-grid-tile,
.install-status-grid-chaser,
.install-status-grid-pixel {
  background: var(--install-spinner-fg);
}
.install-status-grid-pixel {
  width: 4px;
  height: 4px;
  border-radius: 1px;
}
.install-status-grid-anchor-1,
.install-status-grid-tile-1,
.install-status-grid-chaser {
  top: 1px;
  left: 1px;
}
.install-status-grid-anchor-2,
.install-status-grid-tile-2 {
  top: 1px;
  left: 12px;
}
.install-status-grid-anchor-3,
.install-status-grid-tile-3 {
  top: 12px;
  left: 12px;
}
.install-status-grid-anchor-4,
.install-status-grid-tile-4 {
  top: 12px;
  left: 1px;
}
.install-status-grid-pixel {
  top: 2px;
  left: 2px;
}
[data-install-spinner-variant="grid-shift"] .install-status-grid-tile {
  display: block;
}
[data-install-spinner-variant="grid-shift"] .install-status-grid-tile-1 {
  animation: pinokio-grid-shift-1 1.2s cubic-bezier(0.6, 0, 0.2, 1) infinite;
}
[data-install-spinner-variant="grid-shift"] .install-status-grid-tile-2 {
  animation: pinokio-grid-shift-2 1.2s cubic-bezier(0.6, 0, 0.2, 1) infinite;
}
[data-install-spinner-variant="grid-shift"] .install-status-grid-tile-3 {
  animation: pinokio-grid-shift-3 1.2s cubic-bezier(0.6, 0, 0.2, 1) infinite;
}
[data-install-spinner-variant="grid-shift"] .install-status-grid-tile-4 {
  animation: pinokio-grid-shift-4 1.2s cubic-bezier(0.6, 0, 0.2, 1) infinite;
}
[data-install-spinner-variant="single-vacancy"] .install-status-grid-anchor {
  display: block;
}
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-1,
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-2,
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-3 {
  display: block;
}
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-1 {
  animation: pinokio-single-vacancy-1 1.55s cubic-bezier(0.62, 0, 0.22, 1) infinite;
}
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-2 {
  animation: pinokio-single-vacancy-2 1.55s cubic-bezier(0.62, 0, 0.22, 1) infinite;
}
[data-install-spinner-variant="single-vacancy"] .install-status-grid-tile-3 {
  animation: pinokio-single-vacancy-3 1.55s cubic-bezier(0.62, 0, 0.22, 1) infinite;
}
[data-install-spinner-variant="pulse-swap"] .install-status-grid-tile {
  display: block;
}
[data-install-spinner-variant="pulse-swap"] .install-status-grid-tile-1,
[data-install-spinner-variant="pulse-swap"] .install-status-grid-tile-3 {
  animation: pinokio-pulse-swap-a 1.18s ease-in-out infinite;
}
[data-install-spinner-variant="pulse-swap"] .install-status-grid-tile-2,
[data-install-spinner-variant="pulse-swap"] .install-status-grid-tile-4 {
  animation: pinokio-pulse-swap-b 1.18s ease-in-out infinite;
}
[data-install-spinner-variant="corner-chase"] .install-status-grid-anchor {
  display: block;
}
[data-install-spinner-variant="corner-chase"] .install-status-grid-chaser {
  display: block;
