<body class='install-page <%=theme%>' data-agent="<%=agent%>">
<header class='grabbable'></header>
<div class='terminal-container'>
  <div id='terminal'></div>
</div>
<div id='status-screen'>
  <div class="install-status-shell">
    <span class="install-status-spinner" aria-hidden="true">
      <span class="install-status-grid-anchor install-status-grid-anchor-1"></span>
      <span class="install-status-grid-anchor install-status-grid-anchor-2"></span>
      <span class="install-status-grid-anchor install-status-grid-anchor-3"></span>
      <span class="install-status-grid-anchor install-status-grid-anchor-4"></span>
      <span class="install-status-grid-tile install-status-grid-tile-1"></span>
      <span class="install-status-grid-tile install-status-grid-tile-2"></span>
      <span class="install-status-grid-tile install-status-grid-tile-3"></span>
      <span class="install-status-grid-tile install-status-grid-tile-4"></span>
      <span class="install-status-grid-chaser"></span>
      <span class="install-status-grid-pixel"></span>
    </span>
    <div class="install-status-copy">
      <div class="install-status-title">Setting up...</div>
      <div class="install-status-detail">Setting up core modules including conda, uv, git, etc.</div>
    </div>
  </div>
</div>
<input id='requirements' type='hidden' value="<%=requirements%>">
<input id='callback' type='hidden' value="<%=callback%>">
<script>
//
// /install_bin?type=bin&uri=conda
//
let shell_id
let fitAddon
const INSTALL_SPINNER_VARIANTS = ["grid-shift", "single-vacancy", "pulse-swap", "corner-chase", "flip-2x2", "stack-ripple", "pixel-orbit", "binary-shuffle"]
let currentInstallStepKey = null
let lastAutoInstallSpinnerVariant = null
const installSpinnerAssignments = new Map()
const INSTALL_STATUS_SPINNER_HTML = `
<span class="install-status-spinner" aria-hidden="true">
  <span class="install-status-grid-anchor install-status-grid-anchor-1"></span>
  <span class="install-status-grid-anchor install-status-grid-anchor-2"></span>
  <span class="install-status-grid-anchor install-status-grid-anchor-3"></span>
  <span class="install-status-grid-anchor install-status-grid-anchor-4"></span>
  <span class="install-status-grid-tile install-status-grid-tile-1"></span>
  <span class="install-status-grid-tile install-status-grid-tile-2"></span>
  <span class="install-status-grid-tile install-status-grid-tile-3"></span>
  <span class="install-status-grid-tile install-status-grid-tile-4"></span>
  <span class="install-status-grid-chaser"></span>
  <span class="install-status-grid-pixel"></span>
</span>`
const applyInstallSpinnerVariant = (variant) => {
  if (!INSTALL_SPINNER_VARIANTS.includes(variant)) return
  document.documentElement.dataset.installSpinnerVariant = variant
}
const randomInstallSpinnerVariant = () => {
  const candidates = INSTALL_SPINNER_VARIANTS.filter((variant) => {
    return variant !== lastAutoInstallSpinnerVariant
  })
  const pool = candidates.length > 0 ? candidates : INSTALL_SPINNER_VARIANTS
  const variant = pool[Math.floor(Math.random() * pool.length)]
  lastAutoInstallSpinnerVariant = variant
  return variant
}
const applyAutoInstallSpinnerForStep = (stepKey) => {
  if (!stepKey) return
  currentInstallStepKey = stepKey
  if (!installSpinnerAssignments.has(stepKey)) {
    installSpinnerAssignments.set(stepKey, randomInstallSpinnerVariant())
  }
  applyInstallSpinnerVariant(installSpinnerAssignments.get(stepKey))
}
const extractInstallStepKey = (html) => {
  if (!html) return null
  const container = document.createElement("div")
  container.innerHTML = html
  const titleNode = container.querySelector("b, strong")
  const titleText = titleNode ? titleNode.textContent : container.textContent
  const normalizedTitle = (titleText || "").replace(/\s+/g, " ").trim()
  const match = normalizedTitle.match(/\((\d+\/\d+)\)\s+Installing\s+(.+)/i)
  if (!match) return null
  return `${match[1]}:${match[2].trim().toLowerCase()}`
}
const normalizeInstallStatusHtml = (html) => {
  if (!html) {
    return `
      <div class="install-status-shell">
        ${INSTALL_STATUS_SPINNER_HTML}
        <div class="install-status-copy">
          <div class="install-status-title">Setting up...</div>
        </div>
      </div>
    `
  }
  if (html.includes("install-status-shell")) {
    return html
  }
  const container = document.createElement("div")
  container.innerHTML = html
  const titleNode = container.querySelector("b, strong")
  let leadMarkup = INSTALL_STATUS_SPINNER_HTML
  let titleMarkup = "Setting up..."
  if (titleNode) {
    const clonedTitle = titleNode.cloneNode(true)
    const titleIcon = clonedTitle.querySelector("i")
    if (titleIcon) {
      const iconClass = titleIcon.getAttribute("class") || ""
      const isSpinnerIcon = /\bfa-circle-notch\b/.test(iconClass) || /\bfa-spin\b/.test(iconClass)
      if (!isSpinnerIcon) {
        leadMarkup = `<span class="install-status-icon" aria-hidden="true">${titleIcon.outerHTML}</span>`
      }
      titleIcon.remove()
    }
    titleMarkup = (clonedTitle.innerHTML || clonedTitle.textContent || "").trim() || titleMarkup
    titleNode.remove()
  }
  const detailMarkup = container.innerHTML.replace(/^\s*(<br\s*\/?>\s*)+/i, "").trim()
  return `
    <div class="install-status-shell">
      ${leadMarkup}
      <div class="install-status-copy">
        <div class="install-status-title">${titleMarkup}</div>
        ${detailMarkup ? `<div class="install-status-detail">${detailMarkup}</div>` : ""}
      </div>
    </div>
  `
}
const setInstallStatus = (html) => {
  const statusScreen = document.querySelector("#status-screen")
  if (!statusScreen) return
  const stepKey = extractInstallStepKey(html)
  if (stepKey) {
    applyAutoInstallSpinnerForStep(stepKey)
  }
  statusScreen.innerHTML = normalizeInstallStatusHtml(html)
}
const setRestartStatus = () => {
  applyInstallSpinnerVariant("corner-chase")
  setInstallStatus(`
    <div class="install-status-shell">
      ${INSTALL_STATUS_SPINNER_HTML}
      <div class="install-status-copy">
        <div class="install-status-title">Restarting Pinokio...</div>
        <div class="install-status-detail">Applying the updated system tools. Pinokio will continue automatically.</div>
      </div>
    </div>
  `)
}
let networkSharingWarningOpen = false
const isLoopbackHost = (hostname) => {
  const normalized = String(hostname || "").toLowerCase()
  return normalized === "localhost" || normalized === "127.0.0.1" || normalized === "::1" || normalized === "[::1]"
}
const defaultPortForProtocol = (protocol) => {
  return protocol === "https:" ? "443" : "80"
}
const normalizedPort = (url) => {
  return url.port || defaultPortForProtocol(url.protocol)
}
const resolveLanCallbackHref = (href) => {
  if (!href) {
    return "/"
  }
  try {
    const target = new URL(href, window.location.href)
    const current = new URL(window.location.href)
    if (
      !isLoopbackHost(current.hostname) &&
      isLoopbackHost(target.hostname) &&
      target.protocol === current.protocol &&
      normalizedPort(target) === normalizedPort(current)
    ) {
      target.hostname = current.hostname
      return target.toString()
    }
  } catch (_) {}
  return href
}
const requiresNetworkSharing = (href) => {
  if (isLoopbackHost(window.location.hostname)) {
    return false
  }
  try {
    const parsed = new URL(href, window.location.href)
    return parsed.protocol === "http:" && isLoopbackHost(parsed.hostname)
  } catch (_) {
    return false
  }
}
const showNetworkSharingRequired = (href) => {
  if (!requiresNetworkSharing(href)) {
    return false
  }
  if (networkSharingWarningOpen) {
    return true
  }
  networkSharingWarningOpen = true
  Swal.fire({
    title: "Turn on network sharing",
    text: "Open Network to turn on local network sharing, then come back to this install.",
    showCancelButton: true,
    confirmButtonText: "Open Network",
    cancelButtonText: "Stay here"
  }).then((result) => {
    networkSharingWarningOpen = false
    if (result.isConfirmed) {
      window.location.href = "/network"
    }
  })
  return true
}
const navigateToCallback = () => {
  const callback = document.querySelector("#callback")
  const href = resolveLanCallbackHref(callback && callback.value ? callback.value : "/")
  if (showNetworkSharingRequired(href)) {
    return
  }
  location.href = href
}
const resumeInstall = () => {
  const form = document.createElement("form")
  form.method = "post"
  form.action = "/pinokio/install"
  for (const name of ["requirements", "callback"]) {
    const input = document.createElement("input")
    input.type = "hidden"
    input.name = name
    input.value = document.querySelector(`#${name}`).value
    form.appendChild(input)
  }
  document.body.appendChild(form)
  form.submit()
}
const createTerm = async (_theme) => {
  //const theme = Object.assign({ }, xtermTheme.Terminal_Basic, {
  const theme = Object.assign({ }, _theme, {
    selectionBackground: "red",
    selectionForeground: "white"
  })
  <% if (theme !== "dark") { %>
    theme.foreground = "black"
  <% } %>
  let config = {
    scrollback: 9999999,
    fontSize: 12,
    fontFamily: 'monospace',
    theme,
  }
  let res = await fetch("/xterm_config").then((res) => {
    return res.json()
  })
  if (res && res.config) {
    config = res.config
  }
  const baseConfig = Object.assign({}, config)
  if (window.PinokioTerminalSettings && typeof window.PinokioTerminalSettings.applyToConfig === 'function') {
    config = window.PinokioTerminalSettings.applyToConfig(config)
  }
  const term = new Terminal(config)
  term.open(document.querySelector("#terminal"))
  if (window.PinokioTerminalSettings && typeof window.PinokioTerminalSettings.register === 'function') {
    window.PinokioTerminalSettings.register(term, { baseConfig })
  }
  const terminalContainer = document.querySelector("#terminal")
  window.PinokioTouch.bindTerminalFocus(term, terminalContainer)

  term.attachCustomKeyEventHandler(event => {
    if (event.ctrlKey && event.key === 'c' && term.hasSelection()) {
      return false;
    }
    if (event.ctrlKey && event.key === 'v' && this._options.pasteWithCtrlV) {
      return false;
    }
    return true;
  });

  fitAddon = new FitAddon.FitAddon();
  term.loadAddon(fitAddon);
  <% if (agent === "electron") { %>
    term.loadAddon(new WebLinksAddon.WebLinksAddon((event, uri) => {
      window.open(uri, "_blank", "browser")
    }))
  <% } else { %>
    term.loadAddon(new WebLinksAddon.WebLinksAddon());
  <% } %>
  fitAddon.fit();
  term.focus()
  return term
}
document.addEventListener("DOMContentLoaded", async () => {
  applyInstallSpinnerVariant(randomInstallSpinnerVariant())
  const n = new N()
  let socket = new Socket()
  <% if (theme === "dark") { %>
  let term = await createTerm(xtermTheme.FrontEndDelight)
  <% } else { %>
  let term = await createTerm(xtermTheme.Tomorrow)
  <% } %>
  let params = new URLSearchParams(location.search)
  let entries = [...params.entries()]
  let options;
  if (entries.length > 0) {
    options = {}
    for(const [key, value] of entries) {
      options[key] = value;
    }
  }
  if (options && options.fresh === "1") {
    setInstallStatus("<b>Removing existing tools...</b><br>This can take a minute on Windows.")
    try {
      const result = await PinokioPathRemoval.remove({ type: "bin" })
      if (result.cancelled) {
        navigateToCallback()
        return
      }
      if (result.error) throw new Error(result.error)
    } catch (error) {
      ModalInput({
        title: "Error",
        type: "modal",
        description: error && error.message ? error.message : "Unable to reset managed tools."
      })
      return
    }
    setInstallStatus("<b>Installing tools...</b><br>Starting the fresh installation.")
  }
  term.onData((data) => {
    if (shell_id) {
      socket.emit({
        id: shell_id,
        key: data
      })
    }
  })
  let observer = new ResizeObserver(() => {
    fitAddon.fit()
  });
  observer.observe(document.body)
  await new Promise((resolve, reject) => {
    console.log({ cols: term.cols, rows: term.rows })
    const requirements = document.querySelector("#requirements").value
    const rpc = {
      id: location.pathname,
      method: "kernel.bin.install",
      client: {
        cols: term.cols,
        rows: term.rows,
      }
    }
    if (requirements && requirements.trim().length > 0) {
      rpc.params = requirements
    } else {
      rpc.mode = "listen"
    }
    socket.run(rpc, async (packet) => {
      console.log("packet", packet)
      if (packet.type === "connect") {
        if (packet.data && packet.data.shell) {
          shell_id = packet.data.shell
        }
        if (packet.data && packet.data.state) {
          term.write(packet.data.state)
        }
      } else if (packet.type === "stream") {
        if (packet.data.id) {
          shell_id = packet.data.id
        }
        term.write(packet.data.raw)
      } else if (packet.type === "shell.kill") {
        socket.close()
      } else if (packet.type === "result") {
        resolve() 
      } else if (packet.type === "path.remove.blocked") {
        const result = await PinokioPathRemoval.show({
          details: packet.data,
          retry: () => PinokioPathRemoval.tryRemove({ type: "conda-runtime" })
        })
        if (result && result.success) {
          resumeInstall()
        } else if (result && result.cancelled) {
          navigateToCallback()
        }
      } else if (packet.type === "error") {
        if (typeof packet.data === "string" && packet.data.includes("__PINOKIO_BLOCKER__")) {
          return
        }
        //term.write("\r\n" + packet.data + "\r\n")
        ModalInput({
          title: "Error",
          type: "modal",
          description: packet.data
        })
      } else if (packet.type === "notify3") {
        console.log("HTML", packet.data)
        if (packet.data) {
          let payload = {}
          if (packet.data.html) {
            payload.text = packet.data.html
          }
          if (packet.data.type) {
            payload.type = packet.data.type
          }
          setInstallStatus(packet.data.html)
          let audio = new Audio("/chime.mp3")
          audio.play()
          await ModalInput({
            title: "Notice",
            type: "modal",
            description: packet.data.html,
            confirm: "OK",
          })
          if (packet.data.blocker) {
            navigateToCallback()
            return
          }
        }
      } else if (packet.type === "notify2") {
        console.log("HTML", packet.data)
        if (packet.data) {
          let payload = {}
          if (packet.data.html) {
            payload.text = packet.data.html
          }
          if (packet.data.type) {
            payload.type = packet.data.type
          }
          setInstallStatus(packet.data.html)
        }
      } else if (packet.type === "notify") {
        console.log("HTML", packet.data)
        if (packet.data) {
          let payload = {}
          if (packet.data.html) {
            payload.text = packet.data.html
          }
          if (packet.data.type) {
            payload.type = packet.data.type
          }
          payload.silent = packet.data.silent
          n.Noty(payload)
        }
      } else if (packet.type === "input") {
        let params = packet.data
        /*
          params := {
            title,
            description,
            form: [{
              title,
              description
            }]
          }
        */
        let type = (params.type ? params.type : "modal")
        let input
        if (type === "modal") {
          input = await ModalInput(packet.data)
        } else if (type === "notify") {
          input = await NotifyInput(packet.data, n)
        }
        console.log("RESPOND", { input, packet })
        if (input) {
          socket.respond({
            response: input,
            uri: packet.id
          })
        }
      }
    })
  })
  setRestartStatus()
  fetch("/restart", {
    method: "post"
  }).catch((error) => {
    console.warn("restart request ended early", error)
  })
  const restartPoll = setInterval(async () => {
    try {
      let res = await fetch("/bin_ready").then((res) => {
        return res.json()
      })
      if (res.success) {
        //location.href = location.href
        clearInterval(restartPoll)
        navigateToCallback()
      }
    } catch (e) {
      console.log(e)
    }
  }, 1000)
})
</script>
</body>
</html>
