<!doctype html>
<html lang="en">
<%
  const tr = typeof t === "function" ? t : ((key) => { throw new Error("i18n translator is not initialized") })
%>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/css/brands.min.css" rel="stylesheet">
  <link href="/noty.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
  <% if (agent === "electron") { %>
    <link href="/electron.css" rel="stylesheet"/>
  <% } %>
  <script>
  window.PINOKIO_I18N = Object.assign({}, window.PINOKIO_I18N || {}, <%- JSON.stringify(typeof i18nCatalog === "object" && i18nCatalog ? i18nCatalog : {}) %>);
  </script>
  <script src="/task-launcher.js" defer></script>
</head>
<%
  const displayTarget = defaults.target || 'workspaces'
  const targetLabel = (value) => {
    const labels = {
      workspaces: tr("tasks.target_workspaces"),
      api: tr("tasks.target_api"),
      plugin: tr("tasks.target_plugin")
    }
    return labels[value] || value
  }
%>
<body class="<%= theme %> main-sidebar-page task-launcher-page task-page task-builder-page" data-agent="<%= agent %>">
  <%- include('partials/app_navheader', { agent }) %>
  <main>
  <div class="task-container">
  <section class="task-shell task-builder-shell">
    <header class="task-shell-header">
      <div class="task-shell-header-main">
        <p class="task-eyebrow"><%= tr("nav.tasks") %></p>
        <h1 class="task-title"><%= titleText %></h1>
        <p class="task-description"><%- descriptionText %></p>
      </div>
      <div class="task-header-actions">
        <a class="task-link-button" href="<%= backHref %>">
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          <span><%= backLabel %></span>
        </a>
      </div>
    </header>

    <form class="task-shell-body task-builder-body" method="post" action="<%= formAction %>" data-task-builder data-initial-inputs="<%- JSON.stringify(defaults.inputs || []) %>">
      <% if (error) { %>
        <div class="task-status error"><%= error %></div>
      <% } %>

      <section class="task-section task-builder-meta-section">
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title"><%= tr("tasks.details") %></h2>
            <p class="task-section-subcopy"><%- tr("tasks.details_description", { file: "<code>pinokio.json</code>" }) %></p>
          </div>
          <div class="task-section-note">pinokio.json</div>
        </div>
        <div class="task-grid two-up">
          <label class="task-field">
            <span class="task-label"><%= tr("common.title") %></span>
            <input class="task-input" type="text" name="title" value="<%= defaults.title || '' %>" placeholder="<%= tr("tasks.title_placeholder") %>" required>
          </label>
          <label class="task-field">
            <span class="task-label"><%= tr("tasks.target") %></span>
            <% if (allowTargetSelection) { %>
              <select class="task-select" name="target" required>
                <% ['workspaces', 'api', 'plugin'].forEach((targetOption) => { %>
                  <option value="<%= targetOption %>" <%= (defaults.target || 'workspaces') === targetOption ? 'selected' : '' %>><%= targetLabel(targetOption) %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="hidden" name="target" value="<%= defaults.target || 'workspaces' %>">
              <div class="task-input task-input-readonly"><%= targetLabel(displayTarget) %></div>
            <% } %>
          </label>
        </div>
        <label class="task-field">
          <span class="task-label"><%= tr("common.description") %> <span class="task-label-meta"><%= tr("common.optional") %></span></span>
          <textarea class="task-textarea task-textarea-compact" name="description" rows="3" placeholder="<%= tr("tasks.description_placeholder") %>"><%= defaults.description || '' %></textarea>
        </label>
      </section>

      <section class="task-section task-builder-template-section">
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title"><%= tr("tasks.prompt_template") %></h2>
            <p class="task-section-subcopy"><%- tr("tasks.prompt_template_description", { repo: "<code>{{repo_url}}</code>", question: "<code>{{question}}</code>" }) %></p>
          </div>
          <div class="task-section-note">task.md</div>
        </div>
        <label class="task-field">
          <span class="task-label"><%= tr("tasks.template_text") %></span>
          <textarea class="task-textarea task-builder-template-input" name="template" data-task-template placeholder="<%= tr("tasks.template_placeholder") %>" required><%= defaults.template || '' %></textarea>
        </label>
        <div class="task-builder-detected">
          <div class="task-label"><%= tr("tasks.detected_inputs") %></div>
          <div class="task-variable-list" data-task-variable-list></div>
          <p class="task-inline-help task-builder-variable-empty" data-task-variable-empty><%- tr("tasks.variable_empty_help", { variable: "<code>{{variable}}</code>" }) %></p>
        </div>
      </section>

      <section class="task-section task-builder-inputs-section task-hidden" data-task-inputs-section>
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title"><%= tr("tasks.input_settings") %></h2>
            <p class="task-section-subcopy"><%= tr("tasks.input_settings_description") %></p>
          </div>
          <div class="task-section-note" data-task-input-count-note><%= tr("tasks.input_count", { count: 0 }) %></div>
        </div>
        <div class="task-input-editor" data-task-input-editor></div>
      </section>

      <input type="hidden" name="inputsJson" value="[]" data-task-inputs-json>
      <input type="hidden" name="path" value="tasks">
      <input type="hidden" name="sourceWorkspaceCwd" value="<%= defaults.sourceWorkspaceCwd || '' %>">
      <input type="hidden" name="lockTargetSelection" value="<%= defaults.lockTargetSelection ? '1' : '0' %>">

      <% if (defaults.sourceWorkspaceCwd && displayTarget === 'workspaces') { %>
        <section class="task-section task-builder-workspace-section">
          <div class="task-section-head">
            <div>
              <h2 class="task-section-title"><%= tr("tasks.workspace") %></h2>
              <p class="task-section-subcopy"><%= tr("tasks.workspace_description") %></p>
            </div>
          </div>
          <label class="task-toggle">
            <input type="checkbox" name="rememberCurrentWorkspace" value="1" <%= defaults.rememberCurrentWorkspace ? 'checked' : '' %>>
            <span><%= tr("tasks.remember_current_workspace") %></span>
          </label>
          <p class="task-inline-help"><%= tr("tasks.remember_workspace_help", { workspace: defaults.sourceWorkspaceLabel || tr("tasks.this_workspace") }) %></p>
        </section>
      <% } %>

      <div class="task-actions task-builder-actions">
        <button class="task-button primary" type="submit">
          <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
          <span><%= submitLabel %></span>
        </button>
        <a class="task-link-button" href="<%= backHref %>">
          <span><%= tr("common.cancel") %></span>
        </a>
      </div>
    </form>
  </section>
  </div>
  <%- include('partials/main_sidebar', { selected: 'tasks' }) %>
  </main>
  <%- include('partials/app_common_scripts') %>
</body>
</html>
