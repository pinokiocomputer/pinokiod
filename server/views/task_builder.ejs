<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <link href="/css/fontawesome.min.css" rel="stylesheet">
  <link href="/css/solid.min.css" rel="stylesheet">
  <link href="/css/brands.min.css" rel="stylesheet">
  <link href="/noty.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
  <link href="/task-launcher.css" rel="stylesheet">
  <% if (agent === "electron") { %>
    <link href="/electron.css" rel="stylesheet"/>
  <% } %>
  <script src="/task-launcher.js" defer></script>
</head>
<body class="<%= theme %> task-launcher-page task-page task-builder-page" data-agent="<%= agent %>">
  <%- include('partials/app_navheader', { agent }) %>
  <main>
  <div class="task-container">
  <section class="task-shell task-builder-shell">
    <header class="task-shell-header">
      <div class="task-shell-header-main">
        <p class="task-eyebrow">Tasks</p>
        <h1 class="task-title"><%= titleText %></h1>
        <p class="task-description"><%- descriptionText %></p>
      </div>
      <div class="task-header-actions">
        <a class="task-link-button" href="<%= backHref %>">
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          <span><%= backLabel %></span>
        </a>
      </div>
    </header>

    <form class="task-shell-body task-builder-body" method="post" action="<%= formAction %>" data-task-builder data-initial-inputs="<%- JSON.stringify(defaults.inputs || []) %>">
      <% if (error) { %>
        <div class="task-status error"><%= error %></div>
      <% } %>

      <section class="task-section task-builder-meta-section">
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title">Task details</h2>
            <p class="task-section-subcopy">These fields become the canonical metadata in <code>pinokio.json</code>.</p>
          </div>
          <div class="task-section-note">pinokio.json</div>
        </div>
        <div class="task-grid two-up">
          <label class="task-field">
            <span class="task-label">Title</span>
            <input class="task-input" type="text" name="title" value="<%= defaults.title || '' %>" placeholder="Check if a repo is safe" required>
          </label>
          <label class="task-field">
            <span class="task-label">Run from</span>
            <% if (allowPathSelection) { %>
              <select class="task-select" name="path" required>
                <% ['workspaces', 'plugin', 'api'].forEach((pathOption) => { %>
                  <option value="<%= pathOption %>" <%= (defaults.path || 'workspaces') === pathOption ? 'selected' : '' %>><%= pathOption %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="hidden" name="path" value="<%= defaults.path || 'workspaces' %>">
              <div class="task-input task-input-readonly"><%= defaults.path || 'workspaces' %></div>
            <% } %>
          </label>
        </div>
        <label class="task-field">
          <span class="task-label">Description <span class="task-label-meta">Optional</span></span>
          <textarea class="task-textarea task-textarea-compact" name="description" rows="3" placeholder="One short sentence explaining when this template is useful."><%= defaults.description || '' %></textarea>
        </label>
      </section>

      <section class="task-section task-builder-template-section">
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title">Prompt template</h2>
            <p class="task-section-subcopy">Use <code>{{repo_url}}</code>, <code>{{question}}</code>, or any other variable name to create inputs automatically.</p>
          </div>
          <div class="task-section-note">task.md</div>
        </div>
        <label class="task-field">
          <span class="task-label">Template text</span>
          <textarea class="task-textarea task-builder-template-input" name="template" data-task-template placeholder="Check whether {{repo_url}} is trustworthy to install.&#10;&#10;If useful, use this context:&#10;{{selected_text}}" required><%= defaults.template || '' %></textarea>
        </label>
        <div class="task-builder-detected">
          <div class="task-label">Detected inputs</div>
          <div class="task-variable-list" data-task-variable-list></div>
          <p class="task-inline-help task-builder-variable-empty" data-task-variable-empty>Type a <code>{{variable}}</code> in the template to create an input.</p>
        </div>
      </section>

      <section class="task-section task-builder-inputs-section task-hidden" data-task-inputs-section>
        <div class="task-section-head">
          <div>
            <h2 class="task-section-title">Input settings</h2>
            <p class="task-section-subcopy">Pinokio will ask for these values before running the task. You can rename the labels here without changing the template variables.</p>
          </div>
          <div class="task-section-note" data-task-input-count-note>0 inputs</div>
        </div>
        <div class="task-input-editor" data-task-input-editor></div>
      </section>

      <input type="hidden" name="inputsJson" value="[]" data-task-inputs-json>
      <input type="hidden" name="sourceWorkspaceCwd" value="<%= defaults.sourceWorkspaceCwd || '' %>">
      <input type="hidden" name="lockPathSelection" value="<%= defaults.lockPathSelection ? '1' : '0' %>">

      <% if (defaults.sourceWorkspaceCwd && (defaults.path || 'workspaces') === 'workspaces') { %>
        <section class="task-section task-builder-workspace-section">
          <div class="task-section-head">
            <div>
              <h2 class="task-section-title">Workspace</h2>
              <p class="task-section-subcopy">Optional. Keep the task generic unless you want it to remember this workspace.</p>
            </div>
          </div>
          <label class="task-toggle">
            <input type="checkbox" name="rememberCurrentWorkspace" value="1" <%= defaults.rememberCurrentWorkspace ? 'checked' : '' %>>
            <span>Remember current workspace</span>
          </label>
          <p class="task-inline-help">This lets the task offer "Continue in <%= defaults.sourceWorkspaceLabel || 'this workspace' %>" later. No files are copied or saved.</p>
        </section>
      <% } %>

      <div class="task-actions task-builder-actions">
        <button class="task-button primary" type="submit">
          <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
          <span><%= submitLabel %></span>
        </button>
        <a class="task-link-button" href="<%= backHref %>">
          <span>Cancel</span>
        </a>
      </div>
    </form>
  </section>
  </div>
  <%- include('partials/main_sidebar', { selected: 'tasks' }) %>
  </main>
  <%- include('partials/app_common_scripts') %>
</body>
</html>
