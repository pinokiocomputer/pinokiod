<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
  <title>Pinokio</title>
  <style>
    :root {
      --layout-gutter-size: 4px;
      --layout-background: #ffffff;
      --layout-gutter-bg: rgba(0, 0, 0, 0.02);
      --layout-gutter-bg-hover: rgba(0, 0, 0, 0.2);
      --layout-shadow: rgba(0, 0, 0, 0.06);
      color-scheme: light dark;
    }

    html, body {
      height: 100%;
      width: 100%;
      margin: 0;
      padding: 0;
      overflow: hidden;
      background: var(--layout-background);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", sans-serif;
    }

    #dragger {
      -webkit-app-region: drag;
      cursor: grab;
      display: none;
      height: 32px;
      width: 100%;
      background: var(--layout-gutter-bg);
    }
    body.dark > #dragger {
      background: rgb(27, 28, 29);
    }

    body {
      display: flex;
      flex-direction: column;
    }

    body[data-agent="electron"] > #dragger {
      display: block;
    }

    body.dark {
      --layout-background: #1b1c1d;
      --layout-gutter-bg: rgba(0, 0, 0, 0.1);
      --layout-gutter-bg-hover: rgba(255, 255, 255, 0.35);
      --layout-shadow: rgba(0, 0, 0, 0.35);
      color: #f3f3f3;
    }

    #layout-root {
      position: relative;
      width: 100%;
      flex-grow: 1;
      background: var(--layout-background);
      overflow: hidden;
    }

    .layout-leaf {
      background: var(--layout-background);
      position: absolute;
      box-sizing: border-box;
      /*
      box-shadow: inset 0 0 0 1px var(--layout-shadow);
      */
      overflow: hidden;
    }

    .layout-leaf iframe {
      width: 100%;
      height: 100%;
      border: none;
      background: transparent;
      display: block;
    }

    .layout-gutter {
      position: absolute;
      background: var(--layout-gutter-bg);
      z-index: 10;
      transition: background 0.15s ease;
    }

    .layout-gutter:hover {
      background: var(--layout-gutter-bg-hover);
    }

    .layout-gutter-columns {
      cursor: col-resize;
    }

    .layout-gutter-rows {
      cursor: row-resize;
    }

    body.layout-resizing {
      user-select: none;
    }

    body.layout-resize-columns {
      cursor: col-resize;
    }

    body.layout-resize-rows {
      cursor: row-resize;
    }

    body.layout-resizing iframe {
      pointer-events: none;
    }
  </style>
</head>
<body class="<%= theme %>" data-agent="<%= agent %>">
  <div id='dragger'></div>
  <div id="layout-root"></div>
  <script id="pinokio-layout-config" type="application/json">
    <%- JSON.stringify({
      initialPath: initialPath,
      defaultPath: defaultPath,
      sessionId: sessionId || null
    }) %>
  </script>
  <script src="/layout.js"></script>
</body>
</html>
